{
  "realm": "starwars",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "loginTheme": "keycloak",
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Default user role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "starwars-frontend",
      "name": "Star Wars Data Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": false,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "REPLACE_WITH_GOOGLE_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_GOOGLE_CLIENT_SECRET",
        "defaultScope": "openid profile email"
      }
    },
    {
      "alias": "microsoft",
      "displayName": "Microsoft",
      "providerId": "microsoft",
      "enabled": false,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "REPLACE_WITH_MICROSOFT_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_MICROSOFT_CLIENT_SECRET",
        "defaultScope": "openid profile email"
      }
    },
    {
      "alias": "facebook",
      "displayName": "Facebook",
      "providerId": "facebook",
      "enabled": false,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "REPLACE_WITH_FACEBOOK_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_FACEBOOK_CLIENT_SECRET",
        "defaultScope": "openid email public_profile"
      }
    }
  ]
}
