@using StarWarsData.Models.Entities
@using StarWarsData.Frontend.Services
@implements IDisposable

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mr-4">
    <MudSwitch
        T="bool"
        Value="_canonEnabled"
        ValueChanged="OnCanonChanged"
        Label="Canon"
        Color="Color.Primary"
        Size="Size.Small"
        Class="ma-0" />

    <MudSwitch
        T="bool"
        Value="_legendsEnabled"
        ValueChanged="OnLegendsChanged"
        Label="Legends"
        Color="Color.Secondary"
        Size="Size.Small"
        Class="ma-0" />

    <MudDivider Vertical="true" FlexItem="true" />

    <MudSwitch
        T="bool"
        Value="_inUniverseEnabled"
        ValueChanged="OnInUniverseChanged"
        Label="In-Universe"
        Color="Color.Tertiary"
        Size="Size.Small"
        Class="ma-0" />

    <MudSwitch
        T="bool"
        Value="_outOfUniverseEnabled"
        ValueChanged="OnOutOfUniverseChanged"
        Label="Out-of-Universe"
        Color="Color.Warning"
        Size="Size.Small"
        Class="ma-0" />
</MudStack>

@code {
    private bool _canonEnabled = true;
    private bool _legendsEnabled = true;
    private bool _inUniverseEnabled = true;
    private bool _outOfUniverseEnabled = false;

    [Inject] private GlobalFilterService GlobalFilterService { get; set; } = default!;

    protected override void OnInitialized()
    {
        UpdateSwitchesFromService();
        GlobalFilterService.OnChange += OnFilterServiceChanged;
    }

    public void Dispose()
    {
        GlobalFilterService.OnChange -= OnFilterServiceChanged;
    }

    private void UpdateSwitchesFromService()
    {
        switch (GlobalFilterService.SelectedContinuity)
        {
            case Continuity.Canon:
                _canonEnabled = true;
                _legendsEnabled = false;
                break;
            case Continuity.Legends:
                _canonEnabled = false;
                _legendsEnabled = true;
                break;
            default:
                _canonEnabled = true;
                _legendsEnabled = true;
                break;
        }

        switch (GlobalFilterService.SelectedUniverse)
        {
            case Universe.InUniverse:
                _inUniverseEnabled = true;
                _outOfUniverseEnabled = false;
                break;
            case Universe.OutOfUniverse:
                _inUniverseEnabled = false;
                _outOfUniverseEnabled = true;
                break;
            default: // null = both
                _inUniverseEnabled = true;
                _outOfUniverseEnabled = true;
                break;
        }
    }

    private async void OnFilterServiceChanged()
    {
        UpdateSwitchesFromService();
        await InvokeAsync(StateHasChanged);
    }

    private void OnCanonChanged(bool value)
    {
        _canonEnabled = value;
        UpdateContinuityService();
    }

    private void OnLegendsChanged(bool value)
    {
        _legendsEnabled = value;
        UpdateContinuityService();
    }

    private void OnInUniverseChanged(bool value)
    {
        _inUniverseEnabled = value;
        UpdateUniverseService();
    }

    private void OnOutOfUniverseChanged(bool value)
    {
        _outOfUniverseEnabled = value;
        UpdateUniverseService();
    }

    private void UpdateContinuityService()
    {
        if (!_canonEnabled && !_legendsEnabled)
        {
            _canonEnabled = true;
            _legendsEnabled = true;
        }

        Continuity? newContinuity = (_canonEnabled, _legendsEnabled) switch
        {
            (true, false) => Continuity.Canon,
            (false, true) => Continuity.Legends,
            _ => null
        };

        GlobalFilterService.SetContinuity(newContinuity);
    }

    private void UpdateUniverseService()
    {
        if (!_inUniverseEnabled && !_outOfUniverseEnabled)
        {
            _inUniverseEnabled = true;
            _outOfUniverseEnabled = false;
        }

        Universe? newUniverse = (_inUniverseEnabled, _outOfUniverseEnabled) switch
        {
            (true, false) => Universe.InUniverse,
            (false, true) => Universe.OutOfUniverse,
            _ => null
        };

        GlobalFilterService.SetUniverse(newUniverse);
    }
}
