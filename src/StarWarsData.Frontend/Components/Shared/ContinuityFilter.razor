@using StarWarsData.Models.Entities
@using StarWarsData.Frontend.Services
@implements IDisposable

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mr-md-4">
    @* Each switch is rendered twice — full label visible md+, abbreviated visible <md.
       Both versions bind to the same backing field so state stays in sync; only one
       is visible at any breakpoint via MudBlazor's d-* responsive display utilities. *@
    <MudTooltip Placement="Placement.Bottom" Arrow="true" Color="Color.Dark">
        <TooltipContent>
            <div style="max-width:240px; font-size:12px;">
                <strong>Canon</strong> — The official Star Wars continuity established by Lucasfilm after 2014.
                Includes all films, TV series (The Clone Wars, Rebels, Mandalorian, etc.), and post-2014 books, comics, and games.
            </div>
        </TooltipContent>
        <ChildContent>
            <div class="d-none d-md-flex">
                <MudSwitch T="bool" Value="_canonEnabled" ValueChanged="OnCanonChanged"
                           Label="Canon" Color="Color.Primary" Size="Size.Small" Class="ma-0" />
            </div>
            <div class="d-flex d-md-none">
                <MudSwitch T="bool" Value="_canonEnabled" ValueChanged="OnCanonChanged"
                           Label="C" Color="Color.Primary" Size="Size.Small" Class="ma-0" />
            </div>
        </ChildContent>
    </MudTooltip>

    <MudTooltip Placement="Placement.Bottom" Arrow="true" Color="Color.Dark">
        <TooltipContent>
            <div style="max-width:240px; font-size:12px;">
                <strong>Legends</strong> — The pre-2014 Expanded Universe. Thousands of books, comics, and games
                produced before the Disney acquisition. Rich lore but no longer considered official canon.
                <em>Default: OFF</em>
            </div>
        </TooltipContent>
        <ChildContent>
            <div class="d-none d-md-flex">
                <MudSwitch T="bool" Value="_legendsEnabled" ValueChanged="OnLegendsChanged"
                           Label="Legends" Color="Color.Secondary" Size="Size.Small" Class="ma-0" />
            </div>
            <div class="d-flex d-md-none">
                <MudSwitch T="bool" Value="_legendsEnabled" ValueChanged="OnLegendsChanged"
                           Label="L" Color="Color.Secondary" Size="Size.Small" Class="ma-0" />
            </div>
        </ChildContent>
    </MudTooltip>

    <MudDivider Vertical="true" FlexItem="true" Class="d-none d-md-flex" />

    <MudTooltip Placement="Placement.Bottom" Arrow="true" Color="Color.Dark">
        <TooltipContent>
            <div style="max-width:240px; font-size:12px;">
                <strong>Star Wars</strong> — In-universe content: characters, planets, battles, ships, organisations,
                and events from the Star Wars galaxy. Dates use BBY/ABY (Before/After Battle of Yavin).
            </div>
        </TooltipContent>
        <ChildContent>
            <div class="d-none d-md-flex">
                <MudSwitch T="bool" Value="_starwarsEnabled" ValueChanged="OnStarwarsChanged"
                           Label="Star Wars" Color="Color.Tertiary" Size="Size.Small" Class="ma-0" />
            </div>
            <div class="d-flex d-md-none">
                <MudSwitch T="bool" Value="_starwarsEnabled" ValueChanged="OnStarwarsChanged"
                           Label="SW" Color="Color.Tertiary" Size="Size.Small" Class="ma-0" />
            </div>
        </ChildContent>
    </MudTooltip>

    <MudTooltip Placement="Placement.Bottom" Arrow="true" Color="Color.Dark">
        <TooltipContent>
            <div style="max-width:240px; font-size:12px;">
                <strong>Real World</strong> — Behind-the-scenes content: actors, authors, directors,
                publication dates, and release information. Dates use standard years (e.g. 1977, 2025).
            </div>
        </TooltipContent>
        <ChildContent>
            <div class="d-none d-md-flex">
                <MudSwitch T="bool" Value="_realEnabled" ValueChanged="OnRealChanged"
                           Label="Real World" Color="Color.Warning" Size="Size.Small" Class="ma-0" />
            </div>
            <div class="d-flex d-md-none">
                <MudSwitch T="bool" Value="_realEnabled" ValueChanged="OnRealChanged"
                           Label="R" Color="Color.Warning" Size="Size.Small" Class="ma-0" />
            </div>
        </ChildContent>
    </MudTooltip>

    <div class="d-none d-md-flex">
        <MudTooltip Text="Show filter guide" Placement="Placement.Bottom">
            <MudIconButton Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small"
                           Color="Color.Default" OnClick="ToggleGuide" />
        </MudTooltip>
    </div>
    <MudPopover Open="_guideOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-4" MaxHeight="400" DropShadow="true">
        <MudStack Spacing="2" Style="max-width:340px;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.subtitle1"><b>Filter Guide</b></MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="ToggleGuide" />
            </MudStack>
            <MudText Typo="Typo.body2">These filters control which data is shown across every page.</MudText>
            <MudDivider />
            <MudText Typo="Typo.subtitle2">Continuity</MudText>
            <MudText Typo="Typo.body2">
                <MudChip T="string" Color="Color.Primary" Size="Size.Small">Canon</MudChip>
                The official continuity established by Lucasfilm after 2014. Films, TV series, and post-2014 books, comics, and games.
            </MudText>
            <MudText Typo="Typo.body2">
                <MudChip T="string" Color="Color.Secondary" Size="Size.Small">Legends</MudChip>
                The pre-2014 Expanded Universe. Thousands of books, comics, and games. Rich lore but no longer official canon.
            </MudText>
            <MudDivider />
            <MudText Typo="Typo.subtitle2">Realm</MudText>
            <MudText Typo="Typo.body2">
                <b>Star Wars</b> — In-universe content: characters, planets, battles, ships. Dates use BBY/ABY.
            </MudText>
            <MudText Typo="Typo.body2">
                <b>Real World</b> — Behind-the-scenes: actors, authors, directors, publication dates.
            </MudText>
            <MudDivider />
            <MudText Typo="Typo.caption">Toggle any combination. At least one must remain active in each group.</MudText>
        </MudStack>
    </MudPopover>
</MudStack>

@code {
    private bool _canonEnabled = true;
    private bool _legendsEnabled = false;
    private bool _starwarsEnabled = true;
    private bool _realEnabled = false;
    private bool _guideOpen;
    [Inject] private GlobalFilterService GlobalFilterService { get; set; } = default!;

    protected override void OnInitialized()
    {
        UpdateSwitchesFromService();
        GlobalFilterService.OnChange += OnFilterServiceChanged;
    }

    private void ToggleGuide() => _guideOpen = !_guideOpen;

    public void Dispose()
    {
        GlobalFilterService.OnChange -= OnFilterServiceChanged;
    }

    private void UpdateSwitchesFromService()
    {
        switch (GlobalFilterService.SelectedContinuity)
        {
            case Continuity.Canon:
                _canonEnabled = true;
                _legendsEnabled = false;
                break;
            case Continuity.Legends:
                _canonEnabled = false;
                _legendsEnabled = true;
                break;
            default:
                _canonEnabled = true;
                _legendsEnabled = true;
                break;
        }

        switch (GlobalFilterService.SelectedRealm)
        {
            case Realm.Starwars:
                _starwarsEnabled = true;
                _realEnabled = false;
                break;
            case Realm.Real:
                _starwarsEnabled = false;
                _realEnabled = true;
                break;
            default: // null = both
                _starwarsEnabled = true;
                _realEnabled = true;
                break;
        }
    }

    private async void OnFilterServiceChanged()
    {
        UpdateSwitchesFromService();
        await InvokeAsync(StateHasChanged);
    }

    private void OnCanonChanged(bool value)
    {
        _canonEnabled = value;
        UpdateContinuityService();
    }

    private void OnLegendsChanged(bool value)
    {
        _legendsEnabled = value;
        UpdateContinuityService();
    }

    private void OnStarwarsChanged(bool value)
    {
        _starwarsEnabled = value;
        if (!_starwarsEnabled && !_realEnabled)
            _realEnabled = true;
        UpdateRealmService();
    }

    private void OnRealChanged(bool value)
    {
        _realEnabled = value;
        if (!_starwarsEnabled && !_realEnabled)
            _starwarsEnabled = true;
        UpdateRealmService();
    }

    private void UpdateContinuityService()
    {
        if (!_canonEnabled && !_legendsEnabled)
        {
            _canonEnabled = true;
            _legendsEnabled = true;
        }

        Continuity? newContinuity = (_canonEnabled, _legendsEnabled) switch
        {
            (true, false) => Continuity.Canon,
            (false, true) => Continuity.Legends,
            _ => null
        };

        GlobalFilterService.SetContinuity(newContinuity);
    }

    private void UpdateRealmService()
    {
        Realm? newRealm = (_starwarsEnabled, _realEnabled) switch
        {
            (true, false) => Realm.Starwars,
            (false, true) => Realm.Real,
            _ => null
        };

        GlobalFilterService.SetRealm(newRealm);
    }
}
