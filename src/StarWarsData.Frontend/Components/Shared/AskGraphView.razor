@using WikiPage = StarWarsData.Models.Entities.Page
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

<MudPaper Outlined="true" Class="pa-4 mt-4" Style="width:100%">
    <MudText Typo="Typo.h6" Class="mb-2">@Descriptor.Title</MudText>

    @* Graph controls toolbar *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2 flex-wrap">
        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5)">Depth</MudText>
        <MudSlider T="int" Value="_maxDepth" ValueChanged="OnDepthChanged"
                   Min="1" Max="4" Step="1" Style="max-width:120px"
                   Color="Color.Primary" />
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
            @_maxDepth
        </MudChip>

        <MudDivider Vertical="true" FlexItem="true" Style="height:24px" />

        @foreach (var label in _allLabels)
        {
            var l = label;
            var enabled = _enabledLabels.Contains(l);
            var color = _upLabels.Contains(l) ? Color.Info
                      : _downLabels.Contains(l) ? Color.Success
                      : Color.Warning;
            <MudChip T="string" Size="Size.Small"
                     Variant="@(enabled ? Variant.Filled : Variant.Outlined)"
                     Color="@color"
                     Style="@(enabled ? "" : "opacity:0.4")"
                     OnClick="() => ToggleLabel(l)">
                @l
            </MudChip>
        }
    </MudStack>

    @if (_loading)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading relationship graph...</MudText>
        </MudStack>
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_hasData)
    {
        <MudGrid Spacing="2">
            <MudItem xs="12" md="@(_selectedNodePage is not null || _loadingNodeDetails ? 9 : 12)">
                <div id="@_containerId"
                     style="width:100%; height:650px; background:#16162e; border-radius:8px; overflow:hidden;">
                </div>
            </MudItem>

            @if (_loadingNodeDetails)
            {
                <MudItem xs="12" md="3">
                    <MudPaper Class="pa-4" Style="height:650px; overflow-y:auto;">
                        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:100%">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading details...</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            }
            else if (_selectedNodePage is not null)
            {
                <MudItem xs="12" md="3">
                    <MudPaper Class="pa-0" Style="height:650px; overflow-y:auto; border-radius:8px;">
                        <MudCard Elevation="0">
                            @if (_selectedNodePage.Infobox?.ImageUrl is not null)
                            {
                                <MudCardMedia Image="@StripRevision(_selectedNodePage.Infobox.ImageUrl)" Height="200" />
                            }
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@_selectedNodePage.Title</MudText>
                                    @if (_selectedNodePage.Infobox?.Template is not null)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @SanitizeTemplate(_selectedNodePage.Infobox.Template)
                                        </MudText>
                                    }
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                   OnClick="CloseNodePanel" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                @if (_selectedNodePage.Infobox?.Data is not null)
                                {
                                    <MudSimpleTable Dense="true" Bordered="true" Striped="true" Style="overflow-x:auto">
                                        <tbody>
                                            @foreach (var prop in _selectedNodePage.Infobox.Data.Where(HasInfoboxContent))
                                            {
                                                <tr>
                                                    <td style="font-weight:600; white-space:nowrap; width:1%; padding:6px 12px; vertical-align:top;">
                                                        @prop.Label
                                                    </td>
                                                    <td style="padding:6px 12px;">
                                                        @foreach (var link in prop.Links)
                                                        {
                                                            <MudLink Href="@link.Href" Underline="Underline.Always" Class="mr-1" Target="_blank">@link.Content</MudLink>
                                                        }
                                                        @GetPlainValues(prop)
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                            </MudCardContent>
                            <MudCardActions>
                                @if (_selectedNodePage.WikiUrl is not null)
                                {
                                    <MudButton Href="@_selectedNodePage.WikiUrl" Target="_blank" Variant="Variant.Text" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.OpenInNew" Size="Size.Small">
                                        Wookieepedia
                                    </MudButton>
                                }
                                <MudButton Href="@($"/graph/{_selectedNodeId}")" Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Hub">
                                    Explore Graph
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
    <AskReferencesSection References="@Descriptor.References" />
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public GraphDescriptor Descriptor { get; set; } = null!;

    private bool _loading = true;
    private bool _hasData;
    private string? _error;
    private int _loadGeneration;
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<AskGraphView>? _dotnetRef;
    private readonly string _containerId = $"d3-graph-{Guid.NewGuid():N}";

    // Node detail panel state
    private WikiPage? _selectedNodePage;
    private int _selectedNodeId;
    private bool _loadingNodeDetails;

    // Graph controls — initialized from Descriptor, user can tweak
    private int _maxDepth;
    private HashSet<string> _enabledLabels = [];
    private HashSet<string> _upLabels = [];
    private HashSet<string> _downLabels = [];
    private HashSet<string> _peerLabels = [];
    private List<string> _allLabels = [];

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnParametersSetAsync()
    {
        // Initialize controls from AI-configured descriptor
        _maxDepth = Descriptor.MaxDepth;
        _upLabels = [..Descriptor.UpLabels];
        _downLabels = [..Descriptor.DownLabels];
        _peerLabels = [..Descriptor.PeerLabels];
        _allLabels = [..Descriptor.UpLabels, ..Descriptor.DownLabels, ..Descriptor.PeerLabels];
        _enabledLabels = Descriptor.EnabledLabels is { Count: > 0 }
            ? [..Descriptor.EnabledLabels]
            : [.._allLabels];

        await LoadGraph();
    }

    private async Task LoadGraph()
    {
        var generation = ++_loadGeneration;

        _loading = true;
        _error = null;
        _hasData = false;
        CloseNodePanel();
        StateHasChanged();

        try
        {
            var activeUp = _upLabels.Where(_enabledLabels.Contains).ToList();
            var activeDown = _downLabels.Where(_enabledLabels.Contains).ToList();
            var activePeer = _peerLabels.Where(_enabledLabels.Contains).ToList();

            var collection = Uri.EscapeDataString(Descriptor.Collection);
            var query = $"relationships/graph/{Descriptor.RootEntityId}?collection={collection}&maxDepth={_maxDepth}";
            foreach (var l in activeUp)   query += $"&upLabels={Uri.EscapeDataString(l)}";
            foreach (var l in activeDown) query += $"&downLabels={Uri.EscapeDataString(l)}";
            foreach (var l in activePeer) query += $"&peerLabels={Uri.EscapeDataString(l)}";
            var result = await Http.GetFromJsonAsync<GraphResult>(query);

            if (generation != _loadGeneration) return;

            if (result?.Nodes is { Count: > 0 })
            {
                _hasData = true;
                _loading = false;
                StateHasChanged();

                await Task.Delay(50);
                await RenderD3Graph(result);
            }
            else
            {
                _error = $"No relationship data found for \"{Descriptor.RootEntityName}\".";
            }
        }
        catch (Exception ex)
        {
            if (generation != _loadGeneration) return;
            _error = $"Failed to load graph: {ex.Message}";
        }
        finally
        {
            if (generation == _loadGeneration)
                _loading = false;
        }
    }

    private async Task OnDepthChanged(int value)
    {
        _maxDepth = value;
        await LoadGraph();
    }

    private async Task ToggleLabel(string label)
    {
        if (!_enabledLabels.Remove(label))
            _enabledLabels.Add(label);
        await LoadGraph();
    }

    private string _currentModulePath = "";

    private async Task RenderD3Graph(GraphResult result)
    {
        var isTree = Descriptor.LayoutMode == "tree";
        var modulePath = isTree ? "./js/d3-family-tree.js" : "./js/d3-graph.js";

        // Re-import if layout mode changed
        if (_currentModulePath != modulePath)
        {
            if (_jsModule is not null)
            {
                try { await _jsModule.DisposeAsync(); } catch { }
            }
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", modulePath);
            _currentModulePath = modulePath;
        }

        var nodes = result.Nodes.Values.Select(n => new
        {
            id = n.Id,
            name = n.Name,
            type = "Character",
            imageUrl = n.ImageUrl ?? "",
            born = n.Born ?? "",
            died = n.Died ?? "",
            generation = n.Generation,
            parents = n.Parents,
            partners = n.Partners,
            siblings = n.Siblings,
            children = n.Children,
        }).ToArray();

        var edges = result.Edges.Select(e => new
        {
            fromId = e.FromId,
            toId = e.ToId,
            label = e.Label,
            weight = 0.7,
        }).ToArray();

        var data = new { nodes, edges, rootId = result.RootId };

        _dotnetRef?.Dispose();
        _dotnetRef = DotNetObjectReference.Create(this);

        var entryPoint = isTree ? "renderFamilyTree" : "renderForceGraph";
        await _jsModule.InvokeVoidAsync(entryPoint, _containerId, data, _dotnetRef);
    }

    [JSInvokable]
    public async Task OnNodeClicked(int id, string name, string type)
    {
        _selectedNodeId = id;
        _selectedNodePage = null;
        _loadingNodeDetails = true;
        StateHasChanged();

        try
        {
            _selectedNodePage = await Http.GetFromJsonAsync<WikiPage>($"Pages/{id}");
        }
        catch
        {
            _selectedNodePage = null;
        }
        finally
        {
            _loadingNodeDetails = false;
            StateHasChanged();
        }
    }

    private void CloseNodePanel()
    {
        _selectedNodePage = null;
        _selectedNodeId = 0;
        _loadingNodeDetails = false;
    }

    private static string StripRevision(string url)
    {
        var idx = url.IndexOf("/revision", StringComparison.OrdinalIgnoreCase);
        return idx > 0 ? url[..idx] : url;
    }

    private static string SanitizeTemplate(string template)
    {
        var last = template.Split(':').LastOrDefault() ?? template;
        return last.Replace("_", " ");
    }

    private static bool HasInfoboxContent(InfoboxProperty prop) =>
        prop.Links.Count > 0 || prop.Values.Any(v => !string.IsNullOrWhiteSpace(v));

    private static string GetPlainValues(InfoboxProperty prop)
    {
        var linkTexts = prop.Links.Select(l => l.Content).ToHashSet(StringComparer.OrdinalIgnoreCase);
        return string.Join(", ", prop.Values.Where(v => !string.IsNullOrWhiteSpace(v) && !linkTexts.Contains(v)));
    }

    public async ValueTask DisposeAsync()
    {
        _dotnetRef?.Dispose();

        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("destroyGraph", _containerId);
                await _jsModule.DisposeAsync();
            }
            catch (Exception) { }
        }
    }
}
