@using StarWarsData.Models.Queries
@inject IHttpClientFactory HttpClientFactory

<MudPaper Outlined="true" Class="pa-4 mt-4" Style="width:100%">
    <MudText Typo="Typo.h6" Class="mb-2">@Descriptor.Title</MudText>

    @if (_loading)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading relationship graph...</MudText>
        </MudStack>
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_graphData is not null)
    {
        @if (_isPathMode)
        {
            @* Path mode: no depth/label controls — the graph is fixed *@
            <GraphViewer GraphData="_graphData" LayoutMode="@Descriptor.LayoutMode" />
        }
        else
        {
            <GraphViewer GraphData="_graphData" LayoutMode="@Descriptor.LayoutMode"
                         Labels="_allLabels" EnabledLabels="_enabledLabels"
                         OnLabelToggled="ToggleLabel"
                         MaxDepth="_maxDepth" OnDepthChanged="OnDepthChanged" />
        }
    }

    <AskReferencesSection References="@Descriptor.References" />
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public GraphDescriptor Descriptor { get; set; } = null!;

    private bool _loading = true;
    private bool _isPathMode;
    private string? _error;
    private int _loadGeneration;
    private RelationshipGraphResult? _graphData;

    private int _maxDepth;
    private HashSet<string> _enabledLabels = [];
    private List<string> _allLabels = [];

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnParametersSetAsync()
    {
        _isPathMode = Descriptor.PathData is { Steps.Count: > 0 };
        _maxDepth = Descriptor.MaxDepth;
        _allLabels = [..Descriptor.Labels];
        _enabledLabels = Descriptor.EnabledLabels is { Count: > 0 }
            ? [..Descriptor.EnabledLabels]
            : [.._allLabels];

        await LoadGraph();
    }

    async Task LoadGraph()
    {
        var generation = ++_loadGeneration;
        _loading = true;
        _error = null;
        _graphData = null;
        StateHasChanged();

        try
        {
            if (_isPathMode)
            {
                // Path mode: build graph inline from PathData — no API call
                _graphData = BuildGraphFromPath(Descriptor.PathData!);
            }
            else
            {
                // BFS mode: fetch from API
                var activeLabels = _allLabels.Where(_enabledLabels.Contains).ToList();
                var labelsParam = string.Join(",", activeLabels);

                var query = $"api/RelationshipGraph/query/{Descriptor.RootEntityId}?maxDepth={_maxDepth}";
                if (!string.IsNullOrEmpty(labelsParam))
                    query += $"&labels={Uri.EscapeDataString(labelsParam)}";
                if (!string.IsNullOrEmpty(Descriptor.Continuity))
                    query += $"&continuity={Uri.EscapeDataString(Descriptor.Continuity)}";

                var result = await Http.GetFromJsonAsync<RelationshipGraphResult>(query);

                if (generation != _loadGeneration) return;

                if (result?.Nodes is { Count: > 0 })
                    _graphData = result;
                else
                    _error = $"No relationship data found for \"{Descriptor.RootEntityName}\".";
            }
        }
        catch (Exception ex)
        {
            if (generation != _loadGeneration) return;
            _error = $"Failed to load graph: {ex.Message}";
        }
        finally
        {
            if (generation == _loadGeneration) _loading = false;
        }
    }

    static RelationshipGraphResult BuildGraphFromPath(PathData path)
    {
        var nodeMap = new Dictionary<int, RelationshipGraphNode>();
        foreach (var step in path.Steps)
        {
            nodeMap.TryAdd(step.FromId, new RelationshipGraphNode
            {
                Id = step.FromId,
                Name = step.FromName,
                Type = step.FromType,
            });
            nodeMap.TryAdd(step.ToId, new RelationshipGraphNode
            {
                Id = step.ToId,
                Name = step.ToName,
                Type = step.ToType,
            });
        }

        var edges = path.Steps.Select(s => new RelationshipGraphEdge
        {
            FromId = s.FromId,
            ToId = s.ToId,
            Label = s.Label,
            Weight = 1.0,
        }).ToList();

        return new RelationshipGraphResult
        {
            RootId = path.FromId,
            RootName = path.FromName,
            Nodes = [.. nodeMap.Values],
            Edges = edges,
            Truncated = false,
        };
    }

    async Task OnDepthChanged(int value)
    {
        _maxDepth = value;
        await LoadGraph();
    }

    async Task ToggleLabel(string label)
    {
        if (!_enabledLabels.Remove(label))
            _enabledLabels.Add(label);
        await LoadGraph();
    }
}
