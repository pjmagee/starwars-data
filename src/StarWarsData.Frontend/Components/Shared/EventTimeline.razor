@using StarWarsData.Models.Queries
@using StarWarsData.Frontend.Services
@using System.Web
@inject IHttpClientFactory HttpClientFactory
@inject GlobalFilterService GlobalFilterService
@inject IJSRuntime JS
@implements IAsyncDisposable

<div @ref="_timelineContainer" class="@(_maximized ? "timeline-maximized" : "")">

    @* ── Toolbar: collapse filters + maximize toggle ── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        @if (ShowCategoryFilter)
        {
            <MudButton Variant="Variant.Text"
                       Size="Size.Small"
                       StartIcon="@(_filtersCollapsed ? Icons.Material.Filled.FilterList : Icons.Material.Filled.FilterListOff)"
                       OnClick="@(() => _filtersCollapsed = !_filtersCollapsed)">
                @(_filtersCollapsed ? "Show Filters" : "Hide Filters")
            </MudButton>
        }
        <MudSpacer />
        @if (_allItems.Count > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-2">
                @_totalEvents.ToString("N0") events
                @if (_allItems.Count > 0)
                {
                    <text> — showing @_allItems.Sum(g => g.Events.Count)</text>
                }
            </MudText>
        }
        @if (_pagedResult is not null)
        {
            <MudTooltip Text="@(_maximized ? "Exit fullscreen" : "Fullscreen")">
                <MudIconButton Icon="@(_maximized ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                               Size="Size.Small"
                               Variant="Variant.Outlined"
                               OnClick="@(() => _maximized = !_maximized)" />
            </MudTooltip>
        }
    </MudStack>

    @* ── Collapsible filters ── *@
    @if (!_filtersCollapsed)
    {
        @if (_eras is not null && CurrentCalendar == Calendar.Galactic)
        {
            <MudPaper Elevation="0" Class="pa-2">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Filter by Era</MudText>
                <MudChipSet T="string" @bind-SelectedValues="_selectedEraNames" SelectionMode="SelectionMode.MultiSelection" CheckMark="true" Variant="Variant.Text">
                    @foreach (var era in _eras)
                    {
                        var label = $"{era.Name} ({FormatYear(era.StartYear, era.StartDemarcation)}–{FormatYear(era.EndYear, era.EndDemarcation)})";
                        <MudChip Value="@era.Name" Color="Color.Primary" T="string">@label</MudChip>
                    }
                </MudChipSet>
            </MudPaper>
        }

        @if (ShowCategoryFilter && _categories is not null)
        {
            <MudPaper Elevation="0" Class="pa-2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">Event Categories</MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="SelectAllCategories">Select All</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="DeselectAllCategories">Deselect All</MudButton>
                </MudStack>
                <MudChipSet T="string" @bind-SelectedValues="_selectedCategories" SelectionMode="SelectionMode.MultiSelection" CheckMark="true" Variant="Variant.Text">
                    @foreach (var category in GetSortedCategories())
                    {
                        var color = GetChipColor(category);
                        <MudChip @key="category" Value="@category" Style="@($"border-color:{color}; color:{color}")" Variant="Variant.Outlined" T="string">
                            @FormatCategoryName(category)
                        </MudChip>
                    }
                </MudChipSet>
            </MudPaper>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters"
                       Disabled="@(!_selectedCategories.Any())"
                       StartIcon="@Icons.Material.Filled.Search">
                Load Timeline
            </MudButton>
        }
    }
    else if (ShowCategoryFilter && _selectedCategories.Any())
    {
        @* Collapsed summary *@
        <MudPaper Elevation="0" Class="pa-2 d-flex align-center gap-2 flex-wrap">
            <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" Color="Color.Secondary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @_selectedCategories.Count categories selected
                @if (_selectedEraNames.Any())
                {
                    <text> · @_selectedEraNames.Count eras</text>
                }
            </MudText>
            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _filtersCollapsed = false)">Edit</MudButton>
        </MudPaper>
    }

    @* ── Loading indicator ── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    @* ── Empty state ── *@
    @if (!_loading && _pagedResult is null && ShowCategoryFilter)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
            Select one or more event categories above, then click <strong>Load Timeline</strong> to view events.
        </MudAlert>
    }

    @* ── Timeline results ── *@
    @if (!_loading && _pagedResult is not null)
    {
        @if (_totalEvents == 0)
        {
            <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                No timeline events found for the selected filters.
            </MudAlert>
        }
        else
        {
            <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelineAlign="TimelineAlign.Default" TimelinePosition="TimelinePosition.Alternate" Class="ma-4" Modifiers="false">
                @{
                    var isStart = true;
                }

                @foreach (var timelineEvents in _allItems)
                {
                    var contentAlign = isStart ? Align.Left : Align.Right;
                    var yearAlign = isStart ? Align.Right : Align.Left;

                    <MudTimelineItem Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Medium">
                        <ItemOpposite>
                            <MudText Color="Color.Info" Typo="Typo.h5" Align="@yearAlign">@timelineEvents.Year</MudText>
                        </ItemOpposite>
                        <ItemContent>
                            <MudExpansionPanels Dense="true" MultiExpansion="true" Style="max-height: 600px; overflow: auto;">
                                @foreach (var timelineEvent in timelineEvents.Events)
                                {
                                    var color = GetColor(timelineEvent);

                                    <MudExpansionPanel Style="@($"color:{color}; text-align:{contentAlign};")">
                                        <TitleContent>
                                            <div class="d-flex align-center gap-2 flex-wrap">
                                                <MudText Typo="Typo.body2" Style="@($"color:{color}")">@timelineEvent.DisplayTitle</MudText>
                                                @if (!string.IsNullOrEmpty(timelineEvent.Template))
                                                {
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                             Style="@($"border-color:{color}; color:{color}; font-size: 0.7rem;")"
                                                             Class="px-1 py-0">
                                                        @FormatCategoryName(timelineEvent.Template)
                                                    </MudChip>
                                                }
                                            </div>
                                        </TitleContent>
                                        <ChildContent>
                                        <MudCard Outlined="true" Class="ma-2">
                                            @if (timelineEvent.DisplayImageWithoutRevision is not null)
                                            {
                                                <MudImage Fluid="true" Src="@timelineEvent.DisplayImageWithoutRevision" Alt="" Class="rounded-lg ma-2"/>
                                            }
                                            <MudCardContent>
                                                @foreach (var item in timelineEvent.Properties)
                                                {
                                                    @if (item.Links.Count > 0 || item.Values.Count > 0)
                                                    {
                                                        <MudText Typo="Typo.body2">
                                                            <b>@item.Label: </b>
                                                            @foreach (var link in item.Links)
                                                            {
                                                                <MudLink Class="mr-1" Underline="Underline.Always" Href="@link.Href">@link.Content</MudLink>
                                                            }
                                                            @string.Join(", ", item.Values.Where(x => !item.Links.Any(l => l.Content.Equals(x, StringComparison.OrdinalIgnoreCase))))
                                                        </MudText>
                                                    }
                                                }
                                            </MudCardContent>
                                        </MudCard>
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        </ItemContent>
                    </MudTimelineItem>

                    isStart = !isStart;
                }
            </MudTimeline>

            @* ── Infinite scroll sentinel ── *@
            @if (_hasMore)
            {
                <div @ref="_sentinel" class="d-flex justify-center pa-4">
                    @if (_loadingMore)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" />
                        <MudText Typo="Typo.caption" Class="ml-2">Loading more events...</MudText>
                    }
                </div>
            }
            else if (_allItems.Count > 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="pa-4">
                    All @_totalEvents.ToString("N0") events loaded
                </MudText>
            }
        }
    }

    @if (_maximized)
    {
        <MudFab Color="Color.Tertiary"
                StartIcon="@Icons.Material.Filled.ArrowCircleUp"
                Style="position: fixed; bottom: 32px; right: 32px; z-index: 1400;"
                OnClick="ScrollToTop" />
    }

</div>

@if (!_maximized)
{
    <MudScrollToTop>
        <MudFab Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.ArrowCircleUp" />
    </MudScrollToTop>
}

<style>
    .timeline-maximized {
        position: fixed;
        inset: 0;
        z-index: 1300;
        background: var(--mud-palette-background);
        overflow-y: auto;
        padding: 24px;
    }
</style>

@code {
    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");
    private GroupedTimelineResult? _pagedResult;
    private string[]? _categories;
    private Era[]? _eras;
    private bool _loading;

    private IReadOnlyCollection<string> _selectedCategories = new List<string>();
    private IReadOnlyCollection<string> _selectedEraNames = new List<string>();
    private Dictionary<string, string> _templateColorMap = new(StringComparer.OrdinalIgnoreCase);

    private int _pages = 1;
    private int _pageSize = 15;
    private int _currentPage = 1;
    private int _totalEvents;

    // Infinite scroll state
    private List<GroupedTimelines> _allItems = new();
    private bool _hasMore;
    private bool _loadingMore;
    private ElementReference _sentinel;
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<EventTimeline>? _dotNetRef;

    // UX state
    private bool _filtersCollapsed;
    private bool _maximized;
    private ElementReference _timelineContainer;

    [Parameter] public string? Category { get; set; }
    [Parameter] public bool ShowCategoryFilter { get; set; } = true;

    // Derive the calendar mode from the global Realm filter so the page behaviour tracks
    // the existing realm toggle (Star Wars → Galactic BBY/ABY, Real → real-world CE).
    // When the user has no explicit realm selection (null = both), we default to galactic
    // to keep the historical experience unchanged.
    private Calendar CurrentCalendar => GlobalFilterService.SelectedRealm == Realm.Real ? Calendar.Real : Calendar.Galactic;

    // Color map is rebuilt from the currently visible categories whenever the filter
    // set changes. We use HSL hues evenly spaced around the wheel (with a golden-ratio
    // stagger) so every visible template gets a visually distinct color regardless of
    // how many there are — avoiding collisions from a fixed small palette.
    private void RebuildColorMap(IEnumerable<string>? categories)
    {
        _templateColorMap.Clear();
        if (categories is null) return;

        var sorted = categories.OrderBy(c => c, StringComparer.OrdinalIgnoreCase).ToList();
        var n = sorted.Count;
        if (n == 0) return;

        // Golden-ratio hue stepping — gives maximum perceptual separation between
        // adjacent indices even for small n, while still covering the full wheel.
        const double goldenAngle = 137.50776405;
        for (int i = 0; i < n; i++)
        {
            var cleaned = CleanTemplateName(sorted[i]);
            var hue = (i * goldenAngle) % 360;
            _templateColorMap[cleaned] = $"hsl({hue:F0}, 65%, 60%)";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnContinuityChanged;
        await InitializeColorMapping();

        if (ShowCategoryFilter)
        {
            await LoadCategories();
            await LoadEras();
        }

        if (!string.IsNullOrEmpty(Category))
        {
            await LoadInitialData();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/infinite-scroll.js");
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (_hasMore && !_loadingMore && _jsModule is not null && _dotNetRef is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("observe", _sentinel, _dotNetRef);
            }
            catch (JSException) { }
        }
    }

    [JSInvokable]
    public async Task OnSentinelVisible()
    {
        if (_loadingMore || !_hasMore) return;

        _loadingMore = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            _currentPage++;
            var result = await FetchPage(_currentPage);

            if (result?.Items.Any() == true)
            {
                MergeItems(result.Items);
                _hasMore = _currentPage < _pages;
            }
            else
            {
                _hasMore = false;
            }
        }
        finally
        {
            _loadingMore = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ScrollToTop()
    {
        await JS.InvokeVoidAsync("eval", "document.querySelector('.timeline-maximized')?.scrollTo({top: 0, behavior: 'smooth'})");
    }

    public async ValueTask DisposeAsync()
    {
        GlobalFilterService.OnChange -= OnContinuityChanged;

        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("dispose", _sentinel);
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }

        _dotNetRef?.Dispose();
    }

    private async void OnContinuityChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadCategories();
            // Eras list is continuity-scoped too — reload so the chip bar matches
            // the newly selected continuity and any era selections drop stale entries.
            await LoadEras();

            if (_categories is not null)
            {
                var visible = new HashSet<string>(_categories);
                _selectedCategories = _selectedCategories.Where(c => visible.Contains(c)).ToList();
            }

            if (_eras is not null)
            {
                var visibleEras = new HashSet<string>(_eras.Select(e => e.Name));
                _selectedEraNames = _selectedEraNames.Where(n => visibleEras.Contains(n)).ToList();
            }

            if (_selectedCategories.Any())
            {
                await LoadInitialData();
            }
            else
            {
                ResetResults();
            }

            StateHasChanged();
        });
    }

    /// <summary>
    /// Load the era list from the API, scoped to the currently selected continuity.
    /// Called on mount and whenever the global continuity filter changes. Eras are a
    /// galactic-calendar concept only, so the list is cleared in real-world mode.
    /// </summary>
    private async Task LoadEras()
    {
        if (CurrentCalendar != Calendar.Galactic)
        {
            _eras = null;
            _selectedEraNames = new List<string>();
            return;
        }

        var query = System.Web.HttpUtility.ParseQueryString(string.Empty);
        var continuityParam = GlobalFilterService.GetContinuityQueryParam();
        if (!string.IsNullOrEmpty(continuityParam))
            query.Add("continuity", continuityParam);

        var url = query.Count > 0 ? $"Timeline/eras?{query}" : "Timeline/eras";
        _eras = await Http.GetFromJsonAsync<Era[]>(url);
    }

    private async Task InitializeColorMapping()
    {
        try
        {
            var allCategories = await Http.GetFromJsonAsync<string[]>("Timeline/available-categories");
            RebuildColorMap(allCategories);
        }
        catch { }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_templateColorMap.Any())
            await InitializeColorMapping();

        if (!string.IsNullOrEmpty(Category))
            await LoadInitialData();
    }

    private async Task LoadCategories()
    {
        var query = HttpUtility.ParseQueryString(string.Empty);
        AddGlobalFilters(query);
        _categories = await Http.GetFromJsonAsync<string[]>($"Timeline/categories?{query}");
        // Rebuild the color map against the currently visible subset so every
        // visible template gets a distinct hue — prevents collisions when the
        // realm / continuity filter flips and the subset shrinks.
        RebuildColorMap(_categories);
    }

    private async Task ApplyFilters()
    {
        _filtersCollapsed = true;
        await LoadInitialData();
    }

    private void SelectAllCategories()
    {
        _selectedCategories = _categories?.ToList() ?? [];
    }

    private void DeselectAllCategories()
    {
        _selectedCategories = new List<string>();
        ResetResults();
    }

    private void ResetResults()
    {
        _pagedResult = null;
        _allItems.Clear();
        _currentPage = 1;
        _hasMore = false;
        _totalEvents = 0;
    }

    private async Task LoadInitialData()
    {
        _loading = true;
        _currentPage = 1;
        _allItems.Clear();
        StateHasChanged();

        try
        {
            var result = await FetchPage(1);
            _pagedResult = result;

            if (result is not null)
            {
                _totalEvents = result.Total;
                _pages = result.Total > 0 && result.Size > 0
                    ? (int)Math.Ceiling((double)result.Total / result.Size)
                    : 0;
                _allItems = result.Items.ToList();
                _hasMore = _currentPage < _pages;
            }
            else
            {
                ResetResults();
            }
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<GroupedTimelineResult?> FetchPage(int page)
    {
        if (!string.IsNullOrEmpty(Category))
        {
            var query = HttpUtility.ParseQueryString(string.Empty);
            query.Add("Page", page.ToString());
            query.Add("PageSize", _pageSize.ToString());
            AddGlobalFilters(query);
            return await Http.GetFromJsonAsync<GroupedTimelineResult>($"Timeline/categories/{Category}/events?{query}");
        }

        if (!_selectedCategories.Any())
            return null;

        var q = HttpUtility.ParseQueryString(string.Empty);
        q.Add("Page", page.ToString());
        q.Add("PageSize", _pageSize.ToString());

        foreach (var c in _selectedCategories)
            q.Add("Categories", c);

        AddGlobalFilters(q);

        var (yearFrom, fromDem, yearTo, toDem) = GetEraYearRange();
        if (yearFrom.HasValue && fromDem.HasValue && yearTo.HasValue && toDem.HasValue)
        {
            q.Add("YearFrom", yearFrom.Value.ToString());
            q.Add("YearFromDemarcation", fromDem.Value.ToString());
            q.Add("YearTo", yearTo.Value.ToString());
            q.Add("YearToDemarcation", toDem.Value.ToString());
        }

        return await Http.GetFromJsonAsync<GroupedTimelineResult>($"Timeline/events?{q}");
    }

    /// <summary>
    /// Merges new page items into the accumulated list.
    /// If the last existing year matches the first new year, their events are combined.
    /// </summary>
    private void MergeItems(IEnumerable<GroupedTimelines> newItems)
    {
        foreach (var group in newItems)
        {
            var existing = _allItems.LastOrDefault();
            if (existing is not null && existing.Year == group.Year)
            {
                existing.Events.AddRange(group.Events);
            }
            else
            {
                _allItems.Add(group);
            }
        }
    }

    private (float? yearFrom, Demarcation? fromDem, float? yearTo, Demarcation? toDem) GetEraYearRange()
    {
        if (_eras is null || !_selectedEraNames.Any())
            return (null, null, null, null);

        var selected = _eras.Where(e => _selectedEraNames.Contains(e.Name)).ToList();
        if (selected.Count == 0)
            return (null, null, null, null);

        var earliest = selected.MinBy(e => ToLinear(e.StartYear, e.StartDemarcation))!;
        var latest = selected.MaxBy(e => ToLinear(e.EndYear, e.EndDemarcation))!;

        return (earliest.StartYear, earliest.StartDemarcation, latest.EndYear, latest.EndDemarcation);
    }

    static double ToLinear(float year, Demarcation dem) => dem == Demarcation.Bby ? -year : year;

    private void AddGlobalFilters(System.Collections.Specialized.NameValueCollection query)
    {
        var continuityParam = GlobalFilterService.GetContinuityQueryParam();
        if (!string.IsNullOrEmpty(continuityParam))
            query.Add("continuity", continuityParam);

        var realmParam = GlobalFilterService.GetRealmQueryParam();
        if (!string.IsNullOrEmpty(realmParam))
            query.Add("realm", realmParam);

        // Map realm → calendar: Real realm uses the CE calendar, everything else stays
        // galactic. Sent as an explicit query parameter so the API filters timeline rows
        // by calendar and returns a chronologically coherent page.
        query.Add("calendar", CurrentCalendar.ToString());
    }

    private static string CleanTemplateName(string template)
    {
        var lastColon = template.LastIndexOf(':');
        var name = lastColon >= 0 ? template[(lastColon + 1)..] : template;
        return name.Replace("_infobox", "", StringComparison.OrdinalIgnoreCase);
    }

    private string GetColor(StarWarsData.Models.Entities.TimelineEvent timelineEvent)
    {
        if (string.IsNullOrEmpty(timelineEvent.Template))
            return Colors.Blue.Default;

        var cleaned = CleanTemplateName(timelineEvent.Template);
        if (_templateColorMap.TryGetValue(cleaned, out var mapped))
            return mapped;

        return cleaned switch
        {
            "event" => Colors.LightBlue.Lighten1,
            "trade_route" => Colors.Cyan.Default,
            "campaign" => Colors.Shades.Black,
            "mission" => Colors.Gray.Darken4,
            "battle" => Colors.Red.Darken1,
            "duel" => Colors.Red.Darken2,
            "fleet" => Colors.Red.Darken3,
            "war" => Colors.Red.Darken4,
            "disease" => Colors.Green.Darken4,
            "location" => Colors.Blue.Lighten1,
            "city" => Colors.Blue.Darken1,
            "law" => Colors.Green.Darken1,
            "treaty" => Colors.Green.Darken2,
            "election" => Colors.Blue.Darken3,
            "character" => Colors.Brown.Default,
            "government" => Colors.Amber.Darken1,
            "organization" => Colors.Amber.Lighten1,
            "company" => Colors.Amber.Darken3,
            "religion" => Colors.Purple.Lighten1,
            "holocron" => Colors.Purple.Darken1,
            "lightsaber" => Colors.Purple.Darken2,
            "droid" => Colors.BlueGray.Darken2,
            "artifact" => Colors.BlueGray.Darken3,
            _ => Colors.Blue.Default
        };
    }

    private string GetChipColor(string category)
    {
        var cleaned = CleanTemplateName(category);
        return _templateColorMap.TryGetValue(cleaned, out var c) ? c : Colors.Blue.Default;
    }

    private IEnumerable<string> GetSortedCategories()
    {
        if (_categories is null) return [];
        return _categories
            .OrderByDescending(c => _selectedCategories.Contains(c))
            .ThenBy(c => c, StringComparer.OrdinalIgnoreCase);
    }

    private static string FormatCategoryName(string category)
    {
        var cleaned = CleanTemplateName(category).Replace("_", " ").Trim();
        return System.Text.RegularExpressions.Regex.Replace(cleaned, "(?<!^)([A-Z])", " $1");
    }

    private static string FormatYear(float year, Demarcation dem) =>
        $"{year:0.##} {dem.ToString().ToUpper()}";
}
