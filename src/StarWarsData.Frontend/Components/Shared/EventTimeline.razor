@using StarWarsData.Models.Queries
@using StarWarsData.Frontend.Services
@using System.Web
@inject IHttpClientFactory HttpClientFactory
@inject GlobalFilterService GlobalFilterService
@implements IDisposable

<MudStack Row="false" Spacing="4">

    @* ── Era filter chips ── *@
    @if (_eras is not null)
    {
        <MudPaper Elevation="0" Class="pa-2">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Filter by Era</MudText>
            <MudChipSet T="string" @bind-SelectedValues="_selectedEraNames" SelectionMode="SelectionMode.MultiSelection" CheckMark="true" Variant="Variant.Text">
                @foreach (var era in _eras)
                {
                    var label = $"{era.Name} ({FormatYear(era.StartYear, era.StartDemarcation)}–{FormatYear(era.EndYear, era.EndDemarcation)})";
                    <MudChip Value="@era.Name" Color="Color.Primary" T="string">@label</MudChip>
                }
            </MudChipSet>
        </MudPaper>
    }

    @* ── Category filter ── *@
    @if (ShowCategoryFilter && _categories is not null)
    {
        <MudPaper Elevation="0" Class="pa-2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                <MudText Typo="Typo.subtitle2">Event Categories</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="SelectAllCategories">Select All</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="DeselectAllCategories">Deselect All</MudButton>
            </MudStack>
            <MudChipSet T="string" @bind-SelectedValues="_selectedCategories" SelectionMode="SelectionMode.MultiSelection" CheckMark="true" Variant="Variant.Text">
                @foreach (var category in GetSortedCategories())
                {
                    var color = GetChipColor(category);
                    <MudChip Value="@category" Style="@($"border-color:{color}; color:{color}")" Variant="Variant.Outlined" T="string">
                        @FormatCategoryName(category)
                    </MudChip>
                }
            </MudChipSet>
        </MudPaper>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters"
                   Disabled="@(!_selectedCategories.Any())"
                   StartIcon="@Icons.Material.Filled.Search">
            Load Timeline
        </MudButton>
    }

    @* ── Loading indicator ── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    @* ── Empty state ── *@
    @if (!_loading && _pagedResult is null && ShowCategoryFilter)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
            Select one or more event categories above, then click <strong>Load Timeline</strong> to view events.
        </MudAlert>
    }

    @* ── Timeline results ── *@
    @if (!_loading && _pagedResult is not null)
    {
        @if (_pagedResult.Total == 0)
        {
            <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                No timeline events found for the selected filters.
            </MudAlert>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_pagedResult.Total.ToString("N0") events found</MudText>

            <MudPagination @bind-Selected="CurrentPage" ShowFirstButton="true" ShowLastButton="true" Count="_pages" Class="ma-4" />

            <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelineAlign="TimelineAlign.Default" TimelinePosition="TimelinePosition.Alternate" Class="ma-4" Modifiers="false">
                @{
                    var isStart = true;
                }

                @foreach (var timelineEvents in _pagedResult.Items)
                {
                    var contentAlign = isStart ? Align.Left : Align.Right;
                    var yearAlign = isStart ? Align.Right : Align.Left;

                    <MudTimelineItem Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Medium">
                        <ItemOpposite>
                            <MudText Color="Color.Info" Typo="Typo.h5" Align="@yearAlign">@timelineEvents.Year</MudText>
                        </ItemOpposite>
                        <ItemContent>
                            <MudExpansionPanels Dense="true" MultiExpansion="true" Style="max-height: 600px; overflow: auto;">
                                @foreach (var timelineEvent in timelineEvents.Events)
                                {
                                    var color = GetColor(timelineEvent);

                                    <MudExpansionPanel Text="@timelineEvent.DisplayTitle" Style="@($"color:{color}; text-align:{contentAlign};")">
                                        <MudCard Outlined="true" Class="ma-2">
                                            @if (timelineEvent.DisplayImageWithoutRevision is not null)
                                            {
                                                <MudImage Fluid="true" Src="@timelineEvent.DisplayImageWithoutRevision" Alt="" Class="rounded-lg ma-2"/>
                                            }
                                            <MudCardContent>
                                                @foreach (var item in timelineEvent.Properties)
                                                {
                                                    @if (item.Links.Count > 0 || item.Values.Count > 0)
                                                    {
                                                        <MudText Typo="Typo.body2">
                                                            <b>@item.Label: </b>
                                                            @foreach (var link in item.Links)
                                                            {
                                                                <MudLink Class="mr-1" Underline="Underline.Always" Href="@link.Href">@link.Content</MudLink>
                                                            }
                                                            @string.Join(", ", item.Values.Where(x => !item.Links.Any(l => l.Content.Equals(x, StringComparison.OrdinalIgnoreCase))))
                                                        </MudText>
                                                    }
                                                }
                                            </MudCardContent>
                                        </MudCard>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        </ItemContent>
                    </MudTimelineItem>

                    isStart = !isStart;
                }
            </MudTimeline>

            <MudPagination @bind-Selected="CurrentPage" ShowFirstButton="true" ShowLastButton="true" Count="_pages" Class="ma-4" />
        }
    }

</MudStack>

<MudScrollToTop>
    <MudFab Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.ArrowCircleUp" />
</MudScrollToTop>

@code {
    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");
    private GroupedTimelineResult? _pagedResult;
    private string[]? _categories;
    private Era[]? _eras;
    private bool _loading;

    private IReadOnlyCollection<string> _selectedCategories = new List<string>();
    private IReadOnlyCollection<string> _selectedEraNames = new List<string>();
    private Dictionary<string, string> _templateColorMap = new();

    private int _pages = 1;
    private int _pageSize = 15;

    private int _currentPage = 1;
    private int CurrentPage
    {
        get => _currentPage;
        set
        {
            if (_currentPage != value)
            {
                _currentPage = value;
                _ = InvokeAsync(LoadDataForCurrentPage);
            }
        }
    }

    [Parameter] public string? Category { get; set; }
    [Parameter] public bool ShowCategoryFilter { get; set; } = true;

    private readonly List<string> _colorPalette =
    [
        Colors.Red.Darken1, Colors.Blue.Darken1, Colors.Green.Darken1, Colors.Purple.Darken1,
        Colors.Amber.Darken1, Colors.Brown.Default, Colors.Cyan.Default, Colors.Orange.Darken1,
        Colors.Indigo.Darken1, Colors.Teal.Darken1, Colors.DeepPurple.Darken1, Colors.LightGreen.Darken1,
        Colors.Pink.Darken1, Colors.BlueGray.Darken1, Colors.DeepOrange.Darken1, Colors.Lime.Darken1,
        Colors.Red.Darken3, Colors.Blue.Darken3, Colors.Green.Darken3, Colors.Purple.Darken3,
        Colors.Gray.Darken2, Colors.Red.Lighten1, Colors.Blue.Lighten1, Colors.Green.Lighten1
    ];

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnContinuityChanged;
        await InitializeColorMapping();

        if (ShowCategoryFilter)
        {
            await LoadCategories();
            _eras = await Http.GetFromJsonAsync<Era[]>("Timeline/eras");
        }

        // Only auto-load if a specific Category parameter is set (not the multi-select page)
        if (!string.IsNullOrEmpty(Category))
        {
            await LoadDataForCurrentPage();
        }
    }

    public void Dispose()
    {
        GlobalFilterService.OnChange -= OnContinuityChanged;
    }

    private async void OnContinuityChanged()
    {
        await InvokeAsync(async () =>
        {
            _currentPage = 1;

            // Reload categories from API with updated global filters
            await LoadCategories();

            // Remove any selected categories that are no longer in the filtered list
            if (_categories is not null)
            {
                var visible = new HashSet<string>(_categories);
                _selectedCategories = _selectedCategories.Where(c => visible.Contains(c)).ToList();
            }

            // Clear results if no categories remain selected
            if (_selectedCategories.Any())
            {
                await LoadDataForCurrentPage();
            }
            else
            {
                _pagedResult = null;
            }

            StateHasChanged();
        });
    }

    private async Task InitializeColorMapping()
    {
        try
        {
            var allCategories = await Http.GetFromJsonAsync<string[]>("Timeline/available-categories");
            if (allCategories != null)
            {
                var sorted = allCategories.OrderBy(x => x).ToList();
                for (int i = 0; i < sorted.Count; i++)
                {
                    var cleaned = sorted[i].Replace("_infobox", "").ToLower();
                    _templateColorMap[cleaned] = _colorPalette[i % _colorPalette.Count];
                }
            }
        }
        catch { }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_templateColorMap.Any())
            await InitializeColorMapping();

        if (!string.IsNullOrEmpty(Category))
            await LoadDataForCurrentPage();
    }

    private async Task LoadCategories()
    {
        var query = HttpUtility.ParseQueryString(string.Empty);
        AddGlobalFilters(query);
        _categories = await Http.GetFromJsonAsync<string[]>($"Timeline/categories?{query}");
    }

    private async Task ApplyFilters()
    {
        _currentPage = 1;
        await LoadDataForCurrentPage();
    }

    private void SelectAllCategories()
    {
        _selectedCategories = _categories?.ToList() ?? [];
    }

    private void DeselectAllCategories()
    {
        _selectedCategories = new List<string>();
        _pagedResult = null;
    }

    /// <summary>
    /// Compute the merged year range from all selected eras.
    /// Returns the earliest start and latest end across all selected eras.
    /// </summary>
    private (float? yearFrom, Demarcation? fromDem, float? yearTo, Demarcation? toDem) GetEraYearRange()
    {
        if (_eras is null || !_selectedEraNames.Any())
            return (null, null, null, null);

        var selected = _eras.Where(e => _selectedEraNames.Contains(e.Name)).ToList();
        if (selected.Count == 0)
            return (null, null, null, null);

        // Find the era with the earliest start (most negative linear year)
        var earliest = selected.MinBy(e => ToLinear(e.StartYear, e.StartDemarcation))!;
        // Find the era with the latest end (most positive linear year)
        var latest = selected.MaxBy(e => ToLinear(e.EndYear, e.EndDemarcation))!;

        return (earliest.StartYear, earliest.StartDemarcation, latest.EndYear, latest.EndDemarcation);
    }

    static double ToLinear(float year, Demarcation dem) => dem == Demarcation.Bby ? -year : year;

    private async Task LoadDataForCurrentPage()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            if (!string.IsNullOrEmpty(Category))
            {
                var query = HttpUtility.ParseQueryString(string.Empty);
                query.Add("Page", CurrentPage.ToString());
                query.Add("PageSize", _pageSize.ToString());
                AddGlobalFilters(query);
                _pagedResult = await Http.GetFromJsonAsync<GroupedTimelineResult>($"Timeline/categories/{Category}/events?{query}");
            }
            else
            {
                if (!_selectedCategories.Any())
                {
                    _pagedResult = null;
                    return;
                }

                var query = HttpUtility.ParseQueryString(string.Empty);
                query.Add("Page", CurrentPage.ToString());
                query.Add("PageSize", _pageSize.ToString());

                foreach (var c in _selectedCategories)
                    query.Add("Categories", c);

                AddGlobalFilters(query);

                // Add era year range filter
                var (yearFrom, fromDem, yearTo, toDem) = GetEraYearRange();
                if (yearFrom.HasValue && fromDem.HasValue && yearTo.HasValue && toDem.HasValue)
                {
                    query.Add("YearFrom", yearFrom.Value.ToString());
                    query.Add("YearFromDemarcation", fromDem.Value.ToString());
                    query.Add("YearTo", yearTo.Value.ToString());
                    query.Add("YearToDemarcation", toDem.Value.ToString());
                }

                _pagedResult = await Http.GetFromJsonAsync<GroupedTimelineResult>($"Timeline/events?{query}");
            }

            _pages = (_pagedResult is not null && _pagedResult.Total > 0 && _pagedResult.Size > 0)
                ? (int)Math.Ceiling((double)_pagedResult.Total / _pagedResult.Size)
                : 0;

            if (CurrentPage > _pages && _pages > 0)
            {
                _currentPage = 1;
                await LoadDataForCurrentPage();
                return;
            }
            else if (_pages == 0)
            {
                _currentPage = 1;
            }
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void AddGlobalFilters(System.Collections.Specialized.NameValueCollection query)
    {
        var continuityParam = GlobalFilterService.GetContinuityQueryParam();
        if (!string.IsNullOrEmpty(continuityParam))
            query.Add("continuity", continuityParam);

        var universeParam = GlobalFilterService.GetUniverseQueryParam();
        if (!string.IsNullOrEmpty(universeParam))
            query.Add("universe", universeParam);
    }

    private string GetColor(StarWarsData.Models.Entities.TimelineEvent timelineEvent)
    {
        if (string.IsNullOrEmpty(timelineEvent.Template))
            return Colors.Blue.Default;

        var cleaned = timelineEvent.Template.Replace("_infobox", "").ToLower();
        if (_templateColorMap.TryGetValue(cleaned, out var mapped))
            return mapped;

        return cleaned switch
        {
            "event" => Colors.LightBlue.Lighten1,
            "trade_route" => Colors.Cyan.Default,
            "campaign" => Colors.Shades.Black,
            "mission" => Colors.Gray.Darken4,
            "battle" => Colors.Red.Darken1,
            "duel" => Colors.Red.Darken2,
            "fleet" => Colors.Red.Darken3,
            "war" => Colors.Red.Darken4,
            "disease" => Colors.Green.Darken4,
            "location" => Colors.Blue.Lighten1,
            "city" => Colors.Blue.Darken1,
            "law" => Colors.Green.Darken1,
            "treaty" => Colors.Green.Darken2,
            "election" => Colors.Blue.Darken3,
            "character" => Colors.Brown.Default,
            "government" => Colors.Amber.Darken1,
            "organization" => Colors.Amber.Lighten1,
            "company" => Colors.Amber.Darken3,
            "religion" => Colors.Purple.Lighten1,
            "holocron" => Colors.Purple.Darken1,
            "lightsaber" => Colors.Purple.Darken2,
            "droid" => Colors.BlueGray.Darken2,
            "artifact" => Colors.BlueGray.Darken3,
            _ => Colors.Blue.Default
        };
    }

    private string GetChipColor(string category)
    {
        var cleaned = category.Replace("_infobox", "").ToLower();
        return _templateColorMap.TryGetValue(cleaned, out var c) ? c : Colors.Blue.Default;
    }

    private IEnumerable<string> GetSortedCategories()
    {
        if (_categories is null) return [];
        return _categories
            .OrderByDescending(c => _selectedCategories.Contains(c))
            .ThenBy(c => c, StringComparer.OrdinalIgnoreCase);
    }

    private static string FormatCategoryName(string category) =>
        category.Replace("_infobox", "").Replace("_", " ");

    private static string FormatYear(float year, Demarcation dem) =>
        $"{year:0.##} {dem.ToString().ToUpper()}";
}
