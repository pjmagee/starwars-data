@using StarWarsData.Models.Queries
@using StarWarsData.Frontend.Services
@using System.Web
@inject IHttpClientFactory HttpClientFactory
@inject GlobalFilterService GlobalFilterService
@inject IJSRuntime JS
@implements IAsyncDisposable

<MudPaper Outlined="true" Class="@PaperClass" Style="width:100%">

    @* ── Header ── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.h6">@Descriptor.Title</MudText>
        <MudSpacer />
        @if (_pagedResult is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-2">
                @_pagedResult.Total.ToString("N0") events
            </MudText>
            <MudTooltip Text="@(_maximized ? "Exit fullscreen" : "Fullscreen")">
                <MudIconButton Icon="@(_maximized ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                               Size="Size.Small"
                               Variant="Variant.Outlined"
                               OnClick="ToggleFullscreen" />
            </MudTooltip>
        }
    </MudStack>

    @if (Descriptor.YearFrom is not null || !string.IsNullOrEmpty(Descriptor.Search))
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            @if (Descriptor.YearFrom is not null && Descriptor.YearTo is not null)
            {
                @if (IsRealMode)
                {
                    <span>Period: @FormatRealYear(Descriptor.YearFrom.Value) – @FormatRealYear(Descriptor.YearTo.Value)</span>
                }
                else
                {
                    <span>Period: @Descriptor.YearFrom @Descriptor.YearFromDemarcation – @Descriptor.YearTo @Descriptor.YearToDemarcation</span>
                }
            }
            @if (!string.IsNullOrEmpty(Descriptor.Search))
            {
                <span class="ml-2">Filter: "@Descriptor.Search"</span>
            }
        </MudText>
    }

    @if (_loading && _allItems.Count == 0)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading timeline events…</MudText>
        </MudStack>
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_pagedResult is not null)
    {
        <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
            @foreach (var cat in Descriptor.Categories)
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                    @cat.Replace("_infobox", "").Replace("_", " ")
                </MudChip>
            }
        </MudStack>

        @if (!_maximized)
        {
            <MudPagination @bind-Selected="CurrentPage" ShowFirstButton="true" ShowLastButton="true" Count="_pages" Class="ma-4" />
        }

        <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelineAlign="TimelineAlign.Default" TimelinePosition="TimelinePosition.Alternate" Class="ma-4" Modifiers="false">
            @{
                var isStart = true;
                var items = _maximized ? _allItems : (_pagedResult.Items?.ToList() ?? []);
            }

            @foreach (var group in items)
            {
                var contentAlign = isStart ? Align.Left : Align.Right;
                var yearAlign = isStart ? Align.Right : Align.Left;

                <MudTimelineItem Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Medium">
                    <ItemOpposite>
                        <MudText Color="Color.Info" Typo="Typo.h5" Align="@yearAlign">@group.Year</MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudExpansionPanels Dense="true" MultiExpansion="true" Style="max-height: 600px; overflow: auto;">
                            @foreach (var evt in group.Events)
                            {
                                var color = GetColor(evt);
                                <MudExpansionPanel Text="@evt.DisplayTitle" Style="@($"color:{color}; text-align:{contentAlign};")">
                                    <MudCard Outlined="true" Class="ma-2">
                                        @if (evt.DisplayImageWithoutRevision is not null)
                                        {
                                            <MudImage Fluid="true" Src="@evt.DisplayImageWithoutRevision" Alt="" Class="rounded-lg ma-2" />
                                        }
                                        <MudCardContent>
                                            @foreach (var item in evt.Properties)
                                            {
                                                @if (item.Links.Count > 0 || item.Values.Count > 0)
                                                {
                                                    <MudText Typo="Typo.body2">
                                                        <b>@item.Label: </b>
                                                        @foreach (var link in item.Links)
                                                        {
                                                            <MudLink Class="mr-1" Underline="Underline.Always" Href="@link.Href">@link.Content</MudLink>
                                                        }
                                                        @string.Join(", ", item.Values.Where(x => !item.Links.Any(l => l.Content.Equals(x, StringComparison.OrdinalIgnoreCase))))
                                                    </MudText>
                                                }
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </ItemContent>
                </MudTimelineItem>

                isStart = !isStart;
            }
        </MudTimeline>

        @if (!_maximized)
        {
            <MudPagination @bind-Selected="CurrentPage" ShowFirstButton="true" ShowLastButton="true" Count="_pages" Class="ma-4" />
        }

        @* ── Infinite scroll sentinel (fullscreen only) ── *@
        @if (_maximized && _hasMore)
        {
            <div @ref="_sentinel" class="d-flex justify-center pa-4">
                @if (_loadingMore)
                {
                    <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" />
                    <MudText Typo="Typo.caption" Class="ml-2">Loading more events...</MudText>
                }
            </div>
        }
        else if (_maximized && _allItems.Count > 0 && !_hasMore)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="pa-4">
                All @_pagedResult.Total.ToString("N0") events loaded
            </MudText>
        }
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No timeline events found for the selected categories.</MudText>
    }
    <AskReferencesSection References="@Descriptor.References" />
</MudPaper>

@if (_maximized)
{
    <MudFab Color="Color.Tertiary"
            StartIcon="@Icons.Material.Filled.ArrowCircleUp"
            Style="position: fixed; bottom: 32px; right: 32px; z-index: 1400;"
            OnClick="ScrollToTop" />
}

<style>
    .ask-timeline-maximized {
        position: fixed;
        inset: 0;
        z-index: 1300;
        background: var(--mud-palette-background);
        overflow-y: auto;
        padding: 24px;
    }
</style>

@code {
    [Parameter, EditorRequired]
    public TimelineDescriptor Descriptor { get; set; } = null!;

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");
    private GroupedTimelineResult? _pagedResult;
    private bool _loading = true;
    private string? _error;
    private int _pages;

    // Pagination mode (inline)
    private int _currentPage = 1;
    private int CurrentPage
    {
        get => _currentPage;
        set
        {
            if (_currentPage != value)
            {
                _currentPage = value;
                _ = InvokeAsync(LoadData);
            }
        }
    }

    // Fullscreen + infinite scroll state
    private bool _maximized;
    private List<GroupedTimelines> _allItems = [];
    private bool _hasMore;
    private bool _loadingMore;
    private ElementReference _sentinel;
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<AskTimelineView>? _dotNetRef;

    private string PaperClass => _maximized ? "ask-timeline-maximized" : "pa-4 mt-4";

    private readonly Dictionary<string, string> _templateColorMap = new();

    private readonly List<string> _colorPalette =
    [
        Colors.Red.Darken1, Colors.Blue.Darken1, Colors.Green.Darken1,
        Colors.Purple.Darken1, Colors.Amber.Darken1, Colors.Brown.Default,
        Colors.Cyan.Default, Colors.Orange.Darken1, Colors.Indigo.Darken1,
        Colors.Teal.Darken1, Colors.DeepPurple.Darken1, Colors.LightGreen.Darken1,
        Colors.Pink.Darken1, Colors.BlueGray.Darken1, Colors.DeepOrange.Darken1
    ];

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnFilterChanged;
        await InitializeColorMapping();
    }

    protected override async Task OnParametersSetAsync()
    {
        _currentPage = 1;
        _loading = true;
        _error = null;
        _pagedResult = null;
        _allItems.Clear();
        StateHasChanged();
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/infinite-scroll.js");
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (_maximized && _hasMore && !_loadingMore && _jsModule is not null && _dotNetRef is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("observe", _sentinel, _dotNetRef);
            }
            catch (JSException) { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        GlobalFilterService.OnChange -= OnFilterChanged;

        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("dispose", _sentinel);
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }

        _dotNetRef?.Dispose();
    }

    [JSInvokable]
    public async Task OnSentinelVisible()
    {
        if (_loadingMore || !_hasMore || !_maximized) return;

        _loadingMore = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            _currentPage++;
            var result = await FetchPage(_currentPage);

            if (result?.Items.Any() == true)
            {
                MergeItems(result.Items);
                _hasMore = _currentPage < _pages;
            }
            else
            {
                _hasMore = false;
            }
        }
        finally
        {
            _loadingMore = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ToggleFullscreen()
    {
        _maximized = !_maximized;

        if (_maximized)
        {
            // Entering fullscreen: reset to page 1 and load with infinite scroll
            _currentPage = 1;
            _allItems.Clear();
            await LoadData();
        }
        else
        {
            // Exiting fullscreen: reset to page 1 pagination view
            _currentPage = 1;
            _allItems.Clear();
            _hasMore = false;
            await LoadData();
        }
    }

    private async Task ScrollToTop()
    {
        await JS.InvokeVoidAsync("eval", "document.querySelector('.ask-timeline-maximized')?.scrollTo({top: 0, behavior: 'smooth'})");
    }

    private async void OnFilterChanged()
    {
        _currentPage = 1;
        _allItems.Clear();
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task InitializeColorMapping()
    {
        try
        {
            var allCategories = await Http.GetFromJsonAsync<string[]>("Timeline/available-categories");
            if (allCategories is not null)
            {
                var sorted = allCategories.OrderBy(x => x).ToList();
                for (int i = 0; i < sorted.Count; i++)
                {
                    var cleaned = sorted[i].Replace("_infobox", "").ToLower();
                    _templateColorMap[cleaned] = _colorPalette[i % _colorPalette.Count];
                }
            }
        }
        catch { /* fall back to default colors */ }
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            var result = await FetchPage(_currentPage);
            _pagedResult = result;

            _pages = (_pagedResult is { Total: > 0, Size: > 0 })
                ? (int)Math.Ceiling((double)_pagedResult.Total / _pagedResult.Size)
                : 0;

            if (_currentPage > _pages && _pages > 0)
            {
                _currentPage = 1;
                await LoadData();
                return;
            }

            if (_maximized && result?.Items.Any() == true)
            {
                MergeItems(result.Items);
                _hasMore = _currentPage < _pages;
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load timeline: {ex.Message}";
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<GroupedTimelineResult?> FetchPage(int page)
    {
        var query = HttpUtility.ParseQueryString(string.Empty);
        query.Add("Page", page.ToString());
        query.Add("PageSize", Descriptor.PageSize.ToString());

        foreach (var cat in Descriptor.Categories)
            query.Add("Categories", cat);

        var continuity = GlobalFilterService.GetContinuityQueryParam();
        if (!string.IsNullOrEmpty(continuity))
            query.Add("continuity", continuity);

        var realm = GlobalFilterService.GetRealmQueryParam();
        if (!string.IsNullOrEmpty(realm))
            query.Add("realm", realm);

        if (Descriptor.YearFrom is not null)
            query.Add("YearFrom", Descriptor.YearFrom.Value.ToString());
        if (!string.IsNullOrEmpty(Descriptor.YearFromDemarcation))
            query.Add("YearFromDemarcation", Descriptor.YearFromDemarcation);
        if (Descriptor.YearTo is not null)
            query.Add("YearTo", Descriptor.YearTo.Value.ToString());
        if (!string.IsNullOrEmpty(Descriptor.YearToDemarcation))
            query.Add("YearToDemarcation", Descriptor.YearToDemarcation);
        if (!string.IsNullOrEmpty(Descriptor.Search))
            query.Add("Search", Descriptor.Search);
        if (!string.IsNullOrEmpty(Descriptor.Calendar))
            query.Add("Calendar", Descriptor.Calendar);

        return await Http.GetFromJsonAsync<GroupedTimelineResult>($"Timeline/events?{query}");
    }

    private void MergeItems(IEnumerable<GroupedTimelines> newItems)
    {
        foreach (var group in newItems)
        {
            var existing = _allItems.LastOrDefault();
            if (existing is not null && existing.Year == group.Year)
            {
                existing.Events.AddRange(group.Events);
            }
            else
            {
                _allItems.Add(group);
            }
        }
    }

    private string GetColor(TimelineEvent evt)
    {
        if (string.IsNullOrEmpty(evt.Template)) return Colors.Blue.Default;
        var cleaned = evt.Template.Replace("_infobox", "").ToLower();
        return _templateColorMap.TryGetValue(cleaned, out var color) ? color : Colors.Blue.Default;
    }

    private bool IsRealMode => string.Equals(Descriptor.Calendar, "Real", StringComparison.OrdinalIgnoreCase);

    private static string FormatRealYear(float year)
    {
        var ce = (int)Math.Round(year);
        return ce < 0 ? $"{-ce} BCE" : ce.ToString();
    }
}
