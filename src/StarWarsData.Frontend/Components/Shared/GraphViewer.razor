@using WikiPage = StarWarsData.Models.Entities.Page
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

<div style="@($"position:relative; overflow:hidden; border-radius:8px; {(_fullscreen ? "position:fixed; top:0; left:0; right:0; bottom:0; z-index:9999; border-radius:0;" : "")}")">

    @* ── Settings panel (left side, inside canvas) ── *@
    <div style="position:absolute; top:8px; left:8px; bottom:8px; z-index:10; width:320px; max-height:calc(100% - 16px); overflow-y:auto; display:flex; flex-direction:column; gap:4px; background:rgba(20,20,46,0.92); border-radius:8px; padding:8px; scrollbar-width:thin;">

        @* Breadcrumbs *@
        @if (History is { Count: > 0 })
        {
            <div style="display:flex; align-items:center; gap:4px; padding:2px 0; flex-wrap:wrap;">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                               Style="color:#e0e0f0;" OnClick="@(() => OnNavigateBack.InvokeAsync())" />
                @foreach (var crumb in History)
                {
                    var c = crumb;
                    <MudLink Style="color:#90caf9; font-size:11px; cursor:pointer;"
                             OnClick="@(() => OnBreadcrumbClicked.InvokeAsync(c))">@c.Name</MudLink>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);">›</MudText>
                }
                <MudText Typo="Typo.caption" Style="color:#ffa726; font-weight:600; font-size:11px;">@CurrentEntityName</MudText>
            </div>
            <hr style="border:none; border-top:1px solid rgba(255,255,255,0.1); margin:2px 0;" />
        }

        @* Depth control *@
        @if (MaxDepth.HasValue)
        {
            <div style="display:flex; align-items:center; gap:6px; padding:2px 0;">
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5); width:40px;">Depth</MudText>
                <MudSlider T="int" Value="MaxDepth.Value" ValueChanged="@(v => OnDepthChanged.InvokeAsync(v))"
                           Min="1" Max="4" Step="1" TickMarks="true" Immediate="false"
                           Style="flex:1;" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Style="color:#90caf9; width:16px; text-align:right;">@MaxDepth.Value</MudText>
            </div>
        }

        @* Node limit control *@
        @if (MaxNodeLimit.HasValue)
        {
            <div style="display:flex; align-items:center; gap:6px; padding:2px 0;">
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5); width:40px;">Nodes</MudText>
                <MudSlider T="int" Value="MaxNodeLimit.Value" ValueChanged="@(v => OnMaxNodeLimitChanged.InvokeAsync(v))"
                           Min="10" Max="500" Step="10" TickMarks="true" Immediate="false"
                           Style="flex:1;" Color="Color.Secondary" />
                <MudText Typo="Typo.caption" Style="color:#ce93d8; width:28px; text-align:right;">@MaxNodeLimit.Value</MudText>
            </div>
        }

        @* Stats + truncation warning *@
        @if (Stats.HasValue)
        {
            <div style="display:flex; align-items:center; gap:4px; padding:2px 0;">
                @if (IsTruncated)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Style="color:#ffa726;" />
                }
                <MudText Typo="Typo.caption" Style="@($"color:{(IsTruncated ? "#ffa726" : "rgba(255,255,255,0.5)")}")">
                    @Stats.Value.nodes nodes · @Stats.Value.edges edges@(IsTruncated ? " (capped)" : "")
                </MudText>
            </div>
        }

        @* Temporal slider *@
        @if (_hasTemporalData)
        {
            <hr style="border:none; border-top:1px solid rgba(255,255,255,0.1); margin:2px 0;" />
            <div style="display:flex; align-items:center; gap:4px; padding:2px 0;">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Style="color:#ffa726;" />
                <MudSlider T="int" Value="_selectedTickIndex" ValueChanged="OnTickChanged"
                           Min="0" Max="@(_temporalTicks.Count - 1)" Step="1"
                           Style="flex:1;" Color="Color.Warning" />
                <MudText Typo="Typo.caption" Style="color:#ffa726; white-space:nowrap; font-size:11px;">
                    @FormatYear(_temporalTicks[_selectedTickIndex])
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small"
                               OnClick="ClearYearFilter" Style="color:#aaa; padding:2px;" />
            </div>
        }

        @* Node search / highlight *@
        <hr style="border:none; border-top:1px solid rgba(255,255,255,0.1); margin:2px 0;" />
        <div style="display:flex; align-items:center; gap:4px; padding:2px 0;">
            <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Style="color:rgba(255,255,255,0.5);" />
            <input type="text" placeholder="Find node..." @bind="_nodeSearch" @bind:event="oninput"
                   @onkeyup="OnNodeSearchChanged"
                   style="background:transparent; border:none; outline:none; color:white; font-size:12px; flex:1; min-width:0;" />
            @if (!string.IsNullOrEmpty(_nodeSearch))
            {
                <MudText Typo="Typo.caption" Style="color:#90caf9; font-size:10px;">@_nodeSearchCount</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Clear" Size="Size.Small"
                               OnClick="ClearNodeSearch" Style="color:#aaa; padding:2px;" />
            }
        </div>

        @* Label chips + bulk toggle buttons *@
        @if (Labels is { Count: > 0 })
        {
            <hr style="border:none; border-top:1px solid rgba(255,255,255,0.1); margin:2px 0;" />
            <div style="display:flex; align-items:center; gap:4px; flex-wrap:wrap;">
                @{
                    var enabledCount = Labels.Count(l => EnabledLabels?.Contains(l) ?? true);
                }
                @if (OnLabelsBulkSet.HasDelegate)
                {
                    <MudTooltip Text="Enable all labels (warning: noisy for entities with many relationships)">
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   Color="@(enabledCount == Labels.Count ? Color.Success : Color.Default)"
                                   Style="min-width:40px; color:#90caf9; font-size:11px; padding:2px 6px;"
                                   OnClick="@(() => OnLabelsBulkSet.InvokeAsync([..Labels]))">
                            All
                        </MudButton>
                    </MudTooltip>
                    <MudTooltip Text="Disable all labels">
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   Color="@(enabledCount == 0 ? Color.Error : Color.Default)"
                                   Style="min-width:48px; color:#f48fb1; font-size:11px; padding:2px 6px;"
                                   OnClick="@(() => OnLabelsBulkSet.InvokeAsync(new HashSet<string>()))">
                            None
                        </MudButton>
                    </MudTooltip>
                    @if (DefaultLabels is { Count: > 0 })
                    {
                        <MudTooltip Text="@($"Reset to type defaults ({DefaultLabels.Count} labels)")">
                            <MudButton Size="Size.Small" Variant="Variant.Text"
                                       StartIcon="@Icons.Material.Filled.RestartAlt"
                                       Style="min-width:72px; color:#ffa726; font-size:11px; padding:2px 6px;"
                                       OnClick="@(() => OnLabelsBulkSet.InvokeAsync([..DefaultLabels]))">
                                Reset
                            </MudButton>
                        </MudTooltip>
                    }
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4); margin:0 4px;">
                        @enabledCount/@Labels.Count
                    </MudText>
                }
                @foreach (var label in Labels)
                {
                    var l = label;
                    var enabled = EnabledLabels?.Contains(l) ?? true;
                    var isDefault = DefaultLabels?.Contains(l) ?? false;
                    <MudTooltip Text="@(isDefault ? $"{l} (default)" : l)">
                        <MudChip T="string" Size="Size.Small"
                                 Variant="@(enabled ? Variant.Filled : Variant.Outlined)"
                                 Color="Color.Info"
                                 Style="@(enabled ? (isDefault ? "border:1px solid #ffa726" : "") : "opacity:0.4")"
                                 OnClick="@(() => OnLabelToggled.InvokeAsync(l))">
                            @FormatLabel(l)
                        </MudChip>
                    </MudTooltip>
                }
            </div>
        }

        @* Hint text *@
        @if (!string.IsNullOrEmpty(Hint))
        {
            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3); font-size:11px; padding-left:4px;">@Hint</MudText>
        }
    </div>

    @* ── Zoom/fullscreen controls (top-right) ── *@
    <div style="position:absolute; top:8px; right:8px; z-index:10; display:flex; gap:4px;">
        <MudIconButton Icon="@Icons.Material.Filled.ZoomIn" Size="Size.Small"
                       OnClick="ZoomIn" Style="background:rgba(30,30,56,0.8); color:#e0e0f0;" />
        <MudIconButton Icon="@Icons.Material.Filled.ZoomOut" Size="Size.Small"
                       OnClick="ZoomOut" Style="background:rgba(30,30,56,0.8); color:#e0e0f0;" />
        <MudIconButton Icon="@Icons.Material.Filled.FitScreen" Size="Size.Small"
                       OnClick="FitToScreen" Style="background:rgba(30,30,56,0.8); color:#e0e0f0;" />
        <MudIconButton Icon="@(_fullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                       Size="Size.Small" OnClick="ToggleFullscreen"
                       Style="background:rgba(30,30,56,0.8); color:#e0e0f0;" />
    </div>

    @* ── D3 canvas ── *@
    <div id="@_containerId"
         style="@($"width:100%; background:#16162e; {(_fullscreen ? "height:100vh;" : $"height:{Height}px;")}")">
    </div>

    @* ── Node detail panel (inside, right overlay) ── *@
    @if (_loadingNodeDetails)
    {
        <div style="position:absolute; top:0; right:0; width:320px; height:100%; z-index:20; background:var(--mud-palette-surface); border-left:1px solid var(--mud-palette-lines-default); overflow-y:auto;">
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:100%">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        </div>
    }
    else if (_selectedNodePage is not null)
    {
        <div style="position:absolute; top:0; right:0; width:320px; height:100%; z-index:20; background:var(--mud-palette-surface); border-left:1px solid var(--mud-palette-lines-default); overflow-y:auto;">
            <MudCard Elevation="0">
                @if (_selectedNodePage.Infobox?.ImageUrl is not null)
                {
                    <MudCardMedia Image="@StripRevision(_selectedNodePage.Infobox.ImageUrl)" Height="180" />
                }
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@_selectedNodePage.Title</MudText>
                        @if (_selectedNodePage.Infobox?.Template is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @SanitizeTemplate(_selectedNodePage.Infobox.Template)
                            </MudText>
                        }
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseNodePanel" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (_selectedNodePage.Infobox?.Data is not null)
                    {
                        <MudSimpleTable Dense="true" Bordered="true" Striped="true" Style="overflow-x:auto; font-size:12px;">
                            <tbody>
                                @foreach (var prop in _selectedNodePage.Infobox.Data.Where(HasInfoboxContent))
                                {
                                    <tr>
                                        <td style="font-weight:600; white-space:nowrap; width:1%; padding:4px 8px; vertical-align:top;">@prop.Label</td>
                                        <td style="padding:4px 8px;">
                                            @foreach (var link in prop.Links)
                                            {
                                                <MudLink Href="@link.Href" Underline="Underline.Always" Class="mr-1" Target="_blank">@link.Content</MudLink>
                                            }
                                            @GetPlainValues(prop)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudCardContent>
                <MudCardActions>
                    @if (_selectedNodePage.WikiUrl is not null)
                    {
                        <MudButton Href="@_selectedNodePage.WikiUrl" Target="_blank" Variant="Variant.Text" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.OpenInNew" Size="Size.Small">Wookieepedia</MudButton>
                    }
                    @if (OnNodeExpandRequested.HasDelegate)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Hub"
                                   OnClick="@(() => OnNodeExpandRequested.InvokeAsync((_selectedNodeId, _selectedNodePage.Title)))">
                            Explore Graph
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Href="@($"/graph-explorer/{_selectedNodeId}")" Variant="Variant.Text" Color="Color.Secondary"
                                   Size="Size.Small" StartIcon="@Icons.Material.Filled.Hub">Explore</MudButton>
                    }
                </MudCardActions>
            </MudCard>
        </div>
    }

    @* ── Keyboard hints (bottom-left) ── *@
    @if (EnableKeyboardShortcuts)
    {
        <div style="position:absolute; bottom:8px; left:8px; z-index:10;">
            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4); font-size:13px;">
                Double-click: expand &bull; Backspace: back &bull; F: fullscreen &bull; Esc: close/exit
            </MudText>
        </div>
    }

    @* ── Stats overlay (bottom-right) ── *@
    @if (Stats is not null)
    {
        <div style="position:absolute; bottom:8px; right:8px; z-index:10; display:flex; gap:8px;">
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                     Style="background:rgba(30,30,56,0.8);">
                @Stats.Value.nodes nodes
            </MudChip>
            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text"
                     Style="background:rgba(30,30,56,0.8);">
                @Stats.Value.edges edges
            </MudChip>
        </div>
    }
</div>

@code {
    // ── Core parameters ──
    [Parameter, EditorRequired]
    public RelationshipGraphResult GraphData { get; set; } = null!;

    [Parameter] public GraphLayoutMode LayoutMode { get; set; } = GraphLayoutMode.Force;
    [Parameter] public int Height { get; set; } = 650;
    [Parameter] public string? Hint { get; set; }
    [Parameter] public EventCallback<(int id, string name)> OnNodeExpandRequested { get; set; }

    // ── Label toggles (optional) ──
    [Parameter] public List<string>? Labels { get; set; }
    [Parameter] public HashSet<string>? EnabledLabels { get; set; }
    [Parameter] public HashSet<string>? DefaultLabels { get; set; }
    [Parameter] public EventCallback<string> OnLabelToggled { get; set; }
    [Parameter] public EventCallback<HashSet<string>> OnLabelsBulkSet { get; set; }

    // ── Depth control (optional) ──
    [Parameter] public int? MaxDepth { get; set; }
    [Parameter] public EventCallback<int> OnDepthChanged { get; set; }

    // ── Node limit control (optional) ──
    [Parameter] public int? MaxNodeLimit { get; set; }
    [Parameter] public EventCallback<int> OnMaxNodeLimitChanged { get; set; }

    // ── Navigation breadcrumbs (optional) ──
    [Parameter] public List<(int Id, string Name)>? History { get; set; }
    [Parameter] public string? CurrentEntityName { get; set; }
    [Parameter] public EventCallback OnNavigateBack { get; set; }
    [Parameter] public EventCallback<(int Id, string Name)> OnBreadcrumbClicked { get; set; }

    // ── Stats (optional) ──
    [Parameter] public (int nodes, int edges)? Stats { get; set; }
    [Parameter] public bool IsTruncated { get; set; }

    // ── Keyboard shortcuts (optional) ──
    [Parameter] public bool EnableKeyboardShortcuts { get; set; }

    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<GraphViewer>? _dotnetRef;
    private readonly string _containerId = $"d3-graph-{Guid.NewGuid():N}";
    private bool _fullscreen;

    private WikiPage? _selectedNodePage;
    private int _selectedNodeId;
    private bool _loadingNodeDetails;

    private bool _hasTemporalData;
    private List<int> _temporalTicks = [];
    private int _selectedTickIndex;

    // Node search
    private string _nodeSearch = "";
    private int _nodeSearchCount;

    private RelationshipGraphResult? _lastRenderedData;
    private bool _pendingRender;

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override void OnParametersSet()
    {
        // Don't call JS interop here — prerendering runs OnParametersSet before the
        // component is on the page, and JS isn't available yet. Mark dirty instead
        // and let OnAfterRenderAsync perform the render after the circuit is live.
        if (GraphData?.Nodes is { Count: > 0 } && !ReferenceEquals(GraphData, _lastRenderedData))
        {
            _lastRenderedData = GraphData;
            _pendingRender = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingRender)
        {
            _pendingRender = false;
            await RenderGraph();
        }
    }

    async Task RenderGraph()
    {
        _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/d3-graph.js");

        var nodes = GraphData.Nodes.Select(n => new
        {
            id = n.Id, name = n.Name, type = n.Type, imageUrl = n.ImageUrl ?? "",
        }).ToArray();

        var edges = GraphData.Edges.Select(e => new
        {
            fromId = e.FromId, toId = e.ToId, label = e.Label,
            weight = e.Weight > 0 ? e.Weight : 0.7,
            fromYear = e.FromYear, toYear = e.ToYear,
        }).ToArray();

        var yearSet = new SortedSet<int>();
        foreach (var e in GraphData.Edges)
        {
            if (e.FromYear.HasValue) yearSet.Add(e.FromYear.Value);
            if (e.ToYear.HasValue) yearSet.Add(e.ToYear.Value);
        }
        _temporalTicks = [.. yearSet];
        _hasTemporalData = _temporalTicks.Count > 1;
        if (_hasTemporalData)
            _selectedTickIndex = 0;

        var data = new { nodes, edges, rootId = GraphData.RootId, layoutMode = LayoutMode.ToString().ToLowerInvariant() };

        _dotnetRef?.Dispose();
        _dotnetRef = DotNetObjectReference.Create(this);
        await _jsModule.InvokeVoidAsync("renderForceGraph", _containerId, data, _dotnetRef);

        if (EnableKeyboardShortcuts)
            await _jsModule.InvokeVoidAsync("registerKeyboardShortcuts", _dotnetRef);

        // RenderGraph runs from OnAfterRenderAsync, outside the normal parameter-driven
        // render cycle. The temporal slider and other overlay controls depend on
        // _hasTemporalData / _temporalTicks, which we only know after scanning the
        // edges. Trigger a re-render so the overlay reflects the new temporal state.
        StateHasChanged();
    }

    /// <summary>
    /// Merge new nodes/edges into the existing graph (expand-on-double-click or navigate back).
    /// Returns the updated (nodes, edges) stats.
    /// </summary>
    public async Task<(int nodes, int edges)> ExpandWithDataAsync(RelationshipGraphResult data, int newRootId)
    {
        if (_jsModule is null) return (0, 0);

        var payload = new
        {
            nodes = data.Nodes.Select(n => new
            {
                id = n.Id, name = n.Name, type = n.Type, imageUrl = n.ImageUrl ?? "",
            }).ToArray(),
            edges = data.Edges.Select(e => new
            {
                fromId = e.FromId, toId = e.ToId,
                label = e.Label, weight = e.Weight > 0 ? e.Weight : 0.5,
            }).ToArray(),
            rootId = newRootId,
        };

        await _jsModule.InvokeVoidAsync("expandNode", payload);
        var stats = await _jsModule.InvokeAsync<GraphStatsDto>("getStats");
        return (stats.Nodes, stats.Edges);
    }

    record GraphStatsDto(int Nodes, int Edges);

    [JSInvokable]
    public async Task OnNodeClicked(int id, string name, string type)
    {
        _selectedNodeId = id;
        _selectedNodePage = null;
        _loadingNodeDetails = true;
        StateHasChanged();
        try { _selectedNodePage = await Http.GetFromJsonAsync<WikiPage>($"Pages/{id}"); }
        catch { _selectedNodePage = null; }
        finally { _loadingNodeDetails = false; StateHasChanged(); }
    }

    [JSInvokable]
    public async Task OnNodeExpand(int id, string name)
    {
        if (OnNodeExpandRequested.HasDelegate)
            await OnNodeExpandRequested.InvokeAsync((id, name));
    }

    [JSInvokable]
    public void OnKeyAction(string action)
    {
        InvokeAsync(async () =>
        {
            switch (action)
            {
                case "back":
                    if (OnNavigateBack.HasDelegate)
                        await OnNavigateBack.InvokeAsync();
                    break;
                case "fullscreen":
                    ToggleFullscreen();
                    break;
                case "escape":
                    if (_fullscreen) ToggleFullscreen();
                    else CloseNodePanel();
                    break;
            }
            StateHasChanged();
        });
    }

    void ToggleFullscreen() => _fullscreen = !_fullscreen;
    async Task ZoomIn() { if (_jsModule is not null) await _jsModule.InvokeVoidAsync("zoomIn"); }
    async Task ZoomOut() { if (_jsModule is not null) await _jsModule.InvokeVoidAsync("zoomOut"); }
    async Task FitToScreen() { if (_jsModule is not null) await _jsModule.InvokeVoidAsync("fitToScreen"); }

    async Task OnTickChanged(int tickIndex)
    {
        _selectedTickIndex = tickIndex;
        var year = _temporalTicks[tickIndex];
        if (_jsModule is not null) await _jsModule.InvokeVoidAsync("filterByYear", year);
    }

    async Task ClearYearFilter()
    {
        if (_jsModule is not null) await _jsModule.InvokeVoidAsync("filterByYear", (int?)null);
    }

    async Task OnNodeSearchChanged()
    {
        if (_jsModule is null) return;
        if (string.IsNullOrWhiteSpace(_nodeSearch))
        {
            _nodeSearchCount = 0;
            await _jsModule.InvokeVoidAsync("highlightNodes", "");
        }
        else
        {
            _nodeSearchCount = await _jsModule.InvokeAsync<int>("highlightNodes", _nodeSearch);
        }
    }

    async Task ClearNodeSearch()
    {
        _nodeSearch = "";
        _nodeSearchCount = 0;
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("highlightNodes", "");
    }

    void CloseNodePanel() { _selectedNodePage = null; _selectedNodeId = 0; _loadingNodeDetails = false; }

    static string FormatYear(int y) => y <= 0 ? $"{Math.Abs(y)} BBY" : $"{y} ABY";
    static string FormatLabel(string label) =>
        System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(label.Replace("_", " "));
    static string StripRevision(string url) { var i = url.IndexOf("/revision", StringComparison.OrdinalIgnoreCase); return i > 0 ? url[..i] : url; }
    static string SanitizeTemplate(string template) { var last = template.Split(':').LastOrDefault() ?? template; return last.Replace("_", " "); }
    static bool HasInfoboxContent(InfoboxProperty prop) => prop.Links.Count > 0 || prop.Values.Any(v => !string.IsNullOrWhiteSpace(v));
    static string GetPlainValues(InfoboxProperty prop)
    {
        var linkTexts = prop.Links.Select(l => l.Content).ToHashSet(StringComparer.OrdinalIgnoreCase);
        return string.Join(", ", prop.Values.Where(v => !string.IsNullOrWhiteSpace(v) && !linkTexts.Contains(v)));
    }

    public async ValueTask DisposeAsync()
    {
        _dotnetRef?.Dispose();
        if (_jsModule is not null)
        {
            try
            {
                if (EnableKeyboardShortcuts)
                    await _jsModule.InvokeVoidAsync("unregisterKeyboardShortcuts");
                await _jsModule.InvokeVoidAsync("destroyGraph", _containerId);
                await _jsModule.DisposeAsync();
            }
            catch { }
        }
    }
}
