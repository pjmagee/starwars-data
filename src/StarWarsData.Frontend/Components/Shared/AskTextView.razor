@using StarWarsData.Models.Queries

@if (Descriptor?.Sections is not null && Descriptor.Sections.Count > 0)
{
    <MudText Typo="Typo.h5" Class="mt-6 mb-3">@Descriptor.Title</MudText>

    <MudExpansionPanels MultiExpansion="true" Dense="true" Outlined="true">
        @foreach (var textSection in Descriptor.Sections)
        {
            <MudExpansionPanel Expanded="true" Text="@textSection.Heading">
                <MudMarkdown Value="@textSection.Content" />

                @if (textSection.SourcePageTitle is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                        Source: @textSection.SourcePageTitle
                    </MudText>
                }
            </MudExpansionPanel>
        }
    </MudExpansionPanels>

    <AskReferencesSection References="@Descriptor.References" />
}

@code {
    [Parameter, EditorRequired]
    public TextDescriptor Descriptor { get; set; } = default!;
}
