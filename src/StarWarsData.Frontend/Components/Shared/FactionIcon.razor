@* Inline SVG faction icons — simple geometric approximations of iconic Star Wars faction insignia *@

@if (GetPath(Faction) is { } path)
{
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
         width="@($"{Size}px")" height="@($"{Size}px")"
         fill="@Color" style="@Style flex-shrink: 0;">
        @((MarkupString)path)
    </svg>
}
else
{
    <span style="display:inline-block;width:@($"{Size}px");height:@($"{Size}px");border-radius:50%;background:@Color;border:1px solid rgba(255,255,255,0.3);flex-shrink:0;"></span>
}

@code {
    [Parameter] public string Faction { get; set; } = "";
    [Parameter] public string Color { get; set; } = "#888";
    [Parameter] public int Size { get; set; } = 16;
    [Parameter] public string? Style { get; set; }

    /// <summary>
    /// Returns the SVG inner markup for a faction icon. Also used by the D3 territory map.
    /// </summary>
    public static string? GetPath(string faction) => faction switch
    {
        // Imperial cog — 6-spoke gear wheel
        "Galactic Empire" =>
            "<circle cx='12' cy='12' r='4.5'/>" +
            "<rect x='11' y='1' width='2' height='6' rx='1'/>" +
            "<rect x='11' y='17' width='2' height='6' rx='1'/>" +
            "<rect x='11' y='1' width='2' height='6' rx='1' transform='rotate(60 12 12)'/>" +
            "<rect x='11' y='17' width='2' height='6' rx='1' transform='rotate(60 12 12)'/>" +
            "<rect x='11' y='1' width='2' height='6' rx='1' transform='rotate(120 12 12)'/>" +
            "<rect x='11' y='17' width='2' height='6' rx='1' transform='rotate(120 12 12)'/>",

        // Republic — circle with radiating petals
        "Galactic Republic" =>
            "<circle cx='12' cy='12' r='3.5'/>" +
            "<circle cx='12' cy='12' r='10' fill='none' stroke='currentColor' stroke-width='1.5'/>" +
            "<line x1='12' y1='2' x2='12' y2='8.5' stroke='currentColor' stroke-width='1.5'/>" +
            "<line x1='12' y1='15.5' x2='12' y2='22' stroke='currentColor' stroke-width='1.5'/>" +
            "<line x1='2' y1='12' x2='8.5' y2='12' stroke='currentColor' stroke-width='1.5'/>" +
            "<line x1='15.5' y1='12' x2='22' y2='12' stroke='currentColor' stroke-width='1.5'/>",

        // Rebel starbird — simplified phoenix
        "Alliance to Restore the Republic" =>
            "<path d='M12 2 L14 8 L20 10 L14 12 L16 20 L12 15 L8 20 L10 12 L4 10 L10 8 Z'/>",

        // New Republic — starbird with circle
        "New Republic" =>
            "<circle cx='12' cy='12' r='10' fill='none' stroke='currentColor' stroke-width='1.2'/>" +
            "<path d='M12 4 L13.5 9 L18 10.5 L13.5 12 L15 18 L12 14 L9 18 L10.5 12 L6 10.5 L10.5 9 Z'/>",

        // CIS — hexagonal shape
        "Confederacy of Independent Systems" =>
            "<polygon points='12,2 20,7 20,17 12,22 4,17 4,7'/>" +
            "<circle cx='12' cy='12' r='3' fill='rgba(0,0,0,0.5)'/>",

        // First Order — angular starburst
        "First Order" =>
            "<polygon points='12,1 14,9 22,9 15.5,14 18,22 12,17 6,22 8.5,14 2,9 10,9'/>",

        // Resistance — simplified starbird variant
        "Resistance" =>
            "<path d='M12 3 L14 9 L19 11 L14 13 L15 19 L12 15.5 L9 19 L10 13 L5 11 L10 9 Z'/>" +
            "<circle cx='12' cy='10' r='1.5'/>",

        // Mandalorian — T-visor helmet (mythosaur skull simplified)
        "Mandalorians" =>
            "<path d='M6 4 L18 4 L20 10 L17 10 L15 7 L13 10 L11 10 L9 7 L7 10 L4 10 Z'/>" +
            "<path d='M5 11 L8 11 L8 18 L5 15 Z'/>" +
            "<path d='M19 11 L16 11 L16 18 L19 15 Z'/>",

        _ => null,
    };
}
