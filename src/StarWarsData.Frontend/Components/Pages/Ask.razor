@page "/"
@page "/ask"
@page "/ask/{SessionId:guid}"
@using System.Text.Json.Serialization
@inject IHttpClientFactory HttpClientFactory
@inject GlobalFilterService GlobalFilterService
@inject ChatHistoryService ChatHistory
@inject IJSRuntime JS
@inject ILogger<Ask> Logger
@implements IDisposable

<PageTitle>Ask AI — Star Wars Data</PageTitle>

<div class="ask-chat-container">

    @if (_aiUnavailable)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Class="rounded-0" NoIcon="false">
            AI features are temporarily unavailable due to API quota limits. Other features such as Timeline, Data Tables, Graph Explorer, and Galaxy Maps remain fully operational.
        </MudAlert>
    }

    @* ── Scrollable conversation area ── *@
    <div class="ask-chat-messages" @ref="_messagesContainer">

        @if (_conversation.Count == 0 && !_loading)
        {
            @* ── Empty state: mode cards + examples ── *@
            <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
                <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6" Color="Color.Secondary">
                    What would you like to explore?
                </MudText>
                <div class="d-flex flex-wrap gap-2 justify-center mb-6">
                    @foreach (var mode in _modes)
                    {
                        var m = mode;
                        var selected = _selectedMode == m.Key;
                        <MudPaper Outlined="true"
                                  Class="@($"pa-3 cursor-pointer mud-clickable d-flex flex-column align-center gap-1{(selected ? " mud-border-primary" : "")}")"
                                  Style="@($"width: 140px;{(selected ? $" border-color: var(--mud-palette-{m.Color.ToString().ToLower()}); border-width: 2px;" : "")}")"
                                  @onclick="() => ToggleMode(m.Key)">
                            <MudIcon Icon="@m.Icon" Color="@(selected ? m.Color : Color.Default)" Size="Size.Small" />
                            <MudText Typo="Typo.caption" Align="Align.Center" Style="font-weight:600">@m.Label</MudText>
                        </MudPaper>
                    }
                </div>

                <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-3">
                    @(SelectedMode is null ? "Try asking" : $"{SelectedMode.Label} examples")
                </MudText>
                <MudGrid Spacing="2" Justify="Justify.Center">
                    @foreach (var example in FilteredExamples)
                    {
                        var prompt = example;
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Outlined="true" Class="pa-3 cursor-pointer mud-clickable" @onclick="() => UseExample(prompt)">
                                <MudText Typo="Typo.body2">@prompt</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudContainer>
        }
        else
        {
            @* ── Conversation messages ── *@
            <MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
                @foreach (var msg in _conversation)
                {
                    @if (msg.Role == ConversationRole.User)
                    {
                        <div class="ask-msg ask-msg-user mb-3">
                            <MudPaper Elevation="0" Class="pa-3 d-flex align-start gap-3" Style="background:var(--mud-palette-background-grey); border-radius:12px;">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
                                <MudText Typo="Typo.body1" Style="white-space:pre-wrap">@msg.Text</MudText>
                            </MudPaper>
                        </div>
                    }
                    else if (msg.Role == ConversationRole.ToolGroup)
                    {
                        <div class="ask-msg ask-msg-tools mb-2 ml-2">
                            <MudPaper Elevation="0" Class="pa-2 px-3" Style="background:transparent;border-left:3px solid var(--mud-palette-primary);border-radius:0">
                                <div class="d-flex align-center gap-2 cursor-pointer" @onclick="() => msg.IsExpanded = !msg.IsExpanded" style="user-select:none">
                                    @if (msg.ToolCalls!.All(t => t.IsComplete))
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                    }
                                    else
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                                    }
                                    <MudText Typo="Typo.body2" Style="font-weight:600;flex:1">
                                        @{
                                            var done = msg.ToolCalls!.Count(t => t.IsComplete);
                                            var total = msg.ToolCalls!.Count;
                                        }
                                        @if (done == total)
                                        {
                                            @($"Used {total} tool{(total != 1 ? "s" : "")}")
                                        }
                                        else
                                        {
                                            @($"Working\u2026 ({done}/{total} tool{(total != 1 ? "s" : "")})")
                                        }
                                    </MudText>
                                    <MudIcon Icon="@(msg.IsExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" Color="Color.Secondary" />
                                </div>
                                @if (msg.IsExpanded)
                                {
                                    <MudStack Spacing="1" Class="mt-2 ml-7">
                                        @foreach (var tc in msg.ToolCalls!)
                                        {
                                            var tool = tc;
                                            <MudPaper Elevation="0" Class="pa-2" Style="background: rgba(255,255,255,0.02); border-radius:6px;">
                                                <div class="d-flex align-center gap-2" style="cursor:pointer" @onclick="() => tool.IsDetailExpanded = !tool.IsDetailExpanded">
                                                    @if (tool.IsComplete)
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" Style="font-size:14px" />
                                                    }
                                                    else
                                                    {
                                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Style="width:14px;height:14px" />
                                                    }
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex:1">@FriendlyToolName(tool.ToolName)</MudText>
                                                    @if (tool.IsComplete)
                                                    {
                                                        <MudIcon Icon="@(tool.IsDetailExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                                                 Size="Size.Small" Color="Color.Secondary" Style="font-size:14px" />
                                                    }
                                                </div>
                                                @if (tool.IsDetailExpanded && tool.IsComplete)
                                                {
                                                    <div class="mt-2" style="font-size:12px;">
                                                        @if (!string.IsNullOrWhiteSpace(tool.Arguments))
                                                        {
                                                            <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-1">Input</MudText>
                                                            <pre style="background:rgba(0,0,0,0.3); padding:8px; border-radius:4px; overflow-x:auto; white-space:pre-wrap; word-break:break-word; color:#a0c4ff; font-size:11px; max-height:200px; overflow-y:auto;">@FormatJson(tool.Arguments)</pre>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(tool.Result))
                                                        {
                                                            <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-1 mt-2">Output</MudText>
                                                            <pre style="background:rgba(0,0,0,0.3); padding:8px; border-radius:4px; overflow-x:auto; white-space:pre-wrap; word-break:break-word; color:#a0ffa0; font-size:11px; max-height:300px; overflow-y:auto;">@FormatJson(tool.Result)</pre>
                                                        }
                                                    </div>
                                                }
                                            </MudPaper>
                                        }
                                    </MudStack>
                                }
                            </MudPaper>
                        </div>
                    }
                    else if (msg.Role == ConversationRole.Visualization)
                    {
                        <div class="ask-msg ask-msg-viz mb-3 ml-2">
                            @switch (msg.VisualizationType)
                            {
                                case "chart" when msg.ChartDescriptor is not null:
                                    <AskChartView Descriptor="msg.ChartDescriptor" />
                                    break;
                                case "graph" when msg.GraphDescriptor is not null:
                                    <AskGraphView Descriptor="msg.GraphDescriptor" />
                                    break;
                                case "table" when msg.TableDescriptor is not null:
                                    <AskTableView Descriptor="msg.TableDescriptor" />
                                    break;
                                case "data_table" when msg.DataTableDescriptor is not null:
                                    <AskDataTableView Descriptor="msg.DataTableDescriptor" />
                                    break;
                                case "timeline" when msg.TimelineDescriptor is not null:
                                    <AskTimelineView Descriptor="msg.TimelineDescriptor" />
                                    break;
                                case "infobox" when msg.InfoboxDescriptor is not null:
                                    <AskInfoboxView Descriptor="msg.InfoboxDescriptor" />
                                    break;
                                case "text" when msg.TextDescriptor is not null:
                                    <AskTextView Descriptor="msg.TextDescriptor" />
                                    break;
                            }
                        </div>
                    }
                    else if (msg.Role == ConversationRole.Assistant)
                    {
                        <div class="ask-msg ask-msg-assistant mb-3 ml-2">
                            <MudPaper Elevation="0" Class="pa-3 d-flex align-start gap-3" Style="border-radius:12px;">
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Secondary" Style="margin-top:2px" />
                                <MudText Typo="Typo.body1" Style="white-space:pre-wrap">@msg.Text</MudText>
                            </MudPaper>
                        </div>
                    }
                    else if (msg.Role == ConversationRole.Error)
                    {
                        <div class="ask-msg mb-3 ml-2">
                            <MudAlert Severity="Severity.Error">@msg.Text</MudAlert>
                        </div>
                    }
                }

                @if (_loading)
                {
                    <div class="ask-msg mb-3 ml-2">
                        <MudPaper Elevation="0" Class="pa-3 d-flex align-center gap-2" Style="background:transparent">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Working…</MudText>
                        </MudPaper>
                    </div>
                }
            </MudContainer>
        }
    </div>

    @* ── Sticky input area at bottom ── *@
    <div class="ask-chat-input">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-2">

            @* Compact mode chips *@
            <div class="d-flex flex-wrap gap-1 mb-2 justify-center">
                <MudChip T="string"
                         Color="@(_selectedMode == "auto" ? Color.Primary : Color.Default)"
                         Variant="@(_selectedMode == "auto" ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => _selectedMode = "auto")" Size="Size.Small">
                    Auto
                </MudChip>
                @foreach (var mode in _modes)
                {
                    var m = mode;
                    var sel = _selectedMode == m.Key;
                    <MudChip T="string"
                             Color="@(sel ? m.Color : Color.Default)"
                             Variant="@(sel ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => ToggleMode(m.Key))" Size="Size.Small"
                             Icon="@m.Icon">
                        @m.Label
                    </MudChip>
                }
            </div>

            @* Input row *@
            <EditForm Model="_model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />
                <div class="d-flex gap-2 align-end">
                    <MudTextField @bind-Value="_model.Prompt"
                                  Label="@(SelectedMode is null ? "Ask anything about Star Wars\u2026" : SelectedMode.Placeholder)"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  Immediate="true"
                                  FullWidth="true"
                                  Disabled="_loading"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  OnKeyDown="OnInputKeyDown"
                                  Lines="1"
                                  Class="flex-grow-1" />
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(_loading || _aiUnavailable)"
                               StartIcon="@Icons.Material.Filled.Send"
                               Style="height: 56px;">
                        @(_loading ? "Thinking\u2026" : _aiUnavailable ? "Unavailable" : "Send")
                    </MudButton>
                </div>
            </EditForm>

            @if (!_isAuthenticated)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mt-2">
                    <MudLink Href="/authentication/login" Underline="Underline.Always" Color="Color.Secondary">Sign in</MudLink>
                    to save chat history, get more requests, and bring your own OpenAI key.
                </MudText>
            }

        </MudContainer>
    </div>
</div>

<style>
    .ask-chat-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 64px); /* subtract top nav bar */
    }
    .ask-chat-messages {
        flex: 1;
        overflow-y: auto;
        min-height: 0;
    }
    .ask-chat-input {
        border-top: 1px solid var(--mud-palette-lines-default);
        background: var(--mud-palette-surface);
    }
</style>

@code {

    [Parameter] public Guid? SessionId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    // ── Conversation model ──

    enum ConversationRole { User, Assistant, ToolGroup, Visualization, Error }

    class ToolCallInfo
    {
        public string CallId { get; set; } = "";
        public string ToolName { get; set; } = "";
        public string Arguments { get; set; } = "";
        public string? Result { get; set; }
        public bool IsComplete { get; set; }
        public bool IsDetailExpanded { get; set; }
    }

    class ConversationMessage
    {
        public ConversationRole Role { get; set; }
        public string? Text { get; set; }
        public List<ToolCallInfo>? ToolCalls { get; set; }
        public bool IsExpanded { get; set; }
        public DateTime Timestamp { get; set; } = DateTime.UtcNow;

        // Visualization data (for Role == Visualization)
        public string? VisualizationType { get; set; }
        public ChartDescriptor? ChartDescriptor { get; set; }
        public GraphDescriptor? GraphDescriptor { get; set; }
        public TableDescriptor? TableDescriptor { get; set; }
        public DataTableDescriptor? DataTableDescriptor { get; set; }
        public TimelineDescriptor? TimelineDescriptor { get; set; }
        public InfoboxDescriptor? InfoboxDescriptor { get; set; }
        public TextDescriptor? TextDescriptor { get; set; }
    }

    // ── AGUI message replay (sent to /kernel/stream each turn) ──

    class AguiMessage
    {
        [JsonPropertyName("role")]
        public string Role { get; set; } = "";

        [JsonPropertyName("content")]
        public string? Content { get; set; }

        [JsonPropertyName("toolCalls")]
        [JsonIgnore(Condition = JsonIgnoreCondition.WhenWritingNull)]
        public List<AguiToolCall>? ToolCalls { get; set; }

        [JsonPropertyName("toolCallId")]
        [JsonIgnore(Condition = JsonIgnoreCondition.WhenWritingNull)]
        public string? ToolCallId { get; set; }
    }

    class AguiToolCall
    {
        [JsonPropertyName("id")]
        public string Id { get; set; } = "";

        [JsonPropertyName("type")]
        public string Type { get; set; } = "function";

        [JsonPropertyName("function")]
        public AguiFunction Function { get; set; } = new();
    }

    class AguiFunction
    {
        [JsonPropertyName("name")]
        public string Name { get; set; } = "";

        [JsonPropertyName("arguments")]
        public string Arguments { get; set; } = "";
    }

    // ── State ──

    private readonly List<ConversationMessage> _conversation = [];
    private readonly List<AguiMessage> _aguiMessages = [];

    // SSE streaming state for current turn
    private readonly Dictionary<string, string> _sseToolCallNames = [];
    private readonly Dictionary<string, ToolCallInfo> _sseToolCallInfos = [];
    private ConversationMessage? _currentToolGroup;
    private bool _toolGroupInterrupted;
    private ConversationMessage? _currentAssistantMsg;
    private List<AguiToolCall> _pendingAguiToolCalls = [];

    private AskModel _model = new();
    private bool _loading;
    private ElementReference _messagesContainer;

    private static readonly JsonSerializerOptions JsonOpts = new() { PropertyNameCaseInsensitive = true };

    // ── Session state ──
    private Guid? _currentSessionId;
    private string? _userId;
    private bool _isAuthenticated;

    // ── Mode selection ──

    private record VisualizationMode(
        string Key, string Label, string Description, string Placeholder,
        string Icon, Color Color, string[] Examples);

    private static readonly VisualizationMode[] _modes =
    [
        new("chart", "Chart", "Aggregate, compare, and visualize data across the entire Star Wars universe",
            "e.g. Which starship manufacturers produced the most models?",
            Icons.Material.Filled.BarChart, Color.Primary,
            [
                "Which starship manufacturers produced the most distinct ship classes?",
                "Pie chart of Force power alignments: light side, dark side, and neutral",
                "What are the top 10 species by number of known individual characters?",
                "How does the number of Canon vs Legends entries compare across characters, planets, and species?",
                "What are the most common weapon types by manufacturer count?",
                "Chart the most common lightsaber blade colors across all known lightsabers",
            ]),
        new("graph", "Graph", "Explore master-apprentice lineages, family trees, and relationship networks",
            "e.g. Show the apprentice chain descending from Darth Bane",
            Icons.Material.Filled.AccountTree, Color.Secondary,
            [
                "Show the Sith master-apprentice chain descending from Darth Plagueis",
                "Map the family and political connections of Padmé Amidala",
                "Show the Jedi training lineage of Qui-Gon Jinn — who trained him and who did he train?",
                "Show the Skywalker family tree starting from Anakin Skywalker",
            ]),
        new("table", "Table", "Browse and filter paginated collections with custom column selection",
            "e.g. Show all battles of the Clone Wars with location, date, and outcome",
            Icons.Material.Filled.TableChart, Color.Tertiary,
            [
                "Show all battles of the Clone Wars with their date, place, conflict, and outcome",
                "Browse all lightsabers with their blade color, crystal, type, and culture",
                "Browse all species with point of origin, classification, and average lifespan",
                "Show me all military units with their affiliation, commanding officers, and notable battles",
                "List all starship classes with their manufacturer, type, and armament",
            ]),
        new("data_table", "Data Table", "Cross-reference and join data the AI assembles from multiple queries",
            "e.g. Which Jedi survived Order 66 and where did they hide?",
            Icons.Material.Filled.GridOn, Color.Info,
            [
                "Which Jedi survived Order 66 and where did they go into hiding?",
                "List every known master-apprentice pair in the Sith Order with their era",
                "Compare the technical specifications of the Venator, Imperial, and Executor class Star Destroyers",
                "What are all the wars fought by the Mandalorians, with their dates and outcomes?",
                "What foods and beverages originate from Coruscant, Naboo, and Corellia?",
            ]),
        new("timeline", "Timeline", "Temporal events scoped by era, date range, or entity lifetime",
            "e.g. Timeline of the fall of the Republic from the Naboo Crisis to Order 66",
            Icons.Material.Filled.Timeline, Color.Warning,
            [
                "Timeline of battles and missions during the fall of the Republic from 32 BBY to 19 BBY",
                "Show Ahsoka Tano's life events from birth through the fall of the Empire",
                "What major wars and campaigns shaped the galaxy between 4000 BBY and 1000 BBY?",
                "Timeline of the Galactic Civil War from the Battle of Scarif to the Battle of Jakku",
                "Show all character deaths and battles between 22 BBY and 19 BBY",
            ]),
        new("infobox", "Infobox", "Detailed wiki-style profiles and side-by-side entity comparisons",
            "e.g. Compare the Death Star and Starkiller Base side by side",
            Icons.Material.Filled.Badge, Color.Success,
            [
                "Compare the Death Star, Starkiller Base, and the Star Forge side by side",
                "Show me the full profile of General Grievous",
                "Compare Darth Revan and Darth Malak",
                "Put the Millennium Falcon and the Ebon Hawk next to each other",
                "Show me Mandalore the Ultimate",
            ]),
        new("text", "Article", "Semantic search across 479K article passages for lore, analysis, and deep context",
            "e.g. What was the philosophical divide between the Jedi and the Sith?",
            Icons.Material.Filled.Article, Color.Dark,
            [
                "What was the philosophical divide between the Jedi and the Sith regarding the nature of the Force?",
                "How did the Clone Wars fundamentally reshape the political structure of the galaxy?",
                "What role did espionage and intelligence networks play in the Galactic Civil War?",
                "Explain the ecological diversity of Kashyyyk and how it shaped Wookiee culture",
                "What were the long-term consequences of the Mandalorian Wars on the Jedi Order?",
            ]),
    ];

    private string _selectedMode = "auto";
    private VisualizationMode? SelectedMode => _selectedMode == "auto" ? null : _modes.FirstOrDefault(m => m.Key == _selectedMode);

    private string[] _randomExamples = PickRandomExamples();

    private static string[] PickRandomExamples()
    {
        var all = _modes.SelectMany(m => m.Examples).ToArray();
        return Random.Shared.GetItems(all, 6);
    }

    private void ToggleMode(string key)
    {
        _selectedMode = _selectedMode == key ? "auto" : key;
    }

    private string[] FilteredExamples
    {
        get
        {
            if (SelectedMode is not null)
                return SelectedMode.Examples;
            return _randomExamples;
        }
    }

    public class AskModel
    {
        [Required(ErrorMessage = "Please enter a question.")]
        public string Prompt { get; set; } = string.Empty;
    }

    private bool _aiUnavailable;

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnInitializedAsync()
    {
        ChatHistory.OnChange += OnChatHistoryChanged;

        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAuthenticated = state.User.Identity?.IsAuthenticated == true;
            _userId = state.User.FindFirst("sub")?.Value
                      ?? state.User.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;

            if (_isAuthenticated)
                await ChatHistory.EnsureLoadedAsync();
        }

        await CheckAiStatusAsync();
    }

    private async Task CheckAiStatusAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<AiStatusResponse>("api/ai/status");
            _aiUnavailable = response?.Status is "QuotaExceeded" or "RateLimited";
        }
        catch
        {
            // If the status endpoint itself fails, don't block the page
        }
    }

    private record AiStatusResponse(string Status, int ErrorsLastHour);

    private void OnChatHistoryChanged()
    {
        InvokeAsync(() =>
        {
            // New Chat was clicked — reset if there's any state to clear
            if (ChatHistory.ActiveSessionId is null
                && (_currentSessionId is not null || _conversation.Count > 0))
            {
                ResetChat();
            }
        });
    }

    private void ResetChat()
    {
        _currentSessionId = null;
        _model = new AskModel();
        _conversation.Clear();
        _aguiMessages.Clear();
        _randomExamples = PickRandomExamples();
        StateHasChanged();
    }

    public void Dispose()
    {
        ChatHistory.OnChange -= OnChatHistoryChanged;
    }


    protected override async Task OnParametersSetAsync()
    {
        if (SessionId.HasValue && SessionId != _currentSessionId)
        {
            await LoadSession(SessionId.Value);
        }
        else if (!SessionId.HasValue && _currentSessionId.HasValue)
        {
            // Navigated to /ask without a session ID — start fresh
            NewChat();
        }
    }

    private void UseExample(string prompt)
    {
        _model.Prompt = prompt;
        _ = InvokeAsync(SubmitAsync);
    }

    private async Task OnInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_loading && !string.IsNullOrWhiteSpace(_model.Prompt))
            await SubmitAsync();
    }

    // ── Core submit: multi-turn conversation ──

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.Prompt) || _loading) return;

        var userPrompt = _model.Prompt.Trim();
        _model.Prompt = "";
        _loading = true;
        StateHasChanged();

        // Add user message to conversation display
        _conversation.Add(new ConversationMessage { Role = ConversationRole.User, Text = userPrompt });

        // Build AGUI user message with metadata
        var continuity = GlobalFilterService.GetContinuityQueryParam() ?? "Both";
        var modeHint = $" [PREFER: {_selectedMode}]";
        var aguiContent = $"[CONTINUITY: {continuity}]{modeHint} {userPrompt}";
        _aguiMessages.Add(new AguiMessage { Role = "user", Content = aguiContent });

        // Reset per-turn SSE tracking
        _sseToolCallNames.Clear();
        _sseToolCallInfos.Clear();
        _currentToolGroup = null;
        _toolGroupInterrupted = false;
        _currentAssistantMsg = null;
        _pendingAguiToolCalls = [];

        await ScrollToBottom();

        var body = new { messages = _aguiMessages };
        using var cts = new CancellationTokenSource(TimeSpan.FromMinutes(5));

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "kernel/stream")
            {
                Content = JsonContent.Create(body),
            };
            request.Headers.Accept.Add(new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("text/event-stream"));
            // Auth token is forwarded automatically by AuthTokenDelegatingHandler

            using var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead, cts.Token);

            if (response.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
            {
                var retryAfter = response.Headers.RetryAfter?.Delta?.TotalMinutes ?? 30;
                _conversation.Add(new ConversationMessage
                {
                    Role = ConversationRole.Error,
                    Text = _isAuthenticated
                        ? $"You've reached the rate limit (6 requests per 30 minutes). Try again in {retryAfter:0} minutes, or add your own OpenAI API key in your Profile to remove limits."
                        : $"Anonymous users are limited to 1 request per 30 minutes. Sign in for more requests, or add your own OpenAI API key for unlimited access."
                });
                FinalizeAguiTurn();
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _conversation.Add(new ConversationMessage { Role = ConversationRole.Error, Text = $"Request failed ({(int)response.StatusCode}). Please try again." });
                FinalizeAguiTurn();
                return;
            }

            await using var stream = await response.Content.ReadAsStreamAsync(cts.Token);
            using var reader = new System.IO.StreamReader(stream);

            while (!reader.EndOfStream && !cts.Token.IsCancellationRequested)
            {
                var line = await reader.ReadLineAsync(cts.Token);
                if (string.IsNullOrEmpty(line)) continue;
                if (!line.StartsWith("data:")) continue;

                var json = line["data:".Length..].Trim();
                if (json == "[DONE]") break;

                try
                {
                    using var doc = JsonDocument.Parse(json);
                    var root = doc.RootElement;
                    var eventType = root.TryGetProperty("type", out var t) ? t.GetString() : null;

                    switch (eventType)
                    {
                        case "TOOL_CALL_START":
                            HandleToolCallStart(root);
                            break;
                        case "TOOL_CALL_ARGS":
                            HandleToolCallArgs(root);
                            break;
                        case "TOOL_CALL_END":
                            HandleToolCallEnd(root);
                            break;
                        case "TOOL_CALL_RESULT":
                            HandleToolCallResult(root);
                            break;
                        case "TEXT_MESSAGE_START":
                            _currentAssistantMsg = new ConversationMessage { Role = ConversationRole.Assistant, Text = "" };
                            _conversation.Add(_currentAssistantMsg);
                            _toolGroupInterrupted = true;
                            break;
                        case "TEXT_MESSAGE_CONTENT":
                        {
                            var delta = root.TryGetProperty("delta", out var d) ? d.GetString() : null;
                            if (delta is not null)
                            {
                                if (_currentAssistantMsg is null)
                                {
                                    _currentAssistantMsg = new ConversationMessage { Role = ConversationRole.Assistant, Text = "" };
                                    _conversation.Add(_currentAssistantMsg);
                                }
                                _currentAssistantMsg.Text += delta;
                            }
                            break;
                        }
                        case "TEXT_MESSAGE_END":
                            _currentAssistantMsg = null;
                            break;
                        case "RUN_ERROR":
                        {
                            var errorMsg = root.TryGetProperty("message", out var em) ? em.GetString() : "Unknown error";
                            if (errorMsg?.Contains("429", StringComparison.Ordinal) == true
                                || errorMsg?.Contains("quota", StringComparison.OrdinalIgnoreCase) == true
                                || errorMsg?.Contains("insufficient_quota", StringComparison.OrdinalIgnoreCase) == true)
                            {
                                _aiUnavailable = true;
                                _conversation.Add(new ConversationMessage { Role = ConversationRole.Error, Text = "AI features are temporarily unavailable due to API quota limits. Other features such as Timeline, Data Tables, Graph Explorer, and Galaxy Maps remain fully operational." });
                            }
                            else
                            {
                                _conversation.Add(new ConversationMessage { Role = ConversationRole.Error, Text = errorMsg });
                            }
                            Logger.LogError("RUN_ERROR from agent: {Error}", errorMsg);
                            break;
                        }
                    }
                }
                catch (JsonException) { }

                StateHasChanged();
                await ScrollToBottom();
            }

            // If the stream completed but no assistant message was rendered,
            // the guardrail or agent returned an empty/unrecognised response
            var lastNonUser = _conversation.LastOrDefault(m => m.Role != ConversationRole.User);
            if (lastNonUser is null || lastNonUser.Timestamp < _conversation.Last(m => m.Role == ConversationRole.User).Timestamp)
            {
                _conversation.Add(new ConversationMessage
                {
                    Role = ConversationRole.Error,
                    Text = "No response was received. The request may have been blocked or the AI service may be unavailable. Please try again."
                });
            }

            // Finalize: build AGUI replay messages for this turn
            FinalizeAguiTurn();

            // Auto-save session for authenticated users
            if (_isAuthenticated && _userId is not null)
                await SaveCurrentSessionAsync(userPrompt);
        }
        catch (OperationCanceledException)
        {
            _conversation.Add(new ConversationMessage { Role = ConversationRole.Error, Text = "Request timed out. Try a simpler question." });
        }
        catch (Exception ex)
        {
            _conversation.Add(new ConversationMessage { Role = ConversationRole.Error, Text = $"Unexpected error: {ex.Message}" });
        }
        finally
        {
            _loading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    // ── SSE event handlers ──

    private void HandleToolCallStart(JsonElement root)
    {
        var callId = root.TryGetProperty("toolCallId", out var ci) ? ci.GetString() : null;
        var toolName = root.TryGetProperty("toolCallName", out var tn) ? tn.GetString() : "tool";

        if (callId is not null && toolName is not null)
            _sseToolCallNames[callId] = toolName;

        var info = new ToolCallInfo { CallId = callId ?? "", ToolName = toolName ?? "tool" };
        if (callId is not null)
            _sseToolCallInfos[callId] = info;

        // Group consecutive tool calls together — only start a new group
        // when there's no current group or a non-tool message interrupted the sequence
        if (_currentToolGroup is null || _toolGroupInterrupted)
        {
            _currentToolGroup = new ConversationMessage
            {
                Role = ConversationRole.ToolGroup,
                ToolCalls = [info],
                IsExpanded = true,
            };
            _conversation.Add(_currentToolGroup);
            _toolGroupInterrupted = false;
        }
        else
        {
            _currentToolGroup.ToolCalls!.Add(info);
        }
    }

    private void HandleToolCallArgs(JsonElement root)
    {
        var callId = root.TryGetProperty("toolCallId", out var ci) ? ci.GetString() : null;
        if (callId is not null && _sseToolCallInfos.TryGetValue(callId, out var info))
        {
            var delta = root.TryGetProperty("delta", out var d) ? d.GetString() : null;
            if (delta is not null) info.Arguments += delta;
        }
    }

    private void HandleToolCallEnd(JsonElement root)
    {
        var callId = root.TryGetProperty("toolCallId", out var ci) ? ci.GetString() : null;
        if (callId is not null && _sseToolCallInfos.TryGetValue(callId, out var info))
        {
            info.IsComplete = true;

            // Track for AGUI replay
            _pendingAguiToolCalls.Add(new AguiToolCall
            {
                Id = callId,
                Function = new AguiFunction { Name = info.ToolName, Arguments = info.Arguments },
            });
        }
    }

    private void HandleToolCallResult(JsonElement root)
    {
        var callId = root.TryGetProperty("toolCallId", out var ci) ? ci.GetString() : null;
        var toolName = callId is not null && _sseToolCallNames.TryGetValue(callId, out var n) ? n : null;

        string? contentJson = null;
        if (root.TryGetProperty("content", out var contentEl))
        {
            contentJson = contentEl.ValueKind == JsonValueKind.String
                ? contentEl.GetString()
                : contentEl.GetRawText();
            if (contentJson?.StartsWith("\"") == true)
                contentJson = JsonSerializer.Deserialize<string>(contentJson);
        }

        // Store result for AGUI replay
        if (callId is not null && _sseToolCallInfos.TryGetValue(callId, out var info))
            info.Result = contentJson;

        // Check if this is a render_* tool and create inline visualization
        if (toolName is "render_table" or "render_data_table" or "render_chart" or "render_graph" or "render_timeline" or "render_infobox" or "render_text"
            && contentJson is not null)
        {
            var vizMsg = new ConversationMessage { Role = ConversationRole.Visualization };
            try
            {
                switch (toolName)
                {
                    case "render_table":
                        vizMsg.VisualizationType = "table";
                        vizMsg.TableDescriptor = JsonSerializer.Deserialize<TableDescriptor>(contentJson, JsonOpts);
                        break;
                    case "render_data_table":
                        vizMsg.VisualizationType = "data_table";
                        vizMsg.DataTableDescriptor = JsonSerializer.Deserialize<DataTableDescriptor>(contentJson, JsonOpts);
                        break;
                    case "render_chart":
                        vizMsg.VisualizationType = "chart";
                        vizMsg.ChartDescriptor = JsonSerializer.Deserialize<ChartDescriptor>(contentJson, JsonOpts);
                        break;
                    case "render_graph":
                        vizMsg.VisualizationType = "graph";
                        vizMsg.GraphDescriptor = JsonSerializer.Deserialize<GraphDescriptor>(contentJson, JsonOpts);
                        break;
                    case "render_timeline":
                        vizMsg.VisualizationType = "timeline";
                        vizMsg.TimelineDescriptor = JsonSerializer.Deserialize<TimelineDescriptor>(contentJson, JsonOpts);
                        break;
                    case "render_infobox":
                        vizMsg.VisualizationType = "infobox";
                        vizMsg.InfoboxDescriptor = JsonSerializer.Deserialize<InfoboxDescriptor>(contentJson, JsonOpts);
                        break;
                    case "render_text":
                        vizMsg.VisualizationType = "text";
                        vizMsg.TextDescriptor = JsonSerializer.Deserialize<TextDescriptor>(contentJson, JsonOpts);
                        break;
                }
                _conversation.Add(vizMsg);
                _toolGroupInterrupted = true;
            }
            catch (JsonException ex)
            {
                Logger.LogWarning(ex, "Failed to deserialize {ToolName} result", toolName);
            }
        }
    }

    /// <summary>
    /// After a full AI turn completes, build the AGUI replay messages so the next
    /// user message includes the full conversation history.
    /// </summary>
    private void FinalizeAguiTurn()
    {
        // Collapse all tool groups now that the turn is complete
        foreach (var msg in _conversation)
        {
            if (msg.Role == ConversationRole.ToolGroup)
                msg.IsExpanded = false;
        }

        // Emit an assistant message with any pending tool calls
        if (_pendingAguiToolCalls.Count > 0)
        {
            _aguiMessages.Add(new AguiMessage
            {
                Role = "assistant",
                Content = "",
                ToolCalls = [.. _pendingAguiToolCalls],
            });

            // Emit tool result messages
            foreach (var tc in _pendingAguiToolCalls)
            {
                var result = _sseToolCallInfos.TryGetValue(tc.Id, out var info) ? info.Result : null;
                _aguiMessages.Add(new AguiMessage
                {
                    Role = "tool",
                    ToolCallId = tc.Id,
                    Content = result ?? "",
                });
            }

            _pendingAguiToolCalls = [];
        }

        // Capture the last assistant text message if any
        var lastAssistantText = _conversation
            .LastOrDefault(m => m.Role == ConversationRole.Assistant)?.Text;
        if (!string.IsNullOrWhiteSpace(lastAssistantText))
        {
            // Only add if we haven't already captured it as part of tool calls
            var lastAgui = _aguiMessages.LastOrDefault();
            if (lastAgui?.Role != "assistant" || lastAgui.ToolCalls is not null)
            {
                _aguiMessages.Add(new AguiMessage
                {
                    Role = "assistant",
                    Content = lastAssistantText,
                });
            }
        }
    }

    // ── Scroll ──

    private async Task ScrollToBottom()
    {
        try
        {
            await Task.Delay(50);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.ask-chat-messages')?.scrollTo({top: 999999, behavior: 'smooth'})");
        }
        catch { }
    }

    // ── Session management ──

    private async Task SaveCurrentSessionAsync(string userPrompt)
    {
        try
        {
            // Generate an AI-summarized 3-4 word title only for new sessions
            var title = _currentSessionId is null
                ? await ChatHistory.SummarizeTitleAsync(userPrompt)
                : "";

            // Build session messages from conversation + AGUI data for replay
            var messages = new List<ChatSessionMessage>();

            foreach (var msg in _conversation)
            {
                switch (msg.Role)
                {
                    case ConversationRole.User:
                        messages.Add(new ChatSessionMessage
                        {
                            Role = "user",
                            Content = msg.Text ?? "",
                            Timestamp = msg.Timestamp,
                        });
                        break;
                    case ConversationRole.Assistant:
                        messages.Add(new ChatSessionMessage
                        {
                            Role = "assistant",
                            Content = msg.Text ?? "",
                            Timestamp = msg.Timestamp,
                        });
                        break;
                    case ConversationRole.ToolGroup:
                        foreach (var tc in msg.ToolCalls ?? [])
                        {
                            messages.Add(new ChatSessionMessage
                            {
                                Role = "tool",
                                ToolName = tc.ToolName,
                                ToolCallId = tc.CallId,
                                ToolCallArgs = tc.Arguments,
                                Content = tc.Result ?? "",
                                Timestamp = msg.Timestamp,
                            });
                        }
                        break;
                    case ConversationRole.Visualization:
                        messages.Add(new ChatSessionMessage
                        {
                            Role = "visualization",
                            VisualizationType = msg.VisualizationType,
                            VisualizationData = msg.VisualizationType switch
                            {
                                "chart" => JsonSerializer.Serialize(msg.ChartDescriptor, JsonOpts),
                                "graph" => JsonSerializer.Serialize(msg.GraphDescriptor, JsonOpts),
                                "table" => JsonSerializer.Serialize(msg.TableDescriptor, JsonOpts),
                                "data_table" => JsonSerializer.Serialize(msg.DataTableDescriptor, JsonOpts),
                                "timeline" => JsonSerializer.Serialize(msg.TimelineDescriptor, JsonOpts),
                                "infobox" => JsonSerializer.Serialize(msg.InfoboxDescriptor, JsonOpts),
                                "text" => JsonSerializer.Serialize(msg.TextDescriptor, JsonOpts),
                                _ => null,
                            },
                            Timestamp = msg.Timestamp,
                        });
                        break;
                    case ConversationRole.Error:
                        messages.Add(new ChatSessionMessage
                        {
                            Role = "error",
                            Content = msg.Text ?? "",
                            Timestamp = msg.Timestamp,
                        });
                        break;
                }
            }

            var body = new SaveChatSessionRequest { Title = title, Messages = messages };

            if (_currentSessionId is not null)
            {
                // Update existing session
                await Http.PutAsJsonAsync($"api/ChatSessions/{_currentSessionId}", body);
                await ChatHistory.LoadAsync();
            }
            else
            {
                // Create new session
                var response = await Http.PostAsJsonAsync("api/ChatSessions", body);
                if (response.IsSuccessStatusCode)
                {
                    _currentSessionId = await response.Content.ReadFromJsonAsync<Guid>();
                    ChatHistory.ActiveSessionId = _currentSessionId;
                    await ChatHistory.LoadAsync();
                }
            }
        }
        catch { }
    }

    private async Task LoadSession(Guid sessionId)
    {
        _loading = true;
        _conversation.Clear();
        _aguiMessages.Clear();
        StateHasChanged();

        try
        {
            var response = await Http.GetAsync($"api/ChatSessions/{sessionId}");

            if (response.IsSuccessStatusCode)
            {
                var session = await response.Content.ReadFromJsonAsync<ChatSessionDetail>(JsonOpts);
                if (session is not null)
                {
                    _currentSessionId = session.Id;
                    ChatHistory.ActiveSessionId = session.Id;
                    _model.Prompt = "";

                    // Rebuild conversation display and AGUI replay from saved messages
                    foreach (var msg in session.Messages)
                    {
                        switch (msg.Role)
                        {
                            case "user":
                                _conversation.Add(new ConversationMessage { Role = ConversationRole.User, Text = msg.Content, Timestamp = msg.Timestamp });
                                // Rebuild AGUI replay
                                _aguiMessages.Add(new AguiMessage { Role = "user", Content = msg.Content });
                                break;
                            case "assistant":
                                _conversation.Add(new ConversationMessage { Role = ConversationRole.Assistant, Text = msg.Content, Timestamp = msg.Timestamp });
                                _aguiMessages.Add(new AguiMessage { Role = "assistant", Content = msg.Content });
                                break;
                            case "tool":
                            {
                                // Add to AGUI replay as assistant tool call + tool result
                                var aguiTc = new AguiToolCall
                                {
                                    Id = msg.ToolCallId ?? Guid.NewGuid().ToString(),
                                    Function = new AguiFunction
                                    {
                                        Name = msg.ToolName ?? "tool",
                                        Arguments = msg.ToolCallArgs ?? "",
                                    },
                                };
                                // Check if last AGUI message is an assistant with tool calls we can append to
                                var lastAgui = _aguiMessages.LastOrDefault();
                                if (lastAgui?.Role == "assistant" && lastAgui.ToolCalls is not null)
                                {
                                    lastAgui.ToolCalls.Add(aguiTc);
                                }
                                else
                                {
                                    _aguiMessages.Add(new AguiMessage
                                    {
                                        Role = "assistant",
                                        Content = "",
                                        ToolCalls = [aguiTc],
                                    });
                                }
                                _aguiMessages.Add(new AguiMessage
                                {
                                    Role = "tool",
                                    ToolCallId = aguiTc.Id,
                                    Content = msg.Content,
                                });

                                // Add to conversation display as tool group
                                var lastConv = _conversation.LastOrDefault();
                                if (lastConv?.Role == ConversationRole.ToolGroup)
                                {
                                    lastConv.ToolCalls!.Add(new ToolCallInfo
                                    {
                                        CallId = msg.ToolCallId ?? "",
                                        ToolName = msg.ToolName ?? "tool",
                                        Arguments = msg.ToolCallArgs ?? "",
                                        Result = msg.Content,
                                        IsComplete = true,
                                    });
                                }
                                else
                                {
                                    _conversation.Add(new ConversationMessage
                                    {
                                        Role = ConversationRole.ToolGroup,
                                        ToolCalls =
                                        [
                                            new ToolCallInfo
                                            {
                                                CallId = msg.ToolCallId ?? "",
                                                ToolName = msg.ToolName ?? "tool",
                                                Arguments = msg.ToolCallArgs ?? "",
                                                Result = msg.Content,
                                                IsComplete = true,
                                            }
                                        ],
                                        IsExpanded = false,
                                        Timestamp = msg.Timestamp,
                                    });
                                }
                                break;
                            }
                            case "visualization":
                            {
                                var vizMsg = new ConversationMessage
                                {
                                    Role = ConversationRole.Visualization,
                                    VisualizationType = msg.VisualizationType,
                                    Timestamp = msg.Timestamp,
                                };
                                if (msg.VisualizationData is not null)
                                {
                                    switch (msg.VisualizationType)
                                    {
                                        case "chart": vizMsg.ChartDescriptor = JsonSerializer.Deserialize<ChartDescriptor>(msg.VisualizationData, JsonOpts); break;
                                        case "graph": vizMsg.GraphDescriptor = JsonSerializer.Deserialize<GraphDescriptor>(msg.VisualizationData, JsonOpts); break;
                                        case "table": vizMsg.TableDescriptor = JsonSerializer.Deserialize<TableDescriptor>(msg.VisualizationData, JsonOpts); break;
                                        case "data_table": vizMsg.DataTableDescriptor = JsonSerializer.Deserialize<DataTableDescriptor>(msg.VisualizationData, JsonOpts); break;
                                        case "timeline": vizMsg.TimelineDescriptor = JsonSerializer.Deserialize<TimelineDescriptor>(msg.VisualizationData, JsonOpts); break;
                                        case "infobox": vizMsg.InfoboxDescriptor = JsonSerializer.Deserialize<InfoboxDescriptor>(msg.VisualizationData, JsonOpts); break;
                                        case "text": vizMsg.TextDescriptor = JsonSerializer.Deserialize<TextDescriptor>(msg.VisualizationData, JsonOpts); break;
                                    }
                                }
                                _conversation.Add(vizMsg);
                                break;
                            }
                            case "error":
                                _conversation.Add(new ConversationMessage { Role = ConversationRole.Error, Text = msg.Content, Timestamp = msg.Timestamp });
                                break;
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _conversation.Add(new ConversationMessage { Role = ConversationRole.Error, Text = $"Failed to load session: {ex.Message}" });
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void NewChat()
    {
        ChatHistory.ActiveSessionId = null;
        ResetChat();
        ChatHistory.NotifyChanged();
    }

