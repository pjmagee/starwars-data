@page "/"
@page "/ask"
@inject IHttpClientFactory HttpClientFactory
@inject GlobalFilterService GlobalFilterService
@inject ILogger<Ask> Logger

<PageTitle>Ask AI — Star Wars Data</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-4">

    <div class="d-flex align-center gap-3 mb-1">
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                @if (_currentSessionId is not null)
                {
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="NewChat">New Chat</MudButton>
                }
                <MudBadge Content="@_sessions.Count" Visible="@(_sessions.Count > 0)" Color="Color.Primary" Overlap="true">
                    <MudIconButton Icon="@Icons.Material.Filled.History" OnClick="ToggleHistory" aria-label="Chat History" />
                </MudBadge>
            </Authorized>
        </AuthorizeView>
    </div>

    @* ── Visualization mode pills ── *@
    <div class="d-flex flex-wrap gap-2 mb-4">
        @foreach (var mode in _modes)
        {
            var m = mode;
            var selected = _selectedMode == m.Key;
            <MudPaper Outlined="true"
                      Class="@($"pa-3 cursor-pointer mud-clickable d-flex flex-column align-center gap-1{(selected ? " mud-border-primary" : "")}")"
                      Style="@($"width: 160px;{(selected ? $" border-color: var(--mud-palette-{m.Color.ToString().ToLower()}); border-width: 2px;" : "")}")"
                      @onclick="() => ToggleMode(m.Key)">
                <MudIcon Icon="@m.Icon" Color="@(selected ? m.Color : Color.Default)" />
                <MudText Typo="Typo.body2" Align="Align.Center" Style="font-weight:600">@m.Label</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">@m.Description</MudText>
            </MudPaper>
        }
    </div>

    <EditForm Model="_model" OnValidSubmit="Load">
        <DataAnnotationsValidator />
        <div class="d-flex gap-2 align-end">
            <MudTextField @bind-Value="_model.Prompt"
                          Label="@(SelectedMode is null ? "Ask anything about Star Wars…" : SelectedMode.Placeholder)"
                          Variant="Variant.Outlined"
                          Required="true"
                          Immediate="true"
                          FullWidth="true"
                          Disabled="_loading"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="flex-grow-1" />
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_loading"
                       StartIcon="@Icons.Material.Filled.AutoAwesome"
                       Style="height: 56px;">
                @(_loading ? "Thinking…" : "Ask")
            </MudButton>
        </div>
    </EditForm>

    @if (!_loading && !_hasResult && _turns.Count == 0)
    {
        <MudText Typo="Typo.subtitle1" Class="mt-6 mb-2">
            @(SelectedMode is null ? "Try asking" : $"{SelectedMode.Label} examples")
        </MudText>
        <MudGrid Spacing="2">
            @foreach (var example in FilteredExamples)
            {
                var prompt = example;
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Outlined="true" Class="pa-3 cursor-pointer mud-clickable" @onclick="() => UseExample(prompt)">
                        <MudText Typo="Typo.body2">@prompt</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }

    @if (_turns.Count > 0)
    {
        <MudStack Class="mt-6" Spacing="3">
            @foreach (var group in GetDisplayGroups())
            {
                @if (group.Role == TurnRole.User)
                {
                    <MudPaper Elevation="0" Class="pa-3 d-flex align-start gap-3" Style="background:var(--mud-palette-background-grey)">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
                        <MudText Typo="Typo.body1">@group.Turn!.Content</MudText>
                    </MudPaper>
                }
                else if (group.Role == TurnRole.ToolCall)
                {
                    var calls = group.ToolCalls!;
                    var completedCount = calls.Count(t => t.IsComplete);
                    var allComplete = completedCount == calls.Count;
                    var groupKey = group.GroupIndex;
                    var isExpanded = !allComplete || _expandedToolGroups.Contains(groupKey);

                    <MudPaper Elevation="0" Class="pa-2 px-3" Style="background:transparent;border-left:3px solid var(--mud-palette-primary);border-radius:0">
                        <div class="d-flex align-center gap-2 cursor-pointer" @onclick="() => ToggleToolGroup(groupKey)" style="user-select:none">
                            @if (allComplete)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            }
                            else
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                            }
                            <MudText Typo="Typo.body2" Style="font-weight:600;flex:1">
                                @if (allComplete)
                                {
                                    @($"Analyzed in {calls.Count} step{(calls.Count != 1 ? "s" : "")}")
                                }
                                else
                                {
                                    @($"Analyzing… ({completedCount}/{calls.Count})")
                                }
                            </MudText>
                            <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" Color="Color.Secondary" />
                        </div>
                        @if (isExpanded)
                        {
                            <MudStack Spacing="1" Class="mt-2 ml-7">
                                @foreach (var tc in calls)
                                {
                                    <div class="d-flex align-center gap-2">
                                        @if (tc.IsComplete)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" Style="font-size:14px" />
                                        }
                                        else
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Style="width:14px;height:14px" />
                                        }
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FriendlyToolName(tc.ToolName)</MudText>
                                    </div>
                                }
                            </MudStack>
                        }
                    </MudPaper>
                }
                else if (group.Role == TurnRole.Assistant && !HasVisualization)
                {
                    <MudPaper Elevation="0" Class="pa-3 d-flex align-start gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Secondary" Style="margin-top:2px" />
                        <MudText Typo="Typo.body1" Style="white-space:pre-wrap">@group.Turn!.Content</MudText>
                    </MudPaper>
                }
            }

            @if (_loading)
            {
                <MudPaper Elevation="0" Class="pa-3 d-flex align-center gap-2" Style="background:transparent">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Working…</MudText>
                </MudPaper>
            }
        </MudStack>
    }

    @if (!_loading && _error is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
    }

    @* ── AI-configured components ── *@

    @if (!_loading && _chartDescriptor is not null)
    {
        <AskChartView Descriptor="_chartDescriptor" />
    }

    @if (!_loading && _graphDescriptor is not null)
    {
        <AskGraphView Descriptor="_graphDescriptor" />
    }

    @if (!_loading && _tableDescriptor is not null)
    {
        <AskTableView Descriptor="_tableDescriptor" />
    }

    @if (!_loading && _dataTableDescriptor is not null)
    {
        <AskDataTableView Descriptor="_dataTableDescriptor" />
    }

    @if (!_loading && _timelineDescriptor is not null)
    {
        <AskTimelineView Descriptor="_timelineDescriptor" />
    }

    @if (!_loading && _infoboxDescriptor is not null)
    {
        <AskInfoboxView Descriptor="_infoboxDescriptor" />
    }

    @if (!_loading && _textDescriptor is not null)
    {
        <AskTextView Descriptor="_textDescriptor" />
    }

</MudContainer>

@* ── Chat History Drawer ── *@
<MudDrawer @bind-Open="_historyOpen" Anchor="Anchor.End" Elevation="1" Variant="DrawerVariant.Temporary" Width="320px">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Chat History</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="ToggleHistory" Size="Size.Small" />
    </MudDrawerHeader>
    @if (_sessionsLoading)
    {
        <div class="d-flex justify-center pa-4">
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        </div>
    }
    else if (_sessions.Count == 0)
    {
        <MudText Class="pa-4" Color="Color.Secondary" Typo="Typo.body2">No saved chats yet.</MudText>
    }
    else
    {
        <MudList T="ChatSessionSummary" Class="pa-0">
            @foreach (var session in _sessions)
            {
                var s = session;
                <MudListItem T="ChatSessionSummary"
                             OnClick="() => LoadSession(s.Id)"
                             Class="@(_currentSessionId == s.Id ? "mud-primary-text" : "")">
                    <div class="d-flex align-center gap-2" style="width:100%">
                        <div style="flex:1;min-width:0">
                            <MudText Typo="Typo.body2" Style="font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@s.Title</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@s.UpdatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="() => DeleteSession(s.Id)" aria-label="Delete" />
                    </div>
                </MudListItem>
            }
        </MudList>
    }
</MudDrawer>

@code {

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    enum TurnRole { User, Assistant, ToolCall }

    record Turn(TurnRole Role, string? ToolName = null)
    {
        public string Content { get; set; } = string.Empty;
        public bool IsComplete { get; set; }
        public DateTime Timestamp { get; set; } = DateTime.UtcNow;
    }

    record DisplayGroup(TurnRole Role, Turn? Turn = null, List<Turn>? ToolCalls = null, int GroupIndex = 0);

    private AskModel _model = new();
    private bool _loading;
    private bool _hasResult;
    private string? _error;
    private readonly List<Turn> _turns = [];
    private readonly Dictionary<string, string> _toolCallNames = [];
    private readonly Dictionary<string, Turn> _toolCallTurns = [];
    private readonly HashSet<int> _expandedToolGroups = [];
    private Turn? _currentAssistantTurn;

    // descriptor results from AI
    private TableDescriptor? _tableDescriptor;
    private DataTableDescriptor? _dataTableDescriptor;
    private ChartDescriptor? _chartDescriptor;
    private GraphDescriptor? _graphDescriptor;
    private TimelineDescriptor? _timelineDescriptor;
    private InfoboxDescriptor? _infoboxDescriptor;
    private TextDescriptor? _textDescriptor;

    private bool HasVisualization => _chartDescriptor is not null || _graphDescriptor is not null
        || _tableDescriptor is not null || _dataTableDescriptor is not null
        || _timelineDescriptor is not null || _infoboxDescriptor is not null
        || _textDescriptor is not null;

    private static readonly JsonSerializerOptions JsonOpts = new() { PropertyNameCaseInsensitive = true };

    // ── Session history ──
    private bool _historyOpen;
    private bool _sessionsLoading;
    private List<ChatSessionSummary> _sessions = [];
    private Guid? _currentSessionId;
    private string? _userId;
    private bool _isAuthenticated;

    private record VisualizationMode(
        string Key, string Label, string Description, string Placeholder,
        string Icon, Color Color, string[] Examples);

    private static readonly VisualizationMode[] _modes =
    [
        new("chart", "Chart", "Aggregate, compare, and visualize data across the entire Star Wars universe",
            "e.g. Which starship manufacturers produced the most models?",
            Icons.Material.Filled.BarChart, Color.Primary,
            [
                "Which starship manufacturers produced the most distinct ship classes?",
                "Pie chart of Force power alignments: light side, dark side, and neutral",
                "What are the top 10 species by number of known individual characters?",
                "How does the number of Canon vs Legends entries compare across characters, planets, and species?",
                "What are the most common weapon types by manufacturer count?",
                "Chart the most common lightsaber blade colors across all known lightsabers",
            ]),
        new("graph", "Graph", "Explore master-apprentice lineages, family trees, and relationship networks",
            "e.g. Show the apprentice chain descending from Darth Bane",
            Icons.Material.Filled.AccountTree, Color.Secondary,
            [
                "Show the Sith master-apprentice chain descending from Darth Plagueis",
                "Map the family and political connections of Padmé Amidala",
                "Show the Jedi training lineage of Qui-Gon Jinn — who trained him and who did he train?",
                "Show the Skywalker family tree starting from Anakin Skywalker",
            ]),
        new("table", "Table", "Browse and filter paginated collections with custom column selection",
            "e.g. Show all battles of the Clone Wars with location, date, and outcome",
            Icons.Material.Filled.TableChart, Color.Tertiary,
            [
                "Show all battles of the Clone Wars with their date, place, conflict, and outcome",
                "Browse all lightsabers with their blade color, crystal, type, and culture",
                "Browse all species with point of origin, classification, and average lifespan",
                "Show me all military units with their affiliation, commanding officers, and notable battles",
                "List all starship classes with their manufacturer, type, and armament",
            ]),
        new("data_table", "Data Table", "Cross-reference and join data the AI assembles from multiple queries",
            "e.g. Which Jedi survived Order 66 and where did they hide?",
            Icons.Material.Filled.GridOn, Color.Info,
            [
                "Which Jedi survived Order 66 and where did they go into hiding?",
                "List every known master-apprentice pair in the Sith Order with their era",
                "Compare the technical specifications of the Venator, Imperial, and Executor class Star Destroyers",
                "What are all the wars fought by the Mandalorians, with their dates and outcomes?",
                "What foods and beverages originate from Coruscant, Naboo, and Corellia?",
            ]),
        new("timeline", "Timeline", "Temporal events scoped by era, date range, or entity lifetime",
            "e.g. Timeline of the fall of the Republic from the Naboo Crisis to Order 66",
            Icons.Material.Filled.Timeline, Color.Warning,
            [
                "Timeline of battles and missions during the fall of the Republic from 32 BBY to 19 BBY",
                "Show Ahsoka Tano's life events from birth through the fall of the Empire",
                "What major wars and campaigns shaped the galaxy between 4000 BBY and 1000 BBY?",
                "Timeline of the Galactic Civil War from the Battle of Scarif to the Battle of Jakku",
                "Show all character deaths and battles between 22 BBY and 19 BBY",
            ]),
        new("infobox", "Infobox", "Detailed wiki-style profiles and side-by-side entity comparisons",
            "e.g. Compare the Death Star and Starkiller Base side by side",
            Icons.Material.Filled.Badge, Color.Success,
            [
                "Compare the Death Star, Starkiller Base, and the Star Forge side by side",
                "Show me the full profile of General Grievous",
                "Compare Darth Revan and Darth Malak",
                "Put the Millennium Falcon and the Ebon Hawk next to each other",
                "Show me Mandalore the Ultimate",
            ]),
        new("text", "Article", "Semantic search across 479K article passages for lore, analysis, and deep context",
            "e.g. What was the philosophical divide between the Jedi and the Sith?",
            Icons.Material.Filled.Article, Color.Dark,
            [
                "What was the philosophical divide between the Jedi and the Sith regarding the nature of the Force?",
                "How did the Clone Wars fundamentally reshape the political structure of the galaxy?",
                "What role did espionage and intelligence networks play in the Galactic Civil War?",
                "Explain the ecological diversity of Kashyyyk and how it shaped Wookiee culture",
                "What were the long-term consequences of the Mandalorian Wars on the Jedi Order?",
            ]),
    ];

    private string _selectedMode = "auto";
    private VisualizationMode? SelectedMode => _selectedMode == "auto" ? null : _modes.FirstOrDefault(m => m.Key == _selectedMode);

    private string[] _randomExamples = PickRandomExamples();

    private static string[] PickRandomExamples()
    {
        var all = _modes.SelectMany(m => m.Examples).ToArray();
        return Random.Shared.GetItems(all, 6);
    }

    private void ToggleMode(string key)
    {
        _selectedMode = _selectedMode == key ? "auto" : key;
    }

    private string[] FilteredExamples
    {
        get
        {
            if (SelectedMode is not null)
                return SelectedMode.Examples;
            return _randomExamples;
        }
    }

    public class AskModel
    {
        [Required(ErrorMessage = "Please enter a question.")]
        public string Prompt { get; set; } = string.Empty;
    }

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAuthenticated = state.User.Identity?.IsAuthenticated == true;
            _userId = state.User.FindFirst("sub")?.Value
                      ?? state.User.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;

            if (_isAuthenticated && _userId is not null)
            {
                await LoadSessionsAsync();
            }
        }
    }

    private void UseExample(string prompt)
    {
        _model.Prompt = prompt;
        _ = InvokeAsync(SubmitAsync);
    }

    private async Task Load() => await SubmitAsync();

    private async Task SubmitAsync()
    {
        _loading = true;
        _chartDescriptor = null;
        _tableDescriptor = null;
        _dataTableDescriptor = null;
        _graphDescriptor = null;
        _timelineDescriptor = null;
        _infoboxDescriptor = null;
        _textDescriptor = null;
        _error = null;
        _hasResult = false;
        _turns.Clear();
        _toolCallNames.Clear();
        _toolCallTurns.Clear();
        _expandedToolGroups.Clear();
        _currentAssistantTurn = null;
        _currentSessionId = null;
        StateHasChanged();

        var userPrompt = _model.Prompt;
        var continuity = GlobalFilterService.GetContinuityQueryParam() ?? "Both";
        var modeHint = $" [PREFER: {_selectedMode}]";
        var userMessage = $"[CONTINUITY: {continuity}]{modeHint} {userPrompt}";
        _turns.Add(new Turn(TurnRole.User) { Content = userPrompt, IsComplete = true });

        var body = new { messages = new[] { new { role = "user", content = userMessage } } };
        using var cts = new CancellationTokenSource(TimeSpan.FromMinutes(5));

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "kernel/stream")
            {
                Content = JsonContent.Create(body),
            };
            request.Headers.Accept.Add(new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("text/event-stream"));

            using var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead, cts.Token);

            if (!response.IsSuccessStatusCode)
            {
                _error = $"Request failed ({(int)response.StatusCode}). Please try again.";
                return;
            }

            await using var stream = await response.Content.ReadAsStreamAsync(cts.Token);
            using var reader = new System.IO.StreamReader(stream);

            var linesRead = 0;
            var dataLinesRead = 0;

            while (!reader.EndOfStream && !cts.Token.IsCancellationRequested)
            {
                var line = await reader.ReadLineAsync(cts.Token);
                if (string.IsNullOrEmpty(line)) continue;
                linesRead++;

                if (!line.StartsWith("data:"))
                {
                    Logger.LogDebug("SSE non-data line: {Line}", line);
                    continue;
                }

                dataLinesRead++;
                var json = line["data:".Length..].Trim();
                if (json == "[DONE]") break;

                try
                {
                    using var doc = JsonDocument.Parse(json);
                    var root = doc.RootElement;
                    var eventType = root.TryGetProperty("type", out var t) ? t.GetString() : null;

                    switch (eventType)
                    {
                        case "TOOL_CALL_START":
                        {
                            var callId   = root.TryGetProperty("toolCallId",   out var ci) ? ci.GetString() : null;
                            var toolName = root.TryGetProperty("toolCallName", out var tn) ? tn.GetString() : "tool";
                            if (callId is not null && toolName is not null)
                                _toolCallNames[callId] = toolName;
                            var turn = new Turn(TurnRole.ToolCall, toolName);
                            _turns.Add(turn);
                            if (callId is not null)
                                _toolCallTurns[callId] = turn;
                            break;
                        }
                        case "TOOL_CALL_ARGS":
                        {
                            var callId = root.TryGetProperty("toolCallId", out var ci) ? ci.GetString() : null;
                            if (callId is not null && _toolCallTurns.TryGetValue(callId, out var turn))
                            {
                                var delta = root.TryGetProperty("delta", out var d) ? d.GetString() : null;
                                if (delta is not null) turn.Content += delta;
                            }
                            break;
                        }
                        case "TOOL_CALL_END":
                        {
                            var callId = root.TryGetProperty("toolCallId", out var ci) ? ci.GetString() : null;
                            if (callId is not null && _toolCallTurns.TryGetValue(callId, out var turn))
                                turn.IsComplete = true;
                            break;
                        }
                        case "TOOL_CALL_RESULT":
                        {
                            var callId   = root.TryGetProperty("toolCallId", out var ci) ? ci.GetString() : null;
                            var toolName = callId is not null && _toolCallNames.TryGetValue(callId, out var n) ? n : null;
                            if (toolName is "render_table" or "render_data_table" or "render_chart" or "render_graph" or "render_timeline" or "render_infobox" or "render_text"
                                && root.TryGetProperty("content", out var contentEl))
                            {
                                var contentJson = contentEl.ValueKind == JsonValueKind.String
                                    ? contentEl.GetString()
                                    : contentEl.GetRawText();

                                if (contentJson?.StartsWith("\"") == true)
                                    contentJson = JsonSerializer.Deserialize<string>(contentJson);

                                if (contentJson is not null)
                                {
                                    switch (toolName)
                                    {
                                        case "render_table":
                                            _tableDescriptor = JsonSerializer.Deserialize<TableDescriptor>(contentJson, JsonOpts);
                                            break;
                                        case "render_data_table":
                                            _dataTableDescriptor = JsonSerializer.Deserialize<DataTableDescriptor>(contentJson, JsonOpts);
                                            break;
                                        case "render_chart":
                                            _chartDescriptor = JsonSerializer.Deserialize<ChartDescriptor>(contentJson, JsonOpts);
                                            break;
                                        case "render_graph":
                                            _graphDescriptor = JsonSerializer.Deserialize<GraphDescriptor>(contentJson, JsonOpts);
                                            break;
                                        case "render_timeline":
                                            _timelineDescriptor = JsonSerializer.Deserialize<TimelineDescriptor>(contentJson, JsonOpts);
                                            break;
                                        case "render_infobox":
                                            _infoboxDescriptor = JsonSerializer.Deserialize<InfoboxDescriptor>(contentJson, JsonOpts);
                                            break;
                                        case "render_text":
                                            _textDescriptor = JsonSerializer.Deserialize<TextDescriptor>(contentJson, JsonOpts);
                                            break;
                                    }
                                }
                            }
                            break;
                        }
                        case "TEXT_MESSAGE_START":
                            _currentAssistantTurn = new Turn(TurnRole.Assistant);
                            _turns.Add(_currentAssistantTurn);
                            break;
                        case "TEXT_MESSAGE_CONTENT":
                        {
                            var delta = root.TryGetProperty("delta", out var d) ? d.GetString() : null;
                            if (delta is not null && _currentAssistantTurn is not null)
                                _currentAssistantTurn.Content += delta;
                            break;
                        }
                        case "TEXT_MESSAGE_END":
                            if (_currentAssistantTurn is not null) _currentAssistantTurn.IsComplete = true;
                            _currentAssistantTurn = null;
                            break;
                        case "RUN_ERROR":
                            _error = root.TryGetProperty("message", out var em) ? em.GetString() : "Unknown error";
                            Logger.LogError("RUN_ERROR from agent: {Error}", _error);
                            break;
                        default:
                            Logger.LogDebug("Unhandled AGUI event type: {EventType}, json: {Json}", eventType, json);
                            break;
                    }
                }
                catch (JsonException) { }

                StateHasChanged();
            }

            _hasResult = HasVisualization;

            if (!_hasResult && _error is null && _turns.All(t => t.Role != TurnRole.Assistant))
            {
                Logger.LogWarning(
                    "AI returned no results. Lines read: {Lines}, Data lines: {DataLines}, Turns: {Turns}",
                    linesRead, dataLinesRead, _turns.Count);
                _error = "The AI returned no results. Try rephrasing your question.";
            }

            // Auto-save session for authenticated users
            if (_isAuthenticated && _userId is not null && _error is null && _turns.Count > 0)
            {
                await SaveCurrentSessionAsync(userPrompt);
            }
        }
        catch (OperationCanceledException)
        {
            _error = "Request timed out. The query took too long — try a simpler question.";
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    // ── Session management ──

    private async Task LoadSessionsAsync()
    {
        _sessionsLoading = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "api/ChatSessions");
            request.Headers.Add("X-User-Id", _userId);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _sessions = await response.Content.ReadFromJsonAsync<List<ChatSessionSummary>>(JsonOpts) ?? [];
            }
        }
        catch { /* silently ignore session load failures */ }
        finally
        {
            _sessionsLoading = false;
        }
    }

    private async Task SaveCurrentSessionAsync(string userPrompt)
    {
        try
        {
            var title = userPrompt.Length > 80 ? userPrompt[..80] + "…" : userPrompt;
            var messages = _turns
                .Select(t => new ChatSessionMessage
                {
                    Role = t.Role switch
                    {
                        TurnRole.User => "user",
                        TurnRole.Assistant => "assistant",
                        TurnRole.ToolCall => "tool",
                        _ => "unknown",
                    },
                    Content = t.Content,
                    ToolName = t.ToolName,
                    Timestamp = t.Timestamp,
                })
                .ToList();

            var body = new SaveChatSessionRequest { Title = title, Messages = messages };

            using var request = new HttpRequestMessage(HttpMethod.Post, "api/ChatSessions");
            request.Headers.Add("X-User-Id", _userId);
            request.Content = JsonContent.Create(body);
            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var id = await response.Content.ReadFromJsonAsync<Guid>();
                _currentSessionId = id;
                await LoadSessionsAsync();
            }
        }
        catch { /* silently ignore save failures */ }
    }

    private async Task LoadSession(Guid sessionId)
    {
        _historyOpen = false;
        _loading = true;
        _error = null;
        _turns.Clear();
        _chartDescriptor = null;
        _tableDescriptor = null;
        _dataTableDescriptor = null;
        _graphDescriptor = null;
        _timelineDescriptor = null;
        _infoboxDescriptor = null;
        _textDescriptor = null;
        _hasResult = false;
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, $"api/ChatSessions/{sessionId}");
            request.Headers.Add("X-User-Id", _userId);
            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var session = await response.Content.ReadFromJsonAsync<ChatSessionDetail>(JsonOpts);
                if (session is not null)
                {
                    _currentSessionId = session.Id;
                    _model.Prompt = session.Title;

                    foreach (var msg in session.Messages)
                    {
                        var role = msg.Role switch
                        {
                            "user" => TurnRole.User,
                            "tool" => TurnRole.ToolCall,
                            _ => TurnRole.Assistant,
                        };
                        _turns.Add(new Turn(role, msg.ToolName) { Content = msg.Content, IsComplete = true, Timestamp = msg.Timestamp });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load session: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteSession(Guid sessionId)
    {
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Delete, $"api/ChatSessions/{sessionId}");
            request.Headers.Add("X-User-Id", _userId);
            await Http.SendAsync(request);

            _sessions.RemoveAll(s => s.Id == sessionId);
            if (_currentSessionId == sessionId)
            {
                _currentSessionId = null;
                NewChat();
            }
            StateHasChanged();
        }
        catch { /* silently ignore delete failures */ }
    }

    private void NewChat()
    {
        _currentSessionId = null;
        _model = new AskModel();
        _turns.Clear();
        _chartDescriptor = null;
        _tableDescriptor = null;
        _dataTableDescriptor = null;
        _graphDescriptor = null;
        _timelineDescriptor = null;
        _infoboxDescriptor = null;
        _textDescriptor = null;
        _error = null;
        _hasResult = false;
        _randomExamples = PickRandomExamples();
        StateHasChanged();
    }

    private async Task ToggleHistory()
    {
        _historyOpen = !_historyOpen;
        if (_historyOpen && _isAuthenticated && _userId is not null)
        {
            await LoadSessionsAsync();
            StateHasChanged();
        }
    }

    private List<DisplayGroup> GetDisplayGroups()
    {
        var groups = new List<DisplayGroup>();
        var i = 0;
        while (i < _turns.Count)
        {
            if (_turns[i].Role == TurnRole.ToolCall)
            {
                var startIndex = i;
                var calls = new List<Turn>();
                while (i < _turns.Count && _turns[i].Role == TurnRole.ToolCall)
                {
                    calls.Add(_turns[i]);
                    i++;
                }
                groups.Add(new DisplayGroup(TurnRole.ToolCall, ToolCalls: calls, GroupIndex: startIndex));
            }
            else
            {
                groups.Add(new DisplayGroup(_turns[i].Role, Turn: _turns[i], GroupIndex: i));
                i++;
            }
        }
        return groups;
    }

    private void ToggleToolGroup(int key)
    {
        if (!_expandedToolGroups.Add(key))
            _expandedToolGroups.Remove(key);
    }

