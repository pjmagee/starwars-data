    private record CreditGroup(string Category, CreditItem[] Items);

    private static readonly CreditGroup[] _techStack =
    [
        new("Frameworks", [
            new(".NET 10", "https://dotnet.microsoft.com", "Runtime & SDK"),
            new(".NET Aspire", "https://learn.microsoft.com/dotnet/aspire", "Orchestration & observability"),
