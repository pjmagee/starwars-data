@page "/about"

<PageTitle>About</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudStack Spacing="6">

        <div>
            <MudText Typo="Typo.h4" GutterBottom="true">Star Wars Data Explorer</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                An interactive data platform for exploring the Star Wars universe through analytics,
                visualisations, and AI-powered insights &mdash; built on a temporal knowledge graph
                of 166,000+ entities and 652,000+ relationships.
            </MudText>
        </div>

        <MudDivider />

        <MudText Typo="Typo.h5" GutterBottom="true">Vision</MudText>
        <MudText Typo="Typo.body1">
            Traditional wiki browsing is linear &mdash; you read one article, click a link, read another.
            This project aims to surface the connections, patterns, and context that exist across
            the entire Star Wars universe but are impossible to see one page at a time.
        </MudText>
        <MudText Typo="Typo.body1">
            By processing the full breadth of Wookieepedia content through automated pipelines and
            AI-powered analysis, we build structured datasets, knowledge graphs, and semantic indexes
            that power interactive explorations no traditional wiki can offer.
        </MudText>

        <MudDivider />

        <MudText Typo="Typo.h5" GutterBottom="true">Data Source</MudText>
        <MudText Typo="Typo.body1">
            All content is sourced from
            <MudLink Href="https://starwars.fandom.com" Target="_blank" Underline="Underline.Always">
                Wookieepedia
            </MudLink>
            (starwars.fandom.com), the comprehensive Star Wars wiki maintained by the fan community.
            This includes both <strong>Canon</strong> and <strong>Legends</strong> continuity material.
            Structured infobox data, article content, and category metadata are downloaded via the
            MediaWiki API and stored in MongoDB for processing.
        </MudText>

        <MudDivider />

        <MudText Typo="Typo.h5" GutterBottom="true">How It Works</MudText>

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Color="Color.Primary" />
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">ETL Pipeline</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2">
                            Automated daily sync downloads pages from Wookieepedia via the MediaWiki API,
                            parses structured infobox data, and builds categorised timeline events across
                            every era of the Star Wars timeline.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Secondary" />
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Temporal Knowledge Graph</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2">
                            A two-phase approach builds the knowledge graph. Phase 1 deterministically extracts
                            entity nodes, relationships, and temporal lifecycles (born/died, founded/dissolved)
                            directly from infobox links. Phase 2 uses an AI analyst agent to discover complex
                            relationships beyond what infoboxes encode.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Tertiary" />
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Semantic Search</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2">
                            800,000+ article passages are chunked and embedded using OpenAI, enabling
                            vector-based semantic search over the full wiki corpus. Ask natural-language
                            questions and get answers grounded in the actual article content with
                            deep-linked source references.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Warning" />
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">AI Agent</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2">
                            An interactive AI agent equipped with 30+ tools across four toolkits can
                            traverse the knowledge graph, query temporal data, search article content,
                            and render results as charts, tables, relationship graphs, timelines,
                            infobox cards, and formatted articles.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudDivider />

        <MudText Typo="Typo.h5" GutterBottom="true">Features</MudText>

        <MudText Typo="Typo.h6" GutterBottom="true">AI-Powered</MudText>

        <MudList Dense="true" T="string">
            <MudListItem Icon="@Icons.Material.Filled.AutoAwesome" IconColor="Color.Warning">
                <MudText Typo="Typo.body2">
                    <strong>Ask AI</strong> &mdash; Conversational agent with 30+ tools across four toolkits.
                    Queries the knowledge graph, performs semantic search over 800K+ article passages,
                    and renders results inline as charts, relationship graphs, timelines, data tables,
                    infobox cards, and formatted research articles. All data comes from real tool calls;
                    nothing is fabricated.
                </MudText>
            </MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.Search" IconColor="Color.Warning">
                <MudText Typo="Typo.body2">
                    <strong>Semantic Search</strong> &mdash; AI-powered vector search finds content by meaning,
                    not keywords. Ask natural-language questions like &ldquo;why did Anakin turn to the dark side?&rdquo;
                    and get answers grounded in actual article text with deep-linked source references.
                    Available in Ask AI and the Galaxy Map.
                </MudText>
            </MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.Person" IconColor="Color.Warning">
                <MudText Typo="Typo.body2">
                    <strong>Character Timelines</strong> &mdash; AI-generated biographical timelines for characters,
                    synthesised from their full wiki articles and linked pages.
                </MudText>
            </MudListItem>
        </MudList>

        <MudText Typo="Typo.h6" GutterBottom="true" Class="mt-4">Data Exploration</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
            Built on structured data extracted from Wookieepedia and the temporal knowledge graph.
            No AI at runtime &mdash; all data is pre-computed.
        </MudText>

        <MudList Dense="true" T="string">
            <MudListItem Icon="@Icons.Material.Filled.Hub" IconColor="Color.Primary">
                <MudText Typo="Typo.body2">
                    <strong>Knowledge Graph</strong> &mdash; Browse 166,000+ entities and 694,000+ relationships.
                    Rich temporal facets track lifecycles across six semantic dimensions: lifespan, conflict,
                    institutional, construction, creation, and publication.
                </MudText>
            </MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.AccountTree" IconColor="Color.Primary">
                <MudText Typo="Typo.body2">
                    <strong>Graph Explorer</strong> &mdash; Interactive force-directed and hierarchical graph
                    visualisation. Explore entity networks, traverse relationships by label, expand nodes
                    on double-click, and navigate with breadcrumb history. Temporal slider filters edges by year.
                </MudText>
            </MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.Public" IconColor="Color.Primary">
                <MudText Typo="Typo.body2">
                    <strong>Galaxy Map</strong> &mdash; Interactive galactic map with two modes.
                    <strong>Explore</strong>: drill from regions to systems to planets, with keyword and
                    AI semantic search to locate places by concept. <strong>Timeline</strong>: animated
                    playback of galactic events with territory control heatmap, era navigation, and
                    event density visualisation.
                </MudText>
            </MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.Timeline" IconColor="Color.Primary">
                <MudText Typo="Typo.body2">
                    <strong>Timeline</strong> &mdash; Browse thousands of categorised events across all eras
                    with category filtering, year range scoping, and BBY/ABY navigation.
                </MudText>
            </MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.TableView" IconColor="Color.Primary">
                <MudText Typo="Typo.body2">
                    <strong>Data Tables</strong> &mdash; Searchable, sortable, paginated tables for every infobox
                    category: characters, ships, weapons, species, planets, governments, and more.
                </MudText>
            </MudListItem>
        </MudList>

        <MudDivider />

        <MudText Typo="Typo.h5" GutterBottom="true">Built With</MudText>
        <MudText Typo="Typo.body1" Class="mb-2">
            This project was built with assistance from AI coding tools, including
            <MudLink Href="https://claude.ai/code" Target="_blank" Underline="Underline.Always">
                Claude Code</MudLink>.
            AI-assisted development is rapidly becoming a standard part of the software engineering
            workflow. The AI accelerates the work; it does not replace the vision behind it.
        </MudText>

        <MudText Typo="Typo.h6" GutterBottom="true">Technology &amp; Credits</MudText>
        @foreach (var group in _techStack.Concat(_assets))
        {
            <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mt-2">@group.Category</MudText>
            @foreach (var item in group.Items)
            {
                <MudText Typo="Typo.body2">
                    @if (item.Url is not null)
                    {
                        <MudLink Href="@item.Url" Target="_blank" Underline="Underline.Hover">@item.Name</MudLink>
                    }
                    else
                    {
                        @item.Name
                    }
                    @if (item.Note is not null)
                    {
                        <span style="color:var(--mud-palette-text-secondary);"> — @item.Note</span>
                    }
                </MudText>
            }
        }

        <MudDivider />

        <MudText Typo="Typo.h5" GutterBottom="true">Content &amp; AI Usage</MudText>

        <MudText Typo="Typo.body1">
            Wookieepedia's user-contributed text is published under the
            <MudLink Href="https://creativecommons.org/licenses/by-sa/3.0/" Target="_blank" Underline="Underline.Always">
                Creative Commons Attribution-ShareAlike 3.0 (CC-BY-SA 3.0)
            </MudLink>
            licence. This licence explicitly permits copying, redistributing, adapting, and building upon the
            material &mdash; including for commercial purposes &mdash; provided that attribution is given and
            derivative works are shared under the same or a compatible licence.
        </MudText>

        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mt-4" GutterBottom="true">
            How we use AI
        </MudText>
        <MudText Typo="Typo.body2">
            This project does <strong>not</strong> train, fine-tune, or create custom AI models. We use
            standard OpenAI API models exclusively through <strong>agentic tool calling</strong> &mdash; the AI
            agent receives a question, calls tools to query our database and knowledge graph, and generates
            an answer grounded in the referenced material. All answers include source links back to
            Wookieepedia so users can verify the information. Vector embeddings are generated for semantic
            search retrieval only, not for model training.
        </MudText>

        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mt-4" GutterBottom="true">
            Data sourcing
        </MudText>
        <MudText Typo="Typo.body2">
            All content &mdash; including text, structured infobox data, and entity images &mdash; is sourced
            from Wookieepedia via the
            <MudLink Href="https://www.mediawiki.org/wiki/API:Main_page" Target="_blank" Underline="Underline.Always">
                MediaWiki API</MudLink>,
            a standard, publicly available interface. We abide by the API's rate-limiting and usage
            guidelines, and all requests include a descriptive User-Agent header identifying this project.
            We attribute Wookieepedia as the source throughout the site.
        </MudText>

        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mt-4" GutterBottom="true">
            Where there is a grey area
        </MudText>
        <MudText Typo="Typo.body2">
            <MudLink Href="https://www.fandom.com/terms-of-use" Target="_blank" Underline="Underline.Always">
                Fandom's Terms of Use
            </MudLink>
            restrict automated access without written permission. The Terms include an exception for CC-BY-SA
            content, but the boundary between the content licence (which permits reuse) and the platform terms
            (which restrict automated access) is not clearly resolved. Additionally, Fandom's 2025 Terms of Use
            update broadly prohibits using content for AI system development. While our use of embeddings and
            structured extraction is for search retrieval rather than model training, the wording is broad.
        </MudText>

        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mt-4" GutterBottom="true">
            Our position
        </MudText>
        <MudText Typo="Typo.body2">
            This is a non-commercial, <strong>open-source</strong> fan project
            (<MudLink Href="https://github.com/pjmagee/starwars-data" Target="_blank" Underline="Underline.Always">source on GitHub</MudLink>)
            for educational and analytical purposes. We do not train or distribute AI models. We respect the
            Wookieepedia community and the work of its contributors. If the Wookieepedia community or Fandom
            have concerns about this project, we are open to discussion and will act in good faith.
        </MudText>

        <MudDivider />

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Star Wars and all associated content are property of Lucasfilm Ltd.
            Wookieepedia content is maintained by its community contributors under
            <MudLink Href="https://starwars.fandom.com/wiki/Wookieepedia:Copyrights" Target="_blank" Underline="Underline.Always">
                CC-BY-SA 3.0</MudLink>.
        </MudAlert>

    </MudStack>
</MudContainer>

@code {
