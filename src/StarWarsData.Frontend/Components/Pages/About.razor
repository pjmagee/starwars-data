            new("Blazor Interactive Server", "https://learn.microsoft.com/aspnet/core/blazor", "Frontend rendering"),
        ]),
        new("AI & Search", [
            new("OpenAI API", "https://platform.openai.com", "GPT models, embeddings, Batch API"),
            new("Microsoft.Extensions.AI", "https://learn.microsoft.com/dotnet/ai", "AI abstractions"),
            new("Microsoft.Agents.AI", "https://github.com/microsoft/Agents-for-net", "Agent framework"),
            new("MongoDB Atlas Vector Search", "https://www.mongodb.com/products/platform/atlas-vector-search", "Semantic search"),
        ]),
        new("Database", [
            new("MongoDB", "https://www.mongodb.com", "Document store & knowledge graph"),
            new("Hangfire", "https://www.hangfire.io", "Background job processing"),
        ]),
        new("Frontend Libraries", [
            new("MudBlazor", "https://mudblazor.com", "Material Design component library"),
            new("D3.js", "https://d3js.org", "Interactive data visualisations"),
            new("Z.Blazor.Diagrams", "https://github.com/Blazor-Diagrams/Blazor.Diagrams", "Diagram components"),
            new("MudBlazor.Markdown", "https://github.com/AuroraZiling/MudBlazor.Markdown", "Markdown rendering"),
        ]),
        new("Infrastructure", [
            new("Keycloak", "https://www.keycloak.org", "Authentication (OIDC)"),
            new("OpenTelemetry", "https://opentelemetry.io", "Distributed tracing & metrics"),
            new("Docker", "https://www.docker.com", "Containerisation"),
        ]),
        new("Content", [
            new("Wookieepedia", "https://starwars.fandom.com", "Star Wars wiki (CC-BY-SA 3.0)"),
            new("MediaWiki API", "https://www.mediawiki.org/wiki/API:Main_page", "Data sourcing"),
        ]),
    ];

    private static readonly CreditGroup[] _assets =
    [
        new("Fonts", [
            new("Roboto", "https://fonts.google.com/specimen/Roboto", "Primary UI font (Google Fonts, Apache 2.0)"),
            new("Aurebesh", "https://aurekfonts.github.io", "Galactic Basic Standard alphabet (fan-made, open source)"),
        ]),
        new("Development Tools", [
            new("Claude Code", "https://claude.ai/code", "AI-assisted development (Anthropic)"),
            new("GitHub Copilot", "https://github.com/features/copilot", "AI pair programming"),
            new("MudMCP", "https://github.com/pjmagee/MudMCP", "MudBlazor MCP documentation server"),
        ]),
    ];
}
