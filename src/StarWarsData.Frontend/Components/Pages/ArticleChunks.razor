@page "/admin/article-chunks"
@attribute [Authorize(Roles = "admin")]
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject EndpointService EndpointService
@implements IDisposable

<PageTitle>Article Chunks &amp; Embeddings</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-8">
    <OpenAiStatusBanner />
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-6" Dense="true" NoIcon="false">
        <strong>Eligible Pages</strong> are those with non-empty article content, an infobox, and a known template type.
        Pages without content, or without an infobox classification, are excluded since they lack either text to chunk or a type to categorize by.
        This typically excludes redirect pages, disambiguation pages, and stub articles.
        <br /><br />
        <strong>Chunked</strong> = pages that have been semantically split into overlapping text chunks with vector embeddings generated.
        <strong>Pending</strong> = eligible pages that have not yet been chunked.
        <strong>Coverage</strong> in the table below shows each entity type's share of total chunked pages.
    </MudAlert>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @if (_progress != null)
    {
        <!-- Overall Progress -->
        <MudPaper Class="pa-6 mb-6" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                <MudText Typo="Typo.h5">Overall Progress</MudText>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="StartChunking" Disabled="_jobRunning">
                        Run Chunking Batch
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Storage"
                               OnClick="EnsureIndexes" Disabled="_jobRunning">
                        Ensure Indexes
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.TravelExplore"
                               OnClick="CreateVectorIndex" Disabled="_jobRunning">
                        Create Vector Index
                    </MudButton>
                </MudStack>
            </MudStack>

            @{
                var pct = _progress.TotalEligiblePages > 0
                    ? (double)_progress.ChunkedPages / _progress.TotalEligiblePages * 100
                    : 0;
            }

            <MudProgressLinear Value="@pct" Color="Color.Primary" Rounded="true" Size="Size.Large" Class="mb-3">
                <MudText Typo="Typo.body2">@($"{pct:F1}%")</MudText>
            </MudProgressLinear>

            <MudGrid>
                <MudItem xs="12" sm="4" md="2">
                    <MudStack AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h4" Color="Color.Primary">@_progress.TotalEligiblePages.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption">Eligible Pages</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudStack AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h4" Color="Color.Success">@_progress.ChunkedPages.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption">Chunked</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudStack AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h4" Color="Color.Warning">@_progress.PendingPages.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption">Pending</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudStack AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h4" Color="Color.Info">@_progress.TotalChunks.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption">Total Chunks</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudStack AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h4" Color="Color.Secondary">@_progress.AvgChunksPerPage.ToString("F1")</MudText>
                        <MudText Typo="Typo.caption">Avg Chunks/Page</MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>

            @if (_progress.PagesPerHour > 0)
            {
                <MudDivider Class="my-4" />
                <MudStack Row="true" Spacing="6" AlignItems="AlignItems.Center">
                    <MudStack AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5" Color="Color.Tertiary">@_progress.PagesPerHour.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption">Pages / Hour</MudText>
                    </MudStack>
                    @if (_progress.EstimatedHoursRemaining.HasValue)
                    {
                        <MudStack AlignItems="AlignItems.Center">
                            @{
                                var hrs = _progress.EstimatedHoursRemaining.Value;
                                var etaText = hrs >= 24 ? $"{hrs / 24:F1} days" : $"{hrs:F1} hours";
                            }
                            <MudText Typo="Typo.h5" Color="Color.Tertiary">@etaText</MudText>
                            <MudText Typo="Typo.caption">Estimated Remaining</MudText>
                        </MudStack>
                    }
                </MudStack>
            }
        </MudPaper>

        <!-- Progress by Type -->
        @if (_progress.ByType.Count > 0)
        {
            <MudPaper Class="pa-6 mb-6" Elevation="2">
                <MudDataGrid T="ChunkingTypeProgress" Items="_progress.ByType" Dense="true" Hover="true"
                             Filterable="true" SortMode="SortMode.Single"
                             FixedHeader="true" Height="400px"
                             QuickFilter="@_typeQuickFilter">
                    <ToolBarContent>
                        <MudText Typo="Typo.h5">Chunks by Entity Type</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="_typeSearchString" Placeholder="Search types"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Medium" Class="mt-0" Immediate="true" />
                    </ToolBarContent>
                    <Columns>
                        <TemplateColumn T="ChunkingTypeProgress" Title="Type" Sortable="true" SortBy="@(x => x.Type)">
                            <CellTemplate>
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@context.Item.Type</MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn T="ChunkingTypeProgress" TProperty="int" Property="x => x.Pages" Title="Pages" />
                        <PropertyColumn T="ChunkingTypeProgress" TProperty="long" Property="x => x.Chunks" Title="Chunks" />
                        <PropertyColumn T="ChunkingTypeProgress" TProperty="double" Property="x => x.AvgChunksPerPage" Title="Avg Chunks/Page" Format="F1" />
                        <TemplateColumn T="ChunkingTypeProgress" Title="Coverage" Sortable="true"
                                        SortBy="@(x => _progress!.ChunkedPages > 0 ? (double)x.Pages / _progress.ChunkedPages : 0)">
                            <CellTemplate>
                                @{
                                    var typePct = _progress!.ChunkedPages > 0
                                        ? (double)context.Item.Pages / _progress.ChunkedPages * 100
                                        : 0;
                                }
                                <MudProgressLinear Value="@typePct" Color="Color.Primary" Rounded="true" Size="Size.Small" Style="min-width: 120px;" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <PagerContent>
                        <MudDataGridPager T="ChunkingTypeProgress" />
                    </PagerContent>
                </MudDataGrid>
            </MudPaper>
        }
    }
    else if (!_loading)
    {
        <MudAlert Severity="Severity.Info">No progress data available. Run a chunking batch to get started.</MudAlert>
    }
</MudContainer>

@code {
    private ChunkingProgress? _progress;
    private bool _loading = true;
    private bool _jobRunning;
    private Timer? _pollTimer;
    private string _typeSearchString = "";

    private HttpClient Api => HttpClientFactory.CreateClient("StarWarsData");

    private Func<ChunkingTypeProgress, bool> _typeQuickFilter => t =>
        string.IsNullOrWhiteSpace(_typeSearchString)
        || t.Type.Contains(_typeSearchString, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadProgress();
        _pollTimer = new Timer(async _ =>
        {
            await LoadProgress();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadProgress()
    {
        try
        {
            _progress = await Api.GetFromJsonAsync<ChunkingProgress>("api/ArticleChunks/progress");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load progress: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartChunking()
    {
        await RunJob("api/admin/mongo/create-embeddings", "Article chunking batch started!");
    }

    private async Task EnsureIndexes()
    {
        await RunJob("api/admin/mongo/ensure-chunk-indexes", "Chunk index creation started!");
    }

    private async Task CreateVectorIndex()
    {
        await RunJob("api/admin/mongo/create-index-embeddings", "Vector index creation started!");
    }

    private async Task RunJob(string endpoint, string successMessage)
    {
        try
        {
            _jobRunning = true;
            var response = await Api.PostAsync(endpoint, null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(successMessage, Severity.Success);
            }
            else if ((int)response.StatusCode == 409)
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Job not started: {error}", Severity.Warning);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to start job: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _jobRunning = false;
        }
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
    }

    private class ChunkingProgress
    {
        public int TotalEligiblePages { get; set; }
        public int ChunkedPages { get; set; }
        public int PendingPages { get; set; }
        public long TotalChunks { get; set; }
        public double AvgChunksPerPage { get; set; }
        public double PagesPerHour { get; set; }
        public double? EstimatedHoursRemaining { get; set; }
        public List<ChunkingTypeProgress> ByType { get; set; } = [];
    }

    private class ChunkingTypeProgress
    {
        public string Type { get; set; } = "";
        public int Pages { get; set; }
        public long Chunks { get; set; }
        public double AvgChunksPerPage { get; set; }
    }
}
