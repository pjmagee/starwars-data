@page "/knowledge-graph"
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject GlobalFilterService GlobalFilterService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Knowledge Graph — Star Wars Data</PageTitle>
<HeadContent>
    <meta name="description" content="Explore a Star Wars knowledge graph with 166,000+ entities and 694,000+ relationships. Browse by type, search entities, and view temporal lifecycle data." />
</HeadContent>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">

    <MudText Typo="Typo.h5" Class="mb-4">Knowledge Graph</MudText>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0 pt-4">
    <MudTabPanel Text="Nodes" Icon="@Icons.Material.Filled.AccountTree">

    @* ── Bulk action bar (visible when nodes are selected) ── *@
    @if (_selectedItems.Count > 0)
    {
        <MudPaper Elevation="2" Class="pa-3 mb-3" Style="background-color: var(--mud-palette-primary-hover);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" />
                <MudText Typo="Typo.body1">
                    <strong>@_selectedItems.Count</strong> node@(_selectedItems.Count == 1 ? "" : "s") selected
                </MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Hub"
                           OnClick="OpenSelectedInGraphExplorer"
                           Disabled="@(_selectedItems.Count == 0)">
                    Open in Graph Explorer
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="CopySelectedIds">
                    Copy PageIds
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="ClearSelection">
                    Clear
                </MudButton>
            </MudStack>
        </MudPaper>
    }

    <MudTable T="TemporalNodeDto" ServerData="LoadData" @ref="_table" Dense="true"
              Hover="true" Bordered="false" Striped="true" Elevation="1"
              Loading="_loading" LoadingProgressColor="Color.Primary"
              AllowUnsorted="false"
              MultiSelection="true" @bind-SelectedItems="_selectedItems"
              SelectOnRowClick="false">
        <ToolBarContent>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" AlignItems="AlignItems.Center" Class="flex-grow-1">
                <MudTextField T="string" @bind-Value="_search" Placeholder="Search entities..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="OnSearchChanged"
                              Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Style="min-width:240px; max-width:280px;" />
                <MudSelect T="string" @bind-Value="_selectedType" Variant="Variant.Outlined" Margin="Margin.Dense"
                           @bind-Value:after="OnFilterChanged" Style="min-width:160px; max-width:180px;" Clearable="true"
                           Placeholder="All Types">
                    @foreach (var type in _entityTypes)
                    {
                        <MudSelectItem T="string" Value="@type">@FormatTypeName(type)</MudSelectItem>
                    }
                </MudSelect>
                <MudSwitch T="bool" @bind-Value="_temporalOnly" @bind-Value:after="OnFilterChanged"
                           Color="Color.Primary" Label="Temporal only" />
                <MudSelect T="string" @bind-Value="_selectedSemantic" Variant="Variant.Outlined" Margin="Margin.Dense"
                           @bind-Value:after="OnFilterChanged" Style="min-width:160px; max-width:180px;" Clearable="true"
                           Placeholder="All Dimensions">
                    <MudSelectItem T="string" Value="@("lifespan")">Lifespan</MudSelectItem>
                    <MudSelectItem T="string" Value="@("conflict")">Conflict</MudSelectItem>
                    <MudSelectItem T="string" Value="@("construction")">Construction</MudSelectItem>
                    <MudSelectItem T="string" Value="@("creation")">Creation</MudSelectItem>
                    <MudSelectItem T="string" Value="@("institutional")">Institutional</MudSelectItem>
                    <MudSelectItem T="string" Value="@("publication")">Publication</MudSelectItem>
                    <MudSelectItem T="string" Value="@("usage")">Usage</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" @bind-Value="_selectedCalendar" Variant="Variant.Outlined" Margin="Margin.Dense"
                           @bind-Value:after="OnFilterChanged" Style="min-width:160px; max-width:180px;" Clearable="true"
                           Placeholder="All Calendars">
                    <MudSelectItem T="string" Value="@("galactic")">Galactic (BBY/ABY)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("real")">Real-world (CE)</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" @bind-Value="_selectedLabel" Variant="Variant.Outlined" Margin="Margin.Dense"
                           @bind-Value:after="OnFilterChanged" Style="min-width:180px; max-width:200px;" Clearable="true"
                           Placeholder="All Relationships">
                    @foreach (var lbl in _edgeLabels)
                    {
                        <MudSelectItem T="string" Value="@lbl">@FormatPropertyKey(lbl)</MudSelectItem>
                    }
                </MudSelect>
                <MudNumericField T="int?" @bind-Value="_yearFrom" @bind-Value:after="OnFilterChanged"
                                 Placeholder="Year from" Variant="Variant.Outlined" Margin="Margin.Dense"
                                 Clearable="true" HideSpinButtons="true" Style="max-width:130px;"
                                 HelperText="@GetYearHelperText()" />
                <MudNumericField T="int?" @bind-Value="_yearTo" @bind-Value:after="OnFilterChanged"
                                 Placeholder="Year to" Variant="Variant.Outlined" Margin="Margin.Dense"
                                 Clearable="true" HideSpinButtons="true" Style="max-width:130px;"
                                 HelperText="@GetYearHelperText()" />
            </MudStack>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="width:50px"></MudTh>
            <MudTh>
                <MudTableSortLabel T="TemporalNodeDto" SortLabel="name" InitialDirection="SortDirection.Ascending">Name</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel T="TemporalNodeDto" SortLabel="type">Type</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel T="TemporalNodeDto" SortLabel="continuity">Continuity</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel T="TemporalNodeDto" SortLabel="startyear">Temporal Data</MudTableSortLabel>
            </MudTh>
            <MudTh Style="width:60px"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @if (context.ImageUrl is not null)
                {
                    <MudAvatar Size="Size.Small">
                        <MudImage Src="@StripRevision(context.ImageUrl)" Alt="@context.Name" />
                    </MudAvatar>
                }
            </MudTd>
            <MudTd DataLabel="Name">
                <MudLink Href="@($"/graph-explorer/{context.Id}")" Underline="Underline.Hover">
                    @context.Name
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                    @FormatTypeName(context.Type)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Continuity">
                @if (context.Continuity == "Canon")
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Style="font-size:10px;">Canon</MudChip>
                }
                else if (context.Continuity == "Legends")
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary" Style="font-size:10px;">Legends</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Temporal">
                @if (context.TemporalFacets.Count > 0)
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" AlignItems="AlignItems.Center">
                        @foreach (var (facet, idx) in context.TemporalFacets.OrderBy(f => f.Order).Select((f, i) => (f, i)))
                        {
                            @if (idx > 0)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small"
                                         Style="opacity:0.3; font-size:12px;" />
                            }
                            <MudTooltip Text="@($"{facet.Semantic} ({facet.Calendar})")">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Color="@GetFacetColor(facet.Semantic)" Style="font-size:11px;">
                                    @FormatFacetRole(facet.Semantic): @facet.Text
                                </MudChip>
                            </MudTooltip>
                        }
                    </MudStack>
                }
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@(_expandedNodeId == context.Id ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                               Size="Size.Small" OnClick="@(() => ToggleDetails(context.Id))" />
            </MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (_expandedNodeId == context.Id)
            {
                <MudTr>
                    <td colspan="6">
                        <MudPaper Class="pa-4 ma-2" Outlined="true">
                            <MudGrid Spacing="2">
                                @if (context.ImageUrl is not null)
                                {
                                    <MudItem xs="12" sm="3" md="2">
                                        <MudImage Src="@StripRevision(context.ImageUrl)" Alt="@context.Name"
                                                  ObjectFit="ObjectFit.Contain" Style="max-height:200px; width:100%;"
                                                  Class="rounded" />
                                    </MudItem>
                                }
                                <MudItem xs="12" sm="@(context.ImageUrl is not null ? 9 : 12)" md="@(context.ImageUrl is not null ? 10 : 12)">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="2">
                                        <MudText Typo="Typo.h6">@context.Name</MudText>
                                        @if (context.WikiUrl is not null)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                                           Href="@context.WikiUrl" Target="_blank" Color="Color.Primary" />
                                        }
                                        <MudIconButton Icon="@Icons.Material.Filled.Hub" Size="Size.Small"
                                                       Href="@($"/graph-explorer/{context.Id}")" Color="Color.Secondary"
                                                       Title="View in Graph Explorer" />
                                    </MudStack>

                                    @* ── Temporal Facets ── *@
                                    @if (context.TemporalFacets.Count > 0)
                                    {
                                        <MudText Typo="Typo.subtitle2" Class="mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                            Timeline
                                        </MudText>
                                        @foreach (var group in context.TemporalFacets.GroupBy(f => f.Semantic.Split('.')[0]).OrderBy(g => g.Key))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1" Style="text-transform:capitalize;">
                                                @group.Key
                                            </MudText>
                                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" AlignItems="AlignItems.Center" Class="mb-2">
                                                @foreach (var (facet, idx) in group.OrderBy(f => f.Order).Select((f, i) => (f, i)))
                                                {
                                                    @if (idx > 0)
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small"
                                                                 Color="Color.Secondary" Style="opacity:0.5;" />
                                                    }
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                             Color="@GetFacetColor(facet.Semantic)">
                                                        @FormatFacetRole(facet.Semantic): @facet.Text
                                                        @if (facet.Calendar == "real" && facet.Year.HasValue)
                                                        {
                                                            <text> (CE)</text>
                                                        }
                                                    </MudChip>
                                                }
                                            </MudStack>
                                        }

                                        @if (context.StartYear.HasValue && context.EndYear.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="mb-3">
                                                Duration: @Math.Abs(context.EndYear.Value - context.StartYear.Value) years
                                            </MudChip>
                                        }
                                    }
                                    else if (context.StartYear.HasValue || context.EndYear.HasValue)
                                    {
                                        <MudStack Row="true" Spacing="2" Class="mb-3">
                                            @if (context.StartDateText is not null)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                                    Start: @context.StartDateText
                                                </MudChip>
                                            }
                                            @if (context.EndDateText is not null)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                                    End: @context.EndDateText
                                                </MudChip>
                                            }
                                        </MudStack>
                                    }

                                    @* ── Attributes (scalar properties intrinsic to this node) ── *@
                                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.ListAlt" Size="Size.Small" Class="mr-1" />
                                        Attributes
                                    </MudText>
                                    @if (context.Properties.Count > 0)
                                    {
                                        <MudSimpleTable Dense="true" Bordered="true" Striped="true" Style="max-width:600px; font-size:13px;" Class="mb-4">
                                            <tbody>
                                                @foreach (var kvp in context.Properties.OrderBy(p => p.Key))
                                                {
                                                    <tr>
                                                        <td style="font-weight:600; white-space:nowrap; width:1%; padding:4px 8px; vertical-align:top; text-transform:capitalize;">
                                                            @FormatPropertyKey(kvp.Key)
                                                        </td>
                                                        <td style="padding:4px 8px;">
                                                            @string.Join(", ", kvp.Value)
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">No attributes recorded.</MudText>
                                    }

                                    @* ── Relationships (edge labels connecting this node to others) ── *@
                                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Small" Class="mr-1" />
                                        Relationships
                                    </MudText>
                                    @if (_expandedLabelsLoading)
                                    {
                                        <MudProgressLinear Indeterminate="true" Color="Color.Info" Style="max-width:400px;" />
                                    }
                                    else if (_expandedLabels is { Count: > 0 })
                                    {
                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                            @foreach (var label in _expandedLabels)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined"
                                                         Href="@($"/graph-explorer/{context.Id}")" Target="_self">
                                                    @FormatPropertyKey(label)
                                                </MudChip>
                                            }
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">No relationships found.</MudText>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </td>
                </MudTr>
            }
        </ChildRowContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 20, 50, 100 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true">
                No knowledge graph nodes found matching your filters.
            </MudAlert>
        </NoRecordsContent>
    </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Edge Labels" Icon="@Icons.Material.Filled.Hub">
        <MudTable T="EdgeLabelStatsDto" ServerData="LoadLabelStats" @ref="_labelTable" Dense="true"
                  Hover="true" Bordered="false" Striped="true" Elevation="1"
                  Loading="_labelsLoading" LoadingProgressColor="Color.Primary"
                  AllowUnsorted="false">
            <ToolBarContent>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" AlignItems="AlignItems.Center" Class="flex-grow-1">
                    <MudTextField T="string" @bind-Value="_labelSearch" Placeholder="Search labels..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="OnLabelSearchChanged"
                                  Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="min-width:240px; max-width:280px;" />
                    <MudSelect T="string" @bind-Value="_labelFromType" Variant="Variant.Outlined" Margin="Margin.Dense"
                               @bind-Value:after="OnLabelFilterChanged" Style="min-width:160px; max-width:180px;"
                               Clearable="true" Placeholder="From type">
                        @foreach (var t in _entityTypes)
                        {
                            <MudSelectItem T="string" Value="@t">@FormatTypeName(t)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="string" @bind-Value="_labelToType" Variant="Variant.Outlined" Margin="Margin.Dense"
                               @bind-Value:after="OnLabelFilterChanged" Style="min-width:160px; max-width:180px;"
                               Clearable="true" Placeholder="To type">
                        @foreach (var t in _entityTypes)
                        {
                            <MudSelectItem T="string" Value="@t">@FormatTypeName(t)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudNumericField T="long" @bind-Value="_labelMinCount" @bind-Value:after="OnLabelFilterChanged"
                                     Placeholder="Min count" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     HideSpinButtons="true" Style="max-width:130px;" />
                </MudStack>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>
                    <MudTableSortLabel T="EdgeLabelStatsDto" SortLabel="label">Label</MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="EdgeLabelStatsDto" SortLabel="count" InitialDirection="SortDirection.Descending">Count</MudTableSortLabel>
                </MudTh>
                <MudTh>Continuity</MudTh>
                <MudTh>From types</MudTh>
                <MudTh>To types</MudTh>
                <MudTh>
                    <MudTableSortLabel T="EdgeLabelStatsDto" SortLabel="avgWeight">Avg conf.</MudTableSortLabel>
                </MudTh>
                <MudTh>Example</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Label">
                    <MudLink Href="@($"/knowledge-graph")" OnClick="@(() => JumpToNodesFilteredByLabel(context.Label))" Underline="Underline.Hover">
                        <strong>@FormatPropertyKey(context.Label)</strong>
                    </MudLink>
                </MudTd>
                <MudTd DataLabel="Count">@context.Count.ToString("N0")</MudTd>
                <MudTd DataLabel="Continuity">
                    <MudStack Row="true" Spacing="1">
                        @if (context.CanonCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Style="font-size:10px;">C: @context.CanonCount.ToString("N0")</MudChip>
                        }
                        @if (context.LegendsCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary" Style="font-size:10px;">L: @context.LegendsCount.ToString("N0")</MudChip>
                        }
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="From">
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var tc in context.TopFromTypes)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="font-size:10px;">@FormatTypeName(tc.Type) · @tc.Count.ToString("N0")</MudChip>
                        }
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="To">
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var tc in context.TopToTypes)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="font-size:10px;">@FormatTypeName(tc.Type) · @tc.Count.ToString("N0")</MudChip>
                        }
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="AvgWeight">@context.AvgWeight.ToString("F2")</MudTd>
                <MudTd DataLabel="Sample">
                    @if (context.Sample is { } s)
                    {
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudLink Href="@($"/graph-explorer/{s.FromId}")" Underline="Underline.Hover">
                                <MudText Typo="Typo.caption">@s.FromName</MudText>
                            </MudLink>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Style="opacity:.4; font-size:14px;" />
                            <MudLink Href="@($"/graph-explorer/{s.ToId}")" Underline="Underline.Hover">
                                <MudText Typo="Typo.caption">@s.ToName</MudText>
                            </MudLink>
                        </MudStack>
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 25, 50, 100 }" />
            </PagerContent>
            <NoRecordsContent>
                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true">
                    No relationship labels match your filters.
                </MudAlert>
            </NoRecordsContent>
        </MudTable>
    </MudTabPanel>
    </MudTabs>

</MudContainer>

@code {
    private MudTable<TemporalNodeDto>? _table;
    private bool _loading;
    private string _search = "";
    private string _selectedType = "";
    private bool _temporalOnly;
    private string _selectedSemantic = "";
    private string _selectedLabel = "";
    private string _selectedCalendar = "";
    private int? _yearFrom;
    private int? _yearTo;
    private List<string> _entityTypes = [];
    private List<string> _edgeLabels = [];
    private int? _expandedNodeId;
    private List<string>? _expandedLabels;
    private bool _expandedLabelsLoading;

    // Multi-selection: persist across pages by tracking selected ids, not row references
    private HashSet<TemporalNodeDto> _selectedItems = new();

    // Edge Labels tab state
    private MudTable<EdgeLabelStatsDto>? _labelTable;
    private bool _labelsLoading;
    private string _labelSearch = "";
    private string _labelFromType = "";
    private string _labelToType = "";
    private long _labelMinCount;

    private HttpClient Api => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnGlobalFilterChanged;
        await Task.WhenAll(LoadEntityTypes(), LoadEdgeLabels());
    }

    private async Task LoadEntityTypes()
    {
        try
        {
            var types = await Api.GetFromJsonAsync<List<string>>("api/RelationshipGraph/entity-types");
            if (types is { Count: > 0 })
                _entityTypes = types;
        }
        catch { }
    }

    private async Task LoadEdgeLabels()
    {
        try
        {
            var labels = await Api.GetFromJsonAsync<List<string>>("api/RelationshipGraph/edge-labels");
            if (labels is { Count: > 0 })
                _edgeLabels = labels;
        }
        catch { }
    }

    private async void OnGlobalFilterChanged()
    {
        await InvokeAsync(() =>
        {
            _table?.ReloadServerData();
            _labelTable?.ReloadServerData();
            StateHasChanged();
        });
    }

    private async Task<TableData<TemporalNodeDto>> LoadData(TableState state, CancellationToken ct)
    {
        _loading = true;
        try
        {
            var page = state.Page + 1;
            var qs = System.Web.HttpUtility.ParseQueryString(string.Empty);
            qs["page"] = page.ToString();
            qs["pageSize"] = state.PageSize.ToString();

            if (!string.IsNullOrWhiteSpace(_selectedType))
                qs["type"] = _selectedType;
            if (!string.IsNullOrWhiteSpace(_search))
                qs["q"] = _search;
            if (_temporalOnly)
                qs["temporalOnly"] = "true";
            if (!string.IsNullOrWhiteSpace(_selectedSemantic))
                qs["semantic"] = _selectedSemantic;
            if (!string.IsNullOrWhiteSpace(_selectedLabel))
                qs["label"] = _selectedLabel;
            if (!string.IsNullOrWhiteSpace(_selectedCalendar))
                qs["calendar"] = _selectedCalendar;
            if (_yearFrom.HasValue)
                qs["yearFrom"] = _yearFrom.Value.ToString();
            if (_yearTo.HasValue)
                qs["yearTo"] = _yearTo.Value.ToString();

            // Server-side sort via MudTableSortLabel
            if (!string.IsNullOrWhiteSpace(state.SortLabel))
            {
                qs["sortBy"] = state.SortLabel;
                qs["sortDirection"] = state.SortDirection == SortDirection.Descending
                    ? "descending"
                    : "ascending";
            }

            var c = GlobalFilterService.GetContinuityQueryParam();
            if (!string.IsNullOrEmpty(c))
                qs["continuity"] = c;
            var u = GlobalFilterService.GetUniverseQueryParam();
            if (!string.IsNullOrEmpty(u))
                qs["universe"] = u;

            var result = await Api.GetFromJsonAsync<BrowseTemporalNodesResult>(
                $"api/RelationshipGraph/temporal-nodes?{qs}", ct);

            return new TableData<TemporalNodeDto>
            {
                Items = result?.Items ?? [],
                TotalItems = (int)(result?.Total ?? 0),
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load nodes: {ex.Message}", Severity.Error);
            return new TableData<TemporalNodeDto> { Items = [], TotalItems = 0 };
        }
        finally
        {
            _loading = false;
        }
    }

