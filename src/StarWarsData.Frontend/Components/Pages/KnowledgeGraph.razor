    private async Task<TableData<EdgeLabelStatsDto>> LoadLabelStats(TableState state, CancellationToken ct)
    {
        _labelsLoading = true;
        try
        {
            var qs = System.Web.HttpUtility.ParseQueryString(string.Empty);
            qs["page"] = (state.Page + 1).ToString();
            qs["pageSize"] = state.PageSize.ToString();

            if (!string.IsNullOrWhiteSpace(_labelSearch))
                qs["q"] = _labelSearch;
            if (!string.IsNullOrWhiteSpace(_labelFromType))
                qs["fromType"] = _labelFromType;
            if (!string.IsNullOrWhiteSpace(_labelToType))
                qs["toType"] = _labelToType;
            if (_labelMinCount > 0)
                qs["minCount"] = _labelMinCount.ToString();

            if (!string.IsNullOrWhiteSpace(state.SortLabel))
            {
                qs["sortBy"] = state.SortLabel;
                qs["sortDirection"] = state.SortDirection == SortDirection.Descending
                    ? "descending"
                    : "ascending";
            }

            var c = GlobalFilterService.GetContinuityQueryParam();
            if (!string.IsNullOrEmpty(c))
                qs["continuity"] = c;
            var u = GlobalFilterService.GetUniverseQueryParam();
            if (!string.IsNullOrEmpty(u))
                qs["universe"] = u;

            var result = await Api.GetFromJsonAsync<BrowseEdgeLabelsResult>(
                $"api/RelationshipGraph/edge-label-stats?{qs}", ct);

            return new TableData<EdgeLabelStatsDto>
            {
                Items = result?.Items ?? [],
                TotalItems = (int)(result?.Total ?? 0),
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load edge label stats: {ex.Message}", Severity.Error);
            return new TableData<EdgeLabelStatsDto> { Items = [], TotalItems = 0 };
        }
        finally
        {
            _labelsLoading = false;
        }
    }

