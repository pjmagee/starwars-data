    private async Task ToggleDetails(int nodeId)
    {
        if (_expandedNodeId == nodeId)
        {
            _expandedNodeId = null;
            _expandedLabels = null;
            return;
        }

        _expandedNodeId = nodeId;
        _expandedLabels = null;
        _expandedLabelsLoading = true;
        StateHasChanged();

        try
        {
            var result = await Api.GetFromJsonAsync<EntityLabelsResult>(
                $"api/RelationshipGraph/labels/{nodeId}");
            _expandedLabels = result?.Labels ?? [];
        }
        catch
        {
            _expandedLabels = [];
        }
        finally
        {
            _expandedLabelsLoading = false;
        }
    }

    private string GetYearHelperText() => _selectedCalendar switch
    {
        "galactic" => "neg=BBY, pos=ABY",
        "real" => "CE year (e.g. 2015)",
        _ => "BBY neg / ABY pos / CE",
    };

    private void ClearSelection()
    {
        _selectedItems = new HashSet<TemporalNodeDto>();
    }

    private void OpenSelectedInGraphExplorer()
    {
        if (_selectedItems.Count == 0)
            return;

        // Graph explorer currently takes a single root. Open the first; users
        // can open additional nodes in new tabs via shift/ctrl-click on the
        // individual row links. For now, show a note and navigate to the first.
        var first = _selectedItems.First();
        if (_selectedItems.Count > 1)
        {
            Snackbar.Add(
                $"Graph Explorer takes one root at a time — opening '{first.Name}'. " +
                $"{_selectedItems.Count - 1} other(s) remain selected.",
                Severity.Info);
        }
        Navigation.NavigateTo($"/graph-explorer/{first.Id}");
    }

    private async Task CopySelectedIds()
    {
        if (_selectedItems.Count == 0)
            return;

        var ids = string.Join(",", _selectedItems.Select(n => n.Id));
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", ids);
            Snackbar.Add($"Copied {_selectedItems.Count} PageId(s) to clipboard", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Clipboard copy failed", Severity.Warning);
        }
    }

    static string FormatTypeName(string type) => type switch
    {
        "CelestialBody" => "Planet / Body",
        _ => System.Text.RegularExpressions.Regex.Replace(type, "(?<!^)([A-Z])", " $1"),
    };

    static string FormatPropertyKey(string key) =>
        key.Replace("_", " ");

    static string FormatFacetRole(string semantic)
    {
        var role = semantic.Contains('.') ? semantic[(semantic.LastIndexOf('.') + 1)..] : semantic;
        return role switch
        {
            "start" => semantic.StartsWith("lifespan") ? "Born" :
                       semantic.StartsWith("conflict") ? "Began" :
                       semantic.StartsWith("construction") ? "Built" :
                       semantic.StartsWith("creation") ? "Created" :
                       semantic.StartsWith("institutional") ? "Established" :
                       semantic.StartsWith("publication") ? "Released" : "Start",
            "end" => semantic.StartsWith("lifespan") ? "Died" :
                     semantic.StartsWith("conflict") ? "Ended" :
                     semantic.StartsWith("construction") ? "Destroyed" :
                     semantic.StartsWith("creation") ? "Destroyed" :
                     semantic.StartsWith("institutional") ? "Dissolved" :
                     semantic.StartsWith("publication") ? "Ended" : "End",
            "point" => "Date",
            "release" => "Released",
            "rebuilt" => "Rebuilt",
            "reorganized" => "Reorganized",
            "restored" => "Restored",
            "fragmented" => "Fragmented",
            "suspended" => "Suspended",
            "discovered" => "Discovered",
            _ => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(role),
        };
    }

    static Color GetFacetColor(string semantic)
    {
        var role = semantic.Contains('.') ? semantic[(semantic.LastIndexOf('.') + 1)..] : semantic;
        return role switch
        {
            "start" or "release" => Color.Success,
            "end" => Color.Error,
            "point" => Color.Primary,
            "reorganized" or "restored" => Color.Warning,
            "fragmented" or "suspended" => Color.Secondary,
            "discovered" or "rebuilt" => Color.Info,
            _ => Color.Default,
        };
    }

    static string StripRevision(string url)
    {
        var idx = url.IndexOf("/revision", StringComparison.OrdinalIgnoreCase);
        return idx > 0 ? url[..idx] : url;
    }

    public void Dispose()
    {
        GlobalFilterService.OnChange -= OnGlobalFilterChanged;
