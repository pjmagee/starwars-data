@page "/timeline"

<PageTitle>Timeline — Star Wars Data</PageTitle>
<HeadContent>
    <meta name="description" content="Browse thousands of Star Wars timeline events across all eras — from the dawn of the Jedi to the rise of the First Order. Filter by category and year range, in-universe (BBY/ABY) or real-world publication dates." />
</HeadContent>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">

    @* <MudText Typo="Typo.h5" Class="mb-4">Timeline</MudText> *@

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-0 pt-4">
        <MudTabPanel Text="Star Wars" Icon="@Icons.Material.Filled.Public">
            <EventTimeline ShowCategoryFilter="true" CalendarMode="Calendar.Galactic" />
        </MudTabPanel>
        <MudTabPanel Text="Real World" Icon="@Icons.Material.Filled.CalendarMonth">
            <EventTimeline ShowCategoryFilter="true" CalendarMode="Calendar.Real" />
        </MudTabPanel>
    </MudTabs>

</MudContainer>
