@page "/galactic-map-v2"
@rendermode InteractiveServer
@using WikiPage = StarWarsData.Models.Entities.Page
@using StarWarsData.Models.Entities
@using StarWarsData.Models.Queries
@inject IHttpClientFactory HttpClientFactory
@inject StarWarsData.Frontend.Services.GlobalFilterService GlobalFilterService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Galaxy Map</PageTitle>

<style>
    .galaxy-v2-container {
        position: relative;
        width: 100%;
        height: calc(100vh - 120px);
        background: #0a0a1a;
        border-radius: 8px;
        overflow: hidden;
    }
    .galaxy-v2-container svg {
        display: block;
    }
    .galaxy-nav-panel {
        position: absolute;
        top: 12px;
        left: 12px;
        z-index: 100;
        max-width: 420px;
    }
    .galaxy-search-panel {
        position: absolute;
        top: 12px;
        left: 12px;
        z-index: 110;
        width: 360px;
        max-height: calc(100% - 24px);
        display: flex;
        flex-direction: column;
    }
    .galaxy-detail-panel {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 500px;
        max-height: calc(100% - 24px);
        overflow-y: auto;
        z-index: 100;
    }
    .galaxy-detail-panel::-webkit-scrollbar,
    .search-results-list::-webkit-scrollbar {
        width: 6px;
    }
    .galaxy-detail-panel::-webkit-scrollbar-thumb,
    .search-results-list::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.15);
        border-radius: 3px;
    }
    .search-results-list {
        overflow-y: auto;
        max-height: 40vh;
    }
</style>

<div class="galaxy-v2-container" id="galaxy-v2-root">
    @if (_loading)
    {
        <div style="display:flex; align-items:center; justify-content:center; height:100%;">
            <MudStack Row="false" AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5);">Loading galaxy overview...</MudText>
            </MudStack>
        </div>
    }

    @* Search + navigation panel (left) *@
    @if (_overview is not null)
    {
        <div class="galaxy-search-panel">
            @* Search bar *@
            <MudPaper Elevation="8" Class="pa-2" Style="background: rgba(15,15,35,0.9); backdrop-filter: blur(8px);">
                <MudStack Row="false" Spacing="1">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        @if (_currentLevel != "overview")
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                                           Color="Color.Primary" OnClick="GoBack" />
                        }
                        <MudBreadcrumbs Items="_breadcrumbs" MaxItems="3"
                                        Style="padding:0; color: rgba(255,255,255,0.7);" />
                    </MudStack>
                    <MudTextField @bind-Value="_searchTerm"
                                  Placeholder="Search planets, systems, people..."
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="false"
                                  DebounceInterval="600"
                                  OnDebounceIntervalElapsed="OnSearchChanged"
                                  Clearable="true"
                                  OnClearButtonClick="ClearSearch"
                                  Margin="Margin.Dense"
                                  Style="color: #e0e0f0;" />
                    <MudSwitch Value="_onlyWithPlanets" Color="Color.Success" Size="Size.Small"
                               Label="Only systems with planets"
                               Style="color: rgba(255,255,255,0.5); margin: 0;"
                               ValueChanged="OnPlanetFilterChanged" T="bool" />
                    @* Region filter *@
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.4);">Regions</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ShowAllRegions"
                                   Style="color: rgba(255,255,255,0.4); min-width:auto; padding:0 4px; text-transform:none; font-size:11px;">All</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="HideAllRegions"
                                   Style="color: rgba(255,255,255,0.4); min-width:auto; padding:0 4px; text-transform:none; font-size:11px;">None</MudButton>
                    </MudStack>
                    <MudStack Row="true" Spacing="1" Class="flex-wrap" Style="max-height: 180px; overflow-y: auto;">
                        @foreach (var region in _overview.Regions)
                        {
                            var isVisible = !_hiddenRegions.Contains(region.Name);
                            <MudChip T="string" Size="Size.Small"
                                     Variant="@(isVisible ? Variant.Filled : Variant.Outlined)"
                                     OnClick="() => ToggleRegion(region.Name)"
                                     Style="@GetRegionChipStyle(region.Name, isVisible)">
                                @region.Name
                            </MudChip>
                        }
                    </MudStack>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">
                            @_overview.Regions.Count Regions
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">
                            @_overview.TradeRoutes.Count Routes
                        </MudChip>
                        @if (_searching)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_searchResults is not null)
                        {
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5);">
                                @_searchResults.Count result(s)
                            </MudText>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>

            @* Search results *@
            @if (_searchResults is { Count: > 0 })
            {
                <MudPaper Elevation="8" Class="pa-0 mt-1" Style="background: rgba(15,15,35,0.92); backdrop-filter: blur(8px);">
                    <div class="search-results-list">
                        <MudList Dense="true" T="MapSearchResult" Style="color: #e0e0f0;">
                            @foreach (var group in _searchResults.GroupBy(r => r.GridKey))
                            {
                                <MudListSubheader Style="background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.5);">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.GridOn" Size="Size.Small" />
                                        <MudText Typo="Typo.subtitle2">Grid @group.Key</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                                 Style="color: rgba(255,255,255,0.3);">@group.Count()</MudChip>
                                    </MudStack>
                                </MudListSubheader>
                                @foreach (var result in group)
                                {
                                    var isActive = _selectedSearchResult?.PageId == result.PageId;
                                    <MudListItem T="MapSearchResult"
                                                 OnClick="() => SelectSearchResult(result)"
                                                 Style="@(isActive ? "background: rgba(255,255,255,0.08);" : "")">
                                        <MudStack Row="false" Spacing="0">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@GetTemplateIcon(result.Template)" Size="Size.Small"
                                                         Style="color: rgba(255,255,255,0.4);" />
                                                <MudText Typo="Typo.body2" Style="color: #e0e0f0;">
                                                    @result.MatchedName
                                                </MudText>
                                            </MudStack>
                                            @if (result.MatchType == "linked" && result.LinkedVia is not null)
                                            {
                                                <MudText Typo="Typo.caption" Style="color: rgba(255,215,0,0.6);">
                                                    @result.LinkedVia
                                                </MudText>
                                            }
                                            else if (result.Template is not null)
                                            {
                                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.3);">
                                                    @SanitizeTemplate(result.Template)
                                                </MudText>
                                            }
                                        </MudStack>
                                    </MudListItem>
                                }
                            }
                        </MudList>
                    </div>
                </MudPaper>
            }
        </div>
    }

    @* Region hover info panel (right) *@
    @if (_hoveredRegionName is not null && _detailPage is null && _selectedSystem is null && _selectedRegion is null)
    {
        <div class="galaxy-detail-panel">
            <MudPaper Elevation="12" Class="pa-3" Style="background: rgba(15,15,35,0.92); backdrop-filter: blur(12px);">
                <MudStack Row="false" Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <div style="width:12px; height:12px; border-radius:50%; background:@_hoveredRegionColor;"></div>
                        <MudText Typo="Typo.h6" Style="color: #e0e0f0;">@_hoveredRegionName</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.5);">
                        @_hoveredRegionCellCount grid cell@(_hoveredRegionCellCount != 1 ? "s" : "")
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.3);">
                        Click to explore this region
                    </MudText>
                </MudStack>
            </MudPaper>
        </div>
    }

    @* Region detail panel (right, when drilled into a region) *@
    @if (_selectedRegion is not null && _detailPage is null && _selectedSystem is null)
    {
        <div class="galaxy-detail-panel">
            <MudPaper Elevation="12" Class="pa-3" Style="background: rgba(15,15,35,0.92); backdrop-filter: blur(12px);">
                <MudStack Row="false" Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <div style="width:14px; height:14px; border-radius:50%; background:@GetRegionColor(_selectedRegion.Name);"></div>
                        <MudText Typo="Typo.h6" Style="color: #e0e0f0;">@_selectedRegion.Name</MudText>
                    </MudStack>
                    <MudDivider Style="border-color: rgba(255,255,255,0.1);" />
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.5);">
                        <MudIcon Icon="@Icons.Material.Filled.GridOn" Size="Size.Small" Style="vertical-align:middle; margin-right:4px;" />
                        @_selectedRegion.Cells.Count grid cell@(_selectedRegion.Cells.Count != 1 ? "s" : "")
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.3);">
                        Click on a system to view details
                    </MudText>
                </MudStack>
            </MudPaper>
        </div>
    }

    @* Detail / info panel (right) *@
    @if (_detailPage is not null || _selectedSystem is not null)
    {
        <div class="galaxy-detail-panel">
            <MudPaper Elevation="12" Class="pa-0" Style="background: rgba(15,15,35,0.92); backdrop-filter: blur(12px);">
                <MudStack Row="false" Spacing="0">
                    @* Close button *@
                    <div style="display:flex; justify-content:flex-end; padding: 4px 4px 0 0;">
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       Color="Color.Default" OnClick="ClearDetailPanel" />
                    </div>

                    @if (_loadingDetails)
                    {
                        <div style="display:flex; justify-content:center; padding: 24px;">
                            <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                    else if (_detailPage is not null)
                    {
                        @* Full infobox card *@
                        @if (_detailPage.Infobox?.ImageUrl is not null)
                        {
                            <MudCardMedia Image="@StripRevision(_detailPage.Infobox.ImageUrl)" Height="180"
                                          Style="border-radius: 0;" />
                        }
                        <div class="pa-3">
                            <MudText Typo="Typo.h6" Style="color: #e0e0f0;">@_detailPage.Title</MudText>
                            @if (_detailPage.Infobox?.Template is not null)
                            {
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.4);">
                                    @SanitizeTemplate(_detailPage.Infobox.Template)
                                </MudText>
                            }
                            @if (_selectedSearchResult?.MatchType == "linked" && _selectedSearchResult.LinkedVia is not null)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mt-2">
                                    @_selectedSearchResult.LinkedVia
                                </MudAlert>
                            }
                            @if (_detailPage.Infobox?.Data is not null)
                            {
                                <MudSimpleTable Dense="true" Bordered="true" Striped="true" Class="mt-2"
                                                Style="overflow-x:auto; background: transparent;">
                                    <tbody>
                                        @foreach (var prop in _detailPage.Infobox.Data.Where(HasInfoboxContent))
                                        {
                                            <tr>
                                                <td style="font-weight:600; white-space:nowrap; padding:4px 8px; vertical-align:top; color: rgba(255,255,255,0.6); font-size:12px;">
                                                    @prop.Label
                                                </td>
                                                <td style="padding:4px 8px; color: #e0e0f0; font-size:12px;">
                                                    @foreach (var link in prop.Links)
                                                    {
                                                        <MudLink Href="@link.Href" Underline="Underline.Always"
                                                                 Class="mr-1" Target="_blank"
                                                                 Style="font-size:12px;">@link.Content</MudLink>
                                                    }
                                                    @GetPlainValues(prop)
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                            <MudButton Href="@_detailPage.WikiUrl" Target="_blank" Variant="Variant.Text"
                                       Color="Color.Primary" StartIcon="@Icons.Material.Filled.OpenInNew"
                                       Size="Size.Small" Class="mt-2">
                                Wookieepedia
                            </MudButton>
                        </div>
                    }
                    else if (_selectedSystem is not null)
                    {
                        @* Fallback system detail (when no page loaded) *@
                        <div class="pa-3">
                            <MudText Typo="Typo.h6" Style="color: #e0e0f0;">@_selectedSystem.Name</MudText>
                            @if (_selectedSystem.Region is not null)
                            {
                                <MudText Typo="Typo.body2" Style="color: #aaa;">
                                    Region: <span style="color: #e0e0f0;">@_selectedSystem.Region</span>
                                </MudText>
                            }
                            @if (_selectedSystem.Sector is not null)
                            {
                                <MudText Typo="Typo.body2" Style="color: #aaa;">
                                    Sector: <span style="color: #e0e0f0;">@_selectedSystem.Sector</span>
                                </MudText>
                            }
                            <MudText Typo="Typo.body2" Style="color: #aaa;">
                                Grid: <span style="color: #e0e0f0;">@((char)('A' + _selectedSystem.Col))-@(_selectedSystem.Row + 1)</span>
                            </MudText>
                            @if (_selectedSystem.Planets.Count > 0)
                            {
                                <MudDivider Style="border-color: rgba(255,255,255,0.1);" Class="my-2" />
                                <MudText Typo="Typo.subtitle2" Style="color: #aaa;">
                                    Planets (@_selectedSystem.Planets.Count)
                                </MudText>
                                <MudStack Row="true" Class="flex-wrap gap-1 mt-1">
                                    @foreach (var planet in _selectedSystem.Planets)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                 Style="background: rgba(107, 203, 119, 0.2); color: #6bcb77;"
                                                 OnClick="() => LoadPageDetail(planet.Id)">
                                            @planet.Name
                                        </MudChip>
                                    }
                                </MudStack>
                            }
                        </div>
                    }
                </MudStack>
            </MudPaper>
        </div>
    }
</div>

@code {
    private GalaxyMapV2Overview? _overview;
    private bool _loading = true;
    private bool _d3Initialized;
    private IJSObjectReference? _module;
    private DotNetObjectReference<GalacticMapV2>? _dotNetRef;

    // Navigation state
    private MapV2System? _selectedSystem;
    private MapV2Region? _selectedRegion;
    private string _currentLevel = "overview";
    private string _currentLabel = "";
    private string _cellLabel = "";
    private string _regionLabel = "";
    private List<MudBlazor.BreadcrumbItem> _breadcrumbs = [new("Galaxy", null, disabled: false, icon: Icons.Material.Filled.Public)];

    // Filter state
    private bool _onlyWithPlanets;
    private readonly HashSet<string> _hiddenRegions = new();

    // Region hover state
    private string? _hoveredRegionName;
    private int _hoveredRegionCellCount;
    private string? _hoveredRegionColor;

    // Search state
    private string? _searchTerm;
    private bool _searching;
    private List<MapSearchResult>? _searchResults;
    private MapSearchResult? _selectedSearchResult;

    // Detail panel state
    private WikiPage? _detailPage;
    private bool _loadingDetails;

    private readonly Dictionary<int, MapV2System> _systemCache = new();

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnFilterChanged;
        await LoadOverview();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_d3Initialized && _overview is not null)
        {
            _d3Initialized = true;
            await InitializeD3();
        }
    }

    private async Task LoadOverview()
    {
        _loading = true;
        try
        {
            var continuity = GlobalFilterService.GetContinuityQueryParam();
            var url = continuity is not null
                ? $"GalaxyMap/v2/overview?continuity={continuity}"
                : "GalaxyMap/v2/overview";
            _overview = await Http.GetFromJsonAsync<GalaxyMapV2Overview>(url);
        }
        catch { _overview = null; }
        finally { _loading = false; }
    }

    private async Task InitializeD3()
    {
        if (_overview is null) return;
        _dotNetRef?.Dispose();
        _dotNetRef = DotNetObjectReference.Create(this);
        _module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/galactic-map-v2.js");
        await _module.InvokeVoidAsync("initialize", "galaxy-v2-root", _overview, _dotNetRef);
    }

    // === Filters ===

    private async Task OnPlanetFilterChanged(bool value)
    {
        _onlyWithPlanets = value;
        if (_module is not null)
            await _module.InvokeVoidAsync("setSystemFilter", value);
    }

    // === Region filter ===

    private async Task ToggleRegion(string name)
    {
        if (!_hiddenRegions.Remove(name))
            _hiddenRegions.Add(name);
        if (_module is not null)
            await _module.InvokeVoidAsync("setRegionVisibility", (object)_hiddenRegions.ToArray());
    }

    private async Task ShowAllRegions()
    {
        _hiddenRegions.Clear();
        if (_module is not null)
            await _module.InvokeVoidAsync("setRegionVisibility", (object)Array.Empty<string>());
    }

    private async Task HideAllRegions()
    {
        if (_overview is not null)
            foreach (var r in _overview.Regions)
                _hiddenRegions.Add(r.Name);
        if (_module is not null)
            await _module.InvokeVoidAsync("setRegionVisibility", (object)_hiddenRegions.ToArray());
    }

    [JSInvokable]
    public void OnRegionHovered(string name, int cellCount, string color)
    {
        _hoveredRegionName = name;
        _hoveredRegionCellCount = cellCount;
        _hoveredRegionColor = color;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnRegionUnhovered()
    {
        _hoveredRegionName = null;
        InvokeAsync(StateHasChanged);
    }

    // === Search ===

    private async Task OnSearchChanged()
    {
        if (string.IsNullOrWhiteSpace(_searchTerm) || _searchTerm.Length < 2)
        {
            _searchResults = null;
            _selectedSearchResult = null;
            return;
        }

        _searching = true;
        StateHasChanged();

        try
        {
            var continuity = GlobalFilterService.GetContinuityQueryParam();
            var url = $"GalaxyMap/search?term={Uri.EscapeDataString(_searchTerm)}";
            if (continuity is not null)
                url += $"&continuity={continuity}";
            _searchResults = await Http.GetFromJsonAsync<List<MapSearchResult>>(url);
        }
        catch { _searchResults = null; }
        finally
        {
            _searching = false;
            StateHasChanged();
        }
    }

    private void ClearSearch()
    {
        _searchTerm = null;
        _searchResults = null;
        _selectedSearchResult = null;
    }

    private async Task SelectSearchResult(MapSearchResult result)
    {
        _selectedSearchResult = result;

        // Parse grid key (e.g. "M-13") to col/row
        if (TryParseGridKey(result.GridKey, out int col, out int row))
        {
            // Navigate the D3 map to that cell
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("navigateToCell", col, row);
            }
        }

        // Load the full page detail for the infobox panel
        await LoadPageDetail(result.PageId);
    }

    private async Task LoadPageDetail(int pageId)
    {
        _loadingDetails = true;
        StateHasChanged();

        try
        {
            _detailPage = await Http.GetFromJsonAsync<WikiPage>($"Pages/{pageId}");
        }
        catch { _detailPage = null; }
        finally
        {
            _loadingDetails = false;
            StateHasChanged();
        }
    }

    private void ClearDetailPanel()
    {
        _detailPage = null;
        _selectedSystem = null;
        _selectedSearchResult = null;
    }

    // === JS Callbacks ===

    [JSInvokable]
    public async Task<GalaxyMapV2Systems?> FetchSystemsInRange(int minCol, int maxCol, int minRow, int maxRow)
    {
        try
        {
            var continuity = GlobalFilterService.GetContinuityQueryParam();
            var url = $"GalaxyMap/v2/systems?minCol={minCol}&maxCol={maxCol}&minRow={minRow}&maxRow={maxRow}";
            if (continuity is not null)
                url += $"&continuity={continuity}";
            var result = await Http.GetFromJsonAsync<GalaxyMapV2Systems>(url);

            if (result?.Systems is not null)
            {
                foreach (var sys in result.Systems)
                    _systemCache.TryAdd(sys.Id, sys);
            }
            return result;
        }
        catch { return null; }
    }

    [JSInvokable]
    public void OnSystemSelected(int systemId, string systemName)
    {
        _systemCache.TryGetValue(systemId, out _selectedSystem);
        if (_detailPage is null && _selectedSystem is not null)
        {
            // Auto-load page detail for selected system
            _ = LoadPageDetail(systemId);
        }
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnPlanetSelected(int planetId, string planetName)
    {
        InvokeAsync(() => LoadPageDetail(planetId));
    }

    [JSInvokable]
    public void OnSystemDeselected()
    {
        _selectedSystem = null;
        if (_selectedSearchResult is null)
            _detailPage = null;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnLevelChanged(string level, string label)
    {
        _currentLevel = level;
        _currentLabel = label;
        switch (level)
        {
            case "overview":
                _cellLabel = "";
                _regionLabel = "";
                _selectedRegion = null;
                break;
            case "region":
                _regionLabel = label;
                _cellLabel = "";
                _selectedRegion = _overview?.Regions.FirstOrDefault(r => r.Name == label);
                break;
            case "cell":
                _cellLabel = label;
                _regionLabel = "";
                _selectedRegion = null;
                break;
            // "system" — keep parent labels as-is
        }
        _hoveredRegionName = null; // clear hover on navigation
        UpdateBreadcrumbs();
        InvokeAsync(StateHasChanged);
    }

    // === Navigation ===

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = [new("Galaxy", null, disabled: _currentLevel == "overview", icon: Icons.Material.Filled.Public)];

        if (!string.IsNullOrEmpty(_regionLabel))
        {
            _breadcrumbs.Add(new(_regionLabel, null, disabled: _currentLevel != "system", icon: Icons.Material.Filled.Map));
        }

        if (!string.IsNullOrEmpty(_cellLabel))
        {
            _breadcrumbs.Add(new($"Grid {_cellLabel}", null, disabled: _currentLevel != "system", icon: Icons.Material.Filled.GridOn));
        }

        if (_currentLevel == "system")
        {
            _breadcrumbs.Add(new(_currentLabel, null, disabled: true, icon: Icons.Material.Filled.Star));
        }
    }

    private async Task GoBack()
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("goBack");
        }
    }

    // === Region color helpers ===

    private static readonly string[] RegionPalette =
    [
        "#4ecdc4", "#ff6f91", "#7e6fff", "#ffd93d", "#6bcb77",
        "#ff6b6b", "#a29bfe", "#fd79a8", "#fdcb6e", "#00cec9",
        "#e17055", "#0984e3", "#6c5ce7", "#00b894", "#e84393",
        "#fab1a0", "#74b9ff", "#55efc4", "#ff7675", "#dfe6e9",
    ];

    private string GetRegionColor(string regionName)
    {
        if (_overview?.Regions is not { Count: > 0 }) return "#ffffff";
        var idx = _overview.Regions.FindIndex(r => r.Name == regionName);
        return RegionPalette[(idx >= 0 ? idx : 0) % RegionPalette.Length];
    }

    private string GetRegionChipStyle(string regionName, bool isVisible)
    {
        var color = GetRegionColor(regionName);
        return isVisible
            ? $"background-color: {color}; color: #fff;"
            : $"border-color: {color}; color: {color}; opacity: 0.5;";
    }

    // === Helpers ===

    private static bool TryParseGridKey(string gridKey, out int col, out int row)
    {
        col = 0; row = 0;
        if (string.IsNullOrEmpty(gridKey)) return false;
        var parts = gridKey.Split('-');
        if (parts.Length != 2) return false;
        if (parts[0].Length != 1 || !char.IsLetter(parts[0][0])) return false;
        col = char.ToUpper(parts[0][0]) - 'A';
        return int.TryParse(parts[1], out var num) && (row = num - 1) >= 0;
    }

    private static string GetTemplateIcon(string? template)
    {
        if (template is null) return Icons.Material.Filled.Article;
        var t = template.Split(':').Last().ToLowerInvariant();
        return t switch
        {
            "planet" or "celestialbody" or "moon" => Icons.Material.Filled.Public,
            "system" => Icons.Material.Filled.Star,
            "sector" => Icons.Material.Filled.GridView,
            "region" => Icons.Material.Filled.Map,
            "nebula" => Icons.Material.Filled.Cloud,
            "traderoute" or "trade_route" or "hyperspaceroute" => Icons.Material.Filled.Route,
            "character" or "individual" => Icons.Material.Filled.Person,
            _ => Icons.Material.Filled.Article,
        };
    }

    private static bool HasInfoboxContent(InfoboxProperty prop) =>
        prop.Links.Count > 0 || prop.Values.Any(v => !string.IsNullOrWhiteSpace(v));

    private static string GetPlainValues(InfoboxProperty prop)
    {
        var linkTexts = prop.Links.Select(l => l.Content).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var plain = prop.Values.Where(v => !string.IsNullOrWhiteSpace(v) && !linkTexts.Contains(v));
        return string.Join(", ", plain);
    }

    private static string StripRevision(string url)
    {
        var idx = url.IndexOf("/revision", StringComparison.OrdinalIgnoreCase);
        return idx > 0 ? url[..idx] : url;
    }

    private static string SanitizeTemplate(string template)
    {
        var last = template.Split(':').LastOrDefault() ?? template;
        return last.Replace("_", " ");
    }

    // === Lifecycle ===

    private async void OnFilterChanged()
    {
        await InvokeAsync(async () =>
        {
            _systemCache.Clear();
            _selectedSystem = null;
            _selectedRegion = null;
            _detailPage = null;
            _searchResults = null;
            _selectedSearchResult = null;
            _currentLevel = "overview";
            _currentLabel = "";
            _cellLabel = "";
            _regionLabel = "";
            _hoveredRegionName = null;
            _hiddenRegions.Clear();
            UpdateBreadcrumbs();
            _d3Initialized = false;

            if (_module is not null)
            {
                try { await _module.InvokeVoidAsync("dispose"); } catch { }
            }

            await LoadOverview();
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        GlobalFilterService.OnChange -= OnFilterChanged;
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("dispose"); } catch { }
            await _module.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }
}
