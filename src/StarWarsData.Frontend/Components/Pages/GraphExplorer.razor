@page "/graph-explorer"
@page "/graph-explorer/{PageId:int}"
@using WikiPage = StarWarsData.Models.Entities.Page
@using StarWarsData.Models.Entities
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject GlobalFilterService GlobalFilterService
@implements IAsyncDisposable

<PageTitle>Graph Explorer</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">

    <!-- Single table with search + type filter in toolbar -->
    <MudTable T="EntitySearchDto" ServerData="LoadBrowseData" @ref="_browseTable" Dense="true"
              Hover="true" Bordered="false" Striped="true" Elevation="1"
              RowClass="cursor-pointer" OnRowClick="OnBrowseRowClick"
              RowClassFunc="@((item, _) => item.Id == _selectedEntityId ? "mud-theme-primary" : "")"
              Loading="_browseLoading" LoadingProgressColor="Color.Primary" Class="mb-4">
        <ToolBarContent>
            <MudTextField T="string" @bind-Value="_search" Placeholder="Search entities..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="OnSearchChanged"
                          Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="max-width:350px;" Class="mr-4" />
            <MudSelect T="string" @bind-Value="_selectedType" Variant="Variant.Outlined" Margin="Margin.Dense"
                       @bind-Value:after="OnTypeFilterChanged" Style="max-width:200px;" Clearable="true"
                       Placeholder="All Types">
                @foreach (var type in _entityTypes)
                {
                    <MudSelectItem T="string" Value="@type">@FormatTypeName(type)</MudSelectItem>
                }
            </MudSelect>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Continuity</MudTh>
            <MudTh Style="width:80px">ID</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@context.Type</MudChip>
            </MudTd>
            <MudTd DataLabel="Continuity">
                @if (context.Continuity == "Canon")
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Style="font-size:10px;">Canon</MudChip>
                }
                else if (context.Continuity == "Legends")
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary" Style="font-size:10px;">Legends</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="ID">@context.Id</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 20, 50 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true">
                No entities found.
            </MudAlert>
        </NoRecordsContent>
    </MudTable>

    <!-- Selected Entity: Labels & Controls -->
    @if (_selectedEntityId > 0)
    {
        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudText Typo="Typo.h6">@_selectedEntityName</MudText>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Depth:</MudText>
                    <MudSlider T="int" @bind-Value="_maxDepth" Min="1" Max="4" Step="1"
                               Style="width:120px" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@_maxDepth</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Hub"
                               OnClick="LoadGraph" Disabled="@(_graphLoading || _selectedLabels.Count == 0)"
                               Size="Size.Medium">
                        Show Graph
                    </MudButton>
                </MudStack>
            </MudStack>

            @if (_loadingLabels)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-2" />
            }
            else if (_availableLabels is { Count: > 0 })
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">
                    Available relationship labels (select which to traverse):
                </MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var label in _availableLabels)
                    {
                        var isSelected = _selectedLabels.Contains(label);
                        <MudChip T="string"
                                 Color="@(isSelected ? Color.Info : Color.Default)"
                                 Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                 OnClick="@(() => ToggleLabel(label))"
                                 Size="Size.Small">
                            @FormatLabel(label)
                        </MudChip>
                    }
                </MudStack>
                <MudStack Row="true" Spacing="2" Class="mt-2" AlignItems="AlignItems.Center">
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SelectAllLabels">Select All</MudButton>
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearLabels">Clear</MudButton>
                    @if (_selectedLabels.Count == 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">
                            Select at least one label to explore the graph
                        </MudText>
                    }
                </MudStack>
            }
            else if (!_loadingLabels)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                    No relationship labels found for this entity. The graph crawler may not have processed this page yet.
                    Try running a batch from the <MudLink Href="/graph-builder">Graph Builder</MudLink>.
                </MudAlert>
            }
        </MudPaper>
    }

    <!-- Graph -->
    @if (_graphLoading)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
            <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">Loading relationship graph...</MudText>
        </MudStack>
    }
    else if (_graphError is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_graphError</MudAlert>
    }

    @if (_hasGraph)
    {
        @* Navigation breadcrumbs *@
        @if (_history.Count > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                               Color="Color.Secondary" OnClick="NavigateBack" title="Back (Backspace)" />
                @foreach (var crumb in _history)
                {
                    var c = crumb;
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                             OnClick="@(() => SelectEntity(c.Id, c.Name))">@c.Name</MudChip>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">›</MudText>
                }
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">@_selectedEntityName</MudChip>
            </MudStack>
        }

        @if (_hasTemporalData)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Style="color:rgba(255,255,255,0.5);" />
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5);">Year</MudText>
                <MudSlider T="int" Value="_selectedYear" ValueChanged="OnYearChanged"
                           Min="_minYear" Max="_maxYear" Step="1"
                           Style="max-width:400px;" Color="Color.Warning" />
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">
                    @FormatYear(_selectedYear)
                </MudChip>
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                           OnClick="ClearYearFilter">Show All</MudButton>
            </MudStack>
        }

        <MudGrid Spacing="2" Class="mb-4">
            <MudItem xs="12" md="@(_selectedNodePage is not null ? 9 : 12)">
                <MudPaper Outlined="true" Style="@($"overflow:hidden; border-radius:8px; position:relative; {(_fullscreen ? "position:fixed; top:0; left:0; right:0; bottom:0; z-index:9999; border-radius:0;" : "")}")">
                    @* Controls overlay *@
                    <div style="position:absolute; top:8px; right:8px; z-index:10; display:flex; gap:4px;">
                        <MudIconButton Icon="@Icons.Material.Filled.ZoomIn" Size="Size.Small"
                                       Color="Color.Default" OnClick="ZoomIn"
                                       Style="background:rgba(30,30,56,0.8); color:#e0e0f0;" />
                        <MudIconButton Icon="@Icons.Material.Filled.ZoomOut" Size="Size.Small"
                                       Color="Color.Default" OnClick="ZoomOut"
                                       Style="background:rgba(30,30,56,0.8); color:#e0e0f0;" />
                        <MudIconButton Icon="@Icons.Material.Filled.FitScreen" Size="Size.Small"
                                       Color="Color.Default" OnClick="FitToScreen"
                                       Style="background:rgba(30,30,56,0.8); color:#e0e0f0;" />
                        <MudIconButton Icon="@(_fullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                       Size="Size.Small" Color="Color.Default" OnClick="ToggleFullscreen"
                                       Style="background:rgba(30,30,56,0.8); color:#e0e0f0;" />
                    </div>
                    @* Keyboard hints *@
                    <div style="position:absolute; bottom:8px; left:8px; z-index:10;">
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4); font-size:13px;">
                            Double-click: expand node &bull; Backspace: go back &bull; F: fullscreen &bull; Esc: close/exit &bull; Scroll: zoom
                        </MudText>
                    </div>
                    <div id="@_containerId"
                         style="@($"width:100%; background:#16162e; {(_fullscreen ? "height:100vh;" : "height:700px;")}")"
                         >
                    </div>

                    @* Stats overlay (bottom-right) *@
                    @if (_graphStats is not null)
                    {
                        <div style="position:absolute; bottom:8px; right:8px; z-index:10; display:flex; gap:8px;">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                                     Style="background:rgba(30,30,56,0.8);">
                                @_graphStats.Value.nodeCount nodes
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text"
                                     Style="background:rgba(30,30,56,0.8);">
                                @_graphStats.Value.edgeCount edges
                            </MudChip>
                        </div>
                    }

                    @* Info panel overlay (right side, inside the graph container) *@
                    @if (_loadingNodeDetails)
                    {
                        <div style="position:absolute; top:0; right:0; width:320px; height:100%; z-index:20; background:var(--mud-palette-surface); border-left:1px solid var(--mud-palette-lines-default); overflow-y:auto;">
                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:100%">
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading details...</MudText>
                            </MudStack>
                        </div>
                    }
                    else if (_selectedNodePage is not null)
                    {
                        <div style="position:absolute; top:0; right:0; width:320px; height:100%; z-index:20; background:var(--mud-palette-surface); border-left:1px solid var(--mud-palette-lines-default); overflow-y:auto;">
                            <MudCard Elevation="0">
                                @if (_selectedNodePage.Infobox?.ImageUrl is not null)
                                {
                                    <MudCardMedia Image="@StripRevision(_selectedNodePage.Infobox.ImageUrl)" Height="180" />
                                }
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">@_selectedNodePage.Title</MudText>
                                        @if (_selectedNodePage.Infobox?.Template is not null)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @SanitizeTemplate(_selectedNodePage.Infobox.Template)
                                            </MudText>
                                        }
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                       OnClick="CloseNodePanel" />
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent>
                                    @if (_selectedNodePage.Infobox?.Data is not null)
                                    {
                                        <MudSimpleTable Dense="true" Bordered="true" Striped="true" Style="overflow-x:auto; font-size:12px;">
                                            <tbody>
                                                @foreach (var prop in _selectedNodePage.Infobox.Data.Where(HasInfoboxContent))
                                                {
                                                    <tr>
                                                        <td style="font-weight:600; white-space:nowrap; width:1%; padding:4px 8px; vertical-align:top;">
                                                            @prop.Label
                                                        </td>
                                                        <td style="padding:4px 8px;">
                                                            @foreach (var link in prop.Links)
                                                            {
                                                                <MudLink Href="@link.Href" Underline="Underline.Always" Class="mr-1" Target="_blank">@link.Content</MudLink>
                                                            }
                                                            @GetPlainValues(prop)
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    }
                                </MudCardContent>
                                <MudCardActions>
                                    @if (_selectedNodePage.WikiUrl is not null)
                                    {
                                        <MudButton Href="@_selectedNodePage.WikiUrl" Target="_blank" Variant="Variant.Text" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.OpenInNew" Size="Size.Small">
                                            Wookieepedia
                                        </MudButton>
                                    }
                                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Hub"
                                               OnClick="@(() => SelectEntityWithHistory(_selectedNodeId, _selectedNodeName!))">
                                        Explore Graph
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter] public int? PageId { get; set; }

    // Search state
    private string _search = "";
    private string _selectedType = "";
    private List<string> _entityTypes = [];

    // Browse state
    private MudTable<EntitySearchDto>? _browseTable;
    private bool _browseLoading;

    // Selected entity state
    private int _selectedEntityId;
    private string _selectedEntityName = "";
    private List<string>? _availableLabels;
    private HashSet<string> _selectedLabels = new();
    private bool _loadingLabels;
    private int _maxDepth = 2;

    // Graph state
    private bool _graphLoading;
    private bool _hasGraph;
    private string? _graphError;
    private (int nodeCount, int edgeCount)? _graphStats;
    private IJSObjectReference? _jsModule;
    private readonly string _containerId = $"d3-explorer-{Guid.NewGuid():N}";

    // Node info panel state
    private DotNetObjectReference<GraphExplorer>? _dotnetRef;
    private int _selectedNodeId;
    private string? _selectedNodeName;
    private WikiPage? _selectedNodePage;
    private bool _loadingNodeDetails;

    // Navigation & fullscreen
    private List<(int Id, string Name)> _history = [];
    private bool _fullscreen;

    // Temporal slider
    private bool _hasTemporalData;
    private int _minYear;
    private int _maxYear;
    private int _selectedYear;
    private bool _yearFilterActive;

    private HttpClient Api => HttpClientFactory.CreateClient("StarWarsData");

    private void AppendGlobalFilters(System.Collections.Specialized.NameValueCollection query)
    {
        var c = GlobalFilterService.GetContinuityQueryParam();
        if (!string.IsNullOrEmpty(c))
            query["continuity"] = c;
    }

    private string BuildQueryString(params (string key, string value)[] parameters)
    {
        var query = System.Web.HttpUtility.ParseQueryString(string.Empty);
        foreach (var (key, value) in parameters)
            query[key] = value;
        AppendGlobalFilters(query);
        return query.ToString()!;
    }

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnGlobalFilterChanged;
        await LoadEntityTypes();
    }

    private async Task LoadEntityTypes()
    {
        try
        {
            var types = await Api.GetFromJsonAsync<List<string>>("api/RelationshipGraph/entity-types");
            if (types is { Count: > 0 })
            {
                _entityTypes = types;
                if (!_entityTypes.Contains(_selectedType))
                    _selectedType = _entityTypes[0];
            }
        }
        catch
        {
            // Fallback to default if API is unavailable
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (PageId.HasValue && PageId.Value != _selectedEntityId)
        {
            _selectedEntityId = PageId.Value;
            _selectedEntityName = $"Entity #{PageId.Value}";
            await LoadLabels();
        }
    }

    private async void OnGlobalFilterChanged()
    {
        await InvokeAsync(async () =>
        {
            if (!string.IsNullOrWhiteSpace(_search))
                await OnSearchChanged(_search);
            else
                _browseTable?.ReloadServerData();

            if (_selectedEntityId > 0)
            {
                _hasGraph = false;
                _graphStats = null;
                await LoadLabels();
            }

            StateHasChanged();
        });
    }

    // --- Server-side pagination for browse/search table ---

    private async Task<TableData<EntitySearchDto>> LoadBrowseData(TableState state, CancellationToken ct)
    {
        _browseLoading = true;
        try
        {
            var page = state.Page + 1;
            var parameters = new List<(string, string)>
            {
                ("page", page.ToString()),
                ("pageSize", state.PageSize.ToString()),
            };
            if (!string.IsNullOrWhiteSpace(_selectedType))
                parameters.Add(("type", _selectedType));
            if (!string.IsNullOrWhiteSpace(_search))
                parameters.Add(("q", _search));

            var qs = BuildQueryString([.. parameters]);
            var result = await Api.GetFromJsonAsync<BrowseEntitiesResult>(
                $"api/RelationshipGraph/browse?{qs}", ct);

            return new TableData<EntitySearchDto>
            {
                Items = result?.Items ?? [],
                TotalItems = (int)(result?.Total ?? 0),
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load entities: {ex.Message}", Severity.Error);
            return new TableData<EntitySearchDto> { Items = [], TotalItems = 0 };
        }
        finally
        {
            _browseLoading = false;
        }
    }

    private async Task OnBrowseRowClick(TableRowClickEventArgs<EntitySearchDto> args)
    {
        if (args.Item is not null)
            await SelectEntity(args.Item.Id, args.Item.Name);
    }

    // --- Search ---

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        _browseTable?.ReloadServerData();
    }

    private Task OnTypeFilterChanged()
    {
        _browseTable?.ReloadServerData();
        return Task.CompletedTask;
    }

    private async Task SelectEntity(int id, string name)
    {
        _selectedEntityId = id;
        _selectedEntityName = name;
        _hasGraph = false;
        _graphError = null;
        _selectedLabels.Clear();

        Navigation.NavigateTo($"/graph-explorer/{id}", replace: true);

        await LoadLabels();
    }

    private async Task LoadLabels()
    {
        _loadingLabels = true;
        _availableLabels = null;
        StateHasChanged();

        try
        {
            var labelsQs = BuildQueryString();
            var labelsUrl = $"api/RelationshipGraph/labels/{_selectedEntityId}";
            if (!string.IsNullOrEmpty(labelsQs))
                labelsUrl += $"?{labelsQs}";
            _availableLabels = await Api.GetFromJsonAsync<List<string>>(labelsUrl);
            _selectedLabels = new HashSet<string>(_availableLabels ?? []);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load labels: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingLabels = false;
        }

        // Auto-load graph with all labels selected
        if (_selectedLabels.Count > 0)
            await LoadGraph();
    }

    private void ToggleLabel(string label)
    {
        if (!_selectedLabels.Remove(label))
            _selectedLabels.Add(label);
    }

    private void SelectAllLabels()
    {
        if (_availableLabels is not null)
            _selectedLabels = new HashSet<string>(_availableLabels);
    }

    private void ClearLabels() => _selectedLabels.Clear();

    private async Task LoadGraph()
    {
        if (_selectedEntityId <= 0) return;

        _graphLoading = true;
        _graphError = null;
        _hasGraph = false;
        _graphStats = null;
        StateHasChanged();

        try
        {
            var labelsParam = string.Join(",", _selectedLabels);
            var queryParams = new List<(string, string)> { ("maxDepth", _maxDepth.ToString()) };
            if (!string.IsNullOrEmpty(labelsParam))
                queryParams.Add(("labels", labelsParam));
            var url = $"api/RelationshipGraph/query/{_selectedEntityId}?{BuildQueryString([.. queryParams])}";

            var result = await Api.GetFromJsonAsync<RelationshipGraphResult>(url);

            if (result is null || result.Nodes.Count == 0)
            {
                _graphError = "No graph data found. The crawler may not have processed this entity yet.";
                return;
            }

            _hasGraph = true;
            _graphStats = (result.Nodes.Count, result.Edges.Count);
            _graphLoading = false;
            StateHasChanged();

            await Task.Delay(50);
            await RenderD3Graph(result);
        }
        catch (Exception ex)
        {
            _graphError = $"Failed to load graph: {ex.Message}";
        }
        finally
        {
            _graphLoading = false;
        }
    }

    private async Task RenderD3Graph(RelationshipGraphResult result)
    {
        _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/d3-graph.js");

        var nodes = result.Nodes.Select(n => new
        {
            id = n.Id,
            name = n.Name,
            type = n.Type,
            imageUrl = n.ImageUrl ?? "",
            born = "",
            died = "",
        }).ToArray();

        var edges = result.Edges.Select(e => new
        {
            fromId = e.FromId,
            toId = e.ToId,
            label = e.Label,
            weight = e.Weight > 0 ? e.Weight : 0.5,
            fromYear = e.FromYear,
            toYear = e.ToYear,
        }).ToArray();

        // Compute temporal range for slider
        var temporalEdges = result.Edges.Where(e => e.FromYear.HasValue).ToList();
        _hasTemporalData = temporalEdges.Count > 0;
        if (_hasTemporalData)
        {
            _minYear = temporalEdges.Min(e => e.FromYear!.Value);
            _maxYear = temporalEdges.Max(e => e.ToYear ?? e.FromYear!.Value);
            if (_minYear == _maxYear) { _minYear -= 10; _maxYear += 10; }
            _selectedYear = _maxYear;
            _yearFilterActive = false;
        }

        var data = new { nodes, edges, rootId = result.RootId };

        _dotnetRef?.Dispose();
        _dotnetRef = DotNetObjectReference.Create(this);

        await _jsModule.InvokeVoidAsync("renderForceGraph", _containerId, data, _dotnetRef);
        await _jsModule.InvokeVoidAsync("registerKeyboardShortcuts", _dotnetRef);
    }

    [JSInvokable]
    public async Task OnNodeClicked(int id, string name, string type)
    {
        _selectedNodeId = id;
        _selectedNodeName = name;
        _selectedNodePage = null;
        _loadingNodeDetails = true;
        StateHasChanged();

        try
        {
            _selectedNodePage = await Api.GetFromJsonAsync<WikiPage>($"Pages/{id}");
        }
        catch
        {
            _selectedNodePage = null;
        }
        finally
        {
            _loadingNodeDetails = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnNodeExpand(int id, string name)
    {
        // Push current entity to history before expanding
        if (_selectedEntityId > 0 && _selectedEntityId != id)
            _history.Add((_selectedEntityId, _selectedEntityName));
        _selectedEntityId = id;
        _selectedEntityName = name;

        // Load this node's graph data and expand in-place (no page refresh)
        if (_jsModule is null) return;

        try
        {
            var url = $"api/RelationshipGraph/query/{id}?maxDepth=1";
            var result = await Api.GetFromJsonAsync<RelationshipGraphResult>(url);
            if (result is null || result.Nodes.Count == 0) return;

            var data = new
            {
                nodes = result.Nodes.Select(n => new
                {
                    id = n.Id, name = n.Name, type = n.Type,
                    imageUrl = n.ImageUrl ?? "",
                }).ToArray(),
                edges = result.Edges.Select(e => new
                {
                    fromId = e.FromId, toId = e.ToId,
                    label = e.Label, weight = e.Weight > 0 ? e.Weight : 0.5,
                }).ToArray(),
                rootId = id,
            };

            await _jsModule.InvokeVoidAsync("expandNode", data);

            // Update stats
            var stats = await _jsModule.InvokeAsync<GraphStatsDto>("getStats");
            _graphStats = (stats.Nodes, stats.Edges);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to expand node: {ex.Message}", Severity.Error);
        }
    }

    record GraphStatsDto(int Nodes, int Edges);

    private void CloseNodePanel()
    {
        _selectedNodePage = null;
        _selectedNodeName = null;
        _selectedNodeId = 0;
        _loadingNodeDetails = false;
    }

    // ── Navigation history ──

    private async Task NavigateBack()
    {
        if (_history.Count == 0 || _jsModule is null) return;

        var prev = _history[^1];
        _history.RemoveAt(_history.Count - 1);

        // Re-focus the previous node in the existing graph (don't reload)
        try
        {
            var url = $"api/RelationshipGraph/query/{prev.Id}?maxDepth=1";
            var result = await Api.GetFromJsonAsync<RelationshipGraphResult>(url);
            if (result is not null)
            {
                var data = new
                {
                    nodes = result.Nodes.Select(n => new
                    {
                        id = n.Id, name = n.Name, type = n.Type,
                        imageUrl = n.ImageUrl ?? "",
                    }).ToArray(),
                    edges = result.Edges.Select(e => new
                    {
                        fromId = e.FromId, toId = e.ToId,
                        label = e.Label, weight = e.Weight > 0 ? e.Weight : 0.5,
                    }).ToArray(),
                    rootId = prev.Id,
                };
                await _jsModule.InvokeVoidAsync("expandNode", data);

                var stats = await _jsModule.InvokeAsync<GraphStatsDto>("getStats");
                _graphStats = (stats.Nodes, stats.Edges);
            }
        }
        catch { }

        _selectedEntityName = prev.Name;
        CloseNodePanel();
    }

    // Override SelectEntity to push history
    private async Task SelectEntityWithHistory(int id, string name)
    {
        if (_selectedEntityId > 0 && _selectedEntityId != id)
            _history.Add((_selectedEntityId, _selectedEntityName));

        await SelectEntity(id, name);
    }

    // ── Fullscreen & controls ──

    private void ToggleFullscreen()
    {
        _fullscreen = !_fullscreen;
    }

    private async Task ZoomIn()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("zoomIn");
    }

    private async Task ZoomOut()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("zoomOut");
    }

    private async Task FitToScreen()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("fitToScreen");
    }

    [JSInvokable]
    public void OnKeyAction(string action)
    {
        InvokeAsync(async () =>
        {
            switch (action)
            {
                case "back":
                    await NavigateBack();
                    break;
                case "fullscreen":
                    ToggleFullscreen();
                    break;
                case "escape":
                    if (_fullscreen) ToggleFullscreen();
                    else CloseNodePanel();
                    break;
            }
            StateHasChanged();
        });
    }

    private async Task OnYearChanged(int value)
    {
        _selectedYear = value;
        _yearFilterActive = true;
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("filterByYear", _selectedYear);
    }

    private async Task ClearYearFilter()
    {
        _yearFilterActive = false;
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("filterByYear", (int?)null);
    }

    private static string FormatYear(int y) => y <= 0 ? $"{Math.Abs(y)} BBY" : $"{y} ABY";

    private static string FormatLabel(string label) =>
        System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(
            label.Replace("_", " "));

    private static string FormatTypeName(string type) => type switch
    {
        "CelestialBody" => "Planet / Body",
        _ => System.Text.RegularExpressions.Regex.Replace(type, "(?<!^)([A-Z])", " $1"),
    };

    private static string StripRevision(string url)
    {
        var idx = url.IndexOf("/revision", StringComparison.OrdinalIgnoreCase);
        return idx > 0 ? url[..idx] : url;
    }

    private static string SanitizeTemplate(string template)
    {
        var last = template.Split(':').LastOrDefault() ?? template;
        return last.Replace("_", " ");
    }

    private static bool HasInfoboxContent(InfoboxProperty prop) =>
        prop.Links.Count > 0 || prop.Values.Any(v => !string.IsNullOrWhiteSpace(v));

    private static string GetPlainValues(InfoboxProperty prop)
    {
        var linkTexts = prop.Links.Select(l => l.Content).ToHashSet(StringComparer.OrdinalIgnoreCase);
        return string.Join(", ", prop.Values.Where(v => !string.IsNullOrWhiteSpace(v) && !linkTexts.Contains(v)));
    }

    public async ValueTask DisposeAsync()
    {
        GlobalFilterService.OnChange -= OnGlobalFilterChanged;
        _dotnetRef?.Dispose();

        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("destroyGraph", _containerId);
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }
}
