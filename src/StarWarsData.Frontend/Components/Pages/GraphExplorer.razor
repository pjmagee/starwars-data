@page "/graph-explorer"
@page "/graph-explorer/{PageId:int}"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject GlobalFilterService GlobalFilterService
@implements IDisposable

<PageTitle>Graph Explorer</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-4">

    <!-- Entity browse table -->
    <MudTable T="EntitySearchDto" ServerData="LoadBrowseData" @ref="_browseTable" Dense="true"
              Hover="true" Bordered="false" Striped="true" Elevation="1"
              RowClass="cursor-pointer" OnRowClick="OnBrowseRowClick"
              RowClassFunc="@((item, _) => item.Id == _selectedEntityId ? "mud-theme-primary" : "")"
              Loading="_browseLoading" LoadingProgressColor="Color.Primary" Class="mb-4">
        <ToolBarContent>
            <MudTextField T="string" @bind-Value="_search" Placeholder="Search entities..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="OnSearchChanged"
                          Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="max-width:350px;" Class="mr-4" />
            <MudSelect T="string" @bind-Value="_selectedType" Variant="Variant.Outlined" Margin="Margin.Dense"
                       @bind-Value:after="OnTypeFilterChanged" Style="max-width:200px;" Clearable="true"
                       Placeholder="All Types">
                @foreach (var type in _entityTypes)
                {
                    <MudSelectItem T="string" Value="@type">@FormatTypeName(type)</MudSelectItem>
                }
            </MudSelect>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Continuity</MudTh>
            <MudTh Style="width:80px">ID</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@context.Type</MudChip>
            </MudTd>
            <MudTd DataLabel="Continuity">
                @if (context.Continuity == "Canon")
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Style="font-size:10px;">Canon</MudChip>
                }
                else if (context.Continuity == "Legends")
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary" Style="font-size:10px;">Legends</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="ID">@context.Id</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 20, 50 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true">
                No entities found.
            </MudAlert>
        </NoRecordsContent>
    </MudTable>

    <!-- Selected entity header -->
    @if (_selectedEntityId > 0)
    {
        <MudPaper Class="pa-3 mb-4" Outlined="true">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h6">@_selectedEntityName</MudText>
                @if (_loadingLabels)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" />
                }
                else if (_availableLabels is not { Count: > 0 })
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning">
                        No relationship labels found for this entity.
                    </MudText>
                }
            </MudStack>
        </MudPaper>
    }

    <!-- Graph loading / error -->
    @if (_graphLoading)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
            <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">Loading relationship graph...</MudText>
        </MudStack>
    }
    else if (_graphError is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_graphError</MudAlert>
    }

    <!-- Graph (shared component) -->
    @if (_graphData is not null)
    {
        <GraphViewer @ref="_graphViewer"
                     GraphData="_graphData"
                     Height="700"
                     EnableKeyboardShortcuts="true"
                     Labels="_availableLabels"
                     EnabledLabels="_selectedLabels"
                     OnLabelToggled="OnLabelToggled"
                     MaxDepth="_maxDepth"
                     OnDepthChanged="OnDepthChanged"
                     History="_history"
                     CurrentEntityName="_selectedEntityName"
                     OnNavigateBack="NavigateBack"
                     OnBreadcrumbClicked="OnBreadcrumbClicked"
                     Stats="_graphStats"
                     OnNodeExpandRequested="OnNodeExpand" />
    }
</MudContainer>

@code {
    [Parameter] public int? PageId { get; set; }

    // Search state
    private string _search = "";
    private string _selectedType = "";
    private List<string> _entityTypes = [];

    // Browse state
    private MudTable<EntitySearchDto>? _browseTable;
    private bool _browseLoading;

    // Selected entity state
    private int _selectedEntityId;
    private string _selectedEntityName = "";
    private List<string>? _availableLabels;
    private HashSet<string> _selectedLabels = new();
    private bool _loadingLabels;
    private int _maxDepth = 2;

    // Graph state
    private GraphViewer? _graphViewer;
    private RelationshipGraphResult? _graphData;
    private bool _graphLoading;
    private string? _graphError;
    private (int nodes, int edges)? _graphStats;

    // Navigation
    private List<(int Id, string Name)> _history = [];

    private HttpClient Api => HttpClientFactory.CreateClient("StarWarsData");

    private void AppendGlobalFilters(System.Collections.Specialized.NameValueCollection query)
    {
        var c = GlobalFilterService.GetContinuityQueryParam();
        if (!string.IsNullOrEmpty(c))
            query["continuity"] = c;
    }

    private string BuildQueryString(params (string key, string value)[] parameters)
    {
        var query = System.Web.HttpUtility.ParseQueryString(string.Empty);
        foreach (var (key, value) in parameters)
            query[key] = value;
        AppendGlobalFilters(query);
        return query.ToString()!;
    }

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnGlobalFilterChanged;
        await LoadEntityTypes();
    }

    private async Task LoadEntityTypes()
    {
        try
        {
            var types = await Api.GetFromJsonAsync<List<string>>("api/RelationshipGraph/entity-types");
            if (types is { Count: > 0 })
            {
                _entityTypes = types;
                if (!_entityTypes.Contains(_selectedType))
                    _selectedType = _entityTypes[0];
            }
        }
        catch { }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (PageId.HasValue && PageId.Value != _selectedEntityId)
        {
            _selectedEntityId = PageId.Value;
            _selectedEntityName = $"Entity #{PageId.Value}";
            await LoadLabels();
        }
    }

    private async void OnGlobalFilterChanged()
    {
        await InvokeAsync(async () =>
        {
            if (!string.IsNullOrWhiteSpace(_search))
                await OnSearchChanged(_search);
            else
                _browseTable?.ReloadServerData();

            if (_selectedEntityId > 0)
            {
                _graphData = null;
                _graphStats = null;
                await LoadLabels();
            }

            StateHasChanged();
        });
    }

    // ── Server-side pagination for browse/search table ──

    private async Task<TableData<EntitySearchDto>> LoadBrowseData(TableState state, CancellationToken ct)
    {
        _browseLoading = true;
        try
        {
            var page = state.Page + 1;
            var parameters = new List<(string, string)>
            {
                ("page", page.ToString()),
                ("pageSize", state.PageSize.ToString()),
            };
            if (!string.IsNullOrWhiteSpace(_selectedType))
                parameters.Add(("type", _selectedType));
            if (!string.IsNullOrWhiteSpace(_search))
                parameters.Add(("q", _search));

            var qs = BuildQueryString([.. parameters]);
            var result = await Api.GetFromJsonAsync<BrowseEntitiesResult>(
                $"api/RelationshipGraph/browse?{qs}", ct);

            return new TableData<EntitySearchDto>
            {
                Items = result?.Items ?? [],
                TotalItems = (int)(result?.Total ?? 0),
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load entities: {ex.Message}", Severity.Error);
            return new TableData<EntitySearchDto> { Items = [], TotalItems = 0 };
        }
        finally
        {
            _browseLoading = false;
        }
    }

    private async Task OnBrowseRowClick(TableRowClickEventArgs<EntitySearchDto> args)
    {
        if (args.Item is not null)
            await SelectEntity(args.Item.Id, args.Item.Name);
    }

    private Task OnSearchChanged(string value)
    {
        _search = value;
        _browseTable?.ReloadServerData();
        return Task.CompletedTask;
    }

    private Task OnTypeFilterChanged()
    {
        _browseTable?.ReloadServerData();
        return Task.CompletedTask;
    }

    // ── Entity selection & label discovery ──

    private async Task SelectEntity(int id, string name)
    {
        _selectedEntityId = id;
        _selectedEntityName = name;
        _graphData = null;
        _graphError = null;
        _graphStats = null;
        _selectedLabels.Clear();

        Navigation.NavigateTo($"/graph-explorer/{id}", replace: true);

        await LoadLabels();
    }

    private async Task LoadLabels()
    {
        _loadingLabels = true;
        _availableLabels = null;
        StateHasChanged();

        try
        {
            var labelsQs = BuildQueryString();
            var labelsUrl = $"api/RelationshipGraph/labels/{_selectedEntityId}";
            if (!string.IsNullOrEmpty(labelsQs))
                labelsUrl += $"?{labelsQs}";
            _availableLabels = await Api.GetFromJsonAsync<List<string>>(labelsUrl);
            _selectedLabels = new HashSet<string>(_availableLabels ?? []);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load labels: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingLabels = false;
        }

        if (_selectedLabels.Count > 0)
            await LoadGraph();
    }

    // ── Graph loading ──

    private async Task LoadGraph()
    {
        if (_selectedEntityId <= 0) return;

        _graphLoading = true;
        _graphError = null;
        _graphData = null;
        _graphStats = null;
        StateHasChanged();

        try
        {
            var labelsParam = string.Join(",", _selectedLabels);
            var queryParams = new List<(string, string)> { ("maxDepth", _maxDepth.ToString()) };
            if (!string.IsNullOrEmpty(labelsParam))
                queryParams.Add(("labels", labelsParam));
            var url = $"api/RelationshipGraph/query/{_selectedEntityId}?{BuildQueryString([.. queryParams])}";

            var result = await Api.GetFromJsonAsync<RelationshipGraphResult>(url);

            if (result is null || result.Nodes.Count == 0)
            {
                _graphError = "No graph data found. The crawler may not have processed this entity yet.";
                return;
            }

            _graphData = result;
            _graphStats = (result.Nodes.Count, result.Edges.Count);
        }
        catch (Exception ex)
        {
            _graphError = $"Failed to load graph: {ex.Message}";
        }
        finally
        {
            _graphLoading = false;
        }
    }

    // ── GraphViewer callbacks ──

    private async Task OnLabelToggled(string label)
    {
        if (!_selectedLabels.Remove(label))
            _selectedLabels.Add(label);
        await LoadGraph();
    }

    private async Task OnDepthChanged(int value)
    {
        _maxDepth = value;
        await LoadGraph();
    }

    private async Task OnNodeExpand((int id, string name) entity)
    {
        if (_selectedEntityId > 0 && _selectedEntityId != entity.id)
            _history.Add((_selectedEntityId, _selectedEntityName));
        _selectedEntityId = entity.id;
        _selectedEntityName = entity.name;

        try
        {
            var url = $"api/RelationshipGraph/query/{entity.id}?maxDepth=1";
            var result = await Api.GetFromJsonAsync<RelationshipGraphResult>(url);
            if (result is null || result.Nodes.Count == 0 || _graphViewer is null) return;

            var stats = await _graphViewer.ExpandWithDataAsync(result, entity.id);
            _graphStats = stats;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to expand node: {ex.Message}", Severity.Error);
        }
    }

    private async Task NavigateBack()
    {
        if (_history.Count == 0) return;

        var prev = _history[^1];
        _history.RemoveAt(_history.Count - 1);

        try
        {
            var url = $"api/RelationshipGraph/query/{prev.Id}?maxDepth=1";
            var result = await Api.GetFromJsonAsync<RelationshipGraphResult>(url);
            if (result is not null && _graphViewer is not null)
            {
                var stats = await _graphViewer.ExpandWithDataAsync(result, prev.Id);
                _graphStats = stats;
            }
        }
        catch { }

        _selectedEntityId = prev.Id;
        _selectedEntityName = prev.Name;
    }

    private async Task OnBreadcrumbClicked((int Id, string Name) crumb)
    {
        var idx = _history.FindIndex(h => h.Id == crumb.Id);
        if (idx >= 0)
            _history.RemoveRange(idx, _history.Count - idx);

        _selectedEntityId = crumb.Id;
        _selectedEntityName = crumb.Name;
        await LoadGraph();
    }

    // ── Helpers ──

    private static string FormatTypeName(string type) => type switch
    {
        "CelestialBody" => "Planet / Body",
        _ => System.Text.RegularExpressions.Regex.Replace(type, "(?<!^)([A-Z])", " $1"),
    };

    public void Dispose()
    {
        GlobalFilterService.OnChange -= OnGlobalFilterChanged;
    }
}
