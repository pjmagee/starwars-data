@page "/graph-explorer"
@page "/graph-explorer/{PageId:int}"
@using WikiPage = StarWarsData.Models.Entities.Page
@using StarWarsData.Models.Entities
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject GlobalFilterService GlobalFilterService
@implements IAsyncDisposable

<PageTitle>Graph Explorer</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-8 px-4">
    <MudText Typo="Typo.h3" Class="mb-2">Graph Explorer</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Explore the persistent relationship graph built by the LLM analyst agent.
    </MudText>

    <!-- Search Bar -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="8" md="9">
            <MudTextField T="string" @bind-Value="_search" Label="Search entities" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="OnSearchChanged"
                          Placeholder="e.g. Jabba, Luke Skywalker, Coruscant, Rebel Alliance..." />
        </MudItem>
        <MudItem xs="12" sm="4" md="3">
            <MudSelect T="string" @bind-Value="_selectedType" Label="Entity Type" Variant="Variant.Outlined"
                       @bind-Value:after="OnTypeFilterChanged">
                @foreach (var type in _entityTypes)
                {
                    <MudSelectItem T="string" Value="@type">@FormatTypeName(type)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>

    @if (_searching)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }

    <!-- Search Results (when user has typed a search query) -->
    @if (_searchResults is { Count: > 0 })
    {
        <MudPaper Class="pa-3 mb-4" Outlined="true">
            <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Secondary">Select an entity:</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                @foreach (var entity in _searchResults)
                {
                    <MudChip T="string" Color="@(entity.Id == _selectedEntityId ? Color.Primary : Color.Default)"
                             Variant="@(entity.Id == _selectedEntityId ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => SelectEntity(entity.Id, entity.Name))"
                             Size="Size.Medium">
                        @entity.Name
                    </MudChip>
                }
            </MudStack>
        </MudPaper>
    }
    else if (_searchResults is { Count: 0 } && !string.IsNullOrWhiteSpace(_search) && !_searching)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
            No entities found matching "@_search" in @FormatTypeName(_selectedType).
        </MudAlert>
    }

    <!-- Browse Table (when no search query — lets users discover entities) -->
    @if (string.IsNullOrWhiteSpace(_search))
    {
        <MudTable T="EntitySearchDto" ServerData="LoadBrowseData" @ref="_browseTable" Dense="true"
                  Hover="true" Bordered="false" Striped="true" Elevation="0"
                  RowClass="cursor-pointer" OnRowClick="OnBrowseRowClick"
                  RowClassFunc="@((item, _) => item.Id == _selectedEntityId ? "mud-theme-primary" : "")"
                  Loading="_browseLoading" LoadingProgressColor="Color.Primary" Class="mb-4">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                    Browse @FormatTypeName(_selectedType) entities with graph data
                </MudText>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh Style="width:80px">Page ID</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Page ID">@context.Id</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 20, 50 }" />
            </PagerContent>
            <NoRecordsContent>
                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true">
                    No processed entities found for @FormatTypeName(_selectedType). Run a batch from the
                    <MudLink Href="/graph-builder">Graph Builder</MudLink> to start processing.
                </MudAlert>
            </NoRecordsContent>
        </MudTable>
    }

    <!-- Selected Entity: Labels & Controls -->
    @if (_selectedEntityId > 0)
    {
        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudText Typo="Typo.h6">@_selectedEntityName</MudText>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Depth:</MudText>
                    <MudSlider T="int" @bind-Value="_maxDepth" Min="1" Max="4" Step="1"
                               Style="width:120px" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@_maxDepth</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Hub"
                               OnClick="LoadGraph" Disabled="_graphLoading"
                               Size="Size.Medium">
                        Show Graph
                    </MudButton>
                </MudStack>
            </MudStack>

            @if (_loadingLabels)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-2" />
            }
            else if (_availableLabels is { Count: > 0 })
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">
                    Available relationship labels (select which to traverse):
                </MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var label in _availableLabels)
                    {
                        var isSelected = _selectedLabels.Contains(label);
                        <MudChip T="string"
                                 Color="@(isSelected ? Color.Info : Color.Default)"
                                 Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                 OnClick="@(() => ToggleLabel(label))"
                                 Size="Size.Small">
                            @FormatLabel(label)
                        </MudChip>
                    }
                </MudStack>
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SelectAllLabels">Select All</MudButton>
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearLabels">Clear</MudButton>
                </MudStack>
            }
            else if (!_loadingLabels)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                    No relationship labels found for this entity. The graph crawler may not have processed this page yet.
                    Try running a batch from the <MudLink Href="/graph-builder">Graph Builder</MudLink>.
                </MudAlert>
            }
        </MudPaper>
    }

    <!-- Graph -->
    @if (_graphLoading)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
            <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">Loading relationship graph...</MudText>
        </MudStack>
    }
    else if (_graphError is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_graphError</MudAlert>
    }

    @if (_hasGraph)
    {
        <MudGrid Spacing="2" Class="mb-4">
            <MudItem xs="12" md="@(_selectedNodePage is not null ? 9 : 12)">
                <MudPaper Outlined="true" Style="overflow:hidden; border-radius:8px;">
                    <div id="@_containerId"
                         style="width:100%; height:700px; background:#16162e;">
                    </div>
                </MudPaper>

                @if (_graphStats is not null)
                {
                    <MudStack Row="true" Spacing="4" Class="mt-2">
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">
                            @_graphStats.Value.nodeCount nodes
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                            @_graphStats.Value.edgeCount edges
                        </MudChip>
                        @if (_selectedNodeName is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="align-self-center">
                                Click a node to view its details
                            </MudText>
                        }
                    </MudStack>
                }
            </MudItem>

            @if (_loadingNodeDetails)
            {
                <MudItem xs="12" md="3">
                    <MudPaper Class="pa-4" Style="height:700px; overflow-y:auto;">
                        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:100%">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading details...</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            }
            else if (_selectedNodePage is not null)
            {
                <MudItem xs="12" md="3">
                    <MudPaper Class="pa-0" Style="height:700px; overflow-y:auto; border-radius:8px;">
                        <MudCard Elevation="0">
                            @if (_selectedNodePage.Infobox?.ImageUrl is not null)
                            {
                                <MudCardMedia Image="@StripRevision(_selectedNodePage.Infobox.ImageUrl)" Height="200" />
                            }
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@_selectedNodePage.Title</MudText>
                                    @if (_selectedNodePage.Infobox?.Template is not null)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @SanitizeTemplate(_selectedNodePage.Infobox.Template)
                                        </MudText>
                                    }
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                   OnClick="CloseNodePanel" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                @if (_selectedNodePage.Infobox?.Data is not null)
                                {
                                    <MudSimpleTable Dense="true" Bordered="true" Striped="true" Style="overflow-x:auto">
                                        <tbody>
                                            @foreach (var prop in _selectedNodePage.Infobox.Data.Where(HasInfoboxContent))
                                            {
                                                <tr>
                                                    <td style="font-weight:600; white-space:nowrap; width:1%; padding:6px 12px; vertical-align:top;">
                                                        @prop.Label
                                                    </td>
                                                    <td style="padding:6px 12px;">
                                                        @foreach (var link in prop.Links)
                                                        {
                                                            <MudLink Href="@link.Href" Underline="Underline.Always" Class="mr-1" Target="_blank">@link.Content</MudLink>
                                                        }
                                                        @GetPlainValues(prop)
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                            </MudCardContent>
                            <MudCardActions>
                                @if (_selectedNodePage.WikiUrl is not null)
                                {
                                    <MudButton Href="@_selectedNodePage.WikiUrl" Target="_blank" Variant="Variant.Text" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.OpenInNew" Size="Size.Small">
                                        Wookieepedia
                                    </MudButton>
                                }
                                <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Hub"
                                           OnClick="@(() => SelectEntity(_selectedNodeId, _selectedNodeName!))">
                                    Explore Graph
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter] public int? PageId { get; set; }

    // Search state
    private string _search = "";
    private string _selectedType = "Character";
    private bool _searching;
    private List<EntitySearchDto>? _searchResults;
    private List<string> _entityTypes = ["Character"];

    // Browse state
    private MudTable<EntitySearchDto>? _browseTable;
    private bool _browseLoading;

    // Selected entity state
    private int _selectedEntityId;
    private string _selectedEntityName = "";
    private List<string>? _availableLabels;
    private HashSet<string> _selectedLabels = new();
    private bool _loadingLabels;
    private int _maxDepth = 2;

    // Graph state
    private bool _graphLoading;
    private bool _hasGraph;
    private string? _graphError;
    private (int nodeCount, int edgeCount)? _graphStats;
    private IJSObjectReference? _jsModule;
    private readonly string _containerId = $"d3-explorer-{Guid.NewGuid():N}";

    // Node info panel state
    private DotNetObjectReference<GraphExplorer>? _dotnetRef;
    private int _selectedNodeId;
    private string? _selectedNodeName;
    private WikiPage? _selectedNodePage;
    private bool _loadingNodeDetails;

    private HttpClient Api => HttpClientFactory.CreateClient("StarWarsData");

    private void AppendGlobalFilters(System.Collections.Specialized.NameValueCollection query)
    {
        var c = GlobalFilterService.GetContinuityQueryParam();
        if (!string.IsNullOrEmpty(c))
            query["continuity"] = c;
    }

    private string BuildQueryString(params (string key, string value)[] parameters)
    {
        var query = System.Web.HttpUtility.ParseQueryString(string.Empty);
        foreach (var (key, value) in parameters)
            query[key] = value;
        AppendGlobalFilters(query);
        return query.ToString()!;
    }

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnGlobalFilterChanged;
        await LoadEntityTypes();
    }

    private async Task LoadEntityTypes()
    {
        try
        {
            var types = await Api.GetFromJsonAsync<List<string>>("api/RelationshipGraph/entity-types");
            if (types is { Count: > 0 })
            {
                _entityTypes = types;
                if (!_entityTypes.Contains(_selectedType))
                    _selectedType = _entityTypes[0];
            }
        }
        catch
        {
            // Fallback to default if API is unavailable
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (PageId.HasValue && PageId.Value != _selectedEntityId)
        {
            _selectedEntityId = PageId.Value;
            _selectedEntityName = $"Entity #{PageId.Value}";
            await LoadLabels();
        }
    }

    private async void OnGlobalFilterChanged()
    {
        await InvokeAsync(async () =>
        {
            if (!string.IsNullOrWhiteSpace(_search))
                await OnSearchChanged(_search);
            else
                _browseTable?.ReloadServerData();

            if (_selectedEntityId > 0)
            {
                _hasGraph = false;
                _graphStats = null;
                await LoadLabels();
            }

            StateHasChanged();
        });
    }

    // --- Server-side pagination for browse table ---

    private async Task<TableData<EntitySearchDto>> LoadBrowseData(TableState state, CancellationToken ct)
    {
        _browseLoading = true;
        try
        {
            var page = state.Page + 1; // MudTable is 0-based, API is 1-based
            var qs = BuildQueryString(
                ("type", _selectedType),
                ("page", page.ToString()),
                ("pageSize", state.PageSize.ToString()));

            var result = await Api.GetFromJsonAsync<BrowseEntitiesResult>(
                $"api/RelationshipGraph/browse?{qs}", ct);

            return new TableData<EntitySearchDto>
            {
                Items = result?.Items ?? [],
                TotalItems = (int)(result?.Total ?? 0),
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load entities: {ex.Message}", Severity.Error);
            return new TableData<EntitySearchDto> { Items = [], TotalItems = 0 };
        }
        finally
        {
            _browseLoading = false;
        }
    }

    private async Task OnBrowseRowClick(TableRowClickEventArgs<EntitySearchDto> args)
    {
        if (args.Item is not null)
            await SelectEntity(args.Item.Id, args.Item.Name);
    }

    // --- Search ---

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        if (string.IsNullOrWhiteSpace(value))
        {
            _searchResults = null;
            return;
        }

        _searching = true;
        StateHasChanged();

        try
        {
            var qs = BuildQueryString(("q", value), ("collection", _selectedType));
            _searchResults = await Api.GetFromJsonAsync<List<EntitySearchDto>>(
                $"relationships/search?{qs}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _searching = false;
        }
    }

    private async Task OnTypeFilterChanged()
    {
        if (!string.IsNullOrWhiteSpace(_search))
            await OnSearchChanged(_search);
        else
            _browseTable?.ReloadServerData();
    }

    private async Task SelectEntity(int id, string name)
    {
        _selectedEntityId = id;
        _selectedEntityName = name;
        _hasGraph = false;
        _graphError = null;
        _selectedLabels.Clear();

        Navigation.NavigateTo($"/graph-explorer/{id}", replace: true);

        await LoadLabels();
    }

    private async Task LoadLabels()
    {
        _loadingLabels = true;
        _availableLabels = null;
        StateHasChanged();

        try
        {
            var labelsQs = BuildQueryString();
            var labelsUrl = $"api/RelationshipGraph/labels/{_selectedEntityId}";
            if (!string.IsNullOrEmpty(labelsQs))
                labelsUrl += $"?{labelsQs}";
            _availableLabels = await Api.GetFromJsonAsync<List<string>>(labelsUrl);

            if (_availableLabels is { Count: > 0 })
                _selectedLabels = new HashSet<string>(_availableLabels);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load labels: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingLabels = false;
        }
    }

    private void ToggleLabel(string label)
    {
        if (!_selectedLabels.Remove(label))
            _selectedLabels.Add(label);
    }

    private void SelectAllLabels()
    {
        if (_availableLabels is not null)
            _selectedLabels = new HashSet<string>(_availableLabels);
    }

    private void ClearLabels() => _selectedLabels.Clear();

    private async Task LoadGraph()
    {
        if (_selectedEntityId <= 0) return;

        _graphLoading = true;
        _graphError = null;
        _hasGraph = false;
        _graphStats = null;
        StateHasChanged();

        try
        {
            var labelsParam = string.Join(",", _selectedLabels);
            var queryParams = new List<(string, string)> { ("maxDepth", _maxDepth.ToString()) };
            if (!string.IsNullOrEmpty(labelsParam))
                queryParams.Add(("labels", labelsParam));
            var url = $"api/RelationshipGraph/query/{_selectedEntityId}?{BuildQueryString([.. queryParams])}";

            var result = await Api.GetFromJsonAsync<RelationshipGraphResult>(url);

            if (result is null || result.Nodes.Count == 0)
            {
                _graphError = "No graph data found. The crawler may not have processed this entity yet.";
                return;
            }

            _hasGraph = true;
            _graphStats = (result.Nodes.Count, result.Edges.Count);
            _graphLoading = false;
            StateHasChanged();

            await Task.Delay(50);
            await RenderD3Graph(result);
        }
        catch (Exception ex)
        {
            _graphError = $"Failed to load graph: {ex.Message}";
        }
        finally
        {
            _graphLoading = false;
        }
    }

    private async Task RenderD3Graph(RelationshipGraphResult result)
    {
        _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/d3-graph.js");

        var nodes = result.Nodes.Select(n => new
        {
            id = n.Id,
            name = n.Name,
            type = n.Type,
            imageUrl = n.ImageUrl ?? "",
            born = "",
            died = "",
        }).ToArray();

        var edges = result.Edges.Select(e => new
        {
            fromId = e.FromId,
            toId = e.ToId,
            label = e.Label,
            weight = e.Weight > 0 ? e.Weight : 0.5,
        }).ToArray();

        var data = new { nodes, edges, rootId = result.RootId };

        _dotnetRef?.Dispose();
        _dotnetRef = DotNetObjectReference.Create(this);

        await _jsModule.InvokeVoidAsync("renderForceGraph", _containerId, data, _dotnetRef);
    }

    [JSInvokable]
    public async Task OnNodeClicked(int id, string name, string type)
    {
        _selectedNodeId = id;
        _selectedNodeName = name;
        _selectedNodePage = null;
        _loadingNodeDetails = true;
        StateHasChanged();

        try
        {
            _selectedNodePage = await Api.GetFromJsonAsync<WikiPage>($"Pages/{id}");
        }
        catch
        {
            _selectedNodePage = null;
        }
        finally
        {
            _loadingNodeDetails = false;
            StateHasChanged();
        }
    }

    private void CloseNodePanel()
    {
        _selectedNodePage = null;
        _selectedNodeName = null;
        _selectedNodeId = 0;
        _loadingNodeDetails = false;
    }

    private static string FormatLabel(string label) =>
        System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(
            label.Replace("_", " "));

    private static string FormatTypeName(string type) => type switch
    {
        "CelestialBody" => "Planet / Body",
        _ => System.Text.RegularExpressions.Regex.Replace(type, "(?<!^)([A-Z])", " $1"),
    };

    private static string StripRevision(string url)
    {
        var idx = url.IndexOf("/revision", StringComparison.OrdinalIgnoreCase);
        return idx > 0 ? url[..idx] : url;
    }

    private static string SanitizeTemplate(string template)
    {
        var last = template.Split(':').LastOrDefault() ?? template;
        return last.Replace("_", " ");
    }

    private static bool HasInfoboxContent(InfoboxProperty prop) =>
        prop.Links.Count > 0 || prop.Values.Any(v => !string.IsNullOrWhiteSpace(v));

    private static string GetPlainValues(InfoboxProperty prop)
    {
        var linkTexts = prop.Links.Select(l => l.Content).ToHashSet(StringComparer.OrdinalIgnoreCase);
        return string.Join(", ", prop.Values.Where(v => !string.IsNullOrWhiteSpace(v) && !linkTexts.Contains(v)));
    }

    public async ValueTask DisposeAsync()
    {
        GlobalFilterService.OnChange -= OnGlobalFilterChanged;
        _dotnetRef?.Dispose();

        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("destroyGraph", _containerId);
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }
}
