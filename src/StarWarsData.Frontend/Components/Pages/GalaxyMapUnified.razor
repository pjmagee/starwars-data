    async Task HighlightSector(string sectorName)
    {
        if (_geography is null || _module is null) return;
        // Find all cells that contain this sector
        var cells = _geography.Cells
            .Where(c => c.Sectors?.Any(s => s.Name.Equals(sectorName, StringComparison.OrdinalIgnoreCase)) == true)
            .Select(c => new[] { c.Col, c.Row })
            .ToArray();
        if (cells.Length > 0)
            await _module.InvokeVoidAsync("highlightCells", sectorName, (object)cells);
    }

    // ══════════ EXPLORE: Detail panel ══════════

    async Task LoadPageDetail(int pageId)
    {
        _loadingDetails = true; StateHasChanged();
        try { _detailPage = await Http.GetFromJsonAsync<WikiPage>($"Pages/{pageId}"); }
        catch { _detailPage = null; }
        finally { _loadingDetails = false; StateHasChanged(); }
    }

    void ClearDetailPanel() { _detailPage = null; _selectedSystem = null; }

    // ══════════ TIMELINE ══════════

    async Task LoadYear()
    {
        if (_overview is null || _module is null) return;
        try { _yearData = await Http.GetFromJsonAsync<GalaxyYearDocument>($"api/galaxy-map/years/{_year}"); } catch { _yearData = null; }
        if (_yearData is not null)
        {
            var layers = new[] { "regions", "territory", "events" };
            await _module.InvokeVoidAsync("renderTemporalLayer", _yearData, layers, _selectedLens);
        }
        StateHasChanged();
        _ = ScrollDensityToActive();
    }

    async Task OnLensChanged(string lens)
    {
        // Toggle: clicking the active lens deselects it back to All
        if (lens != "All" && lens != "None" && _selectedLens == lens)
            _selectedLens = "All";
        else
            _selectedLens = lens;

        if (_module is not null) await _module.InvokeVoidAsync("setLensFilter", _selectedLens);
        StateHasChanged();
    }

    async Task JumpToYear(int year)
    {
        if (_overview is null) return;
        _year = FilteredYears.OrderBy(y => Math.Abs(y - year)).FirstOrDefault();
        _yearIndex = FilteredYears.IndexOf(_year);
        await LoadYear();
    }

    async Task StepPrevious()
    {
        if (_overview is null || _yearIndex <= 0) return;
        _year = FilteredYears[--_yearIndex];
        await LoadYear();
    }

    async Task StepNext()
    {
        if (_overview is null || _yearIndex >= FilteredYears.Count - 1) return;
        _year = FilteredYears[++_yearIndex];
        await LoadYear();
    }

    void ToggleAutoplay()
    {
        _autoplay = !_autoplay;
        if (_autoplay)
            StartAutoplayTimer();
        else
            StopAutoplayTimer();
    }

    void OnFrameTimeChanged(int value)
    {
        _frameTimeMs = value;
        if (_autoplay)
        {
            StopAutoplayTimer();
            StartAutoplayTimer();
        }
    }

    void StartAutoplayTimer()
    {
        _autoplayTimer = new System.Threading.Timer(async _ =>
            await InvokeAsync(async () => { if (!_autoplay || _overview is null) return;
                _yearIndex = (_yearIndex + 1) % FilteredYears.Count;
                _year = FilteredYears[_yearIndex]; await LoadYear(); }),
            null, _frameTimeMs, _frameTimeMs);
    }

    void StopAutoplayTimer()
    {
        _autoplayTimer?.Dispose();
        _autoplayTimer = null;
    }

    void OnTickZoomChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var w) && w >= 3 && w <= 20)
        {
            _tickWidth = w;
            StateHasChanged();
            _ = ScrollDensityToActive();
        }
    }

    async Task ScrollDensityToActive()
    {
        if (_overview?.YearDensity is null) return;
        await Task.Delay(50); // allow render
        try
        {
            await JS.InvokeVoidAsync("eval", $@"
                (function() {{
                    var vp = document.getElementById('density-viewport');
                    if (!vp) return;
                    var active = vp.querySelector('.density-tick.active');
                    if (active) active.scrollIntoView({{ inline: 'center', block: 'nearest', behavior: 'smooth' }});
                }})();");
        }
        catch { }
    }

    // ══════════ HELPERS ══════════

    static bool TryParseGridKey(string gridKey, out int col, out int row)
    {
        col = 0; row = 0;
        if (string.IsNullOrEmpty(gridKey)) return false;
        var parts = gridKey.Split('-');
        if (parts.Length != 2 || parts[0].Length != 1 || !char.IsLetter(parts[0][0])) return false;
        col = char.ToUpper(parts[0][0]) - 'A';
        return int.TryParse(parts[1], out var num) && (row = num - 1) >= 0;
    }

    /// <summary>Show C/L badges only when both continuities are active (no filter).</summary>
    bool ShowContinuityBadges => GlobalFilterService.SelectedContinuity is null;

    static Continuity ParseContinuity(string? value) =>
        Enum.TryParse<Continuity>(value, true, out var c) ? c : Continuity.Unknown;

    static readonly string[] RegionPalette =
        ["#4ecdc4","#ff6f91","#7e6fff","#ffd93d","#6bcb77","#ff6b6b","#a29bfe","#fd79a8","#fdcb6e","#00cec9",
         "#e17055","#0984e3","#6c5ce7","#00b894","#e84393","#fab1a0","#74b9ff","#55efc4","#ff7675","#dfe6e9"];

    string GetRegionColor(string name)
    {
        if (_geography?.Regions is not { Count: > 0 }) return "#ffffff";
        var idx = _geography.Regions.FindIndex(r => r.Name == name);
        return RegionPalette[(idx >= 0 ? idx : 0) % RegionPalette.Length];
    }

    string GetRegionChipStyle(string name, bool visible)
    {
        var c = GetRegionColor(name);
        return visible ? $"background-color:{c};color:#fff;" : $"border-color:{c};color:{c};opacity:0.5;";
    }

    static string FormatType(string type) =>
        System.Text.RegularExpressions.Regex.Replace(
            type.Replace("_", " "), "(?<!^)([A-Z])", " $1");

    static string GetLensColorCss(string lens)
    {
        int hash = 0; foreach (var c in lens) hash = (hash * 31 + c) | 0;
        var hue = ((hash % 360) + 360) % 360;
        return $"hsl({hue}, 75%, 55%)";
    }

    static string FormatYear(int y) => y <= 0 ? $"{Math.Abs(y)} BBY" : $"{y} ABY";

    RenderFragment RenderEventCard(GalaxyYearEvent evt, string? region) => __builder =>
    {
        var catColor = GetLensColorCss(evt.Lens);
        <div class="event-card" style="@($"border-left-color:{catColor}")" data-highlight-region="@region"
             @onclick="() => OnNoLocationEventClicked(evt)" @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                @if (evt.WikiUrl is not null)
                {
                    <MudLink Href="@evt.WikiUrl" Target="_blank" Typo="Typo.body2"
                             Style="font-weight:500;color:#e0e0f0;">@evt.Title</MudLink>
                }
                else
                {
                    <span style="font-size:13px;font-weight:500;">@evt.Title</span>
                }
                <div style="display:flex;gap:3px;flex-shrink:0;margin-left:4px;">
                    <ContinuityBadge Continuity="evt.Continuity" Short="true"
                                     Style="font-size:8px;height:16px;min-width:16px;padding:0 3px;" />
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="@($"border-color:{catColor};color:{catColor};font-size:9px;height:18px;")">
                        @evt.Lens
                    </MudChip>
                </div>
            </div>
            @if (evt.Place is not null)
            {
                <div style="font-size:11px;color:rgba(255,255,255,0.5);margin-top:2px;">
                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small"
                             Style="font-size:12px;vertical-align:middle;margin-right:2px;" />@evt.Place
                    @if (region is not null)
                    {
                        <span style="opacity:0.6;"> · @region</span>
                    }
                </div>
            }
            @if (evt.Outcome is not null)
            {
                <div style="font-size:11px;color:rgba(255,255,255,0.4);margin-top:2px;font-style:italic;">@evt.Outcome</div>
            }
        </div>
    };

    static bool HasInfoboxContent(InfoboxProperty p) => p.Links.Count > 0 || p.Values.Any(v => !string.IsNullOrWhiteSpace(v));
    static string GetPlainValues(InfoboxProperty p)
    {
        var linkTexts = p.Links.Select(l => l.Content).ToHashSet(StringComparer.OrdinalIgnoreCase);
        return string.Join(", ", p.Values.Where(v => !string.IsNullOrWhiteSpace(v) && !linkTexts.Contains(v)));
    }
    static string StripRevision(string url) { var i = url.IndexOf("/revision", StringComparison.OrdinalIgnoreCase); return i > 0 ? url[..i] : url; }
    static string SanitizeTemplate(string t) => t.Split(':').LastOrDefault()?.Replace("_", " ") ?? t;

    async void OnFilterChanged() => await InvokeAsync(async () =>
    {
        _systemCache.Clear(); _selectedSystem = null; _selectedRegion = null;
        _detailPage = null; _searchResults = null; _currentLevel = "overview";
        _cellLabel = ""; _regionLabel = ""; _sectorLabel = ""; _hoveredRegionName = null; _hiddenRegions.Clear();
        UpdateBreadcrumbs(); _d3Initialized = false;
        if (_module is not null) { try { await _module.InvokeVoidAsync("dispose"); } catch { } }
        await LoadData(); StateHasChanged();
    });

