    async Task ToggleRegion(string name)
    {
        if (!_hiddenRegions.Remove(name)) _hiddenRegions.Add(name);
        if (_module is not null) await _module.InvokeVoidAsync("setRegionVisibility", (object)_hiddenRegions.ToArray());
