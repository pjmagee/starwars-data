    private void ToggleFullscreen() => Layout.SetFullscreen(!Layout.IsFullscreen);

    public async ValueTask DisposeAsync()
    {
        Layout.SetFullscreen(false);
        GlobalFilterService.OnChange -= OnFilterChanged;
        _autoplayTimer?.Dispose();
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("dispose"); await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { } catch (ObjectDisposedException) { }
        }
        _dotNetRef?.Dispose();
    }
