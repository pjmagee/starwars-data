    async Task GoToOverview() { if (_module is not null) await _module.InvokeVoidAsync("goToOverview"); }

    void UpdateBreadcrumbs()
    {
        _breadcrumbs = [new("", null, disabled: true, icon: Icons.Material.Filled.Explore)];
        if (!string.IsNullOrEmpty(_regionLabel))
            _breadcrumbs.Add(new(_regionLabel, null, disabled: true, icon: Icons.Material.Filled.Map));
        if (!string.IsNullOrEmpty(_cellLabel))
            _breadcrumbs.Add(new($"Grid {_cellLabel}", null, disabled: true, icon: Icons.Material.Filled.GridOn));
        if (!string.IsNullOrEmpty(_sectorLabel))
            _breadcrumbs.Add(new(_sectorLabel, null, disabled: true, icon: Icons.Material.Filled.Grain));
        if (_currentLevel == "system")
            _breadcrumbs.Add(new(_currentLabel, null, disabled: true, icon: Icons.Material.Filled.Star));
    }

    // ══════════ EXPLORE: Search ══════════

    async Task OnSearchChanged(string value)
    {
        _searchTerm = value;
        if (string.IsNullOrWhiteSpace(value) || value.Length < 2) { _searchResults = null; return; }
        _searchLoading = true;
        _searchError = null;
        StateHasChanged();
        try {
            var url = $"api/galaxy-map/search?q={Uri.EscapeDataString(value)}";
            if (_semanticSearch) url += "&semantic=true";
            var cq = ContinuityQuery;
            if (!string.IsNullOrEmpty(cq)) url += $"&{cq}";
            _searchResults = await Http.GetFromJsonAsync<List<MapSearchResult>>(url);
            if (_searchResults is { Count: 0 } && _semanticSearch)
                _searchError = "No map-placeable results found. Try broader terms — semantic search finds articles, then locates them on the grid.";
        }
        catch (Exception ex) { _searchResults = null; _searchError = ex.Message; }
        finally { _searchLoading = false; }
        StateHasChanged();
    }

    void OnSemanticToggle(bool value)
    {
        _semanticSearch = value;
        _searchResults = null;
        _searchError = null;
    }

    void ClearSearch() { _searchTerm = null; _searchResults = null; _searchError = null; }

    async Task SelectSearchResult(MapSearchResult result)
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("clearPreviewHighlight");
        if (TryParseGridKey(result.GridKey, out int col, out int row) && _module is not null)
            await _module.InvokeVoidAsync("navigateToCell", col, row);
        await LoadPageDetail(result.PageId);
    }

