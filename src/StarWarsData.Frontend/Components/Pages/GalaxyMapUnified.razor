@page "/galaxy-map"
@using Microsoft.JSInterop
@using WikiPage = StarWarsData.Models.Entities.Page
@using StarWarsData.Models.Entities
@using StarWarsData.Models.Queries
@inject IHttpClientFactory HttpClientFactory
@inject StarWarsData.Frontend.Services.GlobalFilterService GlobalFilterService
@inject IJSRuntime JS
@inject LayoutService Layout
@implements IAsyncDisposable

<PageTitle>Galaxy Map — Star Wars Data</PageTitle>
<HeadContent>
    <meta name="description" content="Interactive Star Wars galaxy map with regions, trade routes, and system drill-down. Explore mode with AI semantic search and Timeline mode with animated territory control." />
</HeadContent>

<style>
    /* Prevent scrolling and ensure dark background covers the entire layout behind the map */
    .mud-main-content:has(.galaxy-map-container) {
        overflow: hidden;
        background: #0a0a1a;
    }
    .mud-layout:has(.galaxy-map-container),
    .mud-drawer-container:has(.galaxy-map-container) {
        background: #0a0a1a;
    }
    .galaxy-map-container {
        position: relative;
        width: 100%;
        height: calc(100vh - 64px);
        background: #0a0a1a;
        overflow: hidden;
    }
    .galaxy-map-container.fullscreen {
        height: 100vh;
    }
    .galaxy-nav-panel {
        position: absolute; top: 60px; left: 12px; z-index: 110;
        width: 360px; max-height: calc(100% - 72px);
        display: flex; flex-direction: column;
    }
    .galaxy-detail-panel {
        position: absolute; top: 60px; right: 12px; width: 420px;
        max-height: calc(100% - 72px); overflow-y: auto; z-index: 100;
    }
    .galaxy-detail-panel::-webkit-scrollbar, .search-results-list::-webkit-scrollbar {
        width: 6px;
    }
    .galaxy-detail-panel::-webkit-scrollbar-thumb, .search-results-list::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.15); border-radius: 3px;
    }
    .search-results-list { overflow-y: auto; max-height: 40vh; }
    .search-result-item {
        padding: 6px 12px; cursor: pointer; border-left: 2px solid transparent;
        transition: background 0.15s, border-left-color 0.15s;
    }
    .search-result-item:hover {
        background: rgba(255,215,0,0.08); border-left-color: #ffd700;
    }
    .galaxy-timeline-bar {
        position: absolute; bottom: 0; left: 0; right: 0; z-index: 110;
        display: flex; flex-direction: column; gap: 4px; padding: 6px 16px 8px;
        background: rgba(15,15,35,0.95); border-top: 1px solid rgba(255,255,255,0.1);
    }
    .timeline-eras {
        display: flex; gap: 4px; overflow-x: auto; overflow-y: hidden;
        scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.2) transparent;
    }
    .timeline-eras::-webkit-scrollbar { height: 4px; }
    .timeline-eras::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.25); border-radius: 2px; }
    .timeline-controls {
        display: flex; align-items: center; gap: 8px; width: 100%;
    }
    .timeline-controls .density-bar { flex: 1; }
    .timeline-controls .mud-select { flex-grow: 0 !important; }
    .timeline-progress {
        height: 3px; background: var(--mud-palette-primary);
        animation: timeline-fill var(--duration) linear infinite;
        transform-origin: left;
    }
    @@keyframes timeline-fill {
        from { transform: scaleX(0); }
        to { transform: scaleX(1); }
    }
    .lens-chip {
        display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px;
        border-radius: 14px; font-size: 11px; cursor: pointer;
        border: 1px solid rgba(255,255,255,0.15); transition: all 0.15s;
    }
    .lens-chip:hover { border-color: rgba(255,255,255,0.4); }
    .lens-chip.active { border-width: 2px; }
    .era-chip {
        padding: 4px 10px; border-radius: 12px; font-size: 12px; cursor: pointer;
        background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.7);
        border: none; transition: background 0.15s; white-space: nowrap;
    }
    .era-chip:hover { background: rgba(255,255,255,0.15); }
    .era-chip.active {
        background: var(--mud-palette-primary);
        color: #fff; font-weight: 600;
        box-shadow: 0 0 10px rgba(var(--mud-palette-primary-rgb), 0.6);
    }
    .density-viewport {
        flex: 1; overflow-x: auto; overflow-y: hidden;
        height: 44px; min-height: 44px;
        scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.2) transparent;
    }
    .density-viewport::-webkit-scrollbar { height: 4px; }
    .density-viewport::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.25); border-radius: 2px; }
    .density-bar {
        display: flex; align-items: flex-end; height: 40px; gap: 0;
    }
    .density-tick {
        flex-shrink: 0; background: rgba(255,255,255,0.4);
        cursor: pointer; border-radius: 1px 1px 0 0; transition: background 0.15s;
    }
    .density-tick:hover { background: rgba(255,255,255,0.85); }
    .density-tick.active { background: #ff6b6b; box-shadow: 0 0 8px rgba(255,107,107,0.6); }
    .timeline-zoom { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
    .timeline-zoom input[type=range] {
        width: 80px; accent-color: var(--mud-palette-primary); cursor: pointer;
    }
    .event-card {
        padding: 8px; margin-bottom: 6px; border-radius: 6px;
        background: rgba(255,255,255,0.04); border-left: 3px solid;
        cursor: pointer;
    }
    .event-card:hover { background: rgba(255,255,255,0.08); }
    .event-popover {
        max-height: 70vh; overflow-y: auto;
        scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.2) transparent;
    }
    .event-detail-panel {
        scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.2) transparent;
    }
    .event-detail-panel .drag-handle {
        cursor: move; user-select: none;
    }

    /* ══════════ TOP BAR (floating breadcrumbs + controls) ══════════ */
    .galaxy-top-bar {
        position: absolute; top: 12px; left: 12px; right: 12px; z-index: 120;
        pointer-events: none;
    }
    .galaxy-top-bar > * {
        pointer-events: auto;
    }

    /* Panel toggle — always visible */
    .galaxy-panel-toggle {
        display: inline-flex !important;
    }

    /* Backdrop scrim when panel is open (tablet/mobile only) */
    .galaxy-panel-backdrop {
        display: none; position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.45); z-index: 105; cursor: pointer;
    }

    /* Panel slide transitions */
    .galaxy-nav-panel, .galaxy-detail-panel {
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
    }
    .galaxy-nav-panel:not(.panel-open) {
        transform: translateX(calc(-100% - 24px));
        opacity: 0;
        pointer-events: none;
    }
    .galaxy-detail-panel:not(.panel-open) {
        transform: translateX(calc(100% + 24px));
        opacity: 0;
        pointer-events: none;
    }

    /* ══════════ TABLET (up to 1280px) ══════════ */
    @@media (max-width: 1279.95px) {
        .galaxy-panel-backdrop.panel-open {
            display: block;
        }
        .galaxy-nav-panel {
            width: 320px;
            max-height: calc(100% - 72px);
        }
        .galaxy-detail-panel {
            width: 340px;
        }
    }

    /* ══════════ SMALL TABLET / LARGE PHONE (up to 960px) ══════════ */
    @@media (max-width: 959.95px) {
        .galaxy-nav-panel {
            width: calc(100vw - 24px);
            max-width: 340px;
        }
        .galaxy-detail-panel {
            width: calc(100vw - 24px);
            max-width: 380px;
        }
    }

    /* ══════════ PHONE (up to 600px) ══════════ */
    @@media (max-width: 599.95px) {
        .galaxy-top-bar {
            left: 8px;
            right: 8px;
            top: 8px;
        }
        .galaxy-nav-panel {
            left: 8px;
            top: 56px;
            width: calc(100vw - 16px);
            max-width: none;
        }
        .galaxy-detail-panel {
            left: 8px;
            right: 8px;
            width: auto;
            max-width: none;
            top: auto;
            bottom: 8px;
            max-height: 50vh;
        }
        .galaxy-timeline-bar {
            padding: 4px 8px 6px;
        }
    }
</style>

<div class="galaxy-map-container @(Layout.IsFullscreen ? "fullscreen" : "")" id="galaxy-map-root"
     @onclick="CloseEventPopover">
    @if (_loading)
    {
        <div style="display:flex;align-items:center;justify-content:center;height:100%;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }

    @* ══════════ FLOATING TOP BAR ══════════ *@
    @if (_geography is not null)
    {
        <div class="galaxy-top-bar">
            <MudPaper Elevation="4" Class="pa-1 px-2 d-flex align-center gap-1 flex-grow-1"
                      Style="background:rgba(15,15,35,0.93);backdrop-filter:blur(10px);border-radius:8px;">
                <MudIconButton Icon="@(_panelOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.Tune)"
                               Size="Size.Small" OnClick="TogglePanel" Class="galaxy-panel-toggle"
                               title="@(_panelOpen ? "Close panel" : "Open controls")"
                               Style="color:rgba(255,255,255,0.8);" />
                @if (_currentLevel != "overview")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                                   Color="Color.Primary" OnClick="GoBack" />
                }
                <MudTooltip Text="Back to galaxy overview">
                    <MudIconButton Icon="@Icons.Material.Filled.Explore" Size="Size.Small"
                                   OnClick="GoToOverview"
                                   Disabled="@(_currentLevel == "overview")"
                                   Style="color:rgba(255,255,255,0.7);" />
                </MudTooltip>
                @if (_breadcrumbs.Count > 1)
                {
                    <MudBreadcrumbs Items="_breadcrumbs.Skip(1).ToList()" MaxItems="3"
                                    Style="padding:0;color:rgba(255,255,255,0.7);font-size:13px;" />
                }
                <MudSpacer />
                <MudToggleGroup T="string" Value="_mode" ValueChanged="OnModeChanged" Size="Size.Small">
                    <MudToggleItem Value="@("explore")" Text="Explore" />
                    <MudToggleItem Value="@("timeline")" Text="Timeline" />
                </MudToggleGroup>
                <MudTooltip Text="@(_detailPanelOpen ? "Hide details" : "Show details")">
                    <MudIconButton Icon="@(_detailPanelOpen ? Icons.Material.Filled.Info : Icons.Material.Outlined.Info)"
                                   Size="Size.Small" OnClick="ToggleDetailPanel"
                                   Style="color:rgba(255,255,255,0.8);" />
                </MudTooltip>
                <MudTooltip Text="@(Layout.IsFullscreen ? "Exit fullscreen" : "Fullscreen")">
                    <MudIconButton Icon="@(Layout.IsFullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                                   Size="Size.Small" Color="Color.Inherit" OnClick="ToggleFullscreen"
                                   Style="color:rgba(255,255,255,0.8);" />
                </MudTooltip>
            </MudPaper>
        </div>

        @* Panel backdrop scrim (tablet/mobile only via CSS) *@
        <div class="galaxy-panel-backdrop @(_panelOpen ? "panel-open" : "")"
             @onclick="@(() => { _panelOpen = false; })"></div>
    }

    @* ══════════ LEFT NAV PANEL ══════════ *@
    @if (_geography is not null)
    {
        <div class="galaxy-nav-panel @(_panelOpen ? "panel-open" : "")">
            <MudPaper Elevation="8" Class="pa-3" Style="background:rgba(15,15,35,0.93);backdrop-filter:blur(10px);min-width:0;">
                <MudStack Row="false" Spacing="1">
                    @* Defer MudTextField until the component is mounted to avoid the
                       MudInput DotNetObjectReference dispose/remount race on navigation.
                       Keep mounted across mode toggles via CSS d-none (not conditional removal). *@
                    @{ var exploreSearchClass = _mode == "explore" ? null : "d-none"; }
                    <div class="@exploreSearchClass">
                        @if (_mounted)
                        {
                            <MudTextField @bind-Value="_searchTerm"
                                          Placeholder="@(_semanticSearch ? "e.g. planets destroyed during the Clone Wars" : "Search planets, systems, people...")"
                                          Variant="Variant.Outlined" Adornment="Adornment.Start"
                                          AdornmentIcon="@(_semanticSearch ? Icons.Material.Filled.AutoAwesome : Icons.Material.Filled.Search)"
                                          Immediate="true" DebounceInterval="@(_semanticSearch ? 1000 : 600)"
                                          OnDebounceIntervalElapsed="OnSearchChanged"
                                          Clearable="true" OnClearButtonClick="ClearSearch" Margin="Margin.Dense"
                                          Style="color:#e0e0f0;" />
                            <MudSwitch Value="_semanticSearch" Color="Color.Tertiary" Size="Size.Small"
                                       Label="AI Semantic Search" Style="color:rgba(255,255,255,0.5);margin:0;"
                                       ValueChanged="OnSemanticToggle" T="bool" />
                        }
                    </div>

                    <MudExpansionPanels Dense="true" Elevation="0"
                                        Style="background:transparent; --mud-palette-surface:transparent;">
                        <!-- Display toggles -->
                        <MudExpansionPanel Text="Display" Expanded="false" Dense="true"
                                           Style="background:rgba(255,255,255,0.03);border-radius:6px;margin-bottom:4px;">
                            <MudStack Spacing="0">
                                <MudSwitch Value="_showBackground" Color="Color.Default" Size="Size.Small"
                                           Label="Background" Style="color:rgba(255,255,255,0.5);margin:0;"
                                           ValueChanged="OnToggleBackground" T="bool" />
                                <MudSwitch Value="_showCanonRoutes" Color="Color.Primary" Size="Size.Small"
                                           Label="Canon Routes" Style="color:rgba(255,255,255,0.5);margin:0;"
                                           ValueChanged="OnToggleCanonRoutes" T="bool" />
                                <MudSwitch Value="_showLegendsRoutes" Color="Color.Secondary" Size="Size.Small"
                                           Label="Legends Routes" Style="color:rgba(255,255,255,0.5);margin:0;"
                                           ValueChanged="OnToggleLegendsRoutes" T="bool" />
                                <MudSwitch Value="_showNebulae" Color="Color.Info" Size="Size.Small"
                                           Label="Nebulae" Style="color:rgba(255,255,255,0.5);margin:0;"
                                           ValueChanged="OnToggleNebulae" T="bool" />
                                @if (_mode == "explore")
                                {
                                    <MudSwitch Value="_onlyWithBodies" Color="Color.Success" Size="Size.Small"
                                               Label="Hide empty systems"
                                               Style="color:rgba(255,255,255,0.5);margin:0;"
                                               ValueChanged="OnCelestialBodyFilterChanged" T="bool" />
                                }
                            </MudStack>
                        </MudExpansionPanel>

                        <!-- Region filter -->
                        <MudExpansionPanel Dense="true" Expanded="true"
                                           Style="background:rgba(255,255,255,0.03);border-radius:6px;margin-bottom:4px;">
                            <TitleContent>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">Regions</MudText>
                                    <MudSpacer />
                                    <span @onclick="ShowAllRegions" @onclick:stopPropagation="true"
                                          style="color:rgba(255,255,255,0.5);font-size:12px;cursor:pointer;">All</span>
                                    <span @onclick="HideAllRegions" @onclick:stopPropagation="true"
                                          style="color:rgba(255,255,255,0.5);font-size:12px;cursor:pointer;">None</span>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                                             Style="margin:0;pointer-events:none;">@(_geography.Regions.Count - _hiddenRegions.Count)/@_geography.Regions.Count</MudChip>
                                </MudStack>
                            </TitleContent>
                            <ChildContent>
                                <MudStack Row="true" Spacing="1" Class="flex-wrap" Style="max-height:160px;overflow-y:auto;">
                                    @foreach (var region in _geography.Regions)
                                    {
                                        var isVisible = !_hiddenRegions.Contains(region.Name);
                                        <MudChip T="string" Size="Size.Small"
                                                 Variant="@(isVisible ? Variant.Filled : Variant.Outlined)"
                                                 OnClick="() => ToggleRegion(region.Name)"
                                                 Style="@GetRegionChipStyle(region.Name, isVisible)">
                                            @region.Name
                                        </MudChip>
                                    }
                                </MudStack>
                            </ChildContent>
                        </MudExpansionPanel>

                        @* Sector browser — CSS-hidden (not conditionally removed) when mode != explore
                           so the inner MudTextField isn't disposed + remounted (first-render JS interop race). *@
                        @if (_geography?.Cells is not null)
                        {
                            var sectorPanelClass = _mode == "explore" ? null : "d-none";
                            <MudExpansionPanel Dense="true" Expanded="false"
                                               Class="@sectorPanelClass"
                                               Style="background:rgba(255,255,255,0.03);border-radius:6px;margin-bottom:4px;">
                                <TitleContent>
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">Sectors</MudText>
                                        <MudSpacer />
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                                                 Style="margin:0;pointer-events:none;">@AllSectors.Count</MudChip>
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                    @if (_mounted)
                                    {
                                        <MudTextField @bind-Value="_sectorSearch" Placeholder="Filter sectors..."
                                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                                      Immediate="true" Style="color:#e0e0f0;margin-bottom:6px;" />
                                    }
                                    <MudStack Row="true" Spacing="1" Class="flex-wrap" Style="max-height:200px;overflow-y:auto;">
                                        @foreach (var sec in FilteredSectors)
                                        {
                                            var s = sec;
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     OnClick="() => HighlightSector(s.Name)"
                                                     Style="border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);">
                                                @s.Name <span style="color:rgba(255,255,255,0.4);margin-left:2px;">@s.Count</span>
                                            </MudChip>
                                        }
                                    </MudStack>
                                </ChildContent>
                            </MudExpansionPanel>
                        }

                        @if (_mode == "timeline" && _overview?.Lenses is not null)
                        {
                            <!-- Event lens filter -->
                            <MudExpansionPanel Dense="true" Expanded="true"
                                               Style="background:rgba(255,255,255,0.03);border-radius:6px;margin-bottom:4px;">
                                <TitleContent>
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">Events</MudText>
                                        <MudSpacer />
                                        <span @onclick="@(() => OnLensChanged("All"))" @onclick:stopPropagation="true"
                                              style="color:rgba(255,255,255,0.5);font-size:12px;cursor:pointer;">All</span>
                                        <span @onclick="@(() => OnLensChanged("None"))" @onclick:stopPropagation="true"
                                              style="color:rgba(255,255,255,0.5);font-size:12px;cursor:pointer;">None</span>
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                    <MudStack Row="true" Spacing="1" Class="flex-wrap" Style="max-height:160px;overflow-y:auto;">
                                        @foreach (var lens in FilteredLenses)
                                        {
                                            var l = lens;
                                            var color = GetLensColorCss(l.Lens);
                                            var isActive = _selectedLens == "All" || _selectedLens == l.Lens;
                                            var chipStyle = isActive
                                                ? $"background-color:{color};color:#fff;"
                                                : $"border-color:{color};color:{color};opacity:0.5;";
                                            <MudChip T="string" Size="Size.Small"
                                                     Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                                                     OnClick="() => OnLensChanged(l.Lens)"
                                                     Style="@chipStyle">
                                                @FormatType(l.Lens) @l.TotalCount
                                            </MudChip>
                                        }
                                    </MudStack>
                                </ChildContent>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>

                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Justify="Justify.Center">
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.35);">
                            @_geography.Regions.Count regions &bull; @_geography.TradeRoutes.Count routes
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>

            @* Search results *@
            @if (_mode == "explore" && _searchLoading)
            {
                <MudPaper Elevation="8" Class="pa-4 mt-1" Style="background:rgba(15,15,35,0.92);backdrop-filter:blur(8px);">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Tertiary" />
                        <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.5);">
                            @(_semanticSearch ? "Searching semantically..." : "Searching...")
                        </MudText>
                    </MudStack>
                </MudPaper>
            }
            else if (_mode == "explore" && _searchError is not null)
            {
                <MudPaper Elevation="8" Class="pa-3 mt-1" Style="background:rgba(15,15,35,0.92);backdrop-filter:blur(8px);">
                    <MudText Typo="Typo.caption" Style="color:rgba(255,180,100,0.8);">@_searchError</MudText>
                </MudPaper>
            }
            else if (_mode == "explore" && _searchResults is { Count: > 0 })
            {
                <MudPaper Elevation="8" Class="pa-0 mt-1" Style="background:rgba(15,15,35,0.92);backdrop-filter:blur(8px);">
                    <div class="search-results-list" style="color:#e0e0f0;">
                        @foreach (var group in _searchResults.GroupBy(r => r.GridKey))
                        {
                            <div style="background:rgba(255,255,255,0.03);color:rgba(255,255,255,0.5);padding:6px 12px;display:flex;align-items:center;gap:6px;">
                                <MudIcon Icon="@Icons.Material.Filled.GridOn" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2">Grid @group.Key</MudText>
                            </div>
                                @foreach (var result in group)
                                {
                                    <div class="search-result-item"
                                         data-search-grid="@result.GridKey"
                                         @onclick="() => SelectSearchResult(result)">
                                        <div style="display:flex;align-items:center;gap:6px;">
                                            <MudText Typo="Typo.body2">@result.MatchedName</MudText>
                                            @if (result.Score.HasValue)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                                         Color="Color.Tertiary" Style="margin:0;font-size:10px;">
                                                    @($"{result.Score:P0}")
                                                </MudChip>
                                            }
                                        </div>
                                        @if (result.MatchType is "linked" or "semantic-linked" && result.LinkedVia is not null)
                                        {
                                            <MudText Typo="Typo.caption" Style="color:rgba(255,215,0,0.6);">
                                                @(result.MatchType == "semantic-linked" ? $"via {result.LinkedVia}" : result.LinkedVia)
                                            </MudText>
                                        }
                                        @if (result.Snippet is not null)
                                        {
                                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);font-size:11px;line-height:1.3;margin-top:2px;">
                                                @result.Snippet
                                            </MudText>
                                        }
                                </div>
                            }
                        }
                    </div>
                </MudPaper>
            }
        </div>
    }

    @* ══════════ RIGHT DETAIL PANEL ══════════ *@
    @if (_mode == "explore")
    {
        @* Region hover *@
        @if (_hoveredRegionName is not null && _detailPage is null && _selectedSystem is null)
        {
            <div class="galaxy-detail-panel @(_detailPanelOpen ? "panel-open" : "")">
                <MudPaper Elevation="12" Class="pa-3" Style="background:rgba(15,15,35,0.92);backdrop-filter:blur(12px);">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <div style="width:12px;height:12px;border-radius:50%;background:@_hoveredRegionColor;"></div>
                        <MudText Typo="Typo.h6" Style="color:#e0e0f0;">@_hoveredRegionName</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.5);">
                        @_hoveredRegionCellCount grid cell@(_hoveredRegionCellCount != 1 ? "s" : "")
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.3);">Click to explore this region</MudText>
                </MudPaper>
            </div>
        }

        @* Entity detail (system, route, body) *@
        @if (_detailPage is not null || _selectedSystem is not null)
        {
            <div class="galaxy-detail-panel @(_detailPanelOpen ? "panel-open" : "")">
                <MudPaper Elevation="12" Class="pa-0" Style="background:rgba(15,15,35,0.92);backdrop-filter:blur(12px);">
                    <div style="display:flex;justify-content:flex-end;padding:4px 4px 0 0;">
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="ClearDetailPanel" />
                    </div>
                    @if (_loadingDetails)
                    {
                        <div style="display:flex;justify-content:center;padding:24px;">
                            <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                    else if (_detailPage is not null)
                    {
                        @if (_detailPage.Infobox?.ImageUrl is not null)
                        {
                            <MudCardMedia Image="@StripRevision(_detailPage.Infobox.ImageUrl)" Height="180" Style="border-radius:0;" />
                        }
                        <div class="pa-3">
                            <MudText Typo="Typo.h6" Style="color:#e0e0f0;">@_detailPage.Title</MudText>
                            @if (_detailPage.Infobox?.Template is not null)
                            {
                                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.4);">@SanitizeTemplate(_detailPage.Infobox.Template)</MudText>
                            }
                            @if (_detailPage.Infobox?.Data is not null)
                            {
                                <MudSimpleTable Dense="true" Bordered="true" Striped="true" Class="mt-2"
                                                Style="overflow-x:auto;background:transparent;">
                                    <tbody>
                                        @foreach (var prop in _detailPage.Infobox.Data.Where(HasInfoboxContent))
                                        {
                                            <tr>
                                                <td style="font-weight:600;white-space:nowrap;padding:4px 8px;vertical-align:top;color:rgba(255,255,255,0.6);font-size:12px;">@prop.Label</td>
                                                <td style="padding:4px 8px;color:#e0e0f0;font-size:12px;">
                                                    @foreach (var link in prop.Links)
                                                    {
                                                        <MudLink Href="@link.Href" Underline="Underline.Always" Class="mr-1" Target="_blank" Style="font-size:12px;">@link.Content</MudLink>
                                                    }
                                                    @GetPlainValues(prop)
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                            <MudButton Href="@_detailPage.WikiUrl" Target="_blank" Variant="Variant.Text" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mt-2">Wookieepedia</MudButton>
                        </div>
                    }
                    else if (_selectedSystem is not null)
                    {
                        <div class="pa-3">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Style="color:#e0e0f0;">@_selectedSystem.Name</MudText>
                                @if (ShowContinuityBadges && _selectedSystem.Continuity is not null)
                                {
                                    <ContinuityBadge Continuity="@ParseContinuity(_selectedSystem.Continuity)" Short="true"
                                                     Style="font-size:8px;height:16px;min-width:16px;padding:0 3px;" />
                                }
                            </MudStack>
                            @if (_selectedSystem.Region is not null)
                            {
                                <MudText Typo="Typo.body2" Style="color:#aaa;">Region: <span style="color:#e0e0f0;">@_selectedSystem.Region</span></MudText>
                            }
                            <MudText Typo="Typo.body2" Style="color:#aaa;">Grid: <span style="color:#e0e0f0;">@((char)('A' + _selectedSystem.Col))-@(_selectedSystem.Row + 1)</span></MudText>
                            @if (_selectedSystem.CelestialBodies.Count > 0)
                            {
                                <MudDivider Style="border-color:rgba(255,255,255,0.1);" Class="my-2" />
                                <MudText Typo="Typo.subtitle2" Style="color:#aaa;">Celestial Bodies (@_selectedSystem.CelestialBodies.Count)</MudText>
                                <MudStack Row="true" Class="flex-wrap gap-1 mt-1">
                                    @foreach (var body in _selectedSystem.CelestialBodies)
                                    {
                                        <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                     Style="background:rgba(107,203,119,0.2);color:#6bcb77;"
                                                     OnClick="() => LoadPageDetail(body.Id)">@body.Name</MudChip>
                                            @if (ShowContinuityBadges && body.Continuity is not null)
                                            {
                                                <ContinuityBadge Continuity="@ParseContinuity(body.Continuity)" Short="true"
                                                                 Style="font-size:7px;height:14px;min-width:14px;padding:0 2px;margin-left:-4px;" />
                                            }
                                        </MudStack>
                                    }
                                </MudStack>
                            }
                        </div>
                    }
                </MudPaper>
            </div>
        }
    }
    else if (_mode == "timeline" && _yearData is not null)
    {
        @* Timeline info panel (right) *@
        <div class="galaxy-detail-panel @(_detailPanelOpen ? "panel-open" : "")" id="galaxy-map-panel">
            <MudPaper Elevation="12" Class="pa-3" Style="background:rgba(15,15,35,0.92);backdrop-filter:blur(12px);">
                <MudText Typo="Typo.h5" Style="color:rgba(255,255,255,0.9);">@_yearData.YearDisplay</MudText>
                @if (_yearData.Era is not null)
                {
                    <MudText Typo="Typo.subtitle2" Style="color:rgba(255,255,255,0.5);margin-bottom:12px;">@_yearData.Era</MudText>
                }

                @if (_yearData.Regions.Count > 0)
                {
                    <MudText Typo="Typo.subtitle1" Style="margin-top:8px;">Territory Control (@_yearData.Regions.Count)</MudText>
                    <div style="max-height:30vh;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.2) transparent;">
                    @foreach (var region in _yearData.Regions)
                    {
                        <div style="margin:4px 0;" data-highlight-region="@region.Region">
                            <MudText Typo="Typo.body2" Style="font-weight:600;">@region.Region</MudText>
                            @foreach (var faction in region.Factions)
                            {
                                <div style="display:flex;align-items:center;gap:6px;margin:2px 0 2px 12px;">
                                    <div style="width:10px;height:10px;border-radius:50%;background:@faction.Color;"></div>
                                    <span style="font-size:12px;">@faction.Faction</span>
                                    <span style="font-size:11px;opacity:0.5;">@((faction.Control * 100).ToString("0"))%</span>
                                    @if (faction.Contested)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                                 Style="font-size:9px;height:18px;">Contested</MudChip>
                                    }
                                </div>
                            }
                        </div>
                    }
                    </div>
                }

                @{
                    var mappedEvents = FilteredEventCells.SelectMany(c => c.Events.Select(e => (evt: e, region: c.Region))).ToList();
                    var unresolvedHidden = GlobalFilterService.SelectedRealm switch
                    {
                        Realm.Starwars => _overview?.Lenses.Where(l => l.IsReal).Select(l => l.Lens).ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new(),
                        Realm.Real => _overview?.Lenses.Where(l => !l.IsReal).Select(l => l.Lens).ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new(),
                        _ => new HashSet<string>(),
                    };
                    var contFilter = GlobalFilterService.SelectedContinuity;
                    var unresolvedFiltered = (_yearData.UnresolvedEvents ?? [])
                        .Where(e => !unresolvedHidden.Contains(e.Lens))
                        .Where(e => contFilter is null || e.Continuity == contFilter)
                        .Where(e => _selectedLens == "All" || e.Lens == _selectedLens).ToList();
                    var totalAll = mappedEvents.Count + unresolvedFiltered.Count;
                }

                @if (totalAll > 0)
                {
                    <MudDivider Style="margin:12px 0;" />

                    @if (mappedEvents.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle1">
                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Style="vertical-align:middle;margin-right:4px;" />
                            On Map (@mappedEvents.Count)
                        </MudText>
                        <div style="max-height:30vh;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.2) transparent;">
                        @foreach (var (evt, region) in mappedEvents.Take(25))
                        {
                            @RenderEventCard(evt, region)
                        }
                        </div>
                    }

                    @if (unresolvedFiltered.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle1" Style="margin-top:12px;color:rgba(255,255,255,0.6);">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOff" Size="Size.Small" Style="vertical-align:middle;margin-right:4px;" />
                            No Location (@unresolvedFiltered.Count)
                        </MudText>
                        <div style="max-height:25vh;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.2) transparent;">
                        @foreach (var evt in unresolvedFiltered.Take(20))
                        {
                            @RenderEventCard(evt, null)
                        }
                        </div>
                    }
                }
            </MudPaper>
        </div>
    }

    @* ══════════ EVENT CELL HOVER POPOVER ══════════ *@
    @if (_hoveredCell is not null)
    {
        <div class="event-popover" style="position:fixed;left:@(_hoveredCell.ScreenX + 20)px;top:@(_hoveredCell.ScreenY - 10)px;z-index:300;"
             @onclick:stopPropagation="true">
            <MudPaper Elevation="16" Class="pa-3" Style="background:rgba(20,20,40,0.98);backdrop-filter:blur(12px);">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                    <MudText Typo="Typo.subtitle2" Style="color:rgba(255,255,255,0.5);">
                        @_hoveredCell.Region &bull; @_hoveredCell.Events.Count event@(_hoveredCell.Events.Count != 1 ? "s" : "")
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseEventPopover" Style="margin:-8px -8px 0 0;" />
                </div>
                @foreach (var evt in _hoveredCell.Events)
                {
                    var lensColor = GetLensColorCss(evt.Lens);
                    var isSelected = _hoveredEvent == evt;
                    <div class="event-card" style="border-left-color:@lensColor;padding:6px;@(isSelected ? "background:rgba(255,255,255,0.12);" : "")"
                         @onclick="() => OnEventItemHovered(evt)" @onclick:stopPropagation="true">
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <span style="font-size:12px;font-weight:500;">@evt.Title</span>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Style="@($"border-color:{lensColor};color:{lensColor};font-size:9px;height:16px;")">@FormatType(evt.Lens)</MudChip>
                        </div>
                    </div>
                }
            </MudPaper>
        </div>
    }

    @* ══════════ EVENT ARTICLE DETAIL POPOVER ══════════ *@
    @if (_hoveredEvent is not null)
    {
        <div class="event-detail-panel" id="event-detail-panel"
             style="position:fixed;right:16px;top:50%;transform:translateY(-50%);z-index:310;width:420px;resize:both;overflow:auto;min-width:300px;min-height:200px;max-width:80vw;max-height:80vh;"
             @onclick:stopPropagation="true">
            <MudPaper Elevation="20" Style="background:rgba(20,20,40,0.98);backdrop-filter:blur(12px);height:100%;display:flex;flex-direction:column;overflow:hidden;">
                <div class="drag-handle" style="display:flex;justify-content:space-between;align-items:center;padding:8px 8px 8px 16px;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;"
                     onmousedown="(function(e){
                        var el=document.getElementById('event-detail-panel');if(!el)return;
                        var rect=el.getBoundingClientRect();
                        el.style.left=rect.left+'px';el.style.top=rect.top+'px';
                        el.style.right='auto';el.style.transform='none';
                        var sx=e.clientX-rect.left,sy=e.clientY-rect.top;
                        function mv(e2){el.style.left=(e2.clientX-sx)+'px';el.style.top=(e2.clientY-sy)+'px';}
                        function up(){document.removeEventListener('mousemove',mv);document.removeEventListener('mouseup',up);}
                        document.addEventListener('mousemove',mv);document.addEventListener('mouseup',up);
                     })(event)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Style="color:rgba(255,255,255,0.3);" />
                        <MudText Typo="Typo.h6" Style="color:rgba(255,255,255,0.95);">@_hoveredEvent.Title</MudText>
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseEventPopover" />
                </div>
                <div style="padding:12px 16px;display:flex;flex-direction:column;flex:1;min-height:0;overflow:hidden;">
                <MudStack Row="true" Spacing="1" Class="mb-2">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="@($"border-color:{GetLensColorCss(_hoveredEvent.Lens)};color:{GetLensColorCss(_hoveredEvent.Lens)};")">@FormatType(_hoveredEvent.Lens)</MudChip>
                    @if (_hoveredEvent.Place is not null)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                                 Icon="@Icons.Material.Filled.Place">@_hoveredEvent.Place</MudChip>
                    }
                </MudStack>
                @if (_hoveredEvent.Outcome is not null)
                {
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.4);font-style:italic;margin-bottom:8px;">@_hoveredEvent.Outcome</MudText>
                }

                @if (_loadingArticle)
                {
                    <div class="d-flex justify-center pa-3">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                    </div>
                }
                else if (_hoveredArticle is not null)
                {
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform:uppercase;letter-spacing:0.5px;">@_hoveredArticle.Heading</MudText>
                    <div style="flex:1;overflow-y:auto;margin-top:4px;font-size:12px;line-height:1.6;color:rgba(255,255,255,0.75);min-height:0;">
                        <MudMarkdown Value="@_hoveredArticle.Text" />
                    </div>
                }

                @if (_hoveredEvent.WikiUrl is not null)
                {
                    <div class="d-flex justify-end mt-2">
                        <MudButton Href="@_hoveredEvent.WikiUrl" Target="_blank" Variant="Variant.Text"
                                   Color="Color.Primary" Size="Size.Small" EndIcon="@Icons.Material.Filled.OpenInNew">
                            Wookieepedia
                        </MudButton>
                    </div>
                }
                </div>
            </MudPaper>
        </div>
    }

    @* ══════════ FACTION LEGEND (bottom-left overlay) ══════════ *@
    @* bottom offset must clear the timeline bar below (era chips row + controls
       row + density viewport + padding ≈ 130px). Using 140px gives a small gap. *@
    @if (_mode == "timeline" && _yearData is not null)
    {
        <div style="position:absolute;bottom:140px;left:12px;z-index:100;">
            <MudPaper Elevation="8" Class="pa-2" Style="background:rgba(15,15,35,0.9);backdrop-filter:blur(8px);">
                @foreach (var name in ActiveFactions)
                {
                    var info = _factionInfo.GetValueOrDefault(name);
                    var color = info?.Color ?? "#888";
                    <div class="d-flex align-center gap-2" style="margin-bottom:4px;">
                        @if (info?.IconUrl is not null)
                        {
                            <img src="@info.IconUrl" alt="@name" style="width:22px;height:22px;object-fit:contain;flex-shrink:0;" />
                        }
                        else
                        {
                            <div style="width:14px;height:14px;border-radius:50%;background:@color;flex-shrink:0;"></div>
                        }
                        @if (info?.WikiUrl is not null)
                        {
                            <MudLink Href="@info.WikiUrl" Target="_blank" Typo="Typo.caption"
                                     Style="@($"color:{color};")">@name</MudLink>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="@($"color:{color};")">@name</MudText>
                        }
                    </div>
                }
            </MudPaper>
        </div>
    }

    @* ══════════ TIMELINE SCRUBBER (bottom bar) ══════════ *@
    @if (_mode == "timeline" && _overview is not null)
    {
        <div class="galaxy-timeline-bar">
            @if (_autoplay)
            {
                <div class="timeline-progress" style="--duration: @(_frameTimeMs)ms;"></div>
            }
            @* Era chip bar — renders every era the backend returned for the current
               continuity filter. The container is horizontally scrollable so the list
               can grow without clipping or pushing the map content up. Era ordering
               follows the aggregation pipeline: chronological by StartYear. *@
            <div class="timeline-eras">
                @foreach (var era in _overview.Eras)
                {
                    var isActiveEra = _year >= era.StartYear && _year <= era.EndYear;
                    <button class="era-chip @(isActiveEra ? "active" : "")" @onclick="() => JumpToYear(era.StartYear)"
                            title="@($"{era.Name} ({FormatYear(era.StartYear)}{(era.EndYear != era.StartYear ? $" – {FormatYear(era.EndYear)}" : "")})")">@era.Name</button>
                }
            </div>
            <div class="timeline-controls">
                <!-- Playback controls (left) -->
                <MudIconButton Icon="@(_autoplay ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                               Size="Size.Medium" OnClick="ToggleAutoplay" Color="Color.Primary"
                               title="@(_autoplay ? "Pause" : "Play")" Style="flex-shrink:0;" />
                <MudSelect T="int" Value="_frameTimeMs" ValueChanged="OnFrameTimeChanged" Dense="true" Variant="Variant.Outlined"
                           Style="min-width:80px;max-width:80px;font-size:13px;flex:0 0 80px;" title="Frame speed">
                    <MudSelectItem Value="2000">2s</MudSelectItem>
                    <MudSelectItem Value="5000">5s</MudSelectItem>
                    <MudSelectItem Value="10000">10s</MudSelectItem>
                    <MudSelectItem Value="30000">30s</MudSelectItem>
                </MudSelect>

                <!-- Year navigation -->
                <MudIconButton Icon="@Icons.Material.Filled.SkipPrevious" Size="Size.Medium" OnClick="StepPrevious"
                               title="Previous year" Style="flex-shrink:0;" />
                <MudText Typo="Typo.h6" Style="min-width:110px;text-align:center;font-weight:700;color:rgba(255,255,255,0.9);white-space:nowrap;flex-shrink:0;">
                    @(_yearData?.YearDisplay ?? "—")
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.SkipNext" Size="Size.Medium" OnClick="StepNext"
                               title="Next year" Style="flex-shrink:0;" />

                <!-- Scrollable density bar -->
                <div class="density-viewport" id="density-viewport">
                    <div class="density-bar" style="width:@(FilteredDensity.Count * _tickWidth)px;">
                        @if (FilteredDensity.Count > 0)
                        {
                            var maxLog = Math.Log(Math.Max(2, FilteredDensity.Max(d => d.Count)));
                            @foreach (var d in FilteredDensity)
                            {
                                var h = d.Count > 0 ? Math.Max(4, (int)(38.0 * Math.Log(d.Count) / maxLog)) : 2;
                                var isActive = d.Year == _year;
                                var w = Math.Max(2, _tickWidth - 1);
                                <div class="density-tick @(isActive ? "active" : "")"
                                     style="@($"height:{h}px;width:{w}px")"
                                     @onclick="() => JumpToYear(d.Year)"
                                     title="@($"{FormatYear(d.Year)}: {d.Count} events")"></div>
                            }
                        }
                    </div>
                </div>

                <!-- Zoom slider -->
                <div class="timeline-zoom" title="Zoom timeline">
                    <MudIcon Icon="@Icons.Material.Filled.ZoomIn" Size="Size.Small" Style="color:rgba(255,255,255,0.4);" />
                    <input type="range" min="3" max="20" step="1" value="@_tickWidth"
                           @oninput="OnTickZoomChanged" />
                </div>
            </div>
        </div>
    }
</div>

@code {
    IJSObjectReference? _module;
    DotNetObjectReference<GalaxyMapUnified>? _dotNetRef;
    bool _mounted;

    // Data
    GalaxyOverviewDocument? _overview;
    GalaxyGeography? _geography;
    record ArticleIntroDto(string Heading, string Text, string WikiUrl, string Type);

    GalaxyYearDocument? _yearData;
    bool _loading = true;
    bool _d3Initialized;

    // Mode
    string _mode = "explore";
    string _selectedLens = "All";
    bool _panelOpen = true;
    bool _detailPanelOpen = true;

    void TogglePanel() => _panelOpen = !_panelOpen;
    void ToggleDetailPanel() => _detailPanelOpen = !_detailPanelOpen;

    // Explore state
    GeoSystem? _selectedSystem;
    GeoRegion? _selectedRegion;
    string _currentLevel = "overview";
    string _currentLabel = "";
    string _cellLabel = "";
    string _regionLabel = "";
    string _sectorLabel = "";
    List<MudBlazor.BreadcrumbItem> _breadcrumbs = [new("", null, disabled: true, icon: Icons.Material.Filled.Explore)];
    bool _onlyWithBodies = true;
    bool _semanticSearch;
    bool _searchLoading;
    string? _searchError;
    bool _showBackground = true;
    bool _showCanonRoutes = true;
    bool _showLegendsRoutes = true;
    bool _showNebulae = true;
    readonly HashSet<string> _hiddenRegions = new();
    string? _sectorSearch;
    string? _hoveredRegionName;
    int _hoveredRegionCellCount;
    string? _hoveredRegionColor;
    string? _searchTerm;
    List<MapSearchResult>? _searchResults;
    WikiPage? _detailPage;
    bool _loadingDetails;
    readonly Dictionary<int, GeoSystem> _systemCache = new();
    Dictionary<string, TerritoryFactionInfo> _factionInfo = new(StringComparer.OrdinalIgnoreCase);

    // Event hover popover state
    public record HoveredCell(string Region, int Col, int Row, double ScreenX, double ScreenY, List<EventPopoverItem> Events);
    public record EventPopoverItem(string Title, string Lens, string? Category, string? Place, string? Outcome, string? WikiUrl, int? PageId, string Continuity);
    HoveredCell? _hoveredCell;
    EventPopoverItem? _hoveredEvent;
    ArticleIntroDto? _hoveredArticle;
    bool _loadingArticle;

    // Timeline state
    int _year;
    int _yearIndex;
    bool _autoplay;
    int _frameTimeMs = 30000;
    int _tickWidth = 6;
    System.Threading.Timer? _autoplayTimer;

    HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");
    string ContinuityQuery => GlobalFilterService.GetContinuityQueryParam() is { } c ? $"continuity={c}" : "";

    IEnumerable<GalaxyYearEventCell> FilteredEventCells
    {
        get
        {
            if (_yearData?.EventCells is null) return [];

            var realLenses = _overview?.Lenses.Where(l => l.IsReal).Select(l => l.Lens).ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new();
            var swLenses = _overview?.Lenses.Where(l => !l.IsReal).Select(l => l.Lens).ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new();

            // Determine which lenses to hide based on realm filter
            var hiddenLenses = GlobalFilterService.SelectedRealm switch
            {
                Realm.Starwars => realLenses,           // hide real-world
                Realm.Real => swLenses,                 // hide in-universe
                _ => new HashSet<string>(),             // null = show both
            };

            var continuityFilter = GlobalFilterService.SelectedContinuity;

            return _yearData.EventCells
                .Select(c => new GalaxyYearEventCell
                {
                    Col = c.Col, Row = c.Row, Region = c.Region,
                    Events = c.Events
                        .Where(e => !hiddenLenses.Contains(e.Lens))
                        .Where(e => continuityFilter is null || e.Continuity == continuityFilter)
                        .Where(e => _selectedLens == "All" || e.Lens == _selectedLens)
                        .ToList(),
                    Count = c.Events
                        .Count(e => !hiddenLenses.Contains(e.Lens)
                            && (continuityFilter is null || e.Continuity == continuityFilter)
                            && (_selectedLens == "All" || e.Lens == _selectedLens)),
                })
                .Where(c => c.Events.Count > 0);
        }
    }

    int FilteredEventCount => FilteredEventCells.Sum(c => c.Events.Count);

    List<int> FilteredYears => FilteredDensity.Select(d => d.Year).ToList();

    List<GalaxyYearDensity> FilteredDensity
    {
        get
        {
            if (_overview?.YearDensity is null) return [];
            var cont = GlobalFilterService.SelectedContinuity;
            return _overview.YearDensity
                .Select(d =>
                {
                    var count = cont switch
                    {
                        Continuity.Canon => d.CanonCount,
                        Continuity.Legends => d.LegendsCount,
                        _ => d.Count // Both or null = all
                    };
                    return new GalaxyYearDensity { Year = d.Year, Count = count, CanonCount = d.CanonCount, LegendsCount = d.LegendsCount, PerLens = d.PerLens };
                })
                .Where(d => d.Count > 0)
                .ToList();
        }
    }

    List<GeoCellSector> AllSectors => _geography?.Cells
        .Where(c => c.Sectors is not null)
        .SelectMany(c => c.Sectors!)
        .GroupBy(s => s.Name, StringComparer.OrdinalIgnoreCase)
        .Select(g => new GeoCellSector { Name = g.Key, Count = g.Sum(s => s.Count) })
        .OrderByDescending(s => s.Count)
        .ToList() ?? [];

    IEnumerable<GeoCellSector> FilteredSectors =>
        string.IsNullOrWhiteSpace(_sectorSearch)
            ? AllSectors.Take(50)
            : AllSectors.Where(s => s.Name.Contains(_sectorSearch, StringComparison.OrdinalIgnoreCase)).Take(50);

    IEnumerable<string> ActiveFactions =>
        _yearData?.Regions.SelectMany(r => r.Factions).Select(f => f.Faction).Distinct().OrderBy(f => f)
        ?? Enumerable.Empty<string>();

    IEnumerable<GalaxyLensSummary> FilteredLenses =>
        _overview?.Lenses.Where(l => GlobalFilterService.SelectedRealm switch
        {
            Realm.Starwars => !l.IsReal,
            Realm.Real => l.IsReal,
            _ => true, // null = show both
        }) ?? [];

    // ══════════ LIFECYCLE ══════════

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnFilterChanged;
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_mounted)
        {
            _mounted = true;
            StateHasChanged();
        }

        if (!_d3Initialized && _geography is not null)
        {
            _d3Initialized = true;
            try
            {
                _dotNetRef?.Dispose();
                _dotNetRef = DotNetObjectReference.Create(this);
                _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/galaxy-map-unified.js");
                await _module.InvokeVoidAsync("initialize", "galaxy-map-root", _geography, _dotNetRef);
                await _module.InvokeVoidAsync("setupPanelHoverListeners", "galaxy-map-panel");
                await _module.InvokeVoidAsync("setupSearchResultHover");
                if (_onlyWithBodies)
                    await _module.InvokeVoidAsync("setSystemFilter", true);
            }
            catch (ObjectDisposedException) { _d3Initialized = false; }
            catch (JSDisconnectedException) { }
        }
    }

    async Task LoadData()
    {
        _loading = true;
        try
        {
            var cq = ContinuityQuery;
            var geoUrl = string.IsNullOrEmpty(cq) ? "api/galaxy-map/geography" : $"api/galaxy-map/geography?{cq}";
            var overviewUrl = string.IsNullOrEmpty(cq) ? "api/galaxy-map" : $"api/galaxy-map?{cq}";
            var geoTask = Http.GetFromJsonAsync<GalaxyGeography>(geoUrl);
            var overviewTask = Http.GetFromJsonAsync<GalaxyOverviewDocument>(overviewUrl);
            _geography = await geoTask;
            try { _overview = await overviewTask; } catch { }

            if (_overview is not null)
            {
                try { _factionInfo = await Http.GetFromJsonAsync<Dictionary<string, TerritoryFactionInfo>>("api/galaxy-map/factions") ?? _factionInfo; }
                catch { }
            }

            if (_overview?.AvailableYears.Count > 0)
            {
                _year = FilteredYears[0];
                _yearIndex = 0;
            }
        }
        catch { }
        finally { _loading = false; }
    }

    // ══════════ MODE SWITCHING ══════════

    async Task OnModeChanged(string mode)
    {
        _mode = mode;
        if (mode == "timeline")
        {
            _hoveredRegionName = null;
            ClearDetailPanel();
            await LoadYear();
        }
        else
        {
            if (_autoplay) { _autoplay = false; StopAutoplayTimer(); }
            if (_module is not null)
                await _module.InvokeVoidAsync("clearTemporalLayers");
        }
        StateHasChanged();
    }

    // ══════════ EXPLORE: JSInvokable callbacks ══════════

    [JSInvokable]
    public async Task<GalaxyGeographySystems?> FetchSystemsInRange(int minCol, int maxCol, int minRow, int maxRow)
    {
        try
        {
            var cq = ContinuityQuery;
            var url = $"api/galaxy-map/systems?minCol={minCol}&maxCol={maxCol}&minRow={minRow}&maxRow={maxRow}";
            if (!string.IsNullOrEmpty(cq)) url += $"&{cq}";
            var result = await Http.GetFromJsonAsync<GalaxyGeographySystems>(url);
            if (result?.Systems is not null)
                foreach (var sys in result.Systems) _systemCache.TryAdd(sys.Id, sys);
            return result;
        }
        catch { return null; }
    }

    [JSInvokable]
    public void OnLevelChanged(string level, string label)
    {
        _currentLevel = level;
        _currentLabel = label;
        switch (level)
        {
            case "overview": _cellLabel = ""; _regionLabel = ""; _sectorLabel = ""; _selectedRegion = null; break;
            case "region":
                _regionLabel = label; _cellLabel = ""; _sectorLabel = "";
                _selectedRegion = _geography?.Regions.FirstOrDefault(r => r.Name == label);
                break;
            case "cell":
                _cellLabel = label; _sectorLabel = "";
                break;
            case "sector":
                _sectorLabel = label;
                break;
        }
        _hoveredRegionName = null;
        UpdateBreadcrumbs();
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnRegionHovered(string name, int cellCount, string color)
    {
        _hoveredRegionName = name; _hoveredRegionCellCount = cellCount; _hoveredRegionColor = color;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnRegionUnhovered() { _hoveredRegionName = null; InvokeAsync(StateHasChanged); }

    [JSInvokable]
    public void OnSystemSelected(int systemId, string systemName)
    {
        _systemCache.TryGetValue(systemId, out _selectedSystem);
        if (_detailPage is null && _selectedSystem is not null) _ = LoadPageDetail(systemId);
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnCelestialBodySelected(int bodyId, string bodyName) => InvokeAsync(() => LoadPageDetail(bodyId));

    [JSInvokable]
    public void OnSystemDeselected()
    {
        _selectedSystem = null; _detailPage = null;
        InvokeAsync(StateHasChanged);
    }

