@page "/tables"
@rendermode InteractiveAuto
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Data Tables — Star Wars Data</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Data Tables</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
    Browse Star Wars data by category. Select a category and use the search box to filter results.
</MudText>

@if (_categories == null)
{
    <MudProgressCircular Color="Color.Default" Indeterminate="true"/>
}
else
{
    <MudSelect
        T="string"
        Value="_category"
        ValueChanged="@CategoryChanged"
        Label="Category"
        Variant="Variant.Outlined"
        Class="mb-4"
        Placeholder="Select a category">

        @foreach (var item in _categories)
        {
            <MudSelectItem Value="@item" T="string">
                @FormatCategoryName(item)
            </MudSelectItem>
        }

    </MudSelect>
}

@if (_category is not null)
{
    <MudTextField @bind-Value="_searchText"
                  Label="Search"
                  Variant="Variant.Outlined"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="false"
                  DebounceInterval="500"
                  OnDebounceIntervalElapsed="OnSearchChanged"
                  Clearable="true"
                  Class="mb-4"
                  Placeholder="Filter by name or property..." />

    <MudTable
        ServerData="ServerReload"
        FixedHeader="true"
        FixedFooter="true"
        Height="1000px"
        ReadOnly="true"
        Dense="true"
        @ref="_table"
        Bordered="true"
        Striped="true"
        HorizontalScrollbar="true">

        <HeaderContent>
            <MudTh>Page</MudTh>
            <MudTh>Image</MudTh>
            @foreach (var item in DynamicHeaders)
            {
                <MudTh>@item</MudTh>
            }
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Page">
                <MudLink Href="@context.WikiUrl">@context.PageTitle</MudLink>
            </MudTd>
            <MudTd DataLabel="Image">
                @if (!string.IsNullOrEmpty(context.ImageUrl))
                {
                    <img src="@context.ImageUrl.Split("/revision", StringSplitOptions.RemoveEmptyEntries)[0]" style="max-height:150px;width:auto;display:block;" />
                }
            </MudTd>
            @foreach (var label in DynamicHeaders)
            {
                var data = context.Data.FirstOrDefault(d => d.Label == label);

                <MudTd DataLabel="@label">
                    @if (data is not null)
                    {
                        <MudList T="string" Gutters="false" Padding="false" Dense="true">
                            @foreach (var link in data.Links)
                            {
                                <MudListItem Dense="true" Gutters="false" Ripple="false">
                                    <MudLink Class="ma-1" Href="@link.Href">@link.Content</MudLink>
                                </MudListItem>
                            }
                            @foreach (var value in data.Values.Where(v => !data.Links.Any(l => l.Content.Equals(v, StringComparison.OrdinalIgnoreCase))))
                            {
                                <MudListItem Dense="true" Gutters="false" Ripple="false">@value</MudListItem>
                            }
                        </MudList>
                    }
                </MudTd>
            }
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No matching records found</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Loading...</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager/>
        </PagerContent>
    </MudTable>
}

@code {

    private string[]? _categories;
    private string? _category;
    private string? _searchText;

    private MudTable<Infobox>? _table;
    private PagedResult? _pagedResult;

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    private IEnumerable<string> DynamicHeaders
    {
        get
        {
            if (_pagedResult is not null)
            {
                foreach (var item in _pagedResult.Items.SelectMany(record => record.Data.Select(property => property.Label).OrderBy(v => v)).Distinct())
                {
                    yield return item;
                }
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        string[]? categories = (await Http.GetFromJsonAsync<string[]>("Categories"))!;
        _categories = categories.OrderBy(x => x).ToArray();
    }

    private async Task<TableData<Infobox>> ServerReload(TableState state, CancellationToken ct)
    {
        if (_category == null)
            return new TableData<Infobox>() { Items = Enumerable.Empty<Infobox>(), TotalItems = 0 };

        var encoded = Uri.EscapeDataString(_category);
        var url = $"Categories/{encoded}?Page={(state.Page + 1)}&PageSize={state.PageSize}";

        if (!string.IsNullOrWhiteSpace(_searchText))
            url += $"&Search={Uri.EscapeDataString(_searchText)}";

        _pagedResult = await Http.GetFromJsonAsync<PagedResult>(url, ct);

        return new TableData<Infobox>() { TotalItems = _pagedResult!.Total, Items = _pagedResult.Items };
    }

    private Task CategoryChanged(string arg)
    {
        _category = arg;
        _searchText = null;

        if (_table is not null)
            return _table.ReloadServerData();

        return Task.CompletedTask;
    }

    private Task OnSearchChanged(string _)
    {
        if (_table is not null)
            return _table.ReloadServerData();

        return Task.CompletedTask;
    }

    private static string FormatCategoryName(string category) =>
        category.Replace("_infobox", "").Replace("_", " ");
}
