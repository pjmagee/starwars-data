@page "/tables"
@inject IHttpClientFactory HttpClientFactory
@inject GlobalFilterService GlobalFilterService
@implements IDisposable

<PageTitle>Data Tables — Star Wars Data</PageTitle>
<HeadContent>
    <meta name="description" content="Browse Star Wars data tables — characters, planets, starships, species, weapons, governments, and more. Searchable, sortable, and paginated." />
</HeadContent>

@if (_categories == null)
{
    <MudProgressCircular Color="Color.Default" Indeterminate="true"/>
}
else
{
    <MudSelect
        T="string"
        Value="_category"
        ValueChanged="@CategoryChanged"
        Label="Category"
        Variant="Variant.Outlined"
        Class="mb-4"
        Placeholder="Select a category">

        @foreach (var item in _categories)
        {
            <MudSelectItem Value="@item" T="string">
                @FormatCategoryName(item)
            </MudSelectItem>
        }

    </MudSelect>
}

@if (_category is not null)
{
    <MudDataGrid T="Infobox"
                 ServerData="ServerReload"
                 @ref="_grid"
                 FixedHeader="true"
                 FixedFooter="true"
                 Height="1000px"
                 Dense="true"
                 Bordered="true"
                 Striped="true"
                 Hideable="true"
                 ColumnResizeMode="ResizeMode.Column">
        <ToolBarContent>
            <MudText Typo="Typo.h6">@FormatCategoryName(_category)</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchText"
                          Placeholder="Search all data..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="false"
                          DebounceInterval="500"
                          OnDebounceIntervalElapsed="OnSearchChanged"
                          Clearable="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="max-width:300px" />
        </ToolBarContent>
        <Columns>
            <TemplateColumn T="Infobox" Title="Page" Sortable="true" SortBy="@(x => x.PageTitle)">
                <CellTemplate>
                    <MudLink Href="@context.Item.WikiUrl">@context.Item.PageTitle</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="Infobox" Title="Image" Sortable="false" Filterable="false">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.ImageUrl))
                    {
                        <img src="@context.Item.ImageUrl.Split("/revision", StringSplitOptions.RemoveEmptyEntries)[0]" style="max-height:150px;width:auto;display:block;" />
                    }
                </CellTemplate>
            </TemplateColumn>
            @foreach (var header in _dynamicHeaders)
            {
                var label = header;
                <TemplateColumn T="Infobox" Title="@label" Sortable="true"
                                SortBy="@(x => x.Data.FirstOrDefault(d => d.Label == label)?.Values.FirstOrDefault() ?? "")">
                    <CellTemplate>
                        @{ var data = context.Item.Data.FirstOrDefault(d => d.Label == label); }
                        @if (data is not null)
                        {
                            @foreach (var link in data.Links)
                            {
                                <MudLink Class="ma-1" Href="@link.Href">@link.Content</MudLink>
                            }
                            @foreach (var value in data.Values.Where(v => !data.Links.Any(l => l.Content.Equals(v, StringComparison.OrdinalIgnoreCase))))
                            {
                                <MudText Typo="Typo.body2">@value</MudText>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
            }
        </Columns>
        <NoRecordsContent>
            <MudText>No matching records found</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Loading...</MudText>
        </LoadingContent>
        <PagerContent>
            <MudDataGridPager T="Infobox" />
        </PagerContent>
    </MudDataGrid>
}

@code {

    private string[]? _categories;
    private string? _category;
    private string? _searchText;

    private MudDataGrid<Infobox>? _grid;
    private string[] _dynamicHeaders = [];

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnGlobalFilterChanged;
        string[]? categories = (await Http.GetFromJsonAsync<string[]>("Categories"))!;
        _categories = categories.OrderBy(x => x).ToArray();
    }

    private async void OnGlobalFilterChanged()
    {
        await InvokeAsync(async () =>
        {
            if (_grid is not null)
                await _grid.ReloadServerData();
        });
    }

    public void Dispose()
    {
        GlobalFilterService.OnChange -= OnGlobalFilterChanged;
    }

    private async Task<GridData<Infobox>> ServerReload(GridState<Infobox> state, CancellationToken ct)
    {
        if (_category == null)
            return new GridData<Infobox> { Items = [], TotalItems = 0 };

        try
        {
            var encoded = Uri.EscapeDataString(_category);
            var qs = System.Web.HttpUtility.ParseQueryString(string.Empty);
            qs["Page"] = (state.Page + 1).ToString();
            qs["PageSize"] = state.PageSize.ToString();
            if (!string.IsNullOrWhiteSpace(_searchText))
                qs["Search"] = _searchText;
            var cont = GlobalFilterService.GetContinuityQueryParam();
            if (!string.IsNullOrEmpty(cont))
                qs["continuity"] = cont;
            var realm = GlobalFilterService.GetRealmQueryParam();
            if (!string.IsNullOrEmpty(realm))
                qs["realm"] = realm;

            var url = $"Categories/{encoded}?{qs}";
            var result = await Http.GetFromJsonAsync<PagedResult>(url, ct);

            _dynamicHeaders = result!.Items
                .SelectMany(r => r.Data.Select(p => p.Label))
                .Where(l => l is not null)
                .Cast<string>()
                .Distinct()
                .OrderBy(l => l)
                .ToArray();

            return new GridData<Infobox> { TotalItems = result.Total, Items = result.Items };
        }
        catch (OperationCanceledException)
        {
            return new GridData<Infobox> { Items = [], TotalItems = 0 };
        }
    }

    private async Task CategoryChanged(string arg)
    {
        _category = arg;
        _searchText = null;
        _dynamicHeaders = [];

        if (_grid is not null)
            await _grid.ReloadServerData();
    }

    private async Task OnSearchChanged(string _)
    {
        if (_grid is not null)
            await _grid.ReloadServerData();
    }

    private static string FormatCategoryName(string category) =>
        category.Replace("_infobox", "").Replace("_", " ");
}
