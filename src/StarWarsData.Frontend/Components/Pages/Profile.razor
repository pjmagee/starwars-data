@page "/profile"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@inject EndpointService EndpointService
@inject NavigationManager NavigationManager
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<PageTitle>Profile</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="my-16 px-8">
    <MudText Typo="Typo.h3" GutterBottom="true" Class="mb-6">Profile</MudText>

    <AuthorizeView>
        <Authorized>
            @{
                var user = context.User;
                var name = user.FindFirst("name")?.Value
                           ?? user.FindFirst(ClaimTypes.Name)?.Value;
                var preferredUsername = user.FindFirst("preferred_username")?.Value;
                var email = user.FindFirst("email")?.Value
                            ?? user.FindFirst(ClaimTypes.Email)?.Value;
                var emailVerified = user.FindFirst("email_verified")?.Value;
                var sub = user.FindFirst("sub")?.Value
                          ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                var roles = user.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();
            }

            <!-- User Info Card -->
            <MudPaper Class="pa-6 mb-6" Elevation="2">
                <div class="d-flex align-center mb-6">
                    <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h5">@(name ?? preferredUsername ?? "Unknown User")</MudText>
                        @if (!string.IsNullOrEmpty(email))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@email</MudText>
                        }
                    </div>
                </div>

                <MudDivider Class="mb-4" />

                <MudSimpleTable Dense="true" Hover="true" Bordered="false" Striped="false" Class="mb-4">
                    <tbody>
                        @if (!string.IsNullOrEmpty(preferredUsername))
                        {
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Username</MudText></td>
                                <td><MudText Typo="Typo.body1">@preferredUsername</MudText></td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(name))
                        {
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Name</MudText></td>
                                <td><MudText Typo="Typo.body1">@name</MudText></td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(email))
                        {
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Email</MudText></td>
                                <td>
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.body1">@email</MudText>
                                        @if (emailVerified == "true")
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Small" />
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (roles.Any())
                        {
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">Roles</MudText></td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var role in roles)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@role</MudChip>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>

            <!-- OpenAI API Key (BYOK) -->
            <MudPaper Class="pa-6 mb-6" Elevation="2">
                <MudText Typo="Typo.h5" Class="mb-2">OpenAI API Key</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Provide your own OpenAI API key to use with the Ask AI feature.
                    This removes rate limits and uses your own API quota instead of the server's.
                    Your key is encrypted and stored securely.
                </MudText>

                @if (_byokLoading)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                }
                else if (_hasOpenAiKey)
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Class="mb-4">
                        Your OpenAI API key is configured. Ask AI will use your key with no rate limits.
                    </MudAlert>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="() => _showKeyInput = true"
                                   Disabled="_byokSaving">
                            Replace Key
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   OnClick="RemoveKeyAsync"
                                   Disabled="_byokSaving">
                            Remove Key
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-4">
                        No API key configured. You are using the server's shared key with rate limits
                        (6 requests per 30 minutes).
                    </MudAlert>
                }

                @if (!_hasOpenAiKey || _showKeyInput)
                {
                    <MudStack Spacing="2" Class="mt-4">
                        <MudTextField @bind-Value="_apiKeyInput"
                                      Label="OpenAI API Key"
                                      Placeholder="sk-..."
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Password"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Key"
                                      HelperText="Your key is encrypted at rest and only used for Ask AI requests."
                                      Disabled="_byokSaving" />
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveKeyAsync"
                                       Disabled="@(string.IsNullOrWhiteSpace(_apiKeyInput) || _byokSaving)">
                                @(_byokSaving ? "Saving..." : "Save Key")
                            </MudButton>
                            @if (_showKeyInput)
                            {
                                <MudButton Variant="Variant.Text" OnClick="() => { _showKeyInput = false; _apiKeyInput = string.Empty; }">
                                    Cancel
                                </MudButton>
                            }
                        </MudStack>
                    </MudStack>
                }

                @if (_byokError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_byokError</MudAlert>
                }
            </MudPaper>

            <!-- Linked Accounts -->
            <MudPaper Class="pa-6 mb-6" Elevation="2">
                <MudText Typo="Typo.h5" Class="mb-2">Linked Accounts</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Manage your social login connections. Link or unlink accounts through the Keycloak Account Console.
                </MudText>

                <MudStack Spacing="2" Class="mb-4">
                    <MudPaper Class="pa-3" Outlined="true">
                        <div class="d-flex align-center justify-space-between">
                            <div class="d-flex align-center gap-3">
                                <MudIcon Icon="@Icons.Custom.Brands.Microsoft" />
                                <MudText Typo="Typo.body1">Microsoft</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">Available</MudChip>
                        </div>
                    </MudPaper>

                    <MudPaper Class="pa-3" Outlined="true">
                        <div class="d-flex align-center justify-space-between">
                            <div class="d-flex align-center gap-3">
                                <MudIcon Icon="@Icons.Custom.Brands.Facebook" />
                                <MudText Typo="Typo.body1">Facebook</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">Available</MudChip>
                        </div>
                    </MudPaper>

                    <MudPaper Class="pa-3" Outlined="true">
                        <div class="d-flex align-center justify-space-between">
                            <div class="d-flex align-center gap-3">
                                <MudIcon Icon="@Icons.Custom.Brands.Google" />
                                <MudText Typo="Typo.body1">Google</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Not configured</MudChip>
                        </div>
                    </MudPaper>
                </MudStack>

                @if (_keycloakLinkedAccountsUrl is not null)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Link"
                               Href="@_keycloakLinkedAccountsUrl" Target="_blank">
                        Manage Linked Accounts
                    </MudButton>
                }
            </MudPaper>

            <!-- Account Management -->
            <MudPaper Class="pa-6 mb-6" Elevation="2">
                <MudText Typo="Typo.h5" Class="mb-2">Account Settings</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Update your username, password, and personal information through the Keycloak Account Console.
                </MudText>

                <MudStack Row="true" Spacing="2">
                    @if (_keycloakAccountUrl is not null)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ManageAccounts"
                                   Href="@_keycloakAccountUrl" Target="_blank">
                            Edit Profile
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Security"
                                   Href="@_keycloakSecurityUrl" Target="_blank">
                            Security Settings
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>

            <!-- Data & Privacy -->
            <MudPaper Class="pa-6 mb-6" Elevation="2">
                <MudText Typo="Typo.h5" Class="mb-2">Data &amp; Privacy</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Under UK GDPR, you have the right to access and delete your personal data.
                    You can export all your data as a JSON file, or permanently delete everything.
                </MudText>

                <MudStack Row="true" Spacing="2" Class="mb-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Download"
                               OnClick="ExportDataAsync"
                               Disabled="_exportInProgress">
                        @(_exportInProgress ? "Exporting..." : "Export My Data")
                    </MudButton>
                </MudStack>

                @if (_exportError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_exportError</MudAlert>
                }

                @if (_deleteSuccess)
                {
                    <MudAlert Severity="Severity.Success" Dense="true">All your data has been deleted.</MudAlert>
                }
                else if (!_confirmDelete)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.DeleteForever"
                               OnClick="() => _confirmDelete = true"
                               Disabled="_deleteInProgress">
                        Delete All My Data
                    </MudButton>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                        Are you sure? This will permanently delete all your chat sessions, API keys, and settings.
                    </MudAlert>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.DeleteForever"
                                   OnClick="DeleteAllDataAsync"
                                   Disabled="_deleteInProgress">
                            @(_deleteInProgress ? "Deleting..." : "Yes, Delete Everything")
                        </MudButton>
                        <MudButton Variant="Variant.Text"
                                   OnClick="() => _confirmDelete = false"
                                   Disabled="_deleteInProgress">
                            Cancel
                        </MudButton>
                    </MudStack>
                }

                @if (_deleteError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_deleteError</MudAlert>
                }
            </MudPaper>

            <!-- Sign Out -->
            <MudPaper Class="pa-6" Elevation="2">
                <MudButton Variant="Variant.Filled" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Logout"
                           Href="/authentication/logout" FullWidth="true" Size="Size.Large">
                    Sign Out
                </MudButton>
            </MudPaper>
        </Authorized>
    </AuthorizeView>
</MudContainer>

@code {
    private string? _keycloakAccountUrl;
    private string? _keycloakLinkedAccountsUrl;
    private string? _keycloakSecurityUrl;
    private string? _userId;

    // BYOK state
    private bool _hasOpenAiKey;
    private bool _byokLoading = true;
    private bool _byokSaving;
    private bool _showKeyInput;
    private string _apiKeyInput = string.Empty;
    private string? _byokError;

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var keycloakBaseUrl = EndpointService.GetKeycloakAccountUrl();
        if (keycloakBaseUrl is not null)
        {
            _keycloakAccountUrl = keycloakBaseUrl;
            _keycloakLinkedAccountsUrl = $"{keycloakBaseUrl}/#/security/linked-accounts";
            _keycloakSecurityUrl = $"{keycloakBaseUrl}/#/security/signingin";
        }

        if (AuthState is not null)
        {
            var state = await AuthState;
            _userId = state.User.FindFirst("sub")?.Value
                      ?? state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }

        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/user/settings");
            if (response.IsSuccessStatusCode)
            {
                var settings = await response.Content.ReadFromJsonAsync<UserSettingsResponse>();
                _hasOpenAiKey = settings?.HasOpenAiKey == true;
            }
        }
        catch { }
        finally
        {
            _byokLoading = false;
        }
    }

    private async Task SaveKeyAsync()
    {
        if (string.IsNullOrWhiteSpace(_apiKeyInput)) return;

        _byokSaving = true;
        _byokError = null;
        StateHasChanged();

        try
        {
            var response = await Http.PutAsJsonAsync("api/user/settings/openai-key", new { apiKey = _apiKeyInput });

            if (response.IsSuccessStatusCode)
            {
                _hasOpenAiKey = true;
                _apiKeyInput = string.Empty;
                _showKeyInput = false;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _byokError = error?.Error ?? "Failed to save API key.";
            }
        }
        catch (Exception ex)
        {
            _byokError = $"Error: {ex.Message}";
        }
        finally
        {
            _byokSaving = false;
        }
    }

    private async Task RemoveKeyAsync()
    {
        _byokSaving = true;
        _byokError = null;
        StateHasChanged();

        try
        {
            var response = await Http.DeleteAsync("api/user/settings/openai-key");

            if (response.IsSuccessStatusCode)
            {
                _hasOpenAiKey = false;
                _showKeyInput = false;
            }
            else
            {
                _byokError = "Failed to remove API key.";
            }
        }
        catch (Exception ex)
        {
            _byokError = $"Error: {ex.Message}";
        }
        finally
        {
            _byokSaving = false;
        }
    }

    // Export data state
    private bool _exportInProgress;
    private string? _exportError;

    // Delete all data state
    private bool _confirmDelete;
    private bool _deleteInProgress;
    private bool _deleteSuccess;
    private string? _deleteError;

    private async Task DeleteAllDataAsync()
    {
        _deleteInProgress = true;
        _deleteError = null;
        StateHasChanged();

        try
        {
            var response = await Http.DeleteAsync("api/user/settings/all-data");
            if (response.IsSuccessStatusCode)
            {
                _deleteSuccess = true;
                _confirmDelete = false;
                _hasOpenAiKey = false;
            }
            else
            {
                _deleteError = "Failed to delete data. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _deleteError = $"Error: {ex.Message}";
        }
        finally
        {
            _deleteInProgress = false;
        }
    }

    private async Task ExportDataAsync()
    {
        _exportInProgress = true;
        _exportError = null;
        StateHasChanged();

        try
        {
            var response = await Http.GetAsync("api/user/settings/export");
            if (response.IsSuccessStatusCode)
            {
                var bytes = await response.Content.ReadAsByteArrayAsync();
                var fileName = $"swdata-export-{DateTime.UtcNow:yyyy-MM-dd}.json";
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("eval",
                    $"(function(){{var a=document.createElement('a');a.href='data:application/json;base64,{base64}';a.download='{fileName}';document.body.appendChild(a);a.click();a.remove();}})()");
            }
            else
            {
                _exportError = "Failed to export data. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _exportError = $"Error: {ex.Message}";
        }
        finally
        {
            _exportInProgress = false;
        }
    }

    private record UserSettingsResponse(bool HasOpenAiKey, DateTime? UpdatedAt);
    private record ErrorResponse(string? Error);
}
