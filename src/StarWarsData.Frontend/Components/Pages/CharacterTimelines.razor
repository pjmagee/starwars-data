    protected override async Task OnInitializedAsync()
    {
        GlobalFilterService.OnChange += OnGlobalFilterChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (PageId is not null)
        {
            StopActiveGenPolling();
            await LoadDetailPage();
        }
        else
        {
            _characterInfo = null;
            _timeline = null;
            _generationStatus = null;
            StopPolling();

            await LoadActiveGenerations();
            StartActiveGenPolling();
        }
    }

    public void Dispose()
    {
        GlobalFilterService.OnChange -= OnGlobalFilterChanged;
        _pollTimer?.Dispose();
        _activeGenPollTimer?.Dispose();
    }

    private async void OnGlobalFilterChanged()
    {
        if (PageId is not null) return;

        await InvokeAsync(async () =>
        {
            // Re-run active search if the user changed continuity/realm
            if (!string.IsNullOrWhiteSpace(_search))
                await OnSearchChanged(_search);

            if (_table is not null)
                await _table.ReloadServerData();

            StateHasChanged();
        });
    }

    // ── Page title ──

    private string GetPageTitle()
    {
        if (_characterInfo is not null) return $"{_characterInfo.Title} — Character Timeline";
        if (_timeline is not null) return $"{_timeline.CharacterTitle} — Character Timeline";
        return "Character Timelines";
    }

    // ── Search ──

    private async Task OnSearchChanged(string value)
    {
        _search = value;
        if (string.IsNullOrWhiteSpace(value))
        {
            _searchResults = null;
            return;
        }

        _searching = true;
        StateHasChanged();

        try
        {
            var query = System.Web.HttpUtility.ParseQueryString(string.Empty);
            query.Add("query", _search);

            var continuity = GlobalFilterService.GetContinuityQueryParam();
            if (!string.IsNullOrEmpty(continuity))
                query.Add("continuity", continuity);

            _searchResults = await Http.GetFromJsonAsync<List<CharacterSearchResult>>($"CharacterTimelines/search?{query}");
        }
        finally
        {
            _searching = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnSearchRowClick(TableRowClickEventArgs<CharacterSearchResult> args)
    {
        if (args.Item is not null)
            NavigateToTimeline(args.Item.PageId);
    }

    // ── Table server data ──

    private async Task<TableData<CharacterTimelineSummary>> LoadServerData(TableState state, CancellationToken ct)
    {
        _tableLoading = true;

        try
        {
            var query = System.Web.HttpUtility.ParseQueryString(string.Empty);
            query.Add("page", (state.Page + 1).ToString()); // MudTable is 0-based, API is 1-based
            query.Add("pageSize", state.PageSize.ToString());

            if (!string.IsNullOrWhiteSpace(_tableSearch))
                query.Add("search", _tableSearch);

            var continuity = GlobalFilterService.GetContinuityQueryParam();
            if (!string.IsNullOrEmpty(continuity))
                query.Add("continuity", continuity);

            if (!string.IsNullOrEmpty(state.SortLabel))
            {
                query.Add("sort", state.SortLabel);
                query.Add("sortDirection", state.SortDirection.ToString());
            }

            var result = await Http.GetFromJsonAsync<CharacterTimelineListResult>(
                $"CharacterTimelines/list?{query}", ct);

            return new TableData<CharacterTimelineSummary>
            {
                Items = result?.Items ?? [],
                TotalItems = result?.Total ?? 0,
            };
        }
        catch
        {
            return new TableData<CharacterTimelineSummary> { Items = [], TotalItems = 0 };
        }
        finally
        {
            _tableLoading = false;
        }
    }

    private async Task OnTableSearchChanged(string value)
    {
        _tableSearch = value;
        if (_table is not null)
            await _table.ReloadServerData();
    }

    private void OnRowClick(TableRowClickEventArgs<CharacterTimelineSummary> args)
    {
        if (args.Item is not null)
            NavigateToTimeline(args.Item.CharacterPageId);
    }

    // ── Active generations (landing page) ──

    private async Task LoadActiveGenerations()
    {
        try
        {
            _activeGenerations = await Http.GetFromJsonAsync<List<ActiveGenerationDto>>("CharacterTimelines/active");
        }
        catch
        {
            _activeGenerations = null;
        }
    }

    private void StartActiveGenPolling()
    {
        StopActiveGenPolling();
        _activeGenPollTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadActiveGenerations();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    private void StopActiveGenPolling()
    {
        _activeGenPollTimer?.Dispose();
        _activeGenPollTimer = null;
    }

    // ── Detail page loading ──

    private async Task LoadDetailPage()
    {
        _loading = true;
        _timeline = null;
        _generationStatus = null;
        StateHasChanged();

        try
        {
            // Load character info (always available from Pages collection)
            try
            {
                _characterInfo = await Http.GetFromJsonAsync<CharacterSearchResult>($"CharacterTimelines/{PageId}/character");
            }
            catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _characterInfo = null;
            }

            // Try to load existing timeline
            try
            {
                _timeline = await Http.GetFromJsonAsync<CharacterTimeline>($"CharacterTimelines/{PageId}");
            }
            catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _timeline = null;
            }

            // Check generation status
            try
            {
                _generationStatus = await Http.GetFromJsonAsync<GenerationStatus>($"CharacterTimelines/{PageId}/status");
            }
            catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _generationStatus = null;
            }

            if (_timeline is not null)
            {
                _eventTypes = _timeline.Events
                    .Select(e => e.EventType)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(e => e)
                    .ToList();
                _selectedEventTypes = _eventTypes.ToList();
            }

            // If generation is in progress, start polling
            if (_generationStatus is not null
                && _generationStatus.Stage is not (GenerationStage.Complete or GenerationStage.Failed))
            {
                StartPolling();
            }
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Generate ──

    private async Task StartGeneration()
    {
        if (PageId is null) return;

        try
        {
            var response = await Http.PostAsync($"CharacterTimelines/{PageId}/generate", null);
            if (response.IsSuccessStatusCode)
            {
                _generationStatus = new GenerationStatus
                {
                    Stage = GenerationStage.Queued,
                    Message = "Queued for generation...",
                    StartedAt = DateTime.UtcNow,
                };
                StateHasChanged();
                StartPolling();
            }
        }
        catch (Exception)
        {
            // Conflict = already running, refresh status
            await PollStatus();
        }
    }

    // ── Polling ──

    private void StartPolling()
    {
        if (_pollTimer is not null) return;

        _pollTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await PollStatus();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private void StopPolling()
    {
        _pollTimer?.Dispose();
        _pollTimer = null;
    }

    private async Task PollStatus()
    {
        if (PageId is null) return;

        try
        {
            _generationStatus = await Http.GetFromJsonAsync<GenerationStatus>($"CharacterTimelines/{PageId}/status");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _generationStatus = null;
        }

        if (_generationStatus?.Stage == GenerationStage.Complete)
        {
            StopPolling();

            // Reload the timeline
            try
            {
                _timeline = await Http.GetFromJsonAsync<CharacterTimeline>($"CharacterTimelines/{PageId}");
                if (_timeline is not null)
                {
                    _eventTypes = _timeline.Events
                        .Select(e => e.EventType)
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .OrderBy(e => e)
                        .ToList();
                    _selectedEventTypes = _eventTypes.ToList();

                    if (_characterInfo is not null)
                        _characterInfo.HasTimeline = true;
                }
            }
            catch { /* timeline will load on next page visit */ }
        }
        else if (_generationStatus?.Stage == GenerationStage.Failed)
        {
            StopPolling();
        }
    }

    private void NavigateToTimeline(int pageId) =>
        Navigation.NavigateTo($"/character-timelines/{pageId}");

    // ── Step state ──

    private StepState GetStepState(GenerationStage stepStage)
    {
        if (_generationStatus is null) return StepState.Pending;

        if (_generationStatus.Stage == GenerationStage.Failed)
        {
            // All steps up to current are complete, current is failed
            return stepStage < _generationStatus.Stage ? StepState.Complete
                 : stepStage == _generationStatus.Stage ? StepState.Failed
                 : StepState.Pending;
        }

        return stepStage < _generationStatus.Stage ? StepState.Complete
             : stepStage == _generationStatus.Stage ? StepState.Active
             : StepState.Pending;
    }

    // ── Event filtering ──

    private List<CharacterEvent> GetFilteredEvents()
    {
        if (_timeline is null) return [];
        if (!_selectedEventTypes.Any()) return _timeline.Events;
        var selected = new HashSet<string>(_selectedEventTypes, StringComparer.OrdinalIgnoreCase);
        return _timeline.Events.Where(e => selected.Contains(e.EventType)).ToList();
    }

    private void SelectAllEventTypes() => _selectedEventTypes = _eventTypes.ToList();
    private void DeselectAllEventTypes() => _selectedEventTypes = new List<string>();

    // ── Formatting ──

    private static string FormatYear(CharacterEvent evt)
    {
        if (!evt.Year.HasValue)
            return evt.DateDescription ?? "Unknown";

        var yearStr = $"{evt.Year.Value:0.##} {evt.Demarcation.ToString().ToUpper()}";
        return evt.DateDescription is not null ? $"{yearStr} ({evt.DateDescription})" : yearStr;
    }

    private static string GetEventTypeColor(string eventType) =>
        EventTypeColors.TryGetValue(eventType, out var color) ? color : Colors.Blue.Default;

    private static Color GetTimelineItemColor(string eventType) => eventType.ToLowerInvariant() switch
    {
        "birth" => Color.Success,
        "death" => Color.Dark,
        "battle" or "duel" or "war" => Color.Error,
        "marriage" => Color.Secondary,
        "promotion" or "alliance" => Color.Info,
        _ => Color.Primary,
    };

    private static Color GetContinuityColor(Continuity continuity) => continuity switch
    {
        Continuity.Canon => Color.Primary,
        Continuity.Legends => Color.Secondary,
        _ => Color.Default,
    };

    private static int GetSubStepProgress(GenerationStatus? status)
    {
        if (status is null || status.TotalSteps <= 0) return 0;
        return (int)((double)status.CurrentStep / status.TotalSteps * 100);
    }

    private static int GetStageProgress(GenerationStatus? status) => status?.Stage switch
    {
        GenerationStage.Queued => 5,
        GenerationStage.Discovering => 15,
        GenerationStage.Bundling => 20,
        GenerationStage.Extracting => 50,
        GenerationStage.Consolidating => 70,
        GenerationStage.Reviewing => 80,
        GenerationStage.Saving => 95,
        GenerationStage.Complete => 100,
        GenerationStage.Failed => 100,
        _ => 0,
    };

    private static Color GetStageColor(GenerationStatus? status) => status?.Stage switch
    {
        GenerationStage.Complete => Color.Success,
        GenerationStage.Failed => Color.Error,
        _ => Color.Primary,
    };

