@page "/character-timelines"
@page "/character-timelines/{PageId:int}"
@using StarWarsData.Models.Entities
@using StarWarsData.Models.Queries
@using StarWarsData.Frontend.Services
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject GlobalFilterService GlobalFilterService
@implements IDisposable

<PageTitle>@GetPageTitle()</PageTitle>
<HeadContent>
    <meta name="description" content="AI-generated biographical timelines for Star Wars characters — key events synthesized from Wookieepedia articles." />
</HeadContent>

@if (PageId is null)
{
    @* ── List View ── *@
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pt-4">
        <MudTabPanel Text="Search" Icon="@Icons.Material.Filled.Search">
            <MudTextField T="string" @bind-Value="_search" Label="Search characters" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="OnSearchChanged"
                          Placeholder="e.g. Anakin Skywalker, Ahsoka Tano, Darth Revan..."
                          Class="mb-4" />

            @if (_searching)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }

            @if (_searchResults is not null)
            {
                @if (_searchResults.Count == 0 && !string.IsNullOrWhiteSpace(_search))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        No characters found matching "@_search".
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="_searchResults" T="CharacterSearchResult" Dense="true" Hover="true"
                              OnRowClick="OnSearchRowClick" RowStyle="cursor:pointer;">
                        <HeaderContent>
                            <MudTh></MudTh>
                            <MudTh>Character</MudTh>
                            <MudTh>Continuity</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                @if (context.ImageUrl is not null)
                                {
                                    <MudImage Src="@context.ImageUrl" Alt="@context.Title"
                                              Width="40" Height="40" ObjectFit="ObjectFit.Cover" Class="rounded" />
                                }
                                else
                                {
                                    <MudAvatar Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                        @context.Title[0]
                                    </MudAvatar>
                                }
                            </MudTd>
                            <MudTd>@context.Title</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@GetContinuityColor(context.Continuity)" Variant="Variant.Filled">
                                    @context.Continuity
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                @if (context.HasTimeline)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                        Timeline available
                                    </MudChip>
                                }
                                else if (context.GenerationStatus is not null
                                    && context.GenerationStatus.Stage is not (GenerationStage.Complete or GenerationStage.Failed))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                        Generating...
                                    </MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">No timeline</MudText>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                    Type a character name above to search all Wookieepedia characters.
                </MudAlert>
            }
        </MudTabPanel>
        <MudTabPanel Text="Generated" Icon="@Icons.Material.Filled.Timeline">
            <MudTable @ref="_table" T="CharacterTimelineSummary" ServerData="LoadServerData"
                      Dense="true" Hover="true" Striped="true" FixedHeader="true"
                      OnRowClick="OnRowClick" RowStyle="cursor:pointer;"
                      Loading="@_tableLoading" LoadingProgressColor="Color.Primary">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Generated Timelines</MudText>
                    <MudSpacer />
                    <MudTextField T="string" @bind-Value="_tableSearch" Placeholder="Search character..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium" Immediate="true" DebounceInterval="400"
                                  OnDebounceIntervalElapsed="OnTableSearchChanged" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh></MudTh>
                    <MudTh><MudTableSortLabel SortLabel="title" T="CharacterTimelineSummary">Character</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortLabel="continuity" T="CharacterTimelineSummary">Continuity</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortLabel="events" T="CharacterTimelineSummary">Events</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortLabel="sources" T="CharacterTimelineSummary">Sources</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortLabel="generated" T="CharacterTimelineSummary" InitialDirection="SortDirection.Descending">Generated</MudTableSortLabel></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Image">
                        @if (context.ImageUrl is not null)
                        {
                            <MudImage Src="@context.ImageUrl" Alt="@context.CharacterTitle"
                                      Width="40" Height="40" ObjectFit="ObjectFit.Cover" Class="rounded" />
                        }
                        else
                        {
                            <MudAvatar Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                @context.CharacterTitle[0]
                            </MudAvatar>
                        }
                    </MudTd>
                    <MudTd DataLabel="Character">@context.CharacterTitle</MudTd>
                    <MudTd DataLabel="Continuity">
                        <MudChip T="string" Size="Size.Small" Color="@GetContinuityColor(context.Continuity)" Variant="Variant.Filled">
                            @context.Continuity
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Events">@context.EventCount</MudTd>
                    <MudTd DataLabel="Sources">@context.SourceCount</MudTd>
                    <MudTd DataLabel="Generated">@context.GeneratedAt.ToString("MMM d, yyyy")</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                        <MudIcon Icon="@Icons.Material.Filled.Timeline" Style="font-size:48px" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Class="mt-2 mb-1">No Timelines Yet</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Search for a character above and generate their first timeline.
                        </MudText>
                    </MudStack>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>
        <MudTabPanel Text="Generating" Icon="@Icons.Material.Filled.HourglassTop"
                     BadgeData="@(_activeGenerations?.Count ?? 0)" BadgeColor="Color.Warning"
                     Disabled="@(_activeGenerations is not { Count: > 0 })">
            @if (_activeGenerations is { Count: > 0 })
            {
                <MudStack Spacing="2">
                    @foreach (var gen in _activeGenerations)
                    {
                        <MudCard Outlined="true" Style="cursor:pointer" @onclick="() => NavigateToTimeline(gen.PageId)">
                            <MudCardContent>
                                <MudStack Spacing="1">
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">
                                                @gen.Stage
                                            </MudChip>
                                            <MudText Typo="Typo.subtitle2">@(gen.CharacterTitle ?? $"Page {gen.PageId}")</MudText>
                                        </MudStack>
                                        @if (gen.EventsExtracted > 0)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @gen.EventsExtracted events extracted
                                            </MudText>
                                        }
                                    </MudStack>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@gen.Message</MudText>
                                    @if (gen.TotalSteps > 0)
                                    {
                                        <MudProgressLinear Value="@gen.CurrentStep" Max="@gen.TotalSteps"
                                                           Color="Color.Warning" Rounded="true" Size="Size.Small" />
                                    }
                                    else
                                    {
                                        <MudProgressLinear Indeterminate="true" Color="Color.Warning" Rounded="true" Size="Size.Small" />
                                    }
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    }
                </MudStack>
            }
        </MudTabPanel>
    </MudTabs>
}
else
{
    @* ── Detail View ── *@
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick='() => Navigation.NavigateTo("/character-timelines")' Class="mb-2">
        Back to Search
    </MudButton>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_characterInfo is not null)
    {
        @* ── Character Header (always visible) ── *@
        <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Start" Class="mb-4">
            @if (_characterInfo.ImageUrl is not null)
            {
                <MudImage Src="@_characterInfo.ImageUrl" Alt="@_characterInfo.Title"
                          Width="120" Height="120" ObjectFit="ObjectFit.Cover"
                          Class="rounded-lg" Elevation="2" />
            }
            <MudStack Spacing="1">
                <MudText Typo="Typo.h3">@_characterInfo.Title</MudText>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="@GetContinuityColor(_characterInfo.Continuity)" Variant="Variant.Filled">
                        @_characterInfo.Continuity
                    </MudChip>
                    @if (_timeline is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_timeline.Events.Count events from @_timeline.Sources.Count sources
                        </MudText>
                    }
                </MudStack>
                <MudLink Href="@_characterInfo.WikiUrl" Target="_blank" Underline="Underline.Always" Typo="Typo.caption">
                    View on Wookieepedia
                </MudLink>
            </MudStack>
        </MudStack>

        @* ── Generation Progress ── *@
        @if (_generationStatus is not null && _generationStatus.Stage is not GenerationStage.Complete)
        {
            <MudPaper Outlined="true" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="mr-1" />
                    Generating Timeline
                </MudText>

                @* ── Step progress ── *@
                <MudStack Spacing="2">
                    @foreach (var step in _workflowSteps)
                    {
                        var state = GetStepState(step.Stage);
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            @if (state == StepState.Complete)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            }
                            else if (state == StepState.Active)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary"
                                                     Style="width:20px; height:20px" />
                            }
                            else if (state == StepState.Failed)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Circle" Color="Color.Default" Size="Size.Small" />
                            }
                            <MudText Typo="Typo.body2"
                                     Color="@(state == StepState.Active ? Color.Primary : state == StepState.Complete ? Color.Success : Color.Default)">
                                @step.Label
                            </MudText>
                        </MudStack>
                    }
                </MudStack>

                <MudProgressLinear Value="@GetStageProgress(_generationStatus)"
                                   Color="@GetStageColor(_generationStatus)"
                                   Striped="true" Size="Size.Medium" Class="mt-3 mb-1" />

                @if (_generationStatus.TotalSteps > 0)
                {
                    <MudProgressLinear Value="@GetSubStepProgress(_generationStatus)"
                                       Color="Color.Secondary" Size="Size.Small" Class="mb-2"
                                       Rounded="true" />
                }

                @if (_generationStatus.CurrentItem is not null)
                {
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Secondary" />
                        <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight:500">
                            @_generationStatus.CurrentItem
                        </MudText>
                        @if (_generationStatus.TotalSteps > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                (@(_generationStatus.CurrentStep + 1) / @_generationStatus.TotalSteps)
                            </MudText>
                        }
                    </MudStack>
                }

                @if (_generationStatus.EventsExtracted > 0)
                {
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" Color="Color.Success" />
                        <MudText Typo="Typo.caption" Color="Color.Success">
                            @_generationStatus.EventsExtracted events extracted so far
                        </MudText>
                    </MudStack>
                }

                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @_generationStatus.Message
                </MudText>

                @* ── Activity Log ── *@
                @if (_generationStatus.ActivityLog.Count > 0)
                {
                    <MudExpansionPanels Class="mt-3" Elevation="0">
                        <MudExpansionPanel Text="@($"Activity Log ({_generationStatus.ActivityLog.Count} events)")"
                                           Expanded="false">
                            <div style="max-height:300px; overflow-y:auto">
                                <MudStack Spacing="0">
                                    @foreach (var entry in _generationStatus.ActivityLog.AsEnumerable().Reverse().Take(100))
                                    {
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center"
                                                   Class="px-2 py-1" Style="border-bottom:1px solid var(--mud-palette-divider)">
                                            <MudIcon Icon="@GetActivityIcon(entry)" Size="Size.Small"
                                                     Color="@GetActivityColor(entry)" />
                                            <MudText Typo="Typo.caption" Color="@GetActivityColor(entry)"
                                                     Style="font-family:monospace; flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                                                @entry.Summary
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex-shrink:0">
                                                @entry.Timestamp.ToString("HH:mm:ss")
                                            </MudText>
                                        </MudStack>
                                    }
                                </MudStack>
                            </div>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }

                @if (_generationStatus.Stage == GenerationStage.Failed)
                {
                    @if (_generationStatus.HasPendingCheckpoint)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                            A previous generation was interrupted. Progress has been saved and can be resumed.
                        </MudAlert>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="StartGeneration" Class="mt-2">
                            Resume Generation
                        </MudButton>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">
                            @(_generationStatus.Error ?? "Unknown error")
                        </MudAlert>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="StartGeneration" Class="mt-2">
                            Retry
                        </MudButton>
                    }
                }
            </MudPaper>
        }
        else if (_timeline is null && _generationStatus is null)
        {
            @* ── No timeline yet, offer to generate ── *@
            <MudPaper Outlined="true" Class="pa-6 mb-4" Style="text-align:center">
                <MudIcon Icon="@Icons.Material.Filled.Timeline" Style="font-size:48px" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Class="mt-2 mb-1">No Timeline Generated Yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Generate an AI-powered timeline of key events in this character's life.
                    This uses a multi-agent workflow to research wiki pages and extract structured events.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.AutoAwesome"
                           OnClick="StartGeneration">
                    Generate Timeline
                </MudButton>
            </MudPaper>
        }

        @* ── Rendered Timeline ── *@
        @if (_timeline is not null)
        {
            @* ── Action buttons ── *@
            <MudStack Row="true" Spacing="2" Class="mb-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           Disabled="@(_generationStatus is not null && _generationStatus.Stage is not (GenerationStage.Complete or GenerationStage.Failed))"
                           OnClick="StartGeneration">
                    Regenerate
                </MudButton>
            </MudStack>

            @* ── Event type filter chips ── *@
            @if (_eventTypes.Count > 1)
            {
                <MudPaper Elevation="0" Class="pa-2 mb-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudText Typo="Typo.subtitle2">Filter by Event Type</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="SelectAllEventTypes">All</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="DeselectAllEventTypes">None</MudButton>
                    </MudStack>
                    <MudChipSet T="string" @bind-SelectedValues="_selectedEventTypes" SelectionMode="SelectionMode.MultiSelection"
                                CheckMark="true" Variant="Variant.Text">
                        @foreach (var eventType in _eventTypes)
                        {
                            <MudChip Value="@eventType" Style="@($"border-color:{GetEventTypeColor(eventType)}; color:{GetEventTypeColor(eventType)}")"
                                     Variant="Variant.Outlined" T="string">
                                @eventType
                            </MudChip>
                        }
                    </MudChipSet>
                </MudPaper>
            }

            @* ── MudTimeline ── *@
            <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelineAlign="TimelineAlign.Default"
                         TimelinePosition="TimelinePosition.Alternate" Class="ma-4" Modifiers="false">
                @{
                    var isStart = true;
                    var filteredEvents = GetFilteredEvents();
                    CharacterEvent? previousEvent = null;
                }

                @foreach (var evt in filteredEvents)
                {
                    var contentAlign = isStart ? Align.Left : Align.Right;
                    var yearAlign = isStart ? Align.Right : Align.Left;
                    var showYearSeparator = previousEvent is null
                        || evt.Year != previousEvent.Year
                        || evt.Demarcation != previousEvent.Demarcation;

                    <MudTimelineItem Variant="Variant.Outlined" Color="@GetTimelineItemColor(evt.EventType)" Size="Size.Medium">
                        <ItemOpposite>
                            @if (showYearSeparator)
                            {
                                <MudText Color="Color.Info" Typo="Typo.h5" Align="@yearAlign">
                                    @FormatYear(evt)
                                </MudText>
                            }
                        </ItemOpposite>
                        <ItemContent>
                            <MudCard Outlined="true" Class="ma-1">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                     Style="@($"background-color:{GetEventTypeColor(evt.EventType)}; color:white")">
                                                @evt.EventType
                                            </MudChip>
                                            @if (evt.Location is not null)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@evt.Location</MudText>
                                            }
                                        </MudStack>
                                    </CardHeaderContent>
                                </MudCardHeader>
                                <MudCardContent>
                                    <MudText Typo="Typo.body2" Style="@($"text-align:{contentAlign}; font-weight:500")">
                                        @evt.Description
                                    </MudText>

                                    @if (!string.IsNullOrWhiteSpace(evt.Narrative))
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-2" Style="@($"text-align:{contentAlign}")">
                                            @evt.Narrative
                                        </MudText>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(evt.Significance))
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2" Style="@($"text-align:{contentAlign}; font-style:italic")">
                                            @evt.Significance
                                        </MudText>
                                    }

                                    @if (evt.Consequences.Count > 0)
                                    {
                                        <MudList T="string" Dense="true" Class="mt-1" ReadOnly="true">
                                            @foreach (var c in evt.Consequences)
                                            {
                                                <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight" IconSize="Size.Small" IconColor="Color.Tertiary">
                                                    <MudText Typo="Typo.caption">@c</MudText>
                                                </MudListItem>
                                            }
                                        </MudList>
                                    }

                                    @if (evt.RelatedCharacters.Count > 0)
                                    {
                                        <MudStack Row="true" Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
                                            @foreach (var character in evt.RelatedCharacters)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">
                                                    @character
                                                </MudChip>
                                            }
                                        </MudStack>
                                    }

                                    @if (evt.SourcePageTitle is not null)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-2">
                                            Source:
                                            @if (evt.SourceWikiUrl is not null)
                                            {
                                                <MudLink Href="@evt.SourceWikiUrl" Target="_blank" Underline="Underline.Always">
                                                    @evt.SourcePageTitle
                                                </MudLink>
                                            }
                                            else
                                            {
                                                @evt.SourcePageTitle
                                            }
                                        </MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </ItemContent>
                    </MudTimelineItem>

                    previousEvent = evt;
                    isStart = !isStart;
                }
            </MudTimeline>

            @* ── Sources ── *@
            @if (_timeline.Sources.Count > 0)
            {
                <MudExpansionPanels Class="mt-4" Outlined="true">
                    <MudExpansionPanel>
                        <TitleContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Source" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle1">Source Pages (@_timeline.Sources.Count)</MudText>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <MudSimpleTable Dense="true" Hover="true">
                                <thead>
                                    <tr>
                                        <th>Page</th>
                                        <th>Link</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var source in _timeline.Sources)
                                    {
                                        <tr>
                                            <td>@source.Title</td>
                                            <td><MudLink Href="@source.WikiUrl" Target="_blank" Underline="Underline.Always">Wookieepedia</MudLink></td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }

            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4">
                Generated @_timeline.GeneratedAt.ToString("yyyy-MM-dd HH:mm") UTC using @_timeline.ModelUsed
            </MudText>
        }
    }
    else
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            Character not found.
        </MudAlert>
    }
}

<MudScrollToTop>
    <MudFab Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.ArrowCircleUp" />
</MudScrollToTop>

@code {
    [Parameter] public int? PageId { get; set; }

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    // ── Search state ──
    private List<CharacterSearchResult>? _searchResults;
    private string? _search;
    private bool _searching;

    // ── Table state ──
    private MudTable<CharacterTimelineSummary>? _table;
    private string? _tableSearch;
    private bool _tableLoading;

    // ── Active generations (landing page banner) ──
    private List<ActiveGenerationDto>? _activeGenerations;
    private Timer? _activeGenPollTimer;

    // ── Detail state ──
    private CharacterSearchResult? _characterInfo;
    private CharacterTimeline? _timeline;
    private GenerationStatus? _generationStatus;
    private bool _loading;
    private List<string> _eventTypes = [];
    private IReadOnlyCollection<string> _selectedEventTypes = new List<string>();
    private Timer? _pollTimer;

    // ── Workflow steps (shown on detail page during generation) ──
    private record WorkflowStep(GenerationStage Stage, string Label);

    private class ActiveGenerationDto
    {
        public int PageId { get; set; }
        public string? CharacterTitle { get; set; }
        public GenerationStage Stage { get; set; }
        public string Message { get; set; } = string.Empty;
        public string? CurrentItem { get; set; }
        public int CurrentStep { get; set; }
        public int TotalSteps { get; set; }
        public int EventsExtracted { get; set; }
        public DateTime StartedAt { get; set; }
    }

    private static readonly WorkflowStep[] _workflowSteps =
    [
        new(GenerationStage.Queued, "Queued for processing"),
        new(GenerationStage.Discovering, "Discovering related wiki pages"),
        new(GenerationStage.Bundling, "Bundling pages into extraction batches"),
        new(GenerationStage.Extracting, "Extracting events from page batches"),
        new(GenerationStage.Consolidating, "Consolidating and deduplicating events"),
        new(GenerationStage.Reviewing, "Reviewing and finalizing timeline"),
        new(GenerationStage.Saving, "Saving timeline to database"),
    ];

    private enum StepState { Pending, Active, Complete, Failed }

    // ── Event type colors ──
