    {
        ["Birth"] = Colors.Green.Darken1,
        ["Death"] = Colors.Gray.Darken2,
        ["Battle"] = Colors.Red.Darken1,
        ["Duel"] = Colors.Red.Darken3,
        ["War"] = Colors.Red.Darken4,
        ["Marriage"] = Colors.Pink.Darken1,
        ["Apprenticeship"] = Colors.Purple.Darken1,
        ["Training"] = Colors.Purple.Lighten1,
        ["Promotion"] = Colors.Blue.Darken1,
        ["Exile"] = Colors.Brown.Default,
        ["Capture"] = Colors.Orange.Darken2,
        ["Rescue"] = Colors.Teal.Darken1,
        ["Discovery"] = Colors.Cyan.Default,
