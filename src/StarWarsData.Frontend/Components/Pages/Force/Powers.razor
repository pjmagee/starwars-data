@page "/powers"
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Force powers</PageTitle>

@if (_chartData is not null)
{
    <MudChart 
        ChartType="ChartType.Bar" 
        ChartSeries="@Series" 
        ChartLabels="@Labels" 
        Width="100%" 
        Height="800px" 
        LegendPosition="Position.Top" />
}

@code {

    private StarWarsData.Models.Queries.ChartData<double>? _chartData;
    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");
    
    public string[] Labels => _chartData!.Labels;

    public List<ChartSeries<double>> Series => _chartData!.Series.Select(x =>
    {
        return new ChartSeries<double>()
        {
            Name = x.Name,
            Data = x.Data.ToArray()
        };
    }).ToList();

    protected override async Task OnInitializedAsync()
    {
        _chartData = await Http.GetFromJsonAsync<StarWarsData.Models.Queries.ChartData<double>>($"powers/charts/categories");
    }
}