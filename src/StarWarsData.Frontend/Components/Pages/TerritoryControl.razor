@page "/territory-control"
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Territory Control — Star Wars Data</PageTitle>

<div class="territory-outer">

    @if (_overview is null)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        @* Era chips — only show eras that overlap with the data range *@
        <div style="display: flex; gap: 4px; padding: 8px 12px; flex-wrap: wrap; flex-shrink: 0;">
            @foreach (var era in _overview.Eras.Where(e => e.EndYear >= _overview.MinYear && e.StartYear <= _overview.MaxYear))
            {
                var eraRef = era;
                var isActive = _activeEra == era.Name;
                var jumpYear = Math.Clamp(era.StartYear, _overview.MinYear, _overview.MaxYear);
                <MudChip T="string" Size="Size.Small" Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                         Color="@(isActive ? Color.Primary : Color.Default)"
                         OnClick="() => JumpToYear(jumpYear)">
                    @era.Name
                </MudChip>
            }
        </div>

        @* Main content: map + info panel *@
        <div class="territory-content">
            @* Map canvas *@
            <div class="territory-canvas-wrap">
                <div id="territory-canvas" class="territory-canvas"></div>

                @* Year display (top-left overlay) *@
                <div class="territory-year-overlay">
                    <span class="territory-year-text">@YearDisplay</span>
                    @if (_yearData?.Era is not null)
                    {
                        <span class="territory-era-text">@_yearData.Era</span>
                    }
                </div>

                @* Faction legend (bottom-left) — only factions with territory this year *@
                <div class="territory-legend">
                    @foreach (var name in ActiveFactions)
                    {
                        var info = _factionInfo.GetValueOrDefault(name);
                        var color = info?.Color ?? "#888";
                        <div class="d-flex align-center gap-2" style="margin-bottom: 5px;">
                            @if (info?.IconUrl is not null)
                            {
                                <img src="@info.IconUrl" alt="@name" style="width:24px; height:24px; object-fit:contain; flex-shrink:0;" />
                            }
                            else
                            {
                                <FactionIcon Faction="@name" Color="@color" Size="22" />
                            }
                            @if (info?.WikiUrl is not null)
                            {
                                <MudLink Href="@info.WikiUrl" Target="_blank" Typo="Typo.caption"
                                         Style="@($"color:{color};")">@name</MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Style="@($"color:{color};")">@name</MudText>
                            }
                        </div>
                    }
                </div>
            </div>

            @* Right info panel *@
            <div class="territory-info-panel">
                <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-1" Style="font-weight:700;">
                    @YearDisplay
                </MudText>

                @if (_yearData?.Era is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Class="mb-2">
                        @_yearData.Era
                    </MudChip>
                    @if (_yearData.EraDescription is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                            @_yearData.EraDescription
                        </MudText>
                    }
                    @if (_yearData.EraConflicts.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Style="font-weight:600; opacity:0.6;" Class="mb-1">Conflicts</MudText>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            @foreach (var conflict in _yearData.EraConflicts)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                         Style="font-size:10px; height:20px;">@conflict</MudChip>
                            }
                        </div>
                    }
                    @if (_yearData.EraImportantEvents.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Style="font-weight:600; opacity:0.6;" Class="mb-1">Era Milestones</MudText>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            @foreach (var evt in _yearData.EraImportantEvents)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                         Style="font-size:10px; height:20px;">@evt</MudChip>
                            }
                        </div>
                    }
                    <MudDivider Class="my-2" />
                }

                @* Events for this year (from Wookieepedia timeline data) *@
                @if (_yearData?.KeyEvents.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">
                        Events (@_yearData.KeyEvents.Count)
                    </MudText>
                    <div style="max-height: 300px; overflow-y: auto;">
                        @foreach (var evt in _yearData.KeyEvents)
                        {
                            var e = evt;
                            var borderColor = e.Category switch
                            {
                                "Battle" => "var(--mud-palette-error)",
                                "War" => "#ff4444",
                                "Campaign" => "#ff8844",
                                "Treaty" => "var(--mud-palette-success)",
                                "Government" => "var(--mud-palette-info)",
                                _ => "var(--mud-palette-primary)",
                            };
                            var hasLocation = e.Col is not null && e.Row is not null;
                            <MudPaper Class="pa-2 mb-2" Elevation="0"
                                      Style="@($"background: rgba(255,255,255,0.04); border-left: 3px solid {borderColor}; {(hasLocation ? "cursor:pointer;" : "")}")"
                                      data-highlight-region="@(e.Region)"
                                      data-highlight-col="@(e.Col)"
                                      data-highlight-row="@(e.Row)"
                                      data-highlight-color="@(borderColor)"
                                      >
                                <div class="d-flex align-center gap-2">
                                    @if (e.Category is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Style="@($"font-size:12px; height:22px; border-color:{borderColor}; color:{borderColor};")">
                                            @e.Category
                                        </MudChip>
                                    }
                                    @if (e.WikiUrl is not null)
                                    {
                                        <MudLink Href="@e.WikiUrl" Target="_blank" Typo="Typo.body2"
                                                 Style="font-weight:600;" Underline="Underline.Hover">@e.Title</MudLink>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">@e.Title</MudText>
                                    }
                                    @if (hasLocation)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small"
                                                 Style="opacity:0.4; font-size:16px;" title="@($"{e.Place} — {e.Region}")" />
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(e.Place))
                                {
                                    <MudText Typo="Typo.caption" Style="font-size:13px; opacity:0.6;">@e.Place @(e.Region is not null ? $"({e.Region})" : "")</MudText>
                                }
                                @if (!string.IsNullOrEmpty(e.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size:13px;">@e.Description</MudText>
                                }
                            </MudPaper>
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        No notable events recorded for this year.
                    </MudText>
                }

                <MudDivider Class="my-3" />

                @* Territory breakdown *@
                <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Territory Control</MudText>
                @if (_yearData?.Regions is not null)
                {
                    @foreach (var region in _yearData.Regions)
                    {
                        <div class="mb-2 territory-region-item"
                             style="cursor:pointer; padding:4px 6px; border-radius:4px;"
                             data-highlight-region="@region.Region">
                            <MudText Typo="Typo.body2" Style="font-weight:600; opacity:0.7;">@region.Region</MudText>
                            @foreach (var f in region.Factions)
                            {
                                var fi = _factionInfo.GetValueOrDefault(f.Faction);
                                <div class="d-flex align-center gap-2 ml-2">
                                    @if (fi?.IconUrl is not null)
                                    {
                                        <img src="@fi.IconUrl" alt="@f.Faction" style="width:20px; height:20px; object-fit:contain; flex-shrink:0;" />
                                    }
                                    else
                                    {
                                        <FactionIcon Faction="@f.Faction" Color="@f.Color" Size="18" />
                                    }
                                    <MudText Typo="Typo.body2" Style="@($"color:{f.Color};")">
                                        @f.Faction — @(Math.Round(f.Control * 100))%
                                        @if (f.Contested) { <em style="opacity:0.5;"> contested</em> }
                                    </MudText>
                                </div>
                            }
                        </div>
                    }
                }

                @* Selected region detail (from clicking map) *@
                @if (_selectedRegion is not null)
                {
                    <MudDivider Class="my-3" />
                    <div class="d-flex justify-space-between align-center">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@_selectedRegion</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="() => { _selectedRegion = null; _selectedFactions = null; }" />
                    </div>
                    @if (_selectedFactions is not null)
                    {
                        @foreach (var f in _selectedFactions)
                        {
                            var fi = _factionInfo.GetValueOrDefault(f.Faction);
                            <div class="d-flex align-center gap-2 mt-1">
                                @if (fi?.IconUrl is not null)
                                {
                                    <img src="@fi.IconUrl" alt="@f.Faction" style="width:28px; height:28px; object-fit:contain; flex-shrink:0;" />
                                }
                                else
                                {
                                    <FactionIcon Faction="@f.Faction" Color="@f.Color" Size="22" />
                                }
                                <div>
                                    @if (fi?.WikiUrl is not null)
                                    {
                                        <MudLink Href="@fi.WikiUrl" Target="_blank" Typo="Typo.body2"
                                                 Style="@($"color:{f.Color}; font-weight:600;")">@f.Faction</MudLink>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Style="@($"color:{f.Color}; font-weight:600;")">@f.Faction</MudText>
                                    }
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @(Math.Round(f.Control * 100))% control
                                        @if (f.Contested) { <em>(contested)</em> }
                                    </MudText>
                                </div>
                            </div>
                            @if (f.Note is not null)
                            {
                                <MudText Typo="Typo.caption" Style="opacity:0.5; margin-left:28px;">@f.Note</MudText>
                            }
                        }
                    }
                }
            </div>
        </div>

        @* Timeline scrubber *@
        <div class="territory-scrubber">
            @if (_autoplay)
            {
                <div class="territory-progress-bar" style="--duration: @(_frameTimeMs)ms;"></div>
            }
            @* Density bar — shows where data clusters across the timeline *@
            @if (_overview.AvailableYears.Count > 1)
            {
                <div class="territory-density-bar">
                    @for (var i = 0; i < _overview.AvailableYears.Count; i++)
                    {
                        var idx = i;
                        var yr = _overview.AvailableYears[i];
                        var isActive = yr == _year;
                        <div class="density-tick @(isActive ? "active" : "")"
                             title="@(yr <= 0 ? $"{Math.Abs(yr)} BBY" : $"{yr} ABY")"
                             @onclick="() => JumpToIndex(idx)"></div>
                    }
                </div>
            }
            <div class="d-flex align-center gap-2" style="padding: 8px 16px;">
                <MudIconButton Icon="@(_autoplay ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                               Color="Color.Primary" Size="Size.Medium"
                               OnClick="ToggleAutoplay" />
                <MudIconButton Icon="@Icons.Material.Filled.SkipPrevious"
                               Color="Color.Secondary" Size="Size.Small"
                               OnClick="StepPrev" Disabled="_yearIndex <= 0" />
                <MudText Typo="Typo.h6" Style="min-width: 120px; text-align:center; font-weight: 700; color: var(--mud-palette-primary);">
                    @YearDisplay
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.SkipNext"
                               Color="Color.Secondary" Size="Size.Small"
                               OnClick="StepNext" Disabled="_yearIndex >= _overview.AvailableYears.Count - 1" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:60px;">
                    @(_yearIndex + 1) / @_overview.AvailableYears.Count
                </MudText>
                <div style="flex: 1;">
                    <MudSlider T="int" Value="@_yearIndex" ValueChanged="OnYearIndexChanged"
                               Min="0" Max="_overview.AvailableYears.Count - 1" Step="1"
                               Style="margin: 0;" Size="Size.Medium" />
                </div>
                <MudMenu Icon="@Icons.Material.Filled.Speed" Size="Size.Medium" Color="Color.Secondary"
                         AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter"
                         title="Frame speed" Style="flex-shrink: 0;">
                    @foreach (var (label, ms) in FrameSpeeds)
                    {
                        var speed = ms;
                        <MudMenuItem OnClick="() => SetFrameSpeed(speed)"
                                     Style="@(_frameTimeMs == speed ? "font-weight:700; color:var(--mud-palette-primary);" : "")">
                            @label per frame
                        </MudMenuItem>
                    }
                </MudMenu>
                <MudIconButton Icon="@Icons.Material.Filled.MusicNote"
                               Size="Size.Medium" Color="Color.Warning"
                               Href="https://www.youtube.com/watch?v=xlYCxbBZUCY&autoplay=1"
                               Target="_blank"
                               title="Duel of the Fates" Style="flex-shrink: 0;" />
            </div>
        </div>
    }
</div>

<style>
    .territory-outer {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 64px);
        margin: 0 -16px -16px -16px;
        overflow: hidden;
    }
    .territory-content {
        flex: 1;
        display: flex;
        min-height: 0;
        overflow: hidden;
    }
    .territory-canvas-wrap {
        flex: 1;
        position: relative;
        min-height: 0;
        overflow: hidden;
    }
    .territory-canvas {
        width: 100%;
        height: 100%;
    }
    .territory-year-overlay {
        position: absolute;
        top: 12px;
        left: 16px;
        z-index: 10;
        pointer-events: none;
        display: flex;
        flex-direction: column;
    }
    .territory-year-text {
        font-size: 2.5rem;
        font-weight: 800;
        color: rgba(255,255,255,0.85);
        line-height: 1;
        text-shadow: 0 2px 12px rgba(0,0,0,0.8), 0 0 40px rgba(126,111,255,0.3);
        letter-spacing: 1px;
    }
    .territory-era-text {
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(255,255,255,0.5);
        margin-top: 4px;
        text-shadow: 0 1px 6px rgba(0,0,0,0.8);
    }
    .territory-legend {
        position: absolute;
        bottom: 12px;
        left: 12px;
        background: rgba(10,10,26,0.85);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 12px 18px;
        z-index: 10;
        font-size: 1rem;
    }
    .territory-info-panel {
        width: 400px;
        flex-shrink: 0;
        overflow-y: auto;
        padding: 16px;
        border-left: 1px solid var(--mud-palette-lines-default);
        background: var(--mud-palette-surface);
    }
    .territory-scrubber {
        flex-shrink: 0;
        border-top: 1px solid var(--mud-palette-lines-default);
        background: var(--mud-palette-surface);
        padding: 4px 0;
    }
    .territory-progress-bar {
        height: 3px;
        background: var(--mud-palette-primary);
        animation: progress-fill var(--duration) linear infinite;
        transform-origin: left;
    }
    @@keyframes progress-fill {
        from { transform: scaleX(0); }
        to { transform: scaleX(1); }
    }
    .territory-region-item:hover {
        background: rgba(255,255,255,0.06);
    }
    .territory-density-bar {
        display: flex;
        align-items: flex-end;
        height: 20px;
        padding: 0 16px;
        gap: 1px;
        overflow: hidden;
    }
    .density-tick {
        flex: 1;
        min-width: 1px;
        height: 6px;
        background: rgba(126,111,255,0.25);
        border-radius: 1px;
        cursor: pointer;
        transition: background 0.15s, height 0.15s;
    }
    .density-tick:hover {
        background: rgba(126,111,255,0.7);
        height: 14px;
    }
    .density-tick.active {
        background: var(--mud-palette-primary);
        height: 14px;
    }
</style>

@code {
    private IJSObjectReference? _module;
    private DotNetObjectReference<TerritoryControl>? _dotNetRef;

    private TerritoryOverviewDto? _overview;
    private TerritoryYearDto? _yearData;
    private Dictionary<string, FactionInfoDto> _factionInfo = new();
    private List<RegionCellsDto>? _regionCells;

    private int _year = 0;
    private int _yearIndex = 0;
    private bool _autoplay;
    private System.Threading.Timer? _autoplayTimer;
    private CancellationTokenSource? _debounceCts;
    private int _frameTimeMs = 30000;
    private static readonly (string Label, int Ms)[] FrameSpeeds =
    [
        ("5s", 5000), ("10s", 10000), ("15s", 15000), ("30s", 30000),
        ("1m", 60000), ("2m", 120000), ("5m", 300000)
    ];

    private string? _selectedRegion;
    private List<FactionControlDto>? _selectedFactions;

    private string YearDisplay => _year <= 0 ? $"{Math.Abs(_year)} BBY" : $"{_year} ABY";
    private string? _activeEra => _yearData?.Era;

    private IEnumerable<string> ActiveFactions =>
        _yearData?.Regions.SelectMany(r => r.Factions).Select(f => f.Faction).Distinct().OrderBy(f => f)
        ?? Enumerable.Empty<string>();

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/territory-control.js");
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        var overviewTask = Http.GetFromJsonAsync<TerritoryOverviewDto>("api/TerritoryControl/overview");
        var factionsTask = Http.GetFromJsonAsync<Dictionary<string, FactionInfoDto>>("api/TerritoryControl/factions");
        var regionsTask = Http.GetFromJsonAsync<GalaxyEventsOverviewDto>("api/galaxyevents/overview");

        await Task.WhenAll(overviewTask, factionsTask, regionsTask);

        _overview = overviewTask.Result;
        _factionInfo = factionsTask.Result ?? new();
        _regionCells = regionsTask.Result?.Regions;

        if (_overview is not null && _overview.AvailableYears.Count > 0)
        {
            _yearIndex = 0;
            _year = _overview.AvailableYears[0];
        }

        StateHasChanged();

        if (_module is not null && _overview is not null)
        {
            var jsOverview = new { gridColumns = 26, gridRows = 20 };
            var factionColors = _factionInfo.ToDictionary(kv => kv.Key, kv => kv.Value.Color);
            var factionWikiUrls = _factionInfo
                .Where(kv => kv.Value.WikiUrl is not null)
                .ToDictionary(kv => kv.Key, kv => kv.Value.WikiUrl!);
            var factionIcons = _factionInfo.Keys
                .Select(name => new { name, svg = FactionIcon.GetPath(name) })
                .Where(x => x.svg is not null)
                .ToDictionary(x => x.name, x => x.svg!);
            await _module.InvokeVoidAsync("initialize", "territory-canvas", jsOverview, _regionCells, factionColors, factionWikiUrls, factionIcons, _dotNetRef);
            await LoadYear();
        }
    }

    private async Task LoadYear()
    {
        try
        {
            _yearData = await Http.GetFromJsonAsync<TerritoryYearDto>($"api/TerritoryControl/year/{_year}");
            if (_module is not null && _yearData is not null)
            {
                await _module.InvokeVoidAsync("renderTerritoryLayer", _yearData);
            }
            StateHasChanged();
        }
        catch { }
    }

    private async Task OnYearIndexChanged(int newIndex)
    {
        if (_overview is null || _overview.AvailableYears.Count == 0) return;
        _yearIndex = Math.Clamp(newIndex, 0, _overview.AvailableYears.Count - 1);
        _year = _overview.AvailableYears[_yearIndex];

        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        try
        {
            await Task.Delay(150, token);
            if (!token.IsCancellationRequested)
                await LoadYear();
        }
        catch (TaskCanceledException) { }
    }

    private void JumpToYear(int year)
    {
        if (_overview is null || _overview.AvailableYears.Count == 0) return;
        // Find nearest available year
        var idx = _overview.AvailableYears.BinarySearch(year);
        if (idx < 0) idx = Math.Clamp(~idx, 0, _overview.AvailableYears.Count - 1);
        JumpToIndex(idx);
    }

    private void JumpToIndex(int idx)
    {
        if (_overview is null || _overview.AvailableYears.Count == 0) return;
        _yearIndex = Math.Clamp(idx, 0, _overview.AvailableYears.Count - 1);
        _year = _overview.AvailableYears[_yearIndex];
        _ = LoadYear();
    }

    private void StepPrev()
    {
        if (_yearIndex > 0) JumpToIndex(_yearIndex - 1);
    }

    private void StepNext()
    {
        if (_overview is not null && _yearIndex < _overview.AvailableYears.Count - 1)
            JumpToIndex(_yearIndex + 1);
    }

    private void SetFrameSpeed(int ms)
    {
        _frameTimeMs = ms;
        if (_autoplay)
        {
            _autoplayTimer?.Dispose();
            _autoplayTimer = new System.Threading.Timer(AutoplayTick, null, _frameTimeMs, _frameTimeMs);
        }
    }

    private void ToggleAutoplay()
    {
        _autoplay = !_autoplay;
        if (_autoplay)
        {
            _ = InvokeAsync(LoadYear);
            _autoplayTimer = new System.Threading.Timer(AutoplayTick, null, _frameTimeMs, _frameTimeMs);
        }
        else
        {
            _autoplayTimer?.Dispose();
            _autoplayTimer = null;
        }
        StateHasChanged();
    }

    private async void AutoplayTick(object? _)
    {
        await InvokeAsync(async () =>
        {
            if (_overview is null || _overview.AvailableYears.Count == 0) return;
            _yearIndex++;
            if (_yearIndex >= _overview.AvailableYears.Count) _yearIndex = 0;
            _year = _overview.AvailableYears[_yearIndex];
            await LoadYear();
            StateHasChanged();
        });
    }



    [JSInvokable]
    public void OnTerritoryCellSelected(string region, List<FactionControlDto> factions)
    {
        _selectedRegion = region;
        _selectedFactions = factions;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _autoplayTimer?.Dispose();
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        if (_module is not null) await _module.DisposeAsync();
        _dotNetRef?.Dispose();
    }

    // DTOs
    record TerritoryOverviewDto
    {
        public int MinYear { get; init; }
        public int MaxYear { get; init; }
        public List<string> Factions { get; init; } = [];
        public List<string> Regions { get; init; } = [];
        public List<TerritoryEraDto> Eras { get; init; } = [];
        public List<int> AvailableYears { get; init; } = [];
    }

    record TerritoryEraDto
    {
        public string Name { get; init; } = "";
        public int StartYear { get; init; }
        public int EndYear { get; init; }
        public string? Description { get; init; }
        public List<string> Conflicts { get; init; } = [];
        public List<string> ImportantEvents { get; init; } = [];
    }

    record TerritoryYearDto
    {
        public int Year { get; init; }
        public string YearDisplay { get; init; } = "";
        public string? Era { get; init; }
        public string? EraDescription { get; init; }
        public List<string> EraConflicts { get; init; } = [];
        public List<string> EraImportantEvents { get; init; } = [];
        public List<TerritoryRegionDto> Regions { get; init; } = [];
        public List<KeyEventDto> KeyEvents { get; init; } = [];
    }

    record TerritoryRegionDto
    {
        public string Region { get; init; } = "";
        public List<FactionControlDto> Factions { get; init; } = [];
    }

    public record FactionControlDto
    {
        public string Faction { get; init; } = "";
        public double Control { get; init; }
        public bool Contested { get; init; }
        public string Color { get; init; } = "";
        public string? Note { get; init; }
    }

    record KeyEventDto
    {
        public int Year { get; init; }
        public string Title { get; init; } = "";
        public string? Description { get; init; }
        public string? WikiUrl { get; init; }
        public string? Category { get; init; }
        public string? Place { get; init; }
        public string? Region { get; init; }
        public int? Col { get; init; }
        public int? Row { get; init; }
    }

    record FactionInfoDto
    {
        public string Color { get; init; } = "";
        public string? WikiUrl { get; init; }
        public string? IconUrl { get; init; }
    }

    record GalaxyEventsOverviewDto
    {
        public List<RegionCellsDto>? Regions { get; init; }
    }

    record RegionCellsDto
    {
        public string Name { get; init; } = "";
        public List<int[]> Cells { get; init; } = [];
    }
}
