@page "/territory-control"
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Territory Control — Star Wars Data</PageTitle>

<div class="territory-outer">

    @if (_overview is null)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        @* Era chips *@
        <div style="display: flex; gap: 4px; padding: 8px 12px; flex-wrap: wrap; flex-shrink: 0;">
            @foreach (var era in _overview.Eras)
            {
                var isActive = _year >= era.StartYear && _year <= era.EndYear;
                <MudChip T="string" Size="Size.Small" Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                         Color="@(isActive ? Color.Primary : Color.Default)"
                         OnClick="() => JumpToYear(era.StartYear)">
                    @era.Name
                </MudChip>
            }
        </div>

        @* Main content: map + info panel *@
        <div class="territory-content">
            @* Map canvas *@
            <div class="territory-canvas-wrap">
                <div id="territory-canvas" class="territory-canvas"></div>

                @* Faction legend (bottom-left) *@
                <div class="territory-legend">
                    @foreach (var (name, info) in _factionInfo)
                    {
                        <div class="d-flex align-center gap-2" style="margin-bottom: 3px;">
                            <FactionIcon Faction="@name" Color="@info.Color" Size="14" />
                            @if (info.WikiUrl is not null)
                            {
                                <MudLink Href="@info.WikiUrl" Target="_blank" Typo="Typo.caption"
                                         Style="@($"color:{info.Color};")">@name</MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Style="@($"color:{info.Color};")">@name</MudText>
                            }
                        </div>
                    }
                </div>
            </div>

            @* Right info panel *@
            <div class="territory-info-panel">
                <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-1" Style="font-weight:700;">
                    @YearDisplay
                </MudText>

                @if (_yearData?.Era is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Class="mb-2">
                        @_yearData.Era
                    </MudChip>
                    @if (_yearData.EraDescription is not null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            @_yearData.EraDescription
                        </MudText>
                    }
                }

                @* Events for this year (from Wookieepedia timeline data) *@
                @if (_yearData?.KeyEvents.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">
                        Events (@_yearData.KeyEvents.Count)
                    </MudText>
                    <div style="max-height: 300px; overflow-y: auto;">
                        @foreach (var evt in _yearData.KeyEvents)
                        {
                            var borderColor = evt.Category switch
                            {
                                "Battle" => "var(--mud-palette-error)",
                                "War" => "#ff4444",
                                "Campaign" => "#ff8844",
                                "Treaty" => "var(--mud-palette-success)",
                                "Government" => "var(--mud-palette-info)",
                                _ => "var(--mud-palette-primary)",
                            };
                            <MudPaper Class="pa-2 mb-2" Elevation="0"
                                      Style="@($"background: rgba(255,255,255,0.04); border-left: 3px solid {borderColor};")">
                                <div class="d-flex align-center gap-2">
                                    @if (evt.Category is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Style="@($"font-size:10px; height:18px; border-color:{borderColor}; color:{borderColor};")">
                                            @evt.Category
                                        </MudChip>
                                    }
                                    @if (evt.WikiUrl is not null)
                                    {
                                        <MudLink Href="@evt.WikiUrl" Target="_blank" Typo="Typo.caption"
                                                 Style="font-weight:600;" Underline="Underline.Hover">@evt.Title</MudLink>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Style="font-weight:600;">@evt.Title</MudText>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(evt.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size:11px;">@evt.Description</MudText>
                                }
                            </MudPaper>
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        No notable events recorded for this year.
                    </MudText>
                }

                <MudDivider Class="my-3" />

                @* Territory breakdown *@
                <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Territory Control</MudText>
                @if (_yearData?.Regions is not null)
                {
                    @foreach (var region in _yearData.Regions)
                    {
                        <div class="mb-2">
                            <MudText Typo="Typo.caption" Style="font-weight:600; opacity:0.7;">@region.Region</MudText>
                            @foreach (var f in region.Factions)
                            {
                                var fi = _factionInfo.GetValueOrDefault(f.Faction);
                                <div class="d-flex align-center gap-2 ml-2">
                                    <FactionIcon Faction="@f.Faction" Color="@f.Color" Size="12" />
                                    <MudText Typo="Typo.caption" Style="@($"color:{f.Color};")">
                                        @f.Faction — @(Math.Round(f.Control * 100))%
                                        @if (f.Contested) { <em style="opacity:0.5;"> contested</em> }
                                    </MudText>
                                </div>
                            }
                        </div>
                    }
                }

                @* Selected region detail (from clicking map) *@
                @if (_selectedRegion is not null)
                {
                    <MudDivider Class="my-3" />
                    <div class="d-flex justify-space-between align-center">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@_selectedRegion</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="() => { _selectedRegion = null; _selectedFactions = null; }" />
                    </div>
                    @if (_selectedFactions is not null)
                    {
                        @foreach (var f in _selectedFactions)
                        {
                            var fi = _factionInfo.GetValueOrDefault(f.Faction);
                            <div class="d-flex align-center gap-2 mt-1">
                                <FactionIcon Faction="@f.Faction" Color="@f.Color" Size="16" />
                                <div>
                                    @if (fi?.WikiUrl is not null)
                                    {
                                        <MudLink Href="@fi.WikiUrl" Target="_blank" Typo="Typo.body2"
                                                 Style="@($"color:{f.Color}; font-weight:600;")">@f.Faction</MudLink>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Style="@($"color:{f.Color}; font-weight:600;")">@f.Faction</MudText>
                                    }
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @(Math.Round(f.Control * 100))% control
                                        @if (f.Contested) { <em>(contested)</em> }
                                    </MudText>
                                </div>
                            </div>
                            @if (f.Note is not null)
                            {
                                <MudText Typo="Typo.caption" Style="opacity:0.5; margin-left:28px;">@f.Note</MudText>
                            }
                        }
                    }
                }
            </div>
        </div>

        @* Timeline scrubber *@
        <div class="territory-scrubber">
            <div class="d-flex align-center gap-3" style="padding: 0 12px;">
                <MudIconButton Icon="@(_autoplay ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                               Color="Color.Primary" Size="Size.Small"
                               OnClick="ToggleAutoplay" />
                <MudText Typo="Typo.subtitle2" Style="min-width: 80px; font-weight: 700; color: var(--mud-palette-primary);">
                    @YearDisplay
                </MudText>
                <div style="flex: 1;">
                    <MudSlider T="int" Value="@_year" ValueChanged="OnYearChanged"
                               Min="_overview.MinYear" Max="_overview.MaxYear" Step="1"
                               Style="margin: 0;" />
                </div>
                <MudToggleIconButton Icon="@Icons.Material.Filled.MusicNote"
                                    ToggledIcon="@Icons.Material.Filled.MusicOff"
                                    Toggled="_musicEnabled" ToggledChanged="ToggleMusic"
                                    Size="Size.Small" Color="Color.Warning"
                                    Title="Duel of the Fates" />
            </div>
        </div>
    }
</div>

@if (_musicEnabled)
{
    <div style="position:fixed;bottom:56px;right:12px;z-index:100;border-radius:8px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.5);">
        <iframe width="280" height="60" allow="autoplay"
                src="https://www.youtube.com/embed/xlYCxbBZUCY?autoplay=1&loop=1&playlist=xlYCxbBZUCY"
                style="border:none;">
        </iframe>
    </div>
}

<style>
    .territory-outer {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 64px);
    }
    .territory-content {
        flex: 1;
        display: flex;
        min-height: 0;
    }
    .territory-canvas-wrap {
        flex: 1;
        position: relative;
        min-height: 0;
    }
    .territory-canvas {
        width: 100%;
        height: 100%;
    }
    .territory-legend {
        position: absolute;
        bottom: 12px;
        left: 12px;
        background: rgba(10,10,26,0.85);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 10px 14px;
        z-index: 10;
    }
    .territory-info-panel {
        width: 320px;
        flex-shrink: 0;
        overflow-y: auto;
        padding: 16px;
        border-left: 1px solid var(--mud-palette-lines-default);
        background: var(--mud-palette-surface);
    }
    .territory-scrubber {
        flex-shrink: 0;
        border-top: 1px solid var(--mud-palette-lines-default);
        background: var(--mud-palette-surface);
        padding: 8px 0;
    }
</style>

@code {
    private IJSObjectReference? _module;
    private DotNetObjectReference<TerritoryControl>? _dotNetRef;

    private TerritoryOverviewDto? _overview;
    private TerritoryYearDto? _yearData;
    private Dictionary<string, FactionInfoDto> _factionInfo = new();
    private List<RegionCellsDto>? _regionCells;

    private int _year = -19;
    private bool _autoplay;
    private bool _musicEnabled;
    private System.Threading.Timer? _autoplayTimer;
    private CancellationTokenSource? _debounceCts;

    private string? _selectedRegion;
    private List<FactionControlDto>? _selectedFactions;

    private string YearDisplay => _year <= 0 ? $"{Math.Abs(_year)} BBY" : $"{_year} ABY";

    private HttpClient Http => HttpClientFactory.CreateClient("StarWarsData");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/territory-control.js");
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        var overviewTask = Http.GetFromJsonAsync<TerritoryOverviewDto>("api/TerritoryControl/overview");
        var factionsTask = Http.GetFromJsonAsync<Dictionary<string, FactionInfoDto>>("api/TerritoryControl/factions");
        var regionsTask = Http.GetFromJsonAsync<GalaxyEventsOverviewDto>("api/galaxyevents/overview");

        await Task.WhenAll(overviewTask, factionsTask, regionsTask);

        _overview = overviewTask.Result;
        _factionInfo = factionsTask.Result ?? new();
        _regionCells = regionsTask.Result?.Regions;

        if (_overview is not null && _overview.MinYear != 0)
        {
            _year = Math.Clamp(_year, _overview.MinYear, _overview.MaxYear);
        }

        StateHasChanged();

        if (_module is not null && _overview is not null)
        {
            var jsOverview = new { gridColumns = 26, gridRows = 20 };
            var factionColors = _factionInfo.ToDictionary(kv => kv.Key, kv => kv.Value.Color);
            var factionWikiUrls = _factionInfo
                .Where(kv => kv.Value.WikiUrl is not null)
                .ToDictionary(kv => kv.Key, kv => kv.Value.WikiUrl!);
            var factionIcons = _factionInfo.Keys
                .Select(name => new { name, svg = FactionIcon.GetPath(name) })
                .Where(x => x.svg is not null)
                .ToDictionary(x => x.name, x => x.svg!);
            await _module.InvokeVoidAsync("initialize", "territory-canvas", jsOverview, _regionCells, factionColors, factionWikiUrls, factionIcons, _dotNetRef);
            await LoadYear();
        }
    }

    private async Task LoadYear()
    {
        try
        {
            _yearData = await Http.GetFromJsonAsync<TerritoryYearDto>($"api/TerritoryControl/year/{_year}");
            if (_module is not null && _yearData is not null)
            {
                await _module.InvokeVoidAsync("renderTerritoryLayer", _yearData);
            }
            StateHasChanged();
        }
        catch { }
    }

    private async Task OnYearChanged(int newYear)
    {
        _year = newYear;
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        try
        {
            await Task.Delay(150, token);
            if (!token.IsCancellationRequested)
                await LoadYear();
        }
        catch (TaskCanceledException) { }
    }

    private void JumpToYear(int year)
    {
        _year = year;
        _ = LoadYear();
    }

    private void ToggleAutoplay()
    {
        _autoplay = !_autoplay;
        if (_autoplay)
        {
            _autoplayTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    if (_overview is null) return;
                    _year++;
                    if (_year > _overview.MaxYear) _year = _overview.MinYear;
                    StateHasChanged();
                    await LoadYear();
                });
            }, null, 0, 800);
        }
        else
        {
            _autoplayTimer?.Dispose();
            _autoplayTimer = null;
        }
    }

    private void ToggleMusic(bool enabled)
    {
        _musicEnabled = enabled;
    }

    [JSInvokable]
    public void OnTerritoryCellSelected(string region, List<FactionControlDto> factions)
    {
        _selectedRegion = region;
        _selectedFactions = factions;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _autoplayTimer?.Dispose();
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        if (_module is not null) await _module.DisposeAsync();
        _dotNetRef?.Dispose();
    }

    // DTOs
    record TerritoryOverviewDto
    {
        public int MinYear { get; init; }
        public int MaxYear { get; init; }
        public List<string> Factions { get; init; } = [];
        public List<string> Regions { get; init; } = [];
        public List<TerritoryEraDto> Eras { get; init; } = [];
    }

    record TerritoryEraDto
    {
        public string Name { get; init; } = "";
        public int StartYear { get; init; }
        public int EndYear { get; init; }
    }

    record TerritoryYearDto
    {
        public int Year { get; init; }
        public string YearDisplay { get; init; } = "";
        public string? Era { get; init; }
        public string? EraDescription { get; init; }
        public List<TerritoryRegionDto> Regions { get; init; } = [];
        public List<KeyEventDto> KeyEvents { get; init; } = [];
    }

    record TerritoryRegionDto
    {
        public string Region { get; init; } = "";
        public List<FactionControlDto> Factions { get; init; } = [];
    }

    public record FactionControlDto
    {
        public string Faction { get; init; } = "";
        public double Control { get; init; }
        public bool Contested { get; init; }
        public string Color { get; init; } = "";
        public string? Note { get; init; }
    }

    record KeyEventDto
    {
        public int Year { get; init; }
        public string Title { get; init; } = "";
        public string? Description { get; init; }
        public string? WikiUrl { get; init; }
        public string? Category { get; init; }
    }

    record FactionInfoDto
    {
        public string Color { get; init; } = "";
        public string? WikiUrl { get; init; }
        public string? IconUrl { get; init; }
    }

    record GalaxyEventsOverviewDto
    {
        public List<RegionCellsDto>? Regions { get; init; }
    }

    record RegionCellsDto
    {
        public string Name { get; init; } = "";
        public List<int[]> Cells { get; init; } = [];
    }
}
