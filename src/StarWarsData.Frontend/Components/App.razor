<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <base href="/"/>
        <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet"/>
        <link href=@Assets["_content/MudBlazor/MudBlazor.min.css"] rel="stylesheet"/>
        <link href=@Assets["_content/MudBlazor.Markdown/MudBlazor.Markdown.min.css"] rel="stylesheet"/>
        <link href=@Assets["_content/Z.Blazor.Diagrams/style.min.css"] rel="stylesheet"/>
        <link href=@Assets["_content/Z.Blazor.Diagrams/default.styles.min.css"] rel="stylesheet"/>
        <link href=@Assets["style.css"] rel="stylesheet"/>
        <ImportMap/>
        <link rel="icon" type="image/svg+xml" href="img/galaxy-logo.svg"/>
        <link rel="alternate icon" type="image/ico" href="favicon.ico"/>

        <!-- SEO: global defaults (pages override via HeadContent) -->
        <meta name="description" content="Explore the Star Wars universe through a temporal knowledge graph of 166,000+ entities, AI-powered semantic search, interactive galaxy map, and relationship visualizations — all sourced from Wookieepedia." />
        <meta name="keywords" content="Star Wars, Wookieepedia, knowledge graph, galaxy map, timeline, AI, semantic search, characters, planets, relationships, Canon, Legends" />
        <meta name="author" content="Patrick Magee" />
        <meta name="robots" content="index, follow" />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="Star Wars Data Explorer" />
        <meta property="og:title" content="Star Wars Data Explorer" />
        <meta property="og:description" content="AI-powered exploration of the Star Wars universe — 166K entities, 694K relationships, semantic search over 800K article passages, interactive galaxy map, and more." />
        <meta property="og:url" content="https://swdata.ai" />
        <meta property="og:image" content="https://swdata.ai/galaxy.png" />
        <meta property="og:image:width" content="1671" />
        <meta property="og:image:height" content="940" />
        <meta property="og:image:alt" content="Star Wars galaxy map background" />
        <meta property="og:locale" content="en_US" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="Star Wars Data Explorer" />
        <meta name="twitter:description" content="AI-powered exploration of the Star Wars universe — knowledge graph, semantic search, galaxy map, and interactive visualizations." />
        <meta name="twitter:image" content="https://swdata.ai/galaxy.png" />
        <meta name="twitter:image:alt" content="Star Wars galaxy map background" />

        <!-- Canonical -->
        <link rel="canonical" href="https://swdata.ai" />

        <HeadOutlet />
        <!-- Google Analytics — loaded only after cookie consent -->
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}

            function swLoadAnalytics() {
                if (document.querySelector('script[src*="googletagmanager"]')) return;
                var s = document.createElement('script');
                s.async = true;
                s.src = 'https://www.googletagmanager.com/gtag/js?id=G-1JWZZ8THNS';
                document.head.appendChild(s);
                gtag('js', new Date());
                gtag('config', 'G-1JWZZ8THNS');
            }

            function swGetCookieConsent() {
                return localStorage.getItem('sw_cookie_consent');
            }

            function swSetCookieConsent(value) {
                localStorage.setItem('sw_cookie_consent', value);
                if (value === 'accepted') swLoadAnalytics();
            }

            // Auto-load if previously accepted
            if (swGetCookieConsent() === 'accepted') swLoadAnalytics();

            // Accessibility: persist font scale preference
            function swSetFontScale(scale) { localStorage.setItem('sw-font-scale', scale.toString()); }
            function swGetFontScale() { return parseFloat(localStorage.getItem('sw-font-scale')) || 1.0; }

            // Faction theme: persist user's selected MudTheme palette
            function swSetTheme(themeId) { localStorage.setItem('sw-theme', themeId); }
            function swGetTheme() { return localStorage.getItem('sw-theme'); }

            // Aurebesh preview: show selected text in galactic script
            var _aurebeshBar = null;
            function swSetAurebesh(enabled) {
                localStorage.setItem('sw-aurebesh', enabled ? 'true' : 'false');
                if (!enabled && _aurebeshBar) {
                    _aurebeshBar.classList.remove('visible');
                    document.removeEventListener('selectionchange', _onSelectionChange);
                    return;
                }
                if (enabled) {
                    if (!_aurebeshBar) {
                        _aurebeshBar = document.createElement('div');
                        _aurebeshBar.className = 'aurebesh-preview';
                        _aurebeshBar.innerHTML = '<span class="aurebesh-label">Aurebesh</span><span class="aurebesh-text"></span>';
                        document.body.appendChild(_aurebeshBar);
                    }
                    document.addEventListener('selectionchange', _onSelectionChange);
                }
            }
            function _onSelectionChange() {
                if (!_aurebeshBar) return;
                var sel = window.getSelection();
                var text = (sel || '').toString().trim();
                var textEl = _aurebeshBar.querySelector('.aurebesh-text');
                var labelEl = _aurebeshBar.querySelector('.aurebesh-label');
                if (text.length > 0) {
                    // Check if selection is inside aurebesh-content (already rendered as Aurebesh)
                    var node = sel.anchorNode;
                    var inAurebesh = false;
                    while (node) {
                        if (node.nodeType === 1 && node.classList && node.classList.contains('aurebesh-content')) {
                            inAurebesh = true;
                            break;
                        }
                        node = node.parentElement;
                    }
                    // If selecting Aurebesh text, show translation in English; otherwise show in Aurebesh
                    textEl.textContent = text;
                    if (inAurebesh) {
                        textEl.style.fontFamily = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
                        labelEl.textContent = 'Translation';
                    } else {
                        textEl.style.fontFamily = "'Aurebesh', sans-serif";
                        labelEl.textContent = 'Aurebesh';
                    }
                    _aurebeshBar.classList.add('visible');
                } else {
                    _aurebeshBar.classList.remove('visible');
                }
            }
            function swGetAurebesh() { return localStorage.getItem('sw-aurebesh') === 'true'; }

            // Chat session localStorage helpers (global, no ES module import needed)
            var _chatKey = 'starwars-chat-sessions';
            function swChatLoad() { try { return JSON.parse(localStorage.getItem(_chatKey)) || []; } catch { return []; } }
            function swChatSave(session) { var s = swChatLoad(); var i = s.findIndex(x => x.id === session.id); if (i >= 0) s[i] = session; else s.unshift(session); localStorage.setItem(_chatKey, JSON.stringify(s)); }
            function swChatLoadOne(id) { return swChatLoad().find(x => x.id === id) || null; }
            function swChatDelete(id) { localStorage.setItem(_chatKey, JSON.stringify(swChatLoad().filter(x => x.id !== id))); }
            function swChatClear() { localStorage.removeItem(_chatKey); }
        </script>
    </head>
    <body>
        <Routes @rendermode="InteractiveServerNoPrerender" />
        <script src="_framework/blazor.web.js"></script>
        <script src=@Assets["_content/MudBlazor/MudBlazor.min.js"]></script>
        <script src=@Assets["_content/MudBlazor.Markdown/MudBlazor.Markdown.min.js"]></script>
        <script src=@Assets["_content/Z.Blazor.Diagrams/script.min.js"]></script>
        <script src="https://d3js.org/d3.v7.min.js"></script>
    </body>
</html>

@code {
    private static readonly InteractiveServerRenderMode InteractiveServerNoPrerender = new(prerender: false);
}