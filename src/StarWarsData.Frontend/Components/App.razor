<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <base href="/"/>
        <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet"/>
        <link href=@Assets["_content/MudBlazor/MudBlazor.min.css"] rel="stylesheet"/>
        <link href=@Assets["_content/Z.Blazor.Diagrams/style.min.css"] rel="stylesheet"/>
        <link href=@Assets["_content/Z.Blazor.Diagrams/default.styles.min.css"] rel="stylesheet"/>
        <link href=@Assets["style.css"] rel="stylesheet"/>
        <ImportMap/>
        <link rel="icon" type="image/ico" href="favicon.ico"/>
        <HeadOutlet />
        <!-- Google Analytics — loaded only after cookie consent -->
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}

            function swLoadAnalytics() {
                if (document.querySelector('script[src*="googletagmanager"]')) return;
                var s = document.createElement('script');
                s.async = true;
                s.src = 'https://www.googletagmanager.com/gtag/js?id=G-1JWZZ8THNS';
                document.head.appendChild(s);
                gtag('js', new Date());
                gtag('config', 'G-1JWZZ8THNS');
            }

            function swGetCookieConsent() {
                return localStorage.getItem('sw_cookie_consent');
            }

            function swSetCookieConsent(value) {
                localStorage.setItem('sw_cookie_consent', value);
                if (value === 'accepted') swLoadAnalytics();
            }

            // Auto-load if previously accepted
            if (swGetCookieConsent() === 'accepted') swLoadAnalytics();
        </script>
    </head>
    <body>
        <Routes @rendermode="InteractiveServer" />
        <script src="_framework/blazor.web.js"></script>
        <script src=@Assets["_content/MudBlazor/MudBlazor.min.js"]></script>
        <script src=@Assets["_content/Z.Blazor.Diagrams/script.min.js"]></script>
        <script src="https://d3js.org/d3.v7.min.js"></script>
    </body>
</html>