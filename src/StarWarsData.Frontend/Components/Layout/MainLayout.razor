@using System.Reflection
@using System.Security.Claims
@using Microsoft.JSInterop
@using StarWarsData.Models.Entities
@using StarWarsData.Frontend.Services
@using StarWarsData.Frontend.Theming
@inherits LayoutComponentBase
@inject LayoutService Layout
@inject IJSRuntime JS
@inject ILogger<MainLayout> Logger
@implements IDisposable

<MudThemeProvider @ref="_mudThemeProvider"
                  Theme="@_theme"
                  @bind-IsDarkMode="_isDarkMode"
                  ObserveSystemDarkModeChange="false" />
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>
<MudLayout>
    @if (!Layout.IsFullscreen)
    {
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())"/>
        <MudImage Src="img/galaxy-logo.svg" Alt="Star Wars Data" Width="32" Height="32" Class="ml-2" />
        @* Title hidden below md (< 960px) — pure CSS via MudBlazor display utilities *@
        <MudText Typo="Typo.h5" Class="ml-2 d-none d-md-flex">Star Wars Data</MudText>
        <MudSpacer/>
        <ContinuityFilter />
        @* Desktop-only secondary controls (md and up): individual icon buttons *@
        <div class="d-none d-md-flex align-center">
            <MudLink Href="https://www.buymeacoffee.com/pjmagee" Target="_blank" Class="d-flex align-center" Style="height:28px;">
                <img src="https://img.buymeacoffee.com/button-api/?text=Buy me a coffee&emoji=&slug=pjmagee&button_colour=FFDD00&font_colour=000000&font_family=Poppins&outline_colour=000000&coffee_colour=ffffff" alt="Buy me a coffee" style="height:28px;" />
            </MudLink>
            <MudTooltip Text="Text size — adjust the font scale">
                <MudMenu Icon="@Icons.Material.Filled.FormatSize" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Dense="true">
                    @foreach (var (label, value) in _textSizes)
                    {
                        var v = value;
                        <MudMenuItem OnClick="@(() => SetTextSize(v))"
                                     Icon="@(_textSize == v ? Icons.Material.Filled.Check : Icons.Material.Filled.FormatSize)">
                            @label
                        </MudMenuItem>
                    }
                </MudMenu>
            </MudTooltip>
            <MudTooltip Text="Faction theme — change the colour palette">
                <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Dense="true">
                    @foreach (var theme in Enum.GetValues<SwTheme>())
                    {
                        var t = theme;
                        <MudMenuItem OnClick="@(() => SetTheme(t))"
                                     Icon="@(_selectedTheme == t ? Icons.Material.Filled.Check : Icons.Material.Filled.Palette)">
                            @t.Label()
                        </MudMenuItem>
                    }
                </MudMenu>
            </MudTooltip>
            <MudTooltip Text="@(_aurebesh ? "Aurebesh mode ON — click to disable" : "Aurebesh mode — render selected text in Star Wars script")">
                <MudIconButton Icon="@Icons.Material.Filled.Translate" Color="@(_aurebesh ? Color.Warning : Color.Inherit)"
                               OnClick="ToggleAurebesh" />
            </MudTooltip>
            <MudTooltip Text="Appearance — light, dark, or follow system">
                <MudMenu Icon="@DarkLightModeButtonIcon" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Dense="true">
                    <MudMenuItem OnClick="@(() => SetDarkMode("light"))"
                                 Icon="@(_darkModePreference == "light" ? Icons.Material.Filled.Check : Icons.Material.Outlined.LightMode)">
                        Light
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => SetDarkMode("dark"))"
                                 Icon="@(_darkModePreference == "dark" ? Icons.Material.Filled.Check : Icons.Material.Outlined.DarkMode)">
                        Dark
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => SetDarkMode("system"))"
                                 Icon="@(_darkModePreference == "system" ? Icons.Material.Filled.Check : Icons.Material.Rounded.AutoMode)">
                        System
                    </MudMenuItem>
                </MudMenu>
            </MudTooltip>
            <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit" Href="https://github.com/pjmagee/starwars-data" Target="_blank" title="GitHub" />
        </div>
        @* Mobile-only overflow menu (below md): collapses the desktop icons into one menu *@
        <div class="d-flex d-md-none align-center">
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit"
                     AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                <MudMenuItem Disabled="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Appearance</MudText>
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => SetDarkMode("light"))"
                             Icon="@(_darkModePreference == "light" ? Icons.Material.Filled.Check : Icons.Material.Outlined.LightMode)">
                    Light
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => SetDarkMode("dark"))"
                             Icon="@(_darkModePreference == "dark" ? Icons.Material.Filled.Check : Icons.Material.Outlined.DarkMode)">
                    Dark
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => SetDarkMode("system"))"
                             Icon="@(_darkModePreference == "system" ? Icons.Material.Filled.Check : Icons.Material.Rounded.AutoMode)">
                    System
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem OnClick="ToggleAurebesh" Icon="@Icons.Material.Filled.Translate"
                             IconColor="@(_aurebesh ? Color.Warning : Color.Default)">
                    @(_aurebesh ? "Aurebesh: ON" : "Aurebesh: OFF")
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Disabled="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Theme</MudText>
                </MudMenuItem>
                @foreach (var theme in Enum.GetValues<SwTheme>())
                {
                    var t = theme;
                    <MudMenuItem OnClick="@(() => SetTheme(t))"
                                 Icon="@(_selectedTheme == t ? Icons.Material.Filled.Check : Icons.Material.Filled.Palette)">
                        @t.Label()
                    </MudMenuItem>
                }
                <MudDivider />
                <MudMenuItem Disabled="true">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Text size</MudText>
                </MudMenuItem>
                @foreach (var (label, value) in _textSizes)
                {
                    var v = value;
                    <MudMenuItem OnClick="@(() => SetTextSize(v))"
                                 Icon="@(_textSize == v ? Icons.Material.Filled.Check : Icons.Material.Filled.FormatSize)">
                        @label
                    </MudMenuItem>
                }
                <MudDivider />
                <MudMenuItem Href="https://github.com/pjmagee/starwars-data" Icon="@Icons.Custom.Brands.GitHub">
                    GitHub
                </MudMenuItem>
            </MudMenu>
        </div>
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <MudMenuItem Disabled="true">
                        <MudText Typo="Typo.body2">@(context.User.Identity?.Name ?? context.User.FindFirst("preferred_username")?.Value ?? "User")</MudText>
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Href="/profile" Icon="@Icons.Material.Filled.Person">Profile</MudMenuItem>
                    <MudMenuItem Href="/authentication/logout" Icon="@Icons.Material.Filled.Logout">Sign out</MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                @* Desktop sign-in button (full text) — md and up *@
                <MudButton Href="/authentication/login" Variant="Variant.Text" Color="Color.Inherit"
                           StartIcon="@Icons.Material.Filled.Login" Class="d-none d-md-inline-flex">Sign in</MudButton>
                @* Mobile sign-in icon — below md *@
                <MudIconButton Icon="@Icons.Material.Filled.Login" Color="Color.Inherit" Edge="Edge.End"
                               Href="/authentication/login" title="Sign in" Class="d-flex d-md-none" />
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Width="280px">
        <NavMenu/>
    </MudDrawer>
    }
    <MudMainContent Class="@(Layout.IsFullscreen ? "" : "pt-16 pa-4")" Style="@(Layout.IsFullscreen ? "padding-top:0!important;" : "")">
        @Body
        @if (!Layout.IsFullscreen)
        {
        <footer class="d-flex flex-column align-center gap-2 pa-4 mt-4">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="flex-wrap">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Made with ❤️ by
                    <MudLink Href="https://magaoidh.pro" Target="_blank" Color="Color.Secondary" Underline="Underline.Always">Patrick Magee</MudLink>
                    &copy; @DateTime.UtcNow.Year
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">|</MudText>
                <MudLink Href="/privacy" Typo="Typo.caption" Color="Color.Secondary" Underline="Underline.Hover">Privacy</MudLink>
                <MudLink Href="/terms" Typo="Typo.caption" Color="Color.Secondary" Underline="Underline.Hover">Terms</MudLink>
                <MudLink Href="/about" Typo="Typo.caption" Color="Color.Secondary" Underline="Underline.Hover">About</MudLink>
                <MudText Typo="Typo.caption" Color="Color.Secondary">|</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">v@(_version)</MudText>
            </MudStack>
            <MudText Typo="Typo.caption" Style="color:rgba(146,146,159,0.6); font-size:11px; text-align:center; max-width:600px;">
                Not affiliated with or endorsed by Wookieepedia, Fandom, Disney, or Lucasfilm.
                Star Wars and all related properties are trademarks of Disney/Lucasfilm Ltd.
                This is an independent fan project. <MudLink Href="/about" Style="font-size:11px;" Color="Color.Secondary" Underline="Underline.Hover">Learn more</MudLink>
            </MudText>
        </footer>
        }
    </MudMainContent>
</MudLayout>

<CookieConsent />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private string _darkModePreference = "system"; // "light" | "dark" | "system"
    private bool _aurebesh;
    private MudTheme? _theme;
    private string _textSize = "default";
    private SwTheme _selectedTheme = SwTheme.Holonet;
    private MudThemeProvider _mudThemeProvider = null!;
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private bool _darkModeWatcherRegistered;

    private static readonly (string Label, string Value)[] _textSizes =
    [
        ("Small", "small"),
        ("Default", "default"),
        ("Large", "large"),
        ("Extra Large", "extra-large"),
    ];

    private readonly string _version = Assembly.GetExecutingAssembly()
        .GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>()?.InformationalVersion?.Split('+')[0]
        ?? Assembly.GetExecutingAssembly().GetName().Version?.ToString(3)
        ?? "0.0.0";

    protected override void OnInitialized()
    {
        Layout.OnChange += StateHasChanged;
        // Build with current (default) field values so MudThemeProvider has a non-null
        // Theme on the very first render. The saved palette is loaded later in
        // OnAfterRenderAsync once JS interop is safe. Text size is handled entirely
        // via CSS variable overrides on <html data-text-size="...">; the inline
        // script in App.razor's <head> applies it synchronously before Blazor loads,
        // so MainLayout never has to rebuild the MudTheme to scale typography.
        _theme = BuildTheme(_selectedTheme);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Critical: load all persisted UI state in ONE round-trip via swGetUiState.
        // Empirically, in Blazor Server with prerender disabled the SignalR circuit
        // can be torn down between consecutive awaited JS interop calls during the
        // first-connect retry race, causing the second call to throw
        // JSDisconnectedException. Batching into a single call sidesteps that.
        try
        {
            var ui = await JS.InvokeAsync<UiState>("swGetUiState");
            if (!string.IsNullOrEmpty(ui.Theme))
                _selectedTheme = SwThemeExtensions.FromId(ui.Theme);
            _textSize = string.IsNullOrEmpty(ui.TextSize) ? "default" : ui.TextSize;
            _aurebesh = ui.Aurebesh;
            _darkModePreference = string.IsNullOrEmpty(ui.DarkMode) ? "system" : ui.DarkMode;

            _isDarkMode = _darkModePreference switch
            {
                "dark" => true,
                "light" => false,
                _ => ui.SystemDark,
            };

            _theme = BuildTheme(_selectedTheme);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed loading persisted UI state");
        }

        // Best-effort follow-ups. These may JSDisconnectedException-throw on the
        // first circuit; if so, the SECOND circuit (the one that survives) will
        // run this method again and pick them up.
        try
        {
            if (_aurebesh)
                await JS.InvokeVoidAsync("swSetAurebesh", true);

            if (!_darkModeWatcherRegistered)
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("swRegisterDarkModeWatcher", _dotNetRef);
                _darkModeWatcherRegistered = true;
            }

            StateHasChanged();
        }
        catch (JSDisconnectedException) { }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed wiring system dark mode watcher");
        }
    }

    private sealed record UiState(string? Theme, string? TextSize, bool Aurebesh, string? DarkMode, bool SystemDark);

    [JSInvokable]
    public Task OnSystemDarkModeChangedJs(bool systemIsDark)
    {
        // Only honour OS-level theme changes when the user has asked to follow
        // the system. Explicit Light/Dark choices must survive any noise the
        // browser emits on prefers-color-scheme.
        if (_darkModePreference != "system") return Task.CompletedTask;
        _isDarkMode = systemIsDark;
        return InvokeAsync(StateHasChanged);
    }

    private async Task SetTextSize(string size)
    {
        _textSize = size;
        await JS.InvokeVoidAsync("swSetTextSize", size);
    }

    private async Task SetTheme(SwTheme theme)
    {
        _selectedTheme = theme;
        _theme = BuildTheme(_selectedTheme);
        await JS.InvokeVoidAsync("swSetTheme", theme.Id());
        StateHasChanged();
    }

    private async Task ToggleAurebesh()
    {
        _aurebesh = !_aurebesh;
        await JS.InvokeVoidAsync("swSetAurebesh", _aurebesh);
    }

    private static MudTheme BuildTheme(SwTheme theme)
    {
        var (light, dark) = Themes.GetPalettes(theme);
        return new MudTheme
        {
            PaletteLight = light,
            PaletteDark = dark,
            LayoutProperties = new LayoutProperties(),
            // Typography intentionally omitted — text-size is controlled by
            // [data-text-size="..."] CSS overrides on <html>, see style.css.
        };
    }

    public void Dispose()
    {
        Layout.OnChange -= StateHasChanged;
        if (_darkModeWatcherRegistered)
        {
            try
            {
                _ = JS.InvokeVoidAsync("swUnregisterDarkModeWatcher");
            }
            catch { }
        }
        _dotNetRef?.Dispose();
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task SetDarkMode(string mode)
    {
        _darkModePreference = mode;
        if (mode == "system")
        {
            try
            {
                _isDarkMode = await JS.InvokeAsync<bool>("swGetSystemDarkMode");
            }
            catch (JSDisconnectedException) { }
        }
        else
        {
            _isDarkMode = mode == "dark";
        }

        try
        {
            await JS.InvokeVoidAsync("swSetDarkMode", mode);
        }
        catch (JSDisconnectedException) { }

        StateHasChanged();
    }

    public string DarkLightModeButtonIcon => _darkModePreference switch
    {
        "light" => Icons.Material.Outlined.LightMode,
        "dark" => Icons.Material.Outlined.DarkMode,
        _ => Icons.Material.Rounded.AutoMode,
    };

}
