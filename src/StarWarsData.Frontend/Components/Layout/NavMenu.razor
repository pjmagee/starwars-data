@using StarWarsData.Frontend.Services
@inject NavigationService NavigationService
@inject IWebHostEnvironment Environment

<MudNavMenu>
    <MudText Typo="Typo.caption" Class="px-4 pt-3 pb-1" Color="Color.Secondary">Chat</MudText>
    <ChatHistoryNav />

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 pt-1 pb-1" Color="Color.Secondary">Explore</MudText>
    <MudNavLink Href="/search" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ManageSearch">Search</MudNavLink>
    <MudNavLink Href="/galaxy-map" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Explore">Galaxy Map</MudNavLink>
    <MudNavLink Href="/timeline" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Timeline">Timeline</MudNavLink>
    <MudNavLink Href="/character-timelines" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person">Character Timelines</MudNavLink>
    <MudNavLink Href="/tables" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.TableView">Data Tables</MudNavLink>
    <MudNavLink Href="/knowledge-graph" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AccountTree">Knowledge Graph</MudNavLink>
    <MudNavLink Href="/graph-explorer" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Hub">Graph Explorer</MudNavLink>

    <MudDivider Class="my-2" />
    <MudNavLink Href="/about" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Info">About</MudNavLink>
    <MudNavLink Href="/privacy" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.PrivacyTip">Privacy</MudNavLink>
    <MudNavLink Href="/terms" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Gavel">Terms</MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Class="px-4 pt-1 pb-1" Color="Color.Secondary">Account</MudText>
            <MudNavLink Href="/profile" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Person">Profile</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
