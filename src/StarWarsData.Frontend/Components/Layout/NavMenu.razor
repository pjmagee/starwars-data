@using StarWarsData.Frontend.Services
@inject NavigationService NavigationService

<MudNavMenu>
    <MudText Typo="Typo.caption" Class="px-4 pt-3 pb-1" Color="Color.Secondary">Explore</MudText>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AutoAwesome">Ask AI</MudNavLink>
    <MudNavLink Href="/timeline" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Timeline">Timeline</MudNavLink>
    <MudNavLink Href="/character-timelines" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person">Character Timelines</MudNavLink>
    <MudNavLink Href="/galactic-map" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Map">Galaxy</MudNavLink>
    <MudNavLink Href="/tables" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.TableView">Data Tables</MudNavLink>
    <AuthorizeView>
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Class="px-4 pt-1 pb-1" Color="Color.Secondary">Account</MudText>
            <MudNavLink Href="/profile" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Person">Profile</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Roles="admin">
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Class="px-4 pt-1 pb-1" Color="Color.Secondary">System</MudText>
            <MudNavLink Href="/admin" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AdminPanelSettings">Admin</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
