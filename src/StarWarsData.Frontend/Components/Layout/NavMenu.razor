@using StarWarsData.Frontend.Services
@inject NavigationService NavigationService
@inject IWebHostEnvironment Environment

<MudNavMenu>
    <MudText Typo="Typo.caption" Class="px-4 pt-3 pb-1" Color="Color.Secondary">Chat</MudText>
    <ChatHistoryNav />

    @* Explore section hidden on phones (< 600px / xs) — visible on tablets (sm+) and desktop *@
    <MudDivider Class="my-2 d-none d-sm-block" />
    <MudText Typo="Typo.caption" Class="px-4 pt-1 pb-1 d-none d-sm-block" Color="Color.Secondary">Explore</MudText>
    <MudNavLink Href="/search" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ManageSearch" Class="d-none d-sm-flex">Search</MudNavLink>
    <MudNavLink Href="/galaxy-map" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Explore" Class="d-none d-sm-flex">Galaxy Map</MudNavLink>
    <MudNavLink Href="/timeline" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Timeline" Class="d-none d-sm-flex">Timeline</MudNavLink>
    <MudNavLink Href="/character-timelines" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person" Class="d-none d-sm-flex">Character Timelines</MudNavLink>
    <MudNavLink Href="/tables" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.TableView" Class="d-none d-sm-flex">Data Tables</MudNavLink>
    <MudNavLink Href="/knowledge-graph" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AccountTree" Class="d-none d-sm-flex">Knowledge Graph</MudNavLink>
    <MudNavLink Href="/graph-explorer" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Hub" Class="d-none d-sm-flex">Graph Explorer</MudNavLink>

    <MudDivider Class="my-2" />
    <MudNavLink Href="/about" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Info">About</MudNavLink>
    <MudNavLink Href="/privacy" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.PrivacyTip">Privacy</MudNavLink>
    <MudNavLink Href="/terms" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Gavel">Terms</MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Class="px-4 pt-1 pb-1" Color="Color.Secondary">Account</MudText>
            <MudNavLink Href="/profile" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Person">Profile</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
