@page "/"
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject StarWarsData.Services.JobToggleService JobToggleService

<PageTitle>Admin Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-8">
    <OpenAiStatusBanner />

    <MudPaper Class="pa-6 mb-6" Elevation="2">
        <MudText Typo="Typo.h5" Class="mb-4">ETL Pipeline</MudText>

        <!-- Phase 1: Pages -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Secondary">Phase 1 — Pages</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.CloudSync"
                OnClick="@(() => RunJob("api/admin/download/pages"))" Disabled="_isLoading" Size="Size.Medium">
                1a. Download Pages
            </MudButton>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudSelect T="string" @bind-Value="_selectedTemplate" Label="Template" Variant="Variant.Outlined"
                    Dense="true" Style="max-width: 300px;" AnchorOrigin="Origin.BottomCenter">
                    @if (_templates is not null)
                    {
                        @foreach (var t in _templates)
                        {
                            <MudSelectItem Value="@t.Template">@t.Template (@t.Count pages)</MudSelectItem>
                        }
                    }
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Refresh"
                    OnClick="RedownloadTemplate" Disabled="@(_isLoading || string.IsNullOrEmpty(_selectedTemplate))" Size="Size.Medium">
                    1b. Redownload Template
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Transform"
                    OnClick="ReparseInfoboxes" Disabled="@(_isLoading || string.IsNullOrEmpty(_selectedTemplate))" Size="Size.Medium">
                    1c. Reparse Infoboxes (no download)
                </MudButton>
            </MudStack>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                OnClick="@(() => RunJob("api/admin/mongo/delete-pages"))" Disabled="_isLoading" Size="Size.Medium">
                Delete Pages
            </MudButton>
        </MudStack>

        <!-- Phase 2: Template Views -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Default">Phase 2 — Template Views</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Default" StartIcon="@Icons.Material.Filled.TableView"
                OnClick="@(() => RunJob("api/admin/mongo/create-template-views"))" Disabled="_isLoading" Size="Size.Medium">
                2. Create Template Views
            </MudButton>
        </MudStack>

        <!-- Phase 3: Timeline Events -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Success">Phase 3 — Timeline Events</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Timeline"
                OnClick="@(() => RunJob("api/admin/mongo/create-categorized-timeline-events"))" Disabled="_isLoading" Size="Size.Medium">
                3a. Build Timeline Events
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Storage"
                OnClick="@(() => RunJob("api/admin/mongo/ensure-indexes"))" Disabled="_isLoading" Size="Size.Medium">
                3b. Create Indexes
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                OnClick="@(() => RunJob("api/admin/mongo/delete-timeline-events"))" Disabled="_isLoading" Size="Size.Medium">
                Delete Timeline Events
            </MudButton>
        </MudStack>

        <MudDivider Class="my-4" />

        <!-- Phase 4: Article Chunks & Embeddings -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Warning">Phase 4 — Article Chunks &amp; Embeddings</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Psychology"
                OnClick="@(() => RunJob("api/admin/mongo/create-embeddings"))" Disabled="_isLoading" Size="Size.Medium">
                4a. Run Article Chunking
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Storage"
                OnClick="@(() => RunJob("api/admin/mongo/ensure-chunk-indexes"))" Disabled="_isLoading" Size="Size.Medium">
                4b. Ensure Chunk Indexes
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.TravelExplore"
                OnClick="@(() => RunJob("api/admin/mongo/create-index-embeddings"))" Disabled="_isLoading" Size="Size.Medium">
                4c. Create Vector Indexes
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteSweep"
                OnClick="@(() => RunJob("api/admin/mongo/delete-embeddings"))" Disabled="_isLoading" Size="Size.Medium">
                Delete Embeddings
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Dashboard"
                Href="/article-chunks" Size="Size.Medium">
                View Chunks Dashboard
            </MudButton>
        </MudStack>

        <MudDivider Class="my-4" />

        <!-- Phase 5: Knowledge Graph -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Info">Phase 5 — Knowledge Graph</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.AccountTree"
                OnClick="@(() => RunJob("api/admin/mongo/build-infobox-graph"))" Disabled="_isLoading" Size="Size.Medium">
                5a. Build Infobox Graph (deterministic)
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Storage"
                OnClick="@(() => RunJob("api/admin/mongo/ensure-graph-indexes"))" Disabled="_isLoading" Size="Size.Medium">
                5b. Ensure Graph Indexes
            </MudButton>
        </MudStack>

        <!-- Phase 6: AI Character Timelines -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Tertiary">Phase 6 — AI Character Timelines</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.PersonSearch"
                OnClick="@(() => RunJob("api/admin/mongo/create-character-timelines"))" Disabled="_isLoading" Size="Size.Medium">
                6. Build Character Timelines
            </MudButton>
        </MudStack>

        <MudDivider Class="my-4" />

        <!-- Phase 7: LLM Relationship Graph (optional) -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Info">Phase 7 — LLM Relationship Graph (optional)</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Hub"
                OnClick="@(() => RunJob("api/admin/mongo/submit-graph-batch"))" Disabled="_isLoading" Size="Size.Medium">
                7a. Submit LLM Graph Batch
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Info" StartIcon="@Icons.Material.Filled.Dashboard"
                Href="/graph-builder" Size="Size.Medium">
                View Graph Builder Dashboard
            </MudButton>
        </MudStack>

        <MudDivider Class="my-4" />

        <!-- Phase 8: Galaxy Map -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Primary">Phase 8 — Galaxy Map</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Public"
                OnClick="@(() => RunJob("api/admin/mongo/build-galaxy-map"))" Disabled="_isLoading" Size="Size.Medium">
                8. Build Galaxy Map
            </MudButton>
            <MudText Typo="Typo.caption" Color="Color.Default">
                Pre-computes territory control, event heatmap, and trade routes from the knowledge graph. Requires Phase 1 + 3 + 5.
            </MudText>
        </MudStack>
    </MudPaper>

    <!-- Recurring Job Toggles -->
    <MudPaper Class="pa-6 mb-6" Elevation="2">
        <MudText Typo="Typo.h5" Class="mb-2">Recurring Jobs</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
            Toggle jobs on/off without restarting the server. Disabled jobs will be skipped on their next scheduled run.
        </MudText>
        @if (_jobToggles is null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_jobToggles.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No recurring jobs configured. Start the server with HangfireEnabled=true.</MudText>
        }
        else
        {
            <MudTable Items="_jobToggles" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Enabled</MudTh>
                    <MudTh>Job</MudTh>
                    <MudTh>Schedule</MudTh>
                    <MudTh>Description</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudSwitch T="bool" Value="context.Enabled" Color="Color.Success"
                                   ValueChanged="@(v => ToggleJob(context.JobId, v))" />
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.JobId</MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                            @(context.Schedule ?? "—")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption">@(context.Description ?? "—")</MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    <!-- Hangfire Dashboard -->
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" Class="mb-4">Job Monitoring</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Dashboard"
            Href="/hangfire" Target="_blank" Size="Size.Large">
            Open Hangfire Dashboard
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    bool _isLoading;
    HttpClient? _http;
    List<StarWarsData.Models.Entities.JobToggle>? _jobToggles;
    List<TemplateInfo>? _templates;
    string? _selectedTemplate;

    HttpClient Http => _http ??= new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadJobToggles(), LoadTemplates());
    }

    record TemplateInfo(string Template, int Count);

    async Task LoadTemplates()
    {
        try { _templates = await Http.GetFromJsonAsync<List<TemplateInfo>>("api/admin/templates"); }
        catch { _templates = []; }
    }

    async Task RedownloadTemplate()
    {
        if (string.IsNullOrEmpty(_selectedTemplate)) return;
        await RunJob($"api/admin/download/pages/redownload-template?template={Uri.EscapeDataString(_selectedTemplate)}");
    }

    async Task ReparseInfoboxes()
    {
        if (string.IsNullOrEmpty(_selectedTemplate)) return;
        await RunJob($"api/admin/download/pages/reparse-infoboxes?template={Uri.EscapeDataString(_selectedTemplate)}");
    }

    async Task LoadJobToggles()
    {
        try { _jobToggles = await JobToggleService.GetAllAsync(); }
        catch { _jobToggles = []; }
    }

    async Task ToggleJob(string jobId, bool enabled)
    {
        await JobToggleService.SetEnabledAsync(jobId, enabled);
        Snackbar.Add($"{jobId}: {(enabled ? "enabled" : "disabled")}", enabled ? Severity.Success : Severity.Warning);
        await LoadJobToggles();
    }

    async Task RunJob(string endpoint)
    {
        try
        {
            _isLoading = true;
            var response = await Http.PostAsync(endpoint, null);
            if (response.IsSuccessStatusCode)
                Snackbar.Add("Job started! Check Hangfire dashboard for status.", Severity.Success);
            else if ((int)response.StatusCode == 409)
                Snackbar.Add($"Job not started: {await response.Content.ReadAsStringAsync()}", Severity.Warning);
            else
                Snackbar.Add($"Failed: {await response.Content.ReadAsStringAsync()}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally { _isLoading = false; }
    }
}
