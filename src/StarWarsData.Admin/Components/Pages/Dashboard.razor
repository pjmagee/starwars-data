@page "/"
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Admin Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 px-8">
    <OpenAiStatusBanner />
    <!-- Job Actions -->
    <MudPaper Class="pa-6 mb-6" Elevation="2">
        <MudText Typo="Typo.h5" Class="mb-4">Data Management Jobs</MudText>

        <!-- Pages Operations -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Secondary">Pages Operations</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.CloudSync"
                OnClick="@(() => StartJobHandler(SyncWookieepediaEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Download Pages (to starwars-raw database)
            </MudButton>

            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                OnClick="@(() => StartJobHandler(DeletePagesEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Delete Pages Database (starwars-raw)
            </MudButton>
        </MudStack>

        <!-- Timeline Events Operations -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Success">Timeline Events Operations</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Timeline"
                OnClick="@(() => StartJobHandler(CreateTimelineEventsEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Create Timeline Events (from Pages to timeline DB)
            </MudButton>

            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                OnClick="@(() => StartJobHandler(DeleteTimelineEventsEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Delete Timeline Events Collections
            </MudButton>
        </MudStack>

        <!-- Relationship Graph Operations -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Info">Relationship Graph Operations</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Hub"
                OnClick="@(() => StartJobHandler(BuildRelationshipGraphEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Build Relationship Graph (process next batch)
            </MudButton>

            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Storage"
                OnClick="@(() => StartJobHandler(EnsureGraphIndexesEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Ensure Graph Indexes
            </MudButton>

            <MudButton Variant="Variant.Text" Color="Color.Info" StartIcon="@Icons.Material.Filled.Dashboard"
                Href="/graph-builder" Size="Size.Medium">
                View Graph Builder Dashboard
            </MudButton>
        </MudStack>

        <MudDivider Class="my-4" />

        <!-- Territory Control -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Tertiary">Territory Control</MudText>
        <MudStack Spacing="2" Class="mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.AutoFixHigh"
                OnClick="@(() => StartJobHandler(InferTerritoryEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Infer Territory Control
            </MudButton>
        </MudStack>

        <MudDivider Class="my-4" />

        <!-- Article Chunks & Embeddings -->
        <MudText Typo="Typo.h6" Class="mb-3 mt-4" Color="Color.Warning">Article Chunks &amp; Embeddings</MudText>
        <MudStack Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Psychology"
                OnClick="@(() => StartJobHandler(CreateEmbeddingsEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Run Chunking Batch
            </MudButton>

            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Storage"
                OnClick="@(() => StartJobHandler(EnsureChunkIndexesEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Ensure Chunk Indexes
            </MudButton>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.TravelExplore"
                OnClick="@(() => StartJobHandler(CreateVectorIndexEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Create Vector Index
            </MudButton>

            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteSweep"
                OnClick="@(() => StartJobHandler(DeleteEmbeddingsEndpoint))" Disabled="_isLoading" Size="Size.Medium">
                Delete Embeddings
            </MudButton>

            <MudButton Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Dashboard"
                Href="/article-chunks" Size="Size.Medium">
                View Chunks Dashboard
            </MudButton>
        </MudStack>
    </MudPaper>

    <!-- Hangfire Dashboard -->
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" Class="mb-4">Job Monitoring</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            Monitor job progress, view logs, and manage running jobs in the Hangfire Dashboard.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Dashboard"
            Href="/hangfire" Target="_blank" Size="Size.Large">
            Open Hangfire Dashboard
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    // API endpoints for job creation (admin app hosts these controllers directly)
    private const string SyncWookieepediaEndpoint = "api/admin/download/pages";
    private const string DeletePagesEndpoint = "api/admin/mongo/delete-pages";

    private const string CreateTimelineEventsEndpoint = "api/admin/mongo/create-categorized-timeline-events";
    private const string DeleteTimelineEventsEndpoint = "api/admin/mongo/delete-timeline-events";

    private const string BuildRelationshipGraphEndpoint = "api/admin/mongo/build-relationship-graph";
    private const string EnsureGraphIndexesEndpoint = "api/admin/mongo/ensure-graph-indexes";

    private const string InferTerritoryEndpoint = "api/admin/mongo/infer-territory-control";

    private const string CreateEmbeddingsEndpoint = "api/admin/mongo/create-embeddings";
    private const string EnsureChunkIndexesEndpoint = "api/admin/mongo/ensure-chunk-indexes";
    private const string CreateVectorIndexEndpoint = "api/admin/mongo/create-index-embeddings";
    private const string DeleteEmbeddingsEndpoint = "api/admin/mongo/delete-embeddings";

    private bool _isLoading = false;
    private HttpClient? _http;

    private HttpClient Http
    {
        get
        {
            if (_http == null)
            {
                _http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            }
            return _http;
        }
    }

    private async Task StartJobHandler(string endpoint)
    {
        try
        {
            _isLoading = true;
            var response = await Http.PostAsync(endpoint, null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Job started successfully! Check Hangfire dashboard for status.", Severity.Success);
            }
            else if ((int)response.StatusCode == 409)
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Job not started: {error}", Severity.Warning);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to start job: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error starting job: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
